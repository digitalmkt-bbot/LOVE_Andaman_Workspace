  const incidentsCard = `<div style="background:white;border-radius:24px;padding:22px 24px">
    <p style="margin:0 0 16px;font-size:15px;font-weight:600;color:${dim.ink}">Incidents per month</p>
    <div style="display:flex;align-items:flex-end;gap:7px;height:100px;margin-bottom:0">${incBars}</div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid #f1eee8;margin-top:14px">
      <span style="font-size:11px;color:${dim.ink2}">${curMonth.incidents} incident${curMonth.incidents!==1?'s':''} this month${incCaption?' · '+incCaption.replace(/this month/i,'').replace(/^\s*·\s*/,'').trim():''}</span>
      ${incDelta !== null ? `<span style="background:${incDelta>0?'#FBE9E9':'#E6F4ED'};color:${incDelta>0?'#A32D2D':'#0F6E56'};padding:3px 10px;border-radius:10px;font-size:10px;font-weight:600">${incDelta>=0?'▴':'▾'} ${Math.abs(incDelta)}%</span>`:''}
    </div>
  </div>`;

  const chartCard = (title, content) => `<div style="background:white;border-radius:24px;padding:22px 24px">
    <p style="margin:0 0 18px;font-size:15px;font-weight:600;color:${dim.ink}">${title}</p>
    ${content}
  </div>`;

  // Cost by supplier — smart extraction
  // Priority 1: mo.supplier (explicit field, most accurate)
  // Priority 2: linked inventory items → supplier field
  // Priority 3: regex on refNote — find segment that looks like company name
  const extractSupplier = (mo) => {
    // Priority 1: explicit supplier field
    if(mo.supplier && mo.supplier.trim()) return mo.supplier.trim();
    
    // Priority 2: items linked to inventory → majority supplier
    if(mo.items && mo.items.length > 0 && FL_INVENTORY){
      const supplierCounts = {};
      mo.items.forEach(it => {
        if(it.invId){
          const inv = FL_INVENTORY.find(x=>x.id===it.invId);
          if(inv && inv.supplier){
            supplierCounts[inv.supplier] = (supplierCounts[inv.supplier]||0) + 1;
          }
        }
      });
      const top = Object.entries(supplierCounts).sort((a,b)=>b[1]-a[1])[0];
      if(top) return top[0];
    }
    
    // Priority 3: regex on refNote (legacy)
    if(mo.refNote){
      const segments = mo.refNote.split('·').map(s=>s.trim());
      const companyRegex = /\b(Marine|Mall|Co\.?\s*Ltd|Co\.|Ltd|Suzuki|Honda|Yamaha|Megazip|บจ\.|บริษัท|Hilltribe|Industries|Hardware|Parts|Service|Materials|Trading)\b/i;
      for(const seg of segments){
        if(companyRegex.test(seg)){
          return seg.replace(/^อ้างอิง\s*/i,'').replace(/\s+(IV\S+|SO\S+|QT\S+|IN\S*|CO\d+|\d{2}\/\d{2}\/\d{4}).*$/i,'').trim();
        }
      }
      const dateOrDocRegex = /^(\d{2}\/\d{2}\/\d{4}|[A-Z]{2,3}[-\s]?\d{4,}|CO\d+|Tax Invoice|Invoice|IV\d+|SO\s?\d+|QT[-\s]?\d+)$/i;
      for(const seg of segments){
        const cleaned = seg.replace(/^อ้างอิง\s*/i,'').trim();
        if(!dateOrDocRegex.test(cleaned) && cleaned.length > 3){
          return cleaned;
        }
      }
    }
    return 'Other';
  };

  // Cost by supplier — memo-centric (approved+ in period)
  // Conditions to appear in this chart:
  //   1. memo.createdDate within selected period (Month/Quarter/YTD/All)
  //   2. memo.status is one of: approved, ordered, received, paid
  //      (Excludes: created, pending_approval, rejected, cancelled)
  //   3. Includes BOTH vessel-scope and general-scope memos
  const APPROVED_STATUSES = ['approved','ordered','received','paid'];
  const supplierMap = {};
  allMemos.forEach(mo=>{
    if(!mo.createdDate || !inPeriod(mo.createdDate)) return;
    if(!APPROVED_STATUSES.includes(mo.status)) return;
    const sup = extractSupplier(mo);
    supplierMap[sup] = (supplierMap[sup]||0) + (mo.amount||0);
  });
  const supplierRows = Object.entries(supplierMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const totalSup = supplierRows.reduce((s,[,v])=>s+v, 0) || 1;
  const supplierBars = supplierRows.length ? supplierRows.map(([name,amt])=>{
    const pct = (amt/totalSup)*100;
    return `<div style="margin-bottom:14px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:${dim.ink};max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500">${name}</span>
        <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${fmtShort(amt)}</span>
      </div>
      <div style="background:#F4F2EE;border-radius:8px;height:8px;overflow:hidden">
        <div style="width:${pct}%;height:100%;background:linear-gradient(90deg,${LIME_SOFT},${FOREST});border-radius:8px;transition:width .3s"></div>
      </div>
    </div>`;
  }).join('') : `<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:20px">No data in period</div>`;

  // Cost by type
  const typeMap = {corrective:0, preventive:0, scheduled:0};
  periodJobs.forEach(j=>{ if(typeMap[j.type]!==undefined) typeMap[j.type] += calcCost(j); });
  const totalType = Object.values(typeMap).reduce((s,v)=>s+v, 0) || 1;
  const TYPE_COLOR = {corrective:'#A32D2D', preventive:'#185FA5', scheduled:'#7C5BC4'};
  const TYPE_LABEL = {corrective:'Corrective', preventive:'Preventive', scheduled:'Scheduled'};
  const typeBars = Object.entries(typeMap).map(([k,v])=>{
    const pct = (v/totalType)*100;
    return `<div style="margin-bottom:14px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:${dim.ink};font-weight:500">${TYPE_LABEL[k]}</span>
        <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${fmtShort(v)}</span>
      </div>
      <div style="background:#F4F2EE;border-radius:8px;height:8px;overflow:hidden">
        <div style="width:${pct}%;height:100%;background:${TYPE_COLOR[k]};border-radius:8px;opacity:.85;transition:width .3s"></div>
      </div>
    </div>`;
  }).join('');

  // Type caption — pattern detection
  let typeCaption = '';
  if(typeMap.corrective > 0 && typeMap.preventive === 0 && typeMap.scheduled === 0){
    typeCaption = '100% reactive cost · Consider preventive maintenance program';
  } else if(typeMap.preventive > typeMap.corrective){
    typeCaption = 'Preventive > Corrective · Healthy maintenance discipline';
  }

  // Build healthy boats wins card (Visual Vault style)
  const healthyBoats_v2 = Object.values(boatStats).filter(s=>s.jobs===0 && s.curStatus==='available');
  const healthyCount = healthyBoats_v2.length;
  const healthyNames = healthyBoats_v2.slice(0,3).map(s=>s.name).join(', ');
  const healthyRest = healthyBoats_v2.length > 3 ? `, +${healthyBoats_v2.length-3} more` : '';
  
  // Get 3 colors from top healthy boats for stacked cards
  const stackBoats = healthyBoats_v2.slice(0,3).map(s=>{
    const b = boats.find(x=>x.id===s.id);
    return b ? boatAvatarColor(b) : '#185FA5';
  });
  while(stackBoats.length < 3) stackBoats.push('#185FA5');
  
  const winsIllustrationCard = `<div style="background:white;border-radius:24px;padding:22px 24px;display:flex;flex-direction:column;align-items:center;text-align:center">
    <div style="position:relative;width:100px;height:80px;margin-bottom:12px">
      <div style="position:absolute;left:0;top:8px;width:50px;height:60px;border-radius:8px;background:${stackBoats[0]};transform:rotate(-12deg);box-shadow:0 4px 12px rgba(0,0,0,.1)"></div>
      <div style="position:absolute;left:22px;top:4px;width:50px;height:60px;border-radius:8px;background:${stackBoats[1]};box-shadow:0 4px 12px rgba(0,0,0,.1)"></div>
      <div style="position:absolute;left:44px;top:0;width:50px;height:60px;border-radius:8px;background:${stackBoats[2]};transform:rotate(8deg);box-shadow:0 4px 12px rgba(0,0,0,.1)"></div>
      <div style="position:absolute;left:14px;top:24px;width:72px;height:48px;border-radius:10px;background:${LIME};display:flex;align-items:center;justify-content:center;box-shadow:0 6px 16px rgba(31,77,44,.2)">
        <span style="font-size:18px;font-weight:700;color:${FOREST}">${healthyCount}</span>
      </div>
    </div>
    <p style="margin:8px 0 0;font-size:11px;color:${LIME_DARK};letter-spacing:.05em;text-transform:uppercase;font-weight:600">${healthyCount} boat${healthyCount!==1?'s':''} healthy</p>
    <p style="margin:6px 0 0;font-size:18px;font-weight:600;color:${FOREST}">Healthy Fleet</p>
    <p style="margin:8px 0 14px;font-size:11px;color:${dim.ink2};line-height:1.5">A curated list of boats with zero issues this month: ${healthyNames}${healthyRest}.</p>
    <button onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="background:${FOREST};color:white;border:none;border-radius:18px;padding:9px 20px;font-size:12px;font-weight:600;cursor:pointer;width:100%">View all healthy boats</button>
  </div>`;
  
  // Build upcoming card (Scheduling pattern)
  let upcomingCard = '';
  if(typeof flEngHours==='function' && FL_ENGINES){
    const upcomingList = [];
    FL_ENGINES.forEach(e=>{
      if(!e.serviceInterval || !e.boatId) return;
      const curH = flEngHours(e.id) || (e.baseHours || 0);
      const hoursUntil = e.serviceInterval - (curH % e.serviceInterval);
      if(hoursUntil <= e.serviceInterval * 0.2 && hoursUntil > 0){
        const b = boats.find(x=>x.id===e.boatId);
        if(b) upcomingList.push({b, hoursUntil, interval: e.serviceInterval, engine: e});
      }
    });
    upcomingList.sort((a,b)=>a.hoursUntil-b.hoursUntil);
    
    if(upcomingList.length > 0){
      const top = upcomingList[0];
      const tbColor = boatAvatarColor(top.b);
      const tbInit = boatInitials(top.b.name);
      upcomingCard = `<div style="background:white;border-radius:24px;padding:22px 24px">
        <div style="display:flex;align-items:start;justify-content:space-between;margin-bottom:14px">
          <div>
            <p style="margin:0;font-size:15px;font-weight:600;color:${dim.ink}">Upcoming</p>
            <p style="margin:4px 0 0;font-size:11px;color:${dim.ink2};line-height:1.4">${upcomingList.length} service${upcomingList.length>1?'s':''} need scheduling this week</p>
          </div>
          <div style="text-align:right">
            <p style="margin:0;font-size:9px;color:#854F0B;letter-spacing:.1em;font-weight:600">SOON</p>
            <p style="margin:3px 0 0;font-size:20px;font-weight:700;color:${dim.ink}">${top.hoursUntil}hr</p>
          </div>
        </div>
        <div style="background:linear-gradient(135deg,${LIME_SOFT} 0%,${LIME} 100%);border-radius:14px;padding:24px 16px;text-align:center;margin-bottom:14px">
          <div style="display:inline-flex;width:50px;height:50px;border-radius:50%;background:${FOREST};color:${LIME};align-items:center;justify-content:center;font-size:13px;font-weight:700;letter-spacing:.5px;margin-bottom:8px">${tbInit}</div>
          <p style="margin:6px 0 0;font-size:14px;font-weight:600;color:${FOREST}">${top.b.name} · Engine service</p>
          <p style="margin:4px 0 0;font-size:11px;color:${LIME_DARK}">~${top.hoursUntil}hr until ${top.interval}hr service interval</p>
        </div>
        <div style="text-align:center"><a onclick="flGoToAsset('boats','${top.b.id}')" style="color:${FOREST};font-size:13px;font-weight:600;cursor:pointer;text-decoration:none">Mark this service →</a></div>
      </div>`;
    }
  }
  if(!upcomingCard){
    // Fallback if no upcoming services
    upcomingCard = `<div style="background:white;border-radius:24px;padding:22px 24px">
      <p style="margin:0;font-size:15px;font-weight:600;color:${dim.ink}">Upcoming</p>
      <p style="margin:4px 0 0;font-size:11px;color:${dim.ink2};line-height:1.4">No services scheduled in the near term</p>
      <div style="background:${LIME_SOFT};border-radius:14px;padding:24px 16px;text-align:center;margin-top:14px">
        <p style="margin:0;font-size:13px;color:${FOREST};font-weight:600">All engines within service interval ✓</p>
      </div>
    </div>`;
  }

  // Count approved memos in period for context caption
  const approvedMemosInPeriod = allMemos.filter(mo => 
    mo.createdDate && inPeriod(mo.createdDate) && APPROVED_STATUSES.includes(mo.status)
  );
  const supplierCaption = approvedMemosInPeriod.length > 0
    ? `${approvedMemosInPeriod.length} approved memo${approvedMemosInPeriod.length>1?'s':''} · ${supplierRows.length} supplier${supplierRows.length>1?'s':''}`
    : `No approved memos in ${periodLabel.toLowerCase()}`;

  const chartsPanel = `${costTrendCard}
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px">
    ${incidentsCard}
    ${chartCard('Cost by supplier', supplierBars + `<p style="margin:14px 0 0;font-size:11px;color:${dim.ink3};line-height:1.5">${supplierCaption}</p>`)}
    ${winsIllustrationCard}
  </div>
  <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:16px">
    ${chartCard('Cost by job type', typeBars + (typeCaption ? `<p style="margin:16px 0 0;font-size:11px;color:${dim.ink2};line-height:1.5">${typeCaption}</p>` : ''))}
    ${upcomingCard}
  </div>`;

  // ──────── TIER 4: Smart Recommendations ────────
  const insights = [];
  
  // 💸 AWAITING INVOICES — Closed MJs flagged "awaiting invoice" only (semantic = "รอใบบิล")
  if(FL_MAINT && FL_MEMOS){
    const awaitingItems = [];
    
    FL_MAINT.forEach(m => {
      if(m.status !== 'done') return;
      if(!m.awaitingInvoice) return;  // ต้องติ๊ก "รอใบวางบิล" เท่านั้น
      const linkedMemos = FL_MEMOS.filter(memo => memo.maintId === m.id);
      if(linkedMemos.length > 0) return;  // ถ้ามี memo แล้ว → ออกจาก list
      
      const boat = boats.find(b=>b.id===m.boatId);
      const closeDate = m.endDate ? new Date(m.endDate) : new Date();
      const daysSince = Math.floor((new Date(TODAY_STR) - closeDate) / 86400000);
      awaitingItems.push({
        mj: m, boat, type:'no_memo',
        amt: 0, daysSince, memoCount: 0, supplier: ''
      });
    });
    
    if(awaitingItems.length > 0){
      awaitingItems.sort((a,b)=>b.daysSince-a.daysSince);
      const top = awaitingItems[0];
      
      insights.push({
        icon:'urgent', color:'#9F1B4F', bg:'#FCE6EF',
        title: 'Awaiting Invoice',
        subtitle: `${awaitingItems.length} closed jobs · no memo yet`,
        detail: `${top.mj.no} · ${top.boat?.name||'?'} · ${top.daysSince} days ago`,
        cta: 'Manage memos',
        ctaLink: 'View jobs →',
        statLabel: 'WAITING',
        stat: `${awaitingItems.length}`,
        type: 'unpaid_invoices',
        meta: { items: awaitingItems.slice(0,5), total: 0, count: awaitingItems.length, type:'unpaid_invoices' },
        metaLine: `${awaitingItems.length} jobs · no memo yet`,
        priority: 1
      });
    }
  }

  // ⏰ UPCOMING — Engines approaching service interval
  if(typeof flEngHours==='function' && FL_ENGINES){
    const upcomingService = [];
    FL_ENGINES.forEach(e=>{
      if(!e.serviceInterval || !e.boatId) return;
      const curH = flEngHours(e.id) || (e.baseHours || 0);
      const remainder = curH % e.serviceInterval;
      const hoursUntil = e.serviceInterval - remainder;
      if(hoursUntil <= e.serviceInterval * 0.2 && hoursUntil > 0){
        const b = boats.find(x=>x.id===e.boatId);
        upcomingService.push({
          boatObj: b,
          boatName: b ? b.name : '?',
          engineSerial: e.serial,
          engineModel: e.model || '',
          hoursUntil: Math.round(hoursUntil),
          currentHours: Math.round(curH),
          interval: e.serviceInterval
        });
      }
    });
    if(upcomingService.length > 0){
      const byBoat = {};
      upcomingService.forEach(u=>{ if(!byBoat[u.boatName]) byBoat[u.boatName]=[]; byBoat[u.boatName].push(u); });
      const topBoats = Object.entries(byBoat).slice(0,2);
      topBoats.forEach(([boatName, list])=>{
        const minHr = Math.min(...list.map(u=>u.hoursUntil));
        const top = list.find(u=>u.hoursUntil===minHr);
        insights.push({
          icon:'clock', color:'#185FA5', bg:'#E6F1FB',
          title: 'Engine service',
          subtitle: `${boatName} ใกล้ครบ service${list.length>1?` (${list.length} เครื่อง)`:''}`,
          detail:`เหลือ ~${minHr}hr ก่อนถึงรอบ ${list[0].interval}hr · ${list.map(u=>u.engineSerial).slice(0,2).join(', ')}${list.length>2?'...':''}`,
          stat: `${minHr} hr`,
          statLabel: 'SOON',
          meta: { type:'upcoming', boat: top.boatObj, hoursUntil: minHr, currentHours: top.currentHours, interval: top.interval, engineModel: top.engineModel },
          category: 'Upcoming',
          metaLine: `${list[0].interval}hr interval`,
          ctaLink: 'Schedule →'
        });
      });
    }
  }

  // 📄 BOAT DOCS — expiring or expired licenses/certificates
  if(boats && boats.length > 0){
    const docAlerts = [];
    boats.forEach(b => {
      if(b.retired || b.ownership==='charter') return;
      if(!b.docs || !Array.isArray(b.docs)) return;
      b.docs.forEach(d => {
        if(!d.exp) return;
        const expD = new Date(d.exp);
        if(isNaN(expD.getTime())) return;
        const daysUntil = Math.floor((expD - todayD) / 86400000);
        let severity = null;
        if(daysUntil < 0) severity = 'expired';
        else if(daysUntil <= 14) severity = 'critical';
        else if(daysUntil <= 60) severity = 'warning';
        else return;
        docAlerts.push({boat: b, doc: d, daysUntil, severity});
      });
    });
    if(docAlerts.length > 0){
      docAlerts.sort((a,b) => a.daysUntil - b.daysUntil);
      const expired = docAlerts.filter(a => a.severity==='expired').length;
      const critical = docAlerts.filter(a => a.severity==='critical').length;
      const warning = docAlerts.filter(a => a.severity==='warning').length;
      const top = docAlerts[0];
      const isUrgent = expired > 0 || critical > 0;
      const color = expired>0?'#A32D2D':critical>0?'#854F0B':'#185FA5';
      const bg = expired>0?'#FBE9E9':critical>0?'#FAEEDA':'#E6F1FB';
      const statLabel = expired>0?'EXPIRED':critical>0?'≤14d':'≤60d';
      const title = expired>0?'Documents expired':critical>0?'Documents expiring soon':'Documents upcoming';
      const topLabel = top.daysUntil<0 ? `หมดอายุแล้ว ${Math.abs(top.daysUntil)}d` :
                       top.daysUntil===0 ? 'วันนี้' :
                       `เหลือ ${top.daysUntil}d`;
      const breakdown = [
        expired ? `${expired} expired` : '',
        critical ? `${critical} ≤14d` : '',
        warning ? `${warning} ≤60d` : ''
      ].filter(Boolean).join(' · ');
      insights.push({
        icon: 'docs',
        color, bg,
        title,
        subtitle: `${docAlerts.length} เอกสารต้องต่ออายุ`,
        detail: `${top.boat.name} · ${top.doc.name} · ${topLabel}${docAlerts.length>1?` · +${docAlerts.length-1} อื่น`:''}`,
        stat: `${docAlerts.length}`,
        statLabel,
        meta: { type:'docs', items: docAlerts.slice(0,5), count: docAlerts.length, expired, critical, warning },
        category: 'Documents',
        metaLine: breakdown,
        ctaLink: 'View boats →',
        priority: isUrgent ? 0 : 2
      });
    }
  }

  // 📊 AVG TIME TO CLOSE — comparison with previous period
  const closedJobs = allJobs.filter(j=>j.status==='done' && j.startDate && j.endDate);
  if(closedJobs.length >= 3){
    const calcDays = (j) => Math.floor((new Date(j.endDate) - new Date(j.startDate))/86400000);
    const recentClosed = closedJobs.filter(j=>inPeriod(j.endDate));
    const oldClosed = closedJobs.filter(j=>!inPeriod(j.endDate));
    if(recentClosed.length > 0){
      const avgRecent = recentClosed.reduce((s,j)=>s+calcDays(j),0)/recentClosed.length;
      const avgOld = oldClosed.length>0 ? oldClosed.reduce((s,j)=>s+calcDays(j),0)/oldClosed.length : null;
      const isImproved = avgOld!==null && avgRecent < avgOld;
      const trend = avgOld!==null ? (avgRecent < avgOld ? '↓ improved' : avgRecent > avgOld ? '↑ slower' : '→ same') : '';
      const pctChange = avgOld!==null ? Math.round(Math.abs((avgRecent - avgOld) / avgOld) * 100) : 0;
      insights.push({
        icon:'chart_bar', color: isImproved ? '#0F6E56' : '#185FA5', 
        bg: isImproved ? '#E6F4ED' : '#E6F1FB',
        title:'Closing speed',
        subtitle: 'ปิดงานเร็ว/ช้า',
        detail: avgOld!==null
          ? `${recentClosed.length} jobs ปิดใน ${periodLabel.toLowerCase()} · ก่อนหน้านี้ ${Math.round(avgOld)} d · ${trend}`
          : `${recentClosed.length} jobs ปิดใน ${periodLabel.toLowerCase()}`,
        stat: `${Math.round(avgRecent)} d`,
        statLabel: isImproved ? `↓ ${pctChange}%` : avgOld!==null ? `↑ ${pctChange}%` : '',
        meta: { type:'avg_close', avgRecent: Math.round(avgRecent), avgOld: avgOld!==null ? Math.round(avgOld) : null, count: recentClosed.length, isImproved },
        category: 'Improvement',
        metaLine: `based on ${recentClosed.length} jobs`,
        ctaLink: 'View details →'
      });
    }
  }

  // ✓ MEMO APPROVAL RATE
  if(allMemos.length >= 3){
    const totalMemos = allMemos.length;
    const approvedOrAbove = allMemos.filter(m=>['approved','ordered','received','paid'].includes(m.status)).length;
    const pendingCnt = allMemos.filter(m=>m.status==='pending_approval').length;
    const approvalRate = Math.round((approvedOrAbove/totalMemos)*100);
    insights.push({
      icon:'trend_up', color: approvalRate>=80?'#0F6E56':approvalRate>=50?'#854F0B':'#A32D2D',
      bg: approvalRate>=80?'#E6F4ED':approvalRate>=50?'#FAEEDA':'#FBE9E9',
      title:'Approval rate',
      subtitle: 'Memo workflow',
      detail:`${approvedOrAbove}/${totalMemos} memos approved${pendingCnt>0?` · ${pendingCnt} ยังรออนุมัติ`:' · ครบทุกใบ'}`,
      stat: `${approvalRate}%`,
      statLabel: approvalRate>=80 ? 'EXCELLENT' : approvalRate>=50 ? 'OK' : 'LOW',
