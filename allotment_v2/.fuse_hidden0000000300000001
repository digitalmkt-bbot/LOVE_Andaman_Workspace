#view-agents .ag-edit-x{width:30px;height:30px;border-radius:50%;border:none;background:var(--fd-bg);color:var(--fd-ink-mid);cursor:pointer;font-size:14px;line-height:1;display:flex;align-items:center;justify-content:center}
