function flProjAddDoc(projId){
  const nameEl = document.getElementById('proj-doc-name-'+projId);
  const urlEl  = document.getElementById('proj-doc-url-'+projId);
  const noteEl = document.getElementById('proj-doc-note-'+projId);
  const name = nameEl?.value.trim(); if(!name){ alert('Document name required'); return; }
  flProjAddDocRecord(projId, name, urlEl?.value.trim()||'', noteEl?.value.trim()||'');
  if(nameEl) nameEl.value=''; if(urlEl) urlEl.value=''; if(noteEl) noteEl.value='';
}
function flProjAddDocPreset(projId, name){ flProjAddDocRecord(projId, name, '', ''); }
function flProjAddDocRecord(projId, name, url, note){
  const p = flProjGetById(projId); if(!p) return;
  if(!p.docs) p.docs=[];
  p.docs.push({
    id:'dc_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    name, url, note,
    status: url? 'received' : 'pending',
    addedAt: TODAY_STR
  });
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`+ Document: ${name}`, by:'user'});
  flSave();
  flRenderProjects();
}
function flProjUpdateDocStatus(projId, docId, status){
  const p = flProjGetById(projId); if(!p||!p.docs) return;
  const d = p.docs.find(x=>x.id===docId); if(!d) return;
  const oldSt = d.status||'pending';
  d.status = status;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`Document "${d.name}" · ${oldSt} → ${status}`, by:'user'});
  flSave();
  flRenderProjects();
}
function flProjDeleteDoc(projId, docId){
  const p = flProjGetById(projId); if(!p||!p.docs) return;
  const d = p.docs.find(x=>x.id===docId); if(!d) return;
  if(!confirm(`Delete document: ${d.name}?`)) return;
  p.docs = p.docs.filter(x=>x.id!==docId);
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`- Document removed: ${d.name}`, by:'user'});
  flSave();
  flRenderProjects();
}

