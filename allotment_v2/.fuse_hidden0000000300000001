function flSaveCreateJob(){
  const boatId=document.getElementById('job-boat').value;
  const title=document.getElementById('job-title').value.trim();
  const startDate=document.getElementById('job-start-date').value;
  if(!boatId||!title){alert('กรุณาเลือกเรือและกรอกชื่องาน');return;}

  // check for existing active job on same boat
  const activeJobs=FL_MAINT.filter(m=>m.boatId===boatId&&m.status!=='done');
  if(activeJobs.length>0){
    const b=getBoat(boatId);
    const jobList=activeJobs.map(m=>`• ${m.no} (${m.status==='inprogress'?'In Progress':'Pending'})`).join('\n');
    if(!confirm(`เรือ ${b?b.name:''} มี Job ที่ยังเปิดอยู่:\n${jobList}\n\nต้องการสร้าง Job ใหม่เพิ่มหรือไม่?\n(กด OK เพื่อสร้าง · Cancel เพื่อยกเลิก)`)) return;
  }

  const incId=document.getElementById('job-incident').value||null;

  // ─── OPTION B: 1 asset in incident = 1 job ───
  // If INC has ≥2 assets, ask the user via Job Choice modal (deferred via _flJobMode)
  if(incId){
    try {
      const inc=FL_INCIDENTS.find(x=>x.id===incId);
      if(inc&&inc.damagedAssets&&inc.damagedAssets.length>1 && !window._flJobMode){
        // First pass — show modal & wait for choice
        flOpenJobChoiceModal(inc);
        return;
      }
      // Asset label helpers (used by split path)
      const _ENG=typeof FL_ENGINES!=='undefined'?FL_ENGINES:[];
      const _GB=typeof FL_GEARBOXES!=='undefined'?FL_GEARBOXES:[];
      const _PR=typeof FL_PROPELLERS!=='undefined'?FL_PROPELLERS:[];
      const labelFor=(a)=>{
        if(a.type==='engine'){const e=a.id?_ENG.find(x=>x.id===a.id):null;return e?e.serial+' · '+(e.pos||''):(a.label||'Engine');}
        if(a.type==='gearbox'){const g=a.id?_GB.find(x=>x.id===a.id):null;return g?g.serial+(g.note?' · '+g.note:''):(a.label||'Gearbox');}
        if(a.type==='propeller'){const p=a.id?_PR.find(x=>x.id===a.id):null;return p?p.serial+(p.note?' · '+p.note:''):(a.label||'Propeller');}
        return a.label||'Hull';
      };
      const typeLabel={engine:'Engine',gearbox:'Gearbox',propeller:'Propeller',hull:'Hull'};
      const chosenMode = window._flJobMode;  // 'single' or 'split'
      window._flJobMode = null;  // reset for next time

      if(inc&&inc.damagedAssets&&inc.damagedAssets.length>1 && chosenMode==='split'){
        const N=inc.damagedAssets.length;
        const baseTitle=title;
        const detail=document.getElementById('job-detail').value.trim();
        const location=document.getElementById('job-location').value.trim();
        const setFixing=document.getElementById('job-fixing').checked;
        const createdJobs=[];

        // Pre-compute max no. once (multi-asset case · each iter increments)
        let _mjBaseNo = FL_MAINT.length
          ? Math.max(0, ...FL_MAINT.map(m => parseInt(String(m.no||'').replace(/^MJ-/,'')) || 0))
          : 0;

        inc.damagedAssets.forEach((a,idx)=>{
          _mjBaseNo++;
          const jobNo='MJ-'+String(_mjBaseNo).padStart(3,'0');
          const subtitle=`${typeLabel[a.type]||'Asset'} ${labelFor(a)}`;
          const aid=a.type==='engine'?'engId':a.type==='gearbox'?'gbId':a.type==='propeller'?'propId':null;
          const jobAsset={type:a.type,label:a.label||labelFor(a),detail:a.note||a.detail||'',status:'fixing'};
          if(aid&&a.id) jobAsset[aid]=a.id;
          const mj={
            id:'mj'+Date.now()+'-'+idx,no:jobNo,boatId,type:_jobType,
            title:`${baseTitle} — ${subtitle}`,
            detail,location,status:'pending',startDate,endDate:null,cost:0,
            incidentId:incId,assets:[jobAsset],progressLog:[],setFixing
          };
          flAssertUniqueNo(FL_MAINT, jobNo, 'MJ');
          FL_MAINT.unshift(mj);
          createdJobs.push(mj);
        });

        inc.maintId=createdJobs[0].id;
        inc.relatedMaintIds=createdJobs.map(j=>j.id);
        if(!inc.progressLog) inc.progressLog=[];
        inc.progressLog.push({date:TODAY_STR,text:`+ สร้าง ${createdJobs.length} jobs: ${createdJobs.map(j=>j.no).join(', ')}`,by:'ระบบ'});

        flSave();closeModal('fl-modal-create-job');
        _selMaintId=createdJobs[0].id;flRenderMaint();
        return;
      }
    } catch(err){
      console.error('[Option B 1-asset-per-job error]',err);
      // fall through to single-job path
    }
  }

  // ─── Single job path (Option A or no incident) ───
  // ใช้ max(MJ-XXX) + 1 (ไม่ใช่ length+1) เพื่อป้องกันเลขซ้ำเมื่อมีงานถูกลบไป
  // หรือเมื่อ sequence มี gap (เช่น MJ-009..018 ขาดไปแล้ว · max ยังเป็น MJ-027)
  const _mjMaxNo = FL_MAINT.length
    ? Math.max(0, ...FL_MAINT.map(m => parseInt(String(m.no||'').replace(/^MJ-/,'')) || 0))
    : 0;
  const no='MJ-'+String(_mjMaxNo+1).padStart(3,'0');
  // Copy damaged assets from incident if linked (single unit case)
  let initialAssets=[];
  if(incId){
    const inc=FL_INCIDENTS.find(x=>x.id===incId);
    if(inc&&inc.damagedAssets){
      initialAssets=inc.damagedAssets.map(a=>{
        const aid=a.type==='engine'?'engId':a.type==='gearbox'?'gbId':a.type==='propeller'?'propId':null;
        const obj={type:a.type,label:a.label||'',detail:a.note||a.detail||'',status:'fixing'};
        if(aid&&a.id) obj[aid]=a.id;
        return obj;
      });
    }
  }
  // Preventive/Scheduled jobs: user selects assets manually (no auto-add)
  if(!incId && (_jobType==='preventive' || _jobType==='scheduled')){
    // Asset status mirrors boatStatus: available→ready (just checking), fixing/unavailable→fixing
    const autoAssetStatus = (_jobBoatStatus === 'available') ? 'ready' : 'fixing';
    // Read engine checkboxes
    document.querySelectorAll('.job-asset-eng-cb:checked').forEach(cb=>{
      const id = cb.value;
      const label = cb.getAttribute('data-label') || '';
      initialAssets.push({type:'engine', engId:id, label, detail:'', status:autoAssetStatus});
    });
    // Read gearbox checkboxes
    document.querySelectorAll('.job-asset-gb-cb:checked').forEach(cb=>{
      const id = cb.value;
      const label = cb.getAttribute('data-label') || '';
      initialAssets.push({type:'gearbox', gbId:id, label, detail:'', status:autoAssetStatus});
    });
    // Read propeller checkboxes
    document.querySelectorAll('.job-asset-prop-cb:checked').forEach(cb=>{
      const id = cb.value;
      const label = cb.getAttribute('data-label') || '';
      initialAssets.push({type:'propeller', propId:id, label, detail:'', status:autoAssetStatus});
    });
    // Read hull input (free text · comma-separated)
    const hullRaw = document.getElementById('job-asset-hull')?.value.trim() || '';
    if(hullRaw){
      hullRaw.split(',').map(s=>s.trim()).filter(Boolean).forEach(label=>{
        initialAssets.push({type:'hull', label, detail:'', status:autoAssetStatus});
      });
    }
  }
  // Validate reason if unavailable
  if(_jobBoatStatus === 'unavailable'){
    const reason = document.getElementById('job-status-reason')?.value || '';
    if(!reason){alert('กรุณาเลือกเหตุผลที่ไม่พร้อมใช้งาน');return;}
  }
  const mj={
    id:'mj'+Date.now(),no,boatId,type:_jobType,title,
    detail:document.getElementById('job-detail').value.trim(),
    location:document.getElementById('job-location').value.trim(),
    status:'pending',startDate,endDate:null,cost:0,
    incidentId:incId,assets:initialAssets,progressLog:[],
    // Boat status during job
    boatStatus: _jobBoatStatus || 'fixing',
    boatStatusReason: (_jobBoatStatus==='unavailable') ? (document.getElementById('job-status-reason')?.value || '') : '',
    // Legacy compat: setFixing true only if boatStatus is fixing or unavailable
    setFixing: (_jobBoatStatus === 'fixing' || _jobBoatStatus === 'unavailable')
  };
  flAssertUniqueNo(FL_MAINT, no, 'MJ');
  // Link to parent project if creation was triggered from project detail
  if(_projCreateForId){
    mj.parentProjectId = _projCreateForId;
    const _proj = (FL_PROJECTS||[]).find(p=>p.id===_projCreateForId);
    if(_proj){
      if(!_proj.log) _proj.log=[];
      _proj.log.push({date:TODAY_STR, text:`+ Created MJ ${mj.no} · ${mj.title}`, by:'user'});
    }
    mj.progressLog = mj.progressLog||[];
    mj.progressLog.push({date:TODAY_STR, text:`+ Created under project ${_proj?_proj.no:_projCreateForId}`, by:'user'});
  }
  FL_MAINT.unshift(mj);
  if(incId){
    const inc=FL_INCIDENTS.find(x=>x.id===incId);
    if(inc){
      inc.maintId=mj.id;
      if(!inc.progressLog) inc.progressLog=[];
      inc.progressLog.push({date:TODAY_STR,text:`+ สร้าง Job ${mj.no} · ${mj.title}${mj.location?' → '+mj.location:''}`,by:'ระบบ'});
    }
  }
  flSave();closeModal('fl-modal-create-job');
  // If created under a project, return to project detail instead of MJ view
  if(_projCreateForId){
    const pid = _projCreateForId;
    _projCreateForId = null;
    _selProjId = pid;
    if(typeof flRenderProjects==='function') flRenderProjects();
    flShowToast(`Created ${mj.no} under project`);
    return;
  }
  _selMaintId=mj.id;flRenderMaint();
}

// ── INCIDENT ──
let _incStFilter='all', _selIncId=null, _incArchiveTab='active';

function flRenderIncident(){
  const wrap=document.getElementById('fl-inc-pink-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  const all=FL_INCIDENTS||[];
  const totalInc=all.length;

  // Effective status from linked maint
  const effStatus=(inc)=>{
    // Direct status override — for Quick Fix or any INC manually marked resolved without an MJ
    if(inc.status==='resolved') return 'resolved';
    const mj=inc.maintId?FL_MAINT.find(m=>m.id===inc.maintId):null;
    if(!mj)return 'open';
    if(mj.status==='pending')return 'pending';
    if(mj.status==='inprogress')return 'inprogress';
    return 'resolved';
  };

  const cntOpen=all.filter(x=>effStatus(x)==='open').length;
  const cntPending=all.filter(x=>effStatus(x)==='pending').length;
  const cntInProgress=all.filter(x=>effStatus(x)==='inprogress').length;
  const cntResolved=all.filter(x=>effStatus(x)==='resolved').length;
  const cntActive=cntOpen+cntPending+cntInProgress;
  const cntUnlinked=all.filter(x=>!x.maintId).length;

  // Severity counts
  const cntCritical=all.filter(x=>x.severity==='critical').length;
  const cntMajor=all.filter(x=>x.severity==='major').length;
  const cntMinor=all.filter(x=>x.severity==='minor'||(!x.severity)).length;

  // Boats affected, jobs created, damage total
  const boatsAffected=new Set(all.map(x=>x.boatId).filter(Boolean)).size;
  const jobsCreated=all.filter(x=>x.maintId).length;
  const damageTotal=all.reduce((s,x)=>s+(x.damageCharge||0),0);

  // Avg fix days for resolved
  const todayD=new Date(TODAY_STR);
  const resolvedIncs=all.filter(x=>{
    const mj=x.maintId?FL_MAINT.find(m=>m.id===x.maintId):null;
    return mj&&mj.status==='done';
  });
  const avgFixDays=resolvedIncs.length?Math.round(resolvedIncs.reduce((s,x)=>{
    const mj=FL_MAINT.find(m=>m.id===x.maintId);
    if(!mj?.endDate||!x.date)return s;
    return s+Math.max(1,Math.ceil((new Date(mj.endDate)-new Date(x.date))/86400000));
  },0)/resolvedIncs.length):0;

  // Header bar
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#A32D2D;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">CR</div><span style="font-size:12px;font-weight:500">Critical · ${cntCritical}</span></div>
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#BA7517;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">MJ</div><span style="font-size:12px;font-weight:500">Major · ${cntMajor}</span></div>
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#666;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">MN</div><span style="font-size:12px;font-weight:500">Minor · ${cntMinor}</span></div>
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">J</div>
    </div>
    <div style="display:flex;gap:6px">
      <button onclick="flOpenAddIncidentModal()" style="background:white;border:1px solid rgba(0,0,0,.08);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;cursor:pointer">+ Log Incident</button>
      <button onclick="flOpenCreateJobModal()" style="background:${dim.ink};color:white;border:none;border-radius:20px;padding:7px 16px;font-size:11px;font-weight:600;cursor:pointer">+ Create Job</button>
    </div>
  </div>`;

  // KPI strip
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 0.85fr 0.85fr 0.85fr 1fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Job Assignments</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${totalInc}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">incidents</span>
        <span style="display:inline-flex;align-items:center;background:#A32D2D;color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${cntActive} active</span>
        ${cntUnlinked?`<span style="display:inline-flex;align-items:center;background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${cntUnlinked} unlinked</span>`:''}
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${boatsAffected} boats affected · ${jobsCreated} jobs created · ฿${damageTotal.toLocaleString()} total damage</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${cntOpen?'#A32D2D':dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Open</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:#A32D2D;color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${cntOpen}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">no job</span></div>
      <div style="font-size:11px;color:#A32D2D;margin-top:7px;font-weight:600">need attention</div>
    </div>

    <div style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${(cntPending+cntInProgress)?'#BA7517':dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">In progress</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:#BA7517;color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${cntPending+cntInProgress}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">active</span></div>
      <div style="font-size:11px;color:#854F0B;margin-top:7px;font-weight:600">linked to jobs</div>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Resolved</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:#1D9E75">${cntResolved}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">closed</span></div>
      <div style="font-size:11px;color:#0F6E56;margin-top:6px;font-weight:600">avg ${avgFixDays} days fix</div>
    </div>

    <div style="grid-column:5;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px">
      <div style="font-size:10px;color:#aaa">By severity</div>
      <div style="display:flex;flex-direction:column;gap:3px;margin-top:4px">
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Critical</span><span style="font-size:11px;font-weight:600;color:${cntCritical?'#FF8FA8':'white'}">${cntCritical} incidents</span></div>
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Major</span><span style="font-size:11px;font-weight:600;color:white">${cntMajor} incidents</span></div>
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Minor</span><span style="font-size:11px;font-weight:600;color:white">${cntMinor} incidents</span></div>
      </div>
    </div>
  </div>`;

  // Split incidents by tab: Active = open/pending/inprogress · Archive = resolved
  const allActiveInc = all.filter(x => effStatus(x) !== 'resolved');
  const allArchiveInc = all.filter(x => effStatus(x) === 'resolved');

  // Filter incidents
  let incs = (_incArchiveTab === 'archive') ? [...allArchiveInc] : [...allActiveInc];
  if(_incStFilter==='open')incs=incs.filter(x=>effStatus(x)==='open');
  else if(_incStFilter==='inprogress')incs=incs.filter(x=>{const e=effStatus(x);return e==='pending'||e==='inprogress';});
  else if(_incStFilter==='resolved')incs=incs.filter(x=>effStatus(x)==='resolved');
  incs.sort((a,b)=>(b.date||'').localeCompare(a.date||''));

  const SEV_STYLE={
    critical:{bg:'#FCEBEB',color:'#A32D2D',label:'CRITICAL',accent:'#A32D2D'},
    major:{bg:'#FAEEDA',color:'#854F0B',label:'MAJOR',accent:'#BA7517'},
    minor:{bg:'#F4F2EE',color:'#666',label:'MINOR',accent:'#666'}
  };
  const ST_STYLE={
    open:{bg:'#FCEBEB',color:'#A32D2D',label:'OPEN',stripe:'#A32D2D'},
    pending:{bg:'#FAEEDA',color:'#854F0B',label:'PENDING',stripe:'#BA7517'},
    inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROG',stripe:'#BA7517'},
    resolved:{bg:'#1D9E75',color:'white',label:'RESOLVED',stripe:'#1D9E75'}
  };

  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtShortD=(s)=>{if(!s)return'';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};

  const buildIncRow=(inc)=>{
    const isSel=_selIncId===inc.id;
    const b=getBoat(inc.boatId);
    const mj=inc.maintId?FL_MAINT.find(m=>m.id===inc.maintId):null;
    const sev=SEV_STYLE[inc.severity||'minor']||SEV_STYLE.minor;
    const st=effStatus(inc);
    const ss=ST_STYLE[st]||ST_STYLE.open;
    const prio=inc.priority||0;
    const assetCount=(inc.damagedAssets||[]).length;
    const isResolved=st==='resolved';
    return`<div onclick="flShowInc('${inc.id}')" style="display:flex;gap:10px;padding:10px 8px;border-radius:8px;cursor:pointer;${isSel?`background:${SVG_PINK.soft};border:1px solid #F0C0D0;`:`border-top:0.5px solid ${dim.line};margin-top:2px;`}${isResolved&&!isSel?'opacity:.7;':''}">
      <div style="width:3px;background:${ss.stripe};border-radius:2px;flex-shrink:0;align-self:stretch"></div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:5px;margin-bottom:2px;flex-wrap:wrap">
          <span style="font-size:10px;font-family:'DM Mono',monospace;color:${isSel?SVG_PINK.text:dim.ink3};font-weight:600">${inc.no||'—'}</span>
          <span style="background:${sev.bg};color:${sev.color};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600">${sev.label}</span>
          ${mj?`<span style="font-size:9px;color:#185FA5">→ ${mj.no}${mj.status==='done'?' ✓':''}</span>`:''}
        </div>
        <div style="font-size:12px;font-weight:${isSel?600:500};color:${dim.ink};overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${b?b.name+' — ':''}${inc.title||'—'}</div>
        <div style="font-size:10px;color:${isSel?SVG_PINK.text:dim.ink3};margin-top:2px;font-family:'DM Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${fmtShortD(inc.date)}${inc.time?' '+inc.time:''}${assetCount?' · '+assetCount+' asset'+(assetCount>1?'s':''):''}</div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0">
        <span style="background:${ss.bg};color:${ss.color};padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600">${ss.label}</span>
        <div style="display:flex;gap:1px">${Array.from({length:5},(_,i)=>`<span style="display:inline-block;width:5px;height:5px;border-radius:50%;background:${i<prio?'#E24B4A':'#E5E1DA'}"></span>`).join('')}</div>
      </div>
    </div>`;
  };

  const fBtn=(val,label,color)=>{
    const isOn=_incStFilter===val;
    return`<button onclick="incFilterSt('${val}')" style="background:${isOn?dim.ink:'transparent'};color:${isOn?'white':(color||dim.ink2)};border:${isOn?'none':'1px solid rgba(0,0,0,.08)'};border-radius:12px;padding:4px 10px;font-size:10px;font-weight:${isOn?600:500};cursor:pointer">${label}</button>`;
  };

  // Tab buttons: Active / Archive
  const archBtn=(val,label,count)=>{
    const isOn=_incArchiveTab===val;
    return`<button onclick="incSetArchive('${val}')" style="background:${isOn?'white':'transparent'};color:${isOn?dim.ink:dim.ink3};border:none;border-bottom:${isOn?'2px solid '+SVG_PINK.accent:'2px solid transparent'};padding:6px 12px;font-size:11px;font-weight:${isOn?600:500};cursor:pointer;border-radius:0;margin-bottom:-1px">${label} <span style="background:${isOn?SVG_PINK.soft:dim.bg};color:${isOn?SVG_PINK.text:dim.ink3};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600;margin-left:3px;font-family:'DM Mono',monospace">${count}</span></button>`;
  };

  const tabBar=`<div style="display:flex;border-bottom:1px solid ${dim.line};margin-bottom:8px;gap:0">
    ${archBtn('active','Active',allActiveInc.length)}
    ${archBtn('archive','Archive',allArchiveInc.length)}
  </div>`;

  // Sub-status filter adapts to tab
  let subFilter;
  if(_incArchiveTab === 'active'){
    subFilter = `${fBtn('all','All')}${fBtn('open','Open','#A32D2D')}${fBtn('inprogress','In Progress','#854F0B')}`;
  } else {
    subFilter = `${fBtn('all','All')}${fBtn('resolved','Resolved','#0F6E56')}`;
  }

  const listHtml=incs.length?incs.map(buildIncRow).join(''):`<div style="font-size:12px;color:${dim.ink3};text-align:center;padding:20px">No incidents match filter</div>`;
  const listPanel=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};max-height:calc(100vh - 360px);overflow-y:auto">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,.06)">
      <span style="font-size:12px;font-weight:600;flex:1">Incidents</span>
      <span style="font-size:10px;color:${dim.ink3}">${incs.length}/${totalInc}</span>
    </div>
    ${tabBar}
    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px">
      ${subFilter}
    </div>
    ${listHtml}
  </div>`;

  const detailPanel=`<div id="fl-inc-detail-mount" style="background:white;border-radius:14px;border:1px solid ${dim.line};overflow:hidden;min-height:400px"></div>`;

  wrap.innerHTML=`${headerBar}${kpiStrip}<div style="display:grid;grid-template-columns:380px 1fr;gap:12px;align-items:start">${listPanel}${detailPanel}</div>`;

  flRenderIncDetailPink();
}

function incFilterSt(v){_incStFilter=v;flRenderIncident();}
function incSetArchive(t){
  _incArchiveTab=t;
  _incStFilter='all';
  flRenderIncident();
}

function flShowInc(id){_selIncId=id;flRenderIncident();}
function flSelIncident(id){_selIncId=id;flRenderIncident();}

function flRenderIncDetailPink(){
  const mount=document.getElementById('fl-inc-detail-mount');
  if(!mount)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  if(!_selIncId){
    mount.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:400px;padding:40px;color:${dim.ink3};gap:10px;text-align:center">
      <div style="font-size:28px;opacity:.25;letter-spacing:.1em">INCIDENT</div>
      <div style="font-size:13px;color:${dim.ink2};font-weight:500">Select an incident to see details</div>
      <div style="font-size:11px;color:${dim.ink3}">Click on the list to see assets, progress, and assignment</div>
    </div>`;
    return;
  }

  const inc=FL_INCIDENTS.find(x=>x.id===_selIncId);
  if(!inc){mount.innerHTML='';return;}

  const b=getBoat(inc.boatId);
  const mj=inc.maintId?FL_MAINT.find(m=>m.id===inc.maintId):null;
  const SEV_STYLE={
    critical:{bg:'#FCEBEB',color:'#A32D2D',label:'CRITICAL',accent:'#A32D2D'},
    major:{bg:'#FAEEDA',color:'#854F0B',label:'MAJOR',accent:'#BA7517'},
    minor:{bg:'#F4F2EE',color:'#666',label:'MINOR',accent:'#666'}
  };
  const ST_STYLE={
    open:{bg:'#FCEBEB',color:'#A32D2D',label:'OPEN'},
    pending:{bg:'#FAEEDA',color:'#854F0B',label:'PENDING JOB'},
    inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROGRESS'},
    resolved:{bg:'#1D9E75',color:'white',label:'RESOLVED'}
  };
  const sev=SEV_STYLE[inc.severity||'minor']||SEV_STYLE.minor;

  let st='open';
  // Quick Fix / manually-resolved INC (status set on the inc itself, no MJ needed) takes precedence
  if(inc.status==='resolved'){
    st='resolved';
  } else if(mj){
    if(mj.status==='pending')st='pending';
    else if(mj.status==='inprogress')st='inprogress';
    else if(mj.status==='done')st='resolved';
  }
  const ss=ST_STYLE[st]||ST_STYLE.open;

  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtD=(s)=>{if(!s)return'—';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};

  const noLast3=(inc.no||'').slice(-3).padStart(3,'0');
  const noPrefix=(inc.no||'INC').replace(/[-\d]+$/,'')||'INC';

  // Header strip
  const headerStrip=`<div style="padding:16px 20px;border-bottom:1px solid rgba(0,0,0,.06);background:linear-gradient(to right,#FFF5EC 0%,#FBEAF0 60%,#F5DDE6 100%)">
    <div style="display:flex;align-items:center;gap:10px">
      <div style="width:50px;height:50px;border-radius:12px;background:${sev.accent};color:white;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace">
        <span style="font-size:9px;opacity:.85">${noPrefix}</span>
        <span style="font-size:13px;font-weight:700;line-height:1">${noLast3}</span>
      </div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:20px;font-weight:700">${inc.title||'—'}</span>
          <span style="background:${ss.bg};color:${ss.color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600;letter-spacing:.04em">${ss.label}</span>
          <span style="background:${sev.accent};color:white;padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600">${sev.label}</span>
        </div>
        <div style="font-size:11px;color:${dim.ink2};margin-top:3px">${b?b.name+' · '+(b.type||'')+' · ':''}${fmtD(inc.date)}${inc.time?' '+inc.time:''}${mj?' · '+mj.no:' · No job linked'}</div>
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0">
        ${(!mj && !inc.quickFix)?`<button onclick="flCreateMaintFromInc('${inc.id}')" style="background:${SVG_PINK.accent};color:white;border:none;border-radius:20px;padding:7px 14px;font-size:11px;font-weight:600;cursor:pointer">→ Create Job</button>`:''}
        <button onclick="flOpenAddIncidentModal('${inc.id}')" style="background:${dim.ink};color:white;border:none;border-radius:20px;padding:7px 14px;font-size:11px;font-weight:600;cursor:pointer">Edit</button>
      </div>
    </div>
  </div>`;

  // 4 stat cards
  const prio=inc.priority||0;
  const PIER_LBL={tublamu:'Tub Lamu',panwa:'Visit Panwa',ranong:'Ranong'};
  const dueD=inc.dueDate?new Date(inc.dueDate):null;
  const today=new Date(TODAY_STR);
  const daysLeft=dueD?Math.ceil((dueD-today)/86400000):null;
  const dueColor=daysLeft==null?dim.ink:daysLeft<0?'#A32D2D':daysLeft<=2?'#A32D2D':daysLeft<=7?'#BA7517':dim.ink;
  const dueText=daysLeft==null?'—':daysLeft<0?`${Math.abs(daysLeft)} days late`:daysLeft===0?'today':`${daysLeft} days left`;
  const prioLbl=prio>=4?'urgent':prio>=3?'high':prio>=2?'medium':prio>=1?'low':'—';
  const statCards=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Boat</div>
      <div style="font-size:14px;font-weight:700;margin-top:2px;color:#185FA5">${b?b.name:'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">${b?(b.type||'')+(b.pier?' · '+(PIER_LBL[b.pier]||b.pier):''):''}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Priority</div>
      <div style="display:flex;gap:2px;margin-top:5px;align-items:center">
        ${Array.from({length:5},(_,i)=>`<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${i<prio?'#E24B4A':'#E5E1DA'}"></span>`).join('')}
        <span style="font-size:10px;color:${prio>=4?'#A32D2D':dim.ink2};margin-left:4px;font-weight:600">${prio}/5</span>
      </div>
      <div style="font-size:10px;color:${dim.ink2};margin-top:3px">${prioLbl}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Due date</div>
      <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px;color:${dueColor}">${dueD?fmtD(inc.dueDate).replace(/, \d+$/,''):'—'}</div>
      <div style="font-size:10px;color:${dueColor}">${dueText}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Damage charge</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px;color:${SVG_PINK.text}">฿${(inc.damageCharge||0).toLocaleString()}</div>
      <div style="font-size:10px;color:${dim.ink2}">est. repair</div>
    </div>
  </div>`;

  // Warning banner if no job, or list of related jobs
  const relatedJobs=(inc.relatedMaintIds||[]).map(id=>FL_MAINT.find(m=>m.id===id)).filter(Boolean);
  const hasMultiple=relatedJobs.length>1;
  let warningBanner;
  if(!mj && inc.quickFix){
    // Quick Fix incidents intentionally have no MJ — show a green confirmation instead of red warning
    warningBanner=`<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#E1F5EE;border:1px solid #9FE1CB;border-radius:10px">
      <div style="width:8px;height:8px;border-radius:50%;background:#0F6E56;flex-shrink:0"></div>
      <span style="font-size:11px;color:#0F6E56;font-weight:500;flex:1">⚡ <strong>Quick Fix — resolved same-day</strong> · No maintenance job needed${inc.resolvedDate?' · closed '+inc.resolvedDate:''}</span>
    </div>`;
  } else if(!mj){
    warningBanner=`<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#FCEBEB;border:1px solid #f0c8c5;border-radius:10px">
      <div style="width:8px;height:8px;border-radius:50%;background:#A32D2D;flex-shrink:0"></div>
      <span style="font-size:11px;color:#A32D2D;font-weight:500;flex:1">⚠ <strong>No maintenance job linked yet</strong> — create job to start tracking parts, progress, and costs</span>
      <button onclick="flCreateMaintFromInc('${inc.id}')" style="background:#A32D2D;color:white;border:none;border-radius:14px;padding:5px 12px;font-size:10px;font-weight:600;cursor:pointer">Create now</button>
    </div>`;
  } else if(hasMultiple){
    const JOB_ST={pending:{bg:'#FCEBEB',color:'#A32D2D',label:'PENDING'},inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROG'},done:{bg:'#1D9E75',color:'white',label:'DONE'}};
    const jobRows=relatedJobs.map(j=>{
      const js=JOB_ST[j.status]||JOB_ST.pending;
      return `<div onclick="if(typeof flSelMaint==='function'){flSelMaint('${j.id}');nav(document.querySelector('[data-view=fl-maintenance]'))}" style="display:flex;align-items:center;gap:8px;padding:8px 12px;border-top:0.5px solid rgba(24,95,165,.15);cursor:pointer">
        <span style="font-size:10px;font-family:'DM Mono',monospace;font-weight:600;color:#185FA5">${j.no}</span>
        <span style="font-size:11px;color:#185FA5;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${j.title}</span>
        <span style="background:${js.bg};color:${js.color};padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600;flex-shrink:0">${js.label}</span>
        <span style="color:#185FA5;font-size:12px">›</span>
      </div>`;
    }).join('');
    warningBanner=`<div style="background:#E6F1FB;border:1px solid #b5d4f4;border-radius:10px;overflow:hidden">
      <div style="display:flex;align-items:center;gap:8px;padding:10px 14px">
        <div style="width:8px;height:8px;border-radius:50%;background:#185FA5;flex-shrink:0"></div>
        <span style="font-size:11px;color:#185FA5;font-weight:600;flex:1">Linked Maintenance: <strong>${relatedJobs.length} jobs</strong> (split by engine unit)</span>
      </div>
      ${jobRows}
    </div>`;
  } else {
    warningBanner=`<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#E6F1FB;border:1px solid #b5d4f4;border-radius:10px;cursor:pointer" onclick="if(typeof flSelMaint==='function'){flSelMaint('${mj.id}');nav(document.querySelector('[data-view=fl-maintenance]'))}">
      <div style="width:8px;height:8px;border-radius:50%;background:#185FA5;flex-shrink:0"></div>
      <span style="font-size:11px;color:#185FA5;font-weight:500;flex:1">Linked Maintenance: <strong>${mj.no}</strong> · ${mj.title}${mj.startDate?' · '+fmtD(mj.startDate):''}</span>
      <span style="color:#185FA5;font-size:14px">›</span>
    </div>`;
  }

  // Description
  const descSection=inc.detail?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Description</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:12px 14px;font-size:11px;color:${dim.ink2};line-height:1.5">${inc.detail}</div>
  </div>`:'';

  // Damaged assets
  const damaged=inc.damagedAssets||[];
  const TYPE_LBL={engine:'Engine',gearbox:'Gearbox',propeller:'Propeller',hull:'Hull'};
  const damagedRows=damaged.map(a=>{
    const posLbl=a.type==='engine'?'EN':a.type==='gearbox'?'GB':a.type==='propeller'?'PR':'HU';
    const swappable=a.type==='gearbox'||a.type==='propeller';
    return`<div style="background:#FCEBEB;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;border:1px solid rgba(163,45,45,.12)">
      <span style="font-size:9px;font-weight:700;color:white;background:#185FA5;padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${posLbl}</span>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:600">${TYPE_LBL[a.type]||'Asset'} · ${a.label||'—'}</div>
        ${a.note?`<div style="font-size:10px;color:#A32D2D;margin-top:1px">${a.note}</div>`:''}
      </div>
      ${a.swapped?`<span style="background:#1D9E75;color:white;padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600">⇄ SWAPPED → ${a.swappedTo||''}</span>`:swappable?`<button onclick="flOpenSwapModal('${inc.id}','${a.type}','${a.id}')" style="background:#185FA5;color:white;border:none;border-radius:8px;padding:3px 8px;font-size:9px;font-weight:600;cursor:pointer">⇄ Swap spare</button>`:`<span style="background:#FAEEDA;color:#854F0B;padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600">DAMAGED</span>`}
    </div>`;
  }).join('');
  const damagedSection=damaged.length?`<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">Damaged assets <span style="color:${dim.ink3};font-weight:400">${damaged.length}</span></span>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px">${damagedRows}</div>
  </div>`:'';

  // Progress timeline — merged from incident's own log + ALL linked maintenance jobs' logs
  const incLog=(inc.progressLog||[]).map(l=>({...l,_fromJob:false}));
  // Collect all linked job IDs (maintId + relatedMaintIds, deduplicated)
  const linkedJobIds=[];
  if(inc.maintId) linkedJobIds.push(inc.maintId);
  if(Array.isArray(inc.relatedMaintIds)) inc.relatedMaintIds.forEach(id=>{if(!linkedJobIds.includes(id))linkedJobIds.push(id);});
  const linkedJobs=linkedJobIds.map(id=>FL_MAINT.find(x=>x.id===id)).filter(Boolean);
  const jobLog=linkedJobs.flatMap(j=>(j.progressLog||[]).map(l=>({...l,_fromJob:true,_jobNo:j.no})));
  // Merge + sort by date desc (newest first); tie-break: incident logs first within same date
  const merged=[...incLog,...jobLog].sort((a,b)=>{
    const da=a.date||'',db=b.date||'';
    if(da!==db) return db.localeCompare(da);
    // same date: incident first, job second
    return (a._fromJob?1:0)-(b._fromJob?1:0);
  });
  const timelineHtml=merged.length?merged.map((l,i,arr)=>{
    const isLast=i===arr.length-1;
    const isFirst=i===0;
    const fromJob=l._fromJob;
    const dotColor=fromJob?'#185FA5':(isFirst?SVG_PINK.accent:'#1D9E75');
    const jobPill=fromJob?`<span style="background:#E6F1FB;color:#185FA5;padding:1px 6px;border-radius:6px;font-size:9px;font-weight:600;margin-right:5px;font-family:'DM Mono',monospace;letter-spacing:.02em">${l._jobNo||'JOB'}</span>`:'';
    const backdated = l.createdAt && l.createdAt !== l.date;
    const backdateBadge = backdated ? `<span title="บันทึกเมื่อ ${l.createdAt}" style="background:rgba(0,0,0,.04);color:${dim.ink3};padding:1px 5px;border-radius:5px;font-size:8px;font-weight:500;margin-left:4px;font-family:'DM Mono',monospace">backdated</span>` : '';
    return`<div style="display:flex;gap:10px;${isLast?'':'margin-bottom:10px'};position:relative">
      ${!isLast?`<div style="position:absolute;left:3.5px;top:11px;bottom:-10px;width:1px;background:rgba(0,0,0,.08)"></div>`:''}
      <div style="width:8px;height:8px;border-radius:50%;background:${dotColor};flex-shrink:0;margin-top:3px;z-index:1;${fromJob?'box-shadow:0 0 0 2px #E6F1FB':''}"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500;line-height:1.45">${jobPill}${l.text||''}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${l.date||''}${l.by?' · '+l.by:''}${backdateBadge}</div>
      </div>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No progress logged</div>`;
  const timelineSection=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:8px">Progress timeline${linkedJobs.length?`<span style="font-size:10px;font-weight:500;color:${dim.ink3};display:inline-flex;align-items:center;gap:3px"><span style="width:6px;height:6px;border-radius:50%;background:#185FA5;display:inline-block"></span>linked ${linkedJobs.map(j=>j.no).join(', ')}</span>`:''}</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:12px 14px">${timelineHtml}</div>
    ${st!=='resolved'?`<div style="display:flex;gap:6px;margin-top:8px">
      <input id="log-text-${inc.id}" placeholder="Add progress note..." style="flex:1;background:#FBFAF7;border:1px solid rgba(0,0,0,.06);border-radius:10px;padding:8px 12px;font-size:11px;outline:none;font-family:inherit"/>
      <input id="log-by-${inc.id}" placeholder="By..." style="width:80px;background:#FBFAF7;border:1px solid rgba(0,0,0,.06);border-radius:10px;padding:8px 12px;font-size:11px;outline:none;font-family:inherit"/>
      <button onclick="flAddIncLog('${inc.id}')" style="background:${SVG_PINK.accent};color:white;border:none;border-radius:10px;padding:6px 14px;font-size:11px;font-weight:600;cursor:pointer">Log</button>
    </div>`:''}
  </div>`;

  // Assignment
  const TYPE_DOT={incident:'#A32D2D',maintenance:'#BA7517',inspection:'#185FA5'};
  const TYPE_TEXT={incident:'Incident · Field failure',maintenance:'Maintenance request',inspection:'Inspection report'};
  const incType=inc.type||'incident';
  const assignmentSection=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Assignment</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:14px;display:flex;flex-direction:column;gap:10px">
      <div>
        <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Assigned to</div>
        <div style="font-size:12px;font-weight:600">${inc.remark||inc.assignee||'—'}</div>
      </div>
      <div>
        <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Reported by</div>
        <div style="font-size:12px;font-weight:500">${inc.reportedBy||'—'}</div>
      </div>
      <div>
        <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Type</div>
        <div style="font-size:11px;font-weight:500;display:flex;align-items:center;gap:5px"><span style="width:8px;height:8px;border-radius:50%;background:${TYPE_DOT[incType]||'#666'}"></span>${TYPE_TEXT[incType]||incType}</div>
      </div>
    </div>
  </div>`;

  mount.innerHTML=`${headerStrip}<div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px;max-height:calc(100vh - 280px);overflow-y:auto">
    ${statCards}
    ${warningBanner}
    ${descSection}
    ${damagedSection}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">${timelineSection}${assignmentSection}</div>
  </div>`;
}

function flAddIncLog(incId){
  const inc=FL_INCIDENTS.find(x=>x.id===incId);if(!inc)return;
  const text=document.getElementById('log-text-'+incId)?.value.trim();
  if(!text)return;
  const by=document.getElementById('log-by-'+incId)?.value.trim()||'';
  if(!inc.progressLog) inc.progressLog=[];
  inc.progressLog.push({date:TODAY_STR,text,by});
  flSave();flShowInc(incId);
}

function flIncUpdateDmgDropdowns(boatId){
  const engs=FL_ENGINES.filter(e=>e.boatId===boatId);
