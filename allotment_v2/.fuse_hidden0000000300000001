function natLearnGuess(name){
  const tokens = _natTokenize(name);
  if(tokens.length === 0) return '';
  const data = _natLearnLoad();
  const votes = {};
  let any = false;
  tokens.forEach(t => {
    const counts = data[t];
    if(!counts) return;
    Object.entries(counts).forEach(([code, n]) => {
      votes[code] = (votes[code] || 0) + n;
      any = true;
    });
  });
  if(!any) return '';
  const sorted = Object.entries(votes).sort((a,b) => b[1] - a[1]);
  if(sorted.length === 0) return '';
  const [topCode, topCount] = sorted[0];
  // Confidence threshold · need at least 2 votes OR sole match with 1 vote
  if(topCount < 2 && sorted.length > 1) return '';
  return topCode;
}

