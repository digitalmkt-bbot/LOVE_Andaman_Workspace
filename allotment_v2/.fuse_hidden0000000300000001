  <main class="main">

    <!-- ══════════ DASHBOARD ══════════ -->
    <div id="view-dashboard" class="view active">
      <div id="dash-wrap" style="background:#E8E3DA;margin:-22px;padding:20px 22px 26px;min-height:calc(100vh - 44px);color:#1A1A1A"></div>
    </div>

    <!-- ══════════ CALENDAR (redesigned · Fleet Insights style) ══════════ -->
    <div id="view-calendar" class="view">
      <div class="page-hd"><div><h1>Calendar</h1><p>Daily availability · per-route averages</p></div></div>
      <div id="cal-wrap" style="background:#F4F2EE;margin:14px -16px -16px;padding:18px 20px 22px"></div>
    </div>

    <!-- ══════════ DAILY AVAILABILITY ══════════ -->
    <div id="view-daily" class="view">
      <div class="page-hd">
        <div><h1>Daily Availability</h1><p>ที่นั่งว่างรายวัน · copy ส่ง agent ได้เลย</p></div>
      </div>
      <div class="da-layout">
        <div class="da-left">
          <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column;flex:1">
            <div class="da-date-row">
              <button class="cal-nav" onclick="changeDA(-1)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
              <span class="da-date-lbl" id="da-date-lbl"></span>
              <button class="cal-nav" onclick="changeDA(1)"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
            </div>
            <div class="da-body" id="da-body"></div>
          </div>
        </div>
        <div class="da-right">
          <div class="da-preview-hd">
            <span class="da-preview-lbl">Message</span>
            <span class="da-preview-hint">click to select all</span>
          </div>
          <div class="da-preview-text" id="da-preview" onclick="this.focus();document.execCommand('selectAll')"></div>
          <button class="da-copy-btn" id="da-copy-btn" onclick="copyDA()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copy message
          </button>
        </div>
      </div>
    </div>

    <!-- ══════════ BOAT STATUS ══════════ -->
    <div id="view-boats" class="view">
      <div class="page-hd">
        <div><h1>Boat Status</h1><p>สถานะ · ตำแหน่ง · Timeline</p></div>
        <div class="page-actions">
          <button class="btn btn-ghost btn-sm" onclick="openCharterModal()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>+ เรือเช่า
          </button>
        </div>
      </div>
      <div id="bs-pink-wrap" style="background:#F4F2EE;margin:14px -16px -16px;padding:18px 20px 22px"></div>
      <div class="boats-layout" style="display:none">
        <div>
          <div class="boat-list-panel">
            <div class="boat-list-hd">
              <div class="filter-pills" id="boats-pier-filter" style="margin-bottom:6px">
                <span class="fp on" onclick="setBoatPier('all',this)">ทั้งหมด</span>
                <span class="fp" onclick="setBoatPier('tublamu',this)">Tub Lamu</span>
                <span class="fp" onclick="setBoatPier('panwa',this)">Visit Panwa</span>
              </div>
              <div class="filter-pills" id="boats-st-filter">
                <span class="fp on" onclick="setBoatSt('all',this)">All</span>
                <span class="fp" onclick="setBoatSt('available',this)">Available</span>
                <span class="fp" onclick="setBoatSt('fixing',this)">Fixing</span>
                <span class="fp" onclick="setBoatSt('unavailable',this)">Unavailable</span>
              </div>
            </div>
            <div style="overflow-y:auto">
              <div id="boat-list"></div>
              <div id="charter-list-section" style="display:none">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px"><span style="font-size:10px;font-weight:700">เรือเช่า</span><span id="charter-count" style="font-size:10px"></span></div>
                <div id="charter-list"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="boat-detail-panel" id="bdp">
          <div class="bdp-empty" id="bdp-empty">
            <div style="font-size:28px;margin-bottom:8px;opacity:.3">⛵</div>
            <div style="font-size:13px">เลือกเรือเพื่อดู Timeline</div>
          </div>
          <div id="bdp-content" style="display:none">
            <div class="bdp-hd">
              <div class="bdp-name-row">
                <div id="bdp-name-display" style="display:flex;align-items:center;gap:6px">
                  <span class="bdp-name" id="bdp-name-text"></span>
                  <button class="icon-btn" onclick="startEditName()"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                </div>
                <div id="bdp-name-edit" style="display:none;align-items:center;gap:5px">
                  <input class="name-input" id="bdp-name-inp" type="text" onkeydown="onNameKey(event)">
                  <button class="icon-btn confirm" onclick="confirmName()"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg></button>
                  <button class="icon-btn" onclick="cancelName()"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                </div>
                <div style="margin-left:auto">
                  <button class="btn btn-primary btn-sm" onclick="openAddStatusModal()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>เพิ่ม Status</button>
                </div>
              </div>
              <div class="bdp-sub" id="bdp-sub" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding-bottom:10px">
                <!-- Type inline edit -->
