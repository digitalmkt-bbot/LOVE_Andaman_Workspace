    // ── Seat locks held on this trip (route+date · incl. month-range) ──
    const trLocks = (typeof bkV2LocksFor==='function') ? bkV2LocksFor(rid, date) : [];
    const trLockedTotal = trLocks.reduce((s,l)=>s+bkV2LockRemaining(l),0);
    const lockBar = trLockedTotal>0 ? `
