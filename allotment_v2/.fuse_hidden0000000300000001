function flProjChildMJs(projId){
  return (FL_MAINT||[]).filter(m=>m.parentProjectId===projId);
}
function flProjCalcCost(projId){
  const kids = flProjChildMJs(projId);
  return kids.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);
}
// Cost breakdown · per-MJ
function flProjMJCostBreakdown(mjId){
  const m = (FL_MAINT||[]).find(x=>x.id===mjId);
  if(!m) return {parts:0, labour:0, memos:0, total:0};
  const partsDirect = (m.parts||[]).reduce((s,p)=>s+((p.qty||0)*(p.cost||0)),0);
  let memoParts = 0, memoLabour = 0, memoOther = 0;
  (FL_MEMOS||[]).filter(mo=>mo.maintId===mjId && (mo.status==='paid'||mo.status==='received'||mo.status==='approved')).forEach(mo=>{
    const items = mo.items||[];
    if(items.length===0){ memoOther += (mo.amount||0); return; }
    items.forEach(it=>{
      const sub = (it.qty||0)*(it.price||it.cost||0);
      const cat = (it.category||'').toLowerCase();
      if(cat==='labor'||cat==='labour') memoLabour += sub;
      else if(cat==='parts') memoParts += sub;
      else memoOther += sub;
    });
  });
  const parts = partsDirect + memoParts;
  const labour = memoLabour;
  const memos = memoOther; // legacy / mixed bucket
  const total = parts + labour + memos;
  return {parts, labour, memos, total};
}
// Cost breakdown · project sum (includes direct project-level memos)
function flProjCostBreakdown(projId){
  const kids = flProjChildMJs(projId);
  let parts=0, labour=0, memos=0;
  kids.forEach(m=>{
    const b = flProjMJCostBreakdown(m.id);
    parts += b.parts; labour += b.labour; memos += b.memos;
  });
  // Add direct project-level memos (overhead)
  (FL_MEMOS||[]).filter(mo=>mo.projectId===projId && (mo.status==='paid'||mo.status==='received'||mo.status==='approved')).forEach(mo=>{
    const items = mo.items||[];
    if(items.length===0){ memos += (mo.amount||0); return; }
    items.forEach(it=>{
      const sub = (it.qty||0)*(it.price||it.cost||0);
      const cat = (it.category||'').toLowerCase();
      if(cat==='labor'||cat==='labour') labour += sub;
      else if(cat==='parts') parts += sub;
      else memos += sub;
    });
  });
  const total = parts + labour + memos;
  return {parts, labour, memos, total};
}
