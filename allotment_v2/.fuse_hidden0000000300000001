#view-agents .ct-arch-banner-ttl{font-size:13px;font-weight:700;color:#8a7548;letter-spacing:-0.005em}
#view-agents .ct-arch-banner-sub{font-size:10px;color:var(--fd-ink-mid);font-variant-numeric:tabular-nums;letter-spacing:.04em;text-transform:uppercase;font-weight:600;margin-top:2px}
#view-agents .ct-arch-x{width:30px;height:30px;border-radius:50%;border:1px solid var(--fd-line);background:#fff;color:var(--fd-ink-mid);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
