/* Print: when user prints the wizard, the modal is moved to be a direct body child (via JS).
   Then we hide all other body children and let the modal render at top of the page. */
@media print {
  @page { size: A4 portrait; margin: 10mm 0; }

  /* Hide all direct body children except the modal */
  body.ct-doc-printing > *:not(#ct-doc-modal) { display: none !important; }
  body.ct-doc-printing { margin: 0 !important; padding: 0 !important; background: #fff !important; }

  /* Modal: take it out of overlay mode, render in normal flow */
  body.ct-doc-printing #ct-doc-modal { position: static !important; display: block !important; background: #fff !important; inset: auto !important; align-items: stretch !important; justify-content: flex-start !important; }
  body.ct-doc-printing .ct-doc-backdrop { display: none !important; }
  body.ct-doc-printing .ct-doc-hd,
  body.ct-doc-printing .ct-doc-side,
  body.ct-doc-printing #ct-doc-toast { display: none !important; }

  /* Reset modal card and body to render as a plain container */
  body.ct-doc-printing .ct-doc-card { position: static !important; width: 100% !important; max-width: none !important; height: auto !important; box-shadow: none !important; border-radius: 0 !important; background: #fff !important; display: block !important; }
  body.ct-doc-printing .ct-doc-body { display: block !important; height: auto !important; overflow: visible !important; }
  body.ct-doc-printing .ct-doc-preview { background: #fff !important; padding: 0 !important; gap: 0 !important; overflow: visible !important; height: auto !important; display: block !important; align-items: stretch !important; }

  /* Each page card becomes one printed A4 page · fill full sheet so content centers vertically */
  /* @page margin 10mm top+bottom → printable area = 297mm - 20mm = 277mm */
  body.ct-doc-printing .ct-doc-page {
    box-shadow: none !important;
    border-radius: 0 !important;
    margin: 0 !important;
    page-break-after: always;
    break-after: page;
    max-width: none !important;
    width: 100% !important;
    min-height: calc(297mm - 20mm) !important;   /* fill A4 printable area · centers content like cover */
    display: flex !important;
    flex-direction: column !important;
    box-sizing: border-box !important;
  }
  body.ct-doc-printing .ct-doc-page:last-child { page-break-after: auto; break-after: auto; }

  /* Remove editable outlines + cursors */
  body.ct-doc-printing .ct-doc-edit { outline: none !important; background: transparent !important; cursor: default !important; }

  /* Avoid splitting tables / rows / clauses across pages */
  body.ct-doc-printing .ct-doc-page table { page-break-inside: avoid; break-inside: avoid; }
  body.ct-doc-printing .ct-doc-page thead { display: table-header-group; }
  body.ct-doc-printing .ct-doc-page tr { page-break-inside: avoid; break-inside: avoid; }
  body.ct-doc-printing .ct-doc-clause-card { page-break-inside: avoid; break-inside: avoid; }

  /* Force the coral letterhead background to print (Chrome/Safari default skips bg colors) */
  body.ct-doc-printing .ct-doc-page > *:first-child,
  body.ct-doc-printing .ct-doc-page aside { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
}

