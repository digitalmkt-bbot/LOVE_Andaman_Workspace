  const msg=`ลบโปรแกรมนี้?\n\n${r.name}\n${r.islands||''}${seasonCount?`\n\n⚠️ มี ${seasonCount} season ที่จะถูกลบไปด้วย`:''}\n\nการลบนี้ไม่สามารถยกเลิกได้`;
