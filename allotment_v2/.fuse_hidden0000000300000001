function flProjRenderYoyModal(){
  const P = PROJ_PALETTE;
  const mount = document.getElementById('fl-proj-yoy-body');
  if(!mount) return;
  const data = flProjYoYStats(_yoyYear);
  const {yearTY, yearLY, TY, LY} = data;

  // Delta helper · returns {pct, ink, label, arrow}
  const delta = (ty, ly, betterUp=true) => {
    if(ly===0 && ty===0) return {pct:0, ink:P.ink3, label:'—', arrow:''};
    if(ly===0) return {pct:100, ink:betterUp?P.mintInk:P.red, label:'new', arrow:''};
    const d = Math.round((ty-ly)/Math.max(1,Math.abs(ly))*100);
    const up = d>0;
    const positive = betterUp ? up : !up;
    return {
      pct: Math.abs(d),
      ink: d===0?P.ink3 : (positive?P.mintInk:P.red),
