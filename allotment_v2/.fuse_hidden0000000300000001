#view-agents .ct-wstep.done .ct-wstep-num-num{display:none}
#view-agents .ct-wstep.current{color:var(--fd-ink)}
#view-agents .ct-wstep.current .ct-wstep-num{background:var(--fd-coral);border-color:var(--fd-coral);color:#fff}
#view-agents .ct-wstep-conn{flex:1;height:1.5px;background:var(--fd-line)}
#view-agents .ct-wstep.done + .ct-wstep-conn{background:#0F6E56}

#view-agents .ct-wiz-body{padding:20px 22px;overflow-y:auto;flex:1}
#view-agents .ct-wiz-intro{font-size:12px;color:var(--fd-ink-mid);margin-bottom:14px;line-height:1.5}

/* Step 1 — period picker */
#view-agents .ct-period-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;align-items:center;margin-bottom:10px}
#view-agents .ct-period-fld{display:flex;flex-direction:column;gap:4px}
