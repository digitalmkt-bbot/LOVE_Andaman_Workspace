function bkV2CloseLockModal(){ _bkV2LockModalOpen = false; bkV2Render(); }
function bkV2LockSetField(field, val){
  _bkV2LockForm[field] = val;
  if(field==='holderType' || field==='routeId' || field==='scope') bkV2Render();
}
function bkV2LockCreateSubmit(){
  const f = _bkV2LockForm;
  if(!f.routeId){ alert('Pick a route first'); return; }
  if(f.scope==='month'){ if(!f.monthFrom){ alert('Pick the start month'); return; } }
  else if(!f.date){ alert('Pick a date'); return; }
  if(!(Number(f.qty) > 0)){ alert('Enter how many seats to lock'); return; }
  let holderId = null;
  if(f.holderType==='agent'){
    const nm = (f.holderName||'').trim();
    if(!nm){ alert('Type the agent that holds the lock'); return; }
    const match = (typeof SB_AGENTS!=='undefined'?SB_AGENTS:[]).find(a => a.name.toLowerCase() === nm.toLowerCase());
    holderId = match ? match.id : nm;   // free-text holder allowed
  }
  const mFrom = f.monthFrom, mTo = f.monthTo || f.monthFrom;
  bkV2CreateLock({ scope:f.scope, routeId:f.routeId, date:f.scope==='day'?f.date:'',
    monthFrom:f.scope==='month'?mFrom:'', monthTo:f.scope==='month'?mTo:'',
    holderType:f.holderType, holderId:holderId, qty:Number(f.qty), reason:f.reason, expiry:f.expiry });
  _bkV2LockForm.qty=''; _bkV2LockForm.reason='';
