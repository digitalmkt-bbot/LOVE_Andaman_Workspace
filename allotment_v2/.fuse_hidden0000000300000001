function flSaveInvEdit(){
  const id=document.getElementById('inv-edit-id').value;
  const item=FL_INVENTORY.find(x=>x.id===id);
  if(!item){alert('ไม่พบรายการ');return;}

  // Collect new values
  const engineModel=document.getElementById('inv-edit-engine')?.value||'';
  const extraNote=document.getElementById('inv-edit-note').value.trim();
  const combinedNote=[engineModel, extraNote].filter(Boolean).join(' · ');
  const newVals={
    name: document.getElementById('inv-edit-name').value.trim(),
    partNo: document.getElementById('inv-edit-partno').value.trim(),
    category: document.getElementById('inv-edit-cat').value,
    supplier: document.getElementById('inv-edit-supplier').value.trim(),
    location: document.getElementById('inv-edit-location').value.trim(),
    qty: parseFloat(document.getElementById('inv-edit-qty').value)||0,
    unit: document.getElementById('inv-edit-unit').value.trim(),
    minQty: parseFloat(document.getElementById('inv-edit-min').value)||0,
    cost: parseFloat(document.getElementById('inv-edit-cost').value)||0,
    note: combinedNote,
  };

  if(!newVals.name){alert('กรุณากรอกชื่อรายการ');return;}

  // Compute changes
  const FIELD_LABELS={name:'ชื่อรายการ',partNo:'Part No',category:'หมวดหมู่',supplier:'Supplier',location:'ที่เก็บ',qty:'จำนวน',unit:'หน่วย',minQty:'ขั้นต่ำ',cost:'ราคา/หน่วย',note:'หมายเหตุ'};
  const changes=[];
  Object.keys(newVals).forEach(k=>{
    const oldV=item[k];
    const newV=newVals[k];
    // Normalize for comparison
    const oldStr=String(oldV==null?'':oldV);
    const newStr=String(newV==null?'':newV);
    if(oldStr!==newStr){
      changes.push({field:FIELD_LABELS[k]||k,from:oldStr,to:newStr,key:k});
    }
  });

  if(changes.length===0){
    closeModal('fl-modal-inv-edit');
    return;
  }

  // Warn if partNo changed (might break memo links)
  const partNoChange=changes.find(c=>c.key==='partNo');
  if(partNoChange){
    if(!confirm(`⚠ คุณกำลังเปลี่ยน Part Number\nจาก: ${partNoChange.from}\nเป็น: ${partNoChange.to}\n\nอาจกระทบประวัติ Memo เก่าที่อ้างอิง Part No นี้\nต้องการดำเนินการต่อหรือไม่?`)) return;
  }

  // Apply changes
  Object.keys(newVals).forEach(k=>{ item[k]=newVals[k]; });

  // Append audit log entry
  if(!item.history) item.history=[];
  item.history.push({
    date: new Date().toISOString().slice(0,10),
    type: 'edit',
    changes: changes.map(c=>({field:c.field,from:c.from,to:c.to})),
    note: '',
    by: ''
  });

  flSave();
  closeModal('fl-modal-inv-edit');
  flRenderInventory();
}

function flSaveReceive(){
  if(_receiveMemoId){
    const mo=FL_MEMOS.find(x=>x.id===_receiveMemoId);
    if(mo){
      const date=document.getElementById('receive-date').value;
      const note=document.getElementById('receive-note').value;
      const memoLocation = document.getElementById('receive-location')?.value || 'คลัง Tub Lamu';
      let updatedCount=0, createdCount=0;
      (mo.items||[]).forEach((it,i)=>{
        const qtyEl=document.getElementById('recv-qty-'+i);
        const qty=parseFloat(qtyEl?.value)||0;
        if(qty<=0) return;
        // Skip labor items — they don't go into stock
        const cat=it.category||mo.memoType||'parts';
        if(cat==='labor') return;
        // match by invId first, then by exact name
        let inv=it.invId
          ?FL_INVENTORY.find(x=>x.id===it.invId)
          :FL_INVENTORY.find(x=>x.name===it.name||it.name.includes(x.name));
        if(inv){
          // Ensure stocks[] exists, then add at chosen location
          invSyncLegacy(inv);
          invAddAt(inv, memoLocation, qty);
          if(!inv.history)inv.history=[];
          inv.history.push({date,type:'receive',qty,location:memoLocation,note:`จาก ${mo.no} · ${note} · @ ${memoLocation}`,by:''});
          updatedCount++;
        } else {
          // Auto-create new inventory item from memo line — with multi-warehouse stocks
          const newInv={
            id:'i'+Date.now()+Math.floor(Math.random()*1000),
            name:it.name,
            partNo:'',
            category:'อื่นๆ',
            supplier:mo.supplier||'',
            location:memoLocation,
            stocks:[{location:memoLocation, qty:qty, minQty:0}],
            qty:qty, totalQty:qty,
            minQty:0,
            unit:it.unit||'ชิ้น',
            cost:it.price||0,
            note:`สร้างอัตโนมัติจาก ${mo.no}`,
            createdFrom:mo.no,
            createdDate:date,
            history:[{date,type:'receive',qty,location:memoLocation,note:`รับครั้งแรก · จาก ${mo.no} · ${note} · @ ${memoLocation}`,by:''}]
          };
          FL_INVENTORY.push(newInv);
          it.invId=newInv.id;
          createdCount++;
        }
      });
      mo.currentStep=4;mo.status='received';
      let toastMsg=`รับของ ${mo.no} เรียบร้อย · @ ${memoLocation}`;
      if(updatedCount&&createdCount) toastMsg+=` · อัพเดท ${updatedCount} · สร้างใหม่ ${createdCount} items`;
      else if(updatedCount) toastMsg+=` · อัพเดท ${updatedCount} items`;
      else if(createdCount) toastMsg+=` · สร้างใหม่ ${createdCount} items`;
      flShowToast(toastMsg);
    }
    _receiveMemoId=null;
    document.getElementById('receive-item-sel').style.display='block';
    document.getElementById('receive-item-fixed').style.display='none';
    const qtyRow=document.getElementById('receive-qty');if(qtyRow)qtyRow.style.display='';
    flSave();closeModal('fl-modal-receive');flRenderInventory();
    return;
  }
  const id=_receiveItemId||document.getElementById('receive-item-sel').value;
  if(!id){alert('กรุณาเลือกรายการ');return;}
  const item=FL_INVENTORY.find(x=>x.id===id);if(!item)return;
  const qty=parseFloat(document.getElementById('receive-qty').value)||0;
  if(qty<=0){alert('กรุณาระบุจำนวน');return;}
  const newLocation = document.getElementById('receive-location')?.value || item.location;
  // Ensure migrated before adding
  invSyncLegacy(item);
  // Multi-warehouse: add qty to the specific location's stock entry
  invAddAt(item, newLocation, qty);
  if(!item.history)item.history=[];
  const baseNote = document.getElementById('receive-note').value;
  item.history.push({
    date:document.getElementById('receive-date').value,
    type:'receive',
    qty,
    location: newLocation,
    note: (baseNote ? baseNote : '') + ` · @ ${newLocation}`,
    by:''
  });
  flSave();closeModal('fl-modal-receive');flRenderInventory();
  flShowToast(`รับ ${item.name} +${qty} ${item.unit} · ${newLocation} เรียบร้อย`);
  _receiveItemId=null;
}
