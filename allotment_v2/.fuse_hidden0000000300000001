function bkPricePreview(){
  const tmp = {..._bkDraft};
  // build a dummy booking and use sbCalcBookingTotal logic but return per-pax
  let unitA=0, unitC=0, unitI=0;
  if(_bkDraft.channelType==='b2b' && _bkDraft.channel && _bkDraft.programId){
    const pm = SB_AGENT_PRICES[_bkDraft.channel];
    if(pm && pm[_bkDraft.programId]){
      const zone = pm[_bkDraft.programId][_bkDraft.transfer||'NoTransfer'];
      if(zone){
        unitA = zone[`adult-${_bkDraft.paxType}`]||0;
        unitC = zone[`child-${_bkDraft.paxType}`]||0;
        unitI = zone[`infant-${_bkDraft.paxType}`]||0;
      }
    }
  } else if(_bkDraft.channelType==='b2c' && _bkDraft.channel && _bkDraft.programId){
    const ch = sbGetB2C(_bkDraft.channel);
    const base = SB_B2C_BASE[_bkDraft.programId];
    if(ch && base){
      const mul = ch.type==='campaign' ? (1-(ch.discount||0)) : (ch.priceMul||1);
      unitA = Math.round((base[`adult-${_bkDraft.paxType}`]||0)*mul);
      unitC = Math.round((base[`child-${_bkDraft.paxType}`]||0)*mul);
      unitI = Math.round((base[`infant-${_bkDraft.paxType}`]||0)*mul);
    }
  }
  const total = unitA*_bkDraft.pax.adult + unitC*_bkDraft.pax.child + unitI*_bkDraft.pax.infant;
  return {adult:unitA, child:unitC, infant:unitI, total};
}
