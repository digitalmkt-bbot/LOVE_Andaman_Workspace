      ${groups || '<div class="bkv2-selday-empty">No seat locks yet · create one above</div>'}
    </div>
    ${releaseModal}
    </div>
  `;
}

// ── Helpers ──
function sbGetMarket(mId){return SB_MARKETS.find(m=>m.id===mId);}
function sbGetAgent(aId){return SB_AGENTS.find(a=>a.id===aId);}
function sbGetB2C(cId){return SB_B2C.find(c=>c.id===cId);}
function sbGetPayment(pId){return SB_PAYMENT_TYPES.find(p=>p.id===pId);}
function sbFmtTHB(n){return new Intl.NumberFormat('en-US').format(Math.round(n||0));}
function sbFmtDate(d){
  if(!d) return '—';
  const dt = typeof d==='string'?new Date(d+'T00:00'):d;
  return dt.toLocaleDateString('en-GB',{day:'2-digit',month:'short'});
}

function sbCalcBookingTotal(bk){
  if(!bk || !bk.programId) return 0;
  const px = bk.paxType||'thai';
  let unitA=0, unitC=0, unitI=0;
  if(bk.channelType==='b2b'){
    const pm = SB_AGENT_PRICES[bk.channel];
    if(!pm || !pm[bk.programId]) return 0;
    const zone = pm[bk.programId][bk.transfer||'NoTransfer'];
    if(!zone) return 0;
    unitA = zone[`adult-${px}`]||0;
    unitC = zone[`child-${px}`]||0;
    unitI = zone[`infant-${px}`]||0;
  } else {
    const ch = sbGetB2C(bk.channel); if(!ch) return 0;
    const base = SB_B2C_BASE[bk.programId]; if(!base) return 0;
    const mul = ch.type==='campaign' ? (1 - (ch.discount||0)) : (ch.priceMul||1);
    unitA = Math.round((base[`adult-${px}`]||0)*mul);
    unitC = Math.round((base[`child-${px}`]||0)*mul);
    unitI = Math.round((base[`infant-${px}`]||0)*mul);
  }
  return (bk.pax.adult||0)*unitA + (bk.pax.child||0)*unitC + (bk.pax.infant||0)*unitI;
