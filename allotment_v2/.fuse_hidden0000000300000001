#view-booking .bkv2-mx th.dh.sel .dnum{color:#fff}
#view-booking .bkv2-mx tr.tot td.today{background:#EAF1FE;color:#2952C8}
/* Matrix · selected data/empty cell = filled (not just outline) */
#view-booking .bkv2-mx td.cell.sel{outline:none;box-shadow:inset 0 0 0 2px #3A6FF7;background:#3A6FF7;color:#fff}
#view-booking .bkv2-mx td.cell.empty.sel{background:#3A6FF7;color:#fff}
/* Calendar · day cell · Today = ring on white · Selected = filled */
#view-booking .bkv2-cal-cell.today{background:#fff;border:2px solid #9DBFF6}
#view-booking .bkv2-cal-cell.weekend.today{background:#fff}
#view-booking .bkv2-cal-cell.today .bkv2-cal-daynum{color:#3A6FF7;font-weight:700}
#view-booking .bkv2-cal-cell.sel{background:#E4ECFC;border:2px solid #3A6FF7;box-shadow:0 2px 8px rgba(58,111,247,.18)}
#view-booking .bkv2-cal-cell.sel .bkv2-cal-daynum{color:#1F2A44;font-weight:700}
</style>
