  if(maintId){
    _selMaintId = maintId;
    // Switch to appropriate tab — if job is done, go to archive
    const m = FL_MAINT.find(x=>x.id===maintId);
    if(m){
      if(m.status === 'done' && m.awaitingInvoice && !FL_MEMOS.some(memo=>memo.maintId===m.id)){
        _maintArchiveTab = 'awaiting';
      } else if(m.status === 'done'){
