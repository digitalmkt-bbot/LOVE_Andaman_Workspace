// Backfill historical pricing snapshots for ALL IN TRAVEL (after SB_AGENT_PRICES is ready)
(function _seedHistoricalPricing(){
  const allin = SB_AGENTS.find(x=>x.id==='a73');
  if(!allin || !allin.contractHistory) return;
  const currentPrices = SB_AGENT_PRICES[allin.id] || {};
  // Apply discount per archive year — older = cheaper
  const applyDiscount = (basePrices, factor)=>{
    const out = {};
    Object.keys(basePrices).forEach(routeId=>{
      out[routeId] = {};
      Object.keys(basePrices[routeId]).forEach(zone=>{
        out[routeId][zone] = {};
        Object.keys(basePrices[routeId][zone]).forEach(pax=>{
          const v = basePrices[routeId][zone][pax];
          out[routeId][zone][pax] = v ? Math.round(v*factor/100)*100 : v;
        });
      });
    });
    return out;
  };
  // v2024-1 = 92% of current
  const v2024 = allin.contractHistory.find(h=>h.version==='v2024-1');
  if(v2024){
    // Only include routes that were in that contract
    const routeIds = (v2024.snapshot.programPeriods||[]).map(p=>p.routeId);
    const filtered = {};
    routeIds.forEach(rId=>{ if(currentPrices[rId]) filtered[rId] = currentPrices[rId]; });
    v2024.snapshot.prices = applyDiscount(filtered, 0.92);
  }
  // v2023-1 = 85% of current
  const v2023 = allin.contractHistory.find(h=>h.version==='v2023-1');
  if(v2023){
    const routeIds = (v2023.snapshot.programPeriods||[]).map(p=>p.routeId);
    const filtered = {};
    routeIds.forEach(rId=>{ if(currentPrices[rId]) filtered[rId] = currentPrices[rId]; });
    v2023.snapshot.prices = applyDiscount(filtered, 0.85);
  }
})();

