        <div class="aos-svc-body">
          <div class="aos-variants">
            ${svc.variants.map(v=>`
              <div class="aos-variant-row">
                <div class="aos-variant-info">
                  <div class="aos-variant-ttl">${v.name}</div>
                  <div class="aos-variant-unit">${v.unit||'—'}</div>
                </div>
                <div class="aos-variant-actions">
                  <button class="aos-icon-btn" onclick="aosEditVariant('${svc.id}','${v.id}')" title="แก้ไข">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </button>
                  <button class="aos-icon-btn danger" onclick="aosDeleteVariant('${svc.id}','${v.id}')" title="ลบ">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 01-2 2H9a2 2 0 01-2-2L5 6"/></svg>
