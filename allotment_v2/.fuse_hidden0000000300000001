<script>
// ══════════════════════════════════════
const LOVE_LOGO_B64='data:image/png;base64,';

// FLEET — Data (shared localStorage)
// ══════════════════════════════════════
const FLEET_VERSION='fleet_v34';
// ════ Snapshot Restore Helpers (for safety) ════
// Run in console:
//   flListSnapshots()     - ดู snapshot ทั้งหมด
//   flRestoreSnapshot(N)  - restore snapshot ที่ N
window.flListSnapshots = function(){
  const snapKeys = Object.keys(localStorage)
    .filter(k => k.startsWith(LS_KEY + '_snap_'))
    .sort();
  console.log('Available snapshots (oldest → newest):');
  snapKeys.forEach((k, i) => {
    const ts = parseInt(k.replace(LS_KEY + '_snap_', ''));
    const date = new Date(ts).toLocaleString();
    try {
      const data = JSON.parse(localStorage.getItem(k));
      const counts = {
        MJ: data.fleet_maintenance?.length || 0,
        MO: data.fleet_memos?.length || 0,
        INC: data.fleet_incidents?.length || 0,
        size: (localStorage.getItem(k).length / 1024).toFixed(1) + 'KB'
      };
      console.log(`  [${i}] ${date} · ${JSON.stringify(counts)}`);
    } catch(e){
      console.log(`  [${i}] ${date} · (parse error)`);
    }
  });
  return snapKeys.length + ' snapshots';
};

window.flRestoreSnapshot = function(idx){
  const snapKeys = Object.keys(localStorage)
    .filter(k => k.startsWith(LS_KEY + '_snap_'))
    .sort();
  if(idx < 0 || idx >= snapKeys.length){
    console.error('Invalid index. Use flListSnapshots() to see available.');
    return false;
  }
  const key = snapKeys[idx];
  const snapData = localStorage.getItem(key);
  if(!confirm('Restore snapshot [' + idx + ']?\n\nWill overwrite current data. Refresh after restore to apply.')){
    return false;
  }
  localStorage.setItem(LS_KEY, snapData);
  console.log('✓ Restored snapshot [' + idx + ']. Refresh page to apply.');
  return true;
};

function flLoad(){
  const d=JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  
  // ════ AUTO-SNAPSHOT BACKUP (safety net) ════
  // Save snapshot of LocalStorage BEFORE any migration runs
  // Keeps last 10 snapshots (rotating)
  try {
    const hasData = d.fleet_maintenance?.length || d.fleet_memos?.length || d.fleet_incidents?.length;
    if(hasData){
      const ts = Date.now();
      const snapKey = LS_KEY + '_snap_' + ts;
      localStorage.setItem(snapKey, JSON.stringify(d));
      // Rotate: keep only last 10 snapshots
      const snapKeys = Object.keys(localStorage)
        .filter(k => k.startsWith(LS_KEY + '_snap_'))
        .sort();
      while(snapKeys.length > 10){
        const oldest = snapKeys.shift();
        localStorage.removeItem(oldest);
      }
    }
  } catch(e){ console.warn('[Auto-snapshot] failed:', e); }
  
  // First-time / unknown version path
