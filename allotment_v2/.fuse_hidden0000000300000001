function bkV2RenderAddOnsSection(){
  const d = _bkV2.newBooking;
  const rt = bkV2GetRT();
  if(!rt) return `<div style="font-size:12px;color:var(--ink-soft);font-style:italic;padding:12px 0">Pick an agent first to see available add-ons.</div>`;

  const escapeHTML = s => String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
  const checked = type => d.addOns.some(a => a.type === type);
  const opts = [];

  // Check if any selected trip route has bundled longtail · disable Longtail Join in that case
  const bundledRoutes = d.trips
    .filter(t => t.routeId && rt.routeBundles?.[t.routeId]?.longtail)
    .map(t => ({ rid: t.routeId, mode: rt.routeBundles[t.routeId].longtail.mode, name: (typeof ROUTES!=='undefined' ? ROUTES.find(r=>r.id===t.routeId)?.name : t.routeId) }));

  // Filter longtail by applies[] · only show if at least one trip route is in applies
  const tripRouteIds = d.trips.map(t => t.routeId).filter(Boolean);
  const ltApplies = Array.isArray(rt.addOns?.longtail?.applies) ? rt.addOns.longtail.applies : null;
  const longtailApplicable = ltApplies ? tripRouteIds.some(rid => ltApplies.includes(rid)) : true;
  const ltJoin = rt.addOns?.longtail?.join;
  if(longtailApplicable && ltJoin && (ltJoin.adult || ltJoin.child)){
    const info = bkV2AddOnInfo('longtail-join');
    const locked = bundledRoutes.length > 0;
    opts.push({
      type:'longtail-join',
      label:`Longtail Join`,
      sub: locked
        ? `Locked &middot; bundled in ${bundledRoutes.map(b=>b.name).join(' &middot; ')}`
        : `฿${ltJoin.adult||0}/A · ฿${ltJoin.child||0}/C`,
      amount: info.total,
      locked
    });
  }
  const ltCharter = rt.addOns?.longtail?.charter;
  if(longtailApplicable && ltCharter && ltCharter.price){
    const info = bkV2AddOnInfo('longtail-charter');
    opts.push({ type:'longtail-charter', label:`Longtail Charter`, sub:`฿${ltCharter.price}/boat · max ${ltCharter.capacity||6} pax`, amount: info.total });
  }
  // Private transfers per trip's route+zone
  const ptMap = rt.addOns?.privateTransfer || {};
  d.trips.forEach(t => {
    if(!t.routeId || !t.zone || t.zone === 'NoTransfer') return;
    const zoneOpts = ptMap[t.routeId]?.[t.zone];
    if(!zoneOpts) return;
    Object.entries(zoneOpts).forEach(([vehicle, price]) => {
      if(!price) return;
      const type = `transfer-${t.routeId}-${t.zone}-${vehicle}`;
      if(opts.some(o => o.type === type)) return;
      opts.push({ type, label:`Transfer · ${vehicle.charAt(0).toUpperCase()+vehicle.slice(1)}`, sub:`${t.zone} for ${(typeof ROUTES!=='undefined'?ROUTES.find(r=>r.id===t.routeId)?.name:t.routeId)} · ฿${price}/trip`, amount: price });
    });
  });

  if(opts.length === 0) return `<div style="font-size:12px;color:var(--ink-soft);font-style:italic;padding:12px 0">No add-ons available for this rate type · or pick trips first to enable transfer options.</div>`;

  return `
    <div class="bkv2-nb-addons">
      ${opts.map(o => `
        <label class="bkv2-nb-addon ${checked(o.type)?'on':''}" style="${o.locked?'opacity:.55;cursor:not-allowed;background:#fafafa':''}">
          <input type="checkbox" ${checked(o.type) && !o.locked?'checked':''} ${o.locked?'disabled':''} onchange="${o.locked?'':`bkV2ToggleAddOn('${o.type}')`}">
          <div style="flex:1;min-width:0">
            <div style="font-weight:600;font-size:12px;color:var(--ink)">${escapeHTML(o.label)} ${o.locked?'<span style="background:#0F6E56;color:#fff;font-size:8px;padding:1px 5px;border-radius:3px;font-weight:700;letter-spacing:.06em;margin-left:4px;vertical-align:middle">LOCKED</span>':''}</div>
            <div style="font-size:10px;color:var(--ink-soft);margin-top:1px;font-family:'DM Mono',monospace">${o.sub}</div>
          </div>
          <div style="font-family:Manrope,sans-serif;font-weight:700;color:${o.locked?'var(--ink-soft)':'var(--bk-navy)'};font-size:14px;font-variant-numeric:tabular-nums;letter-spacing:-.01em">${o.locked?'—':`฿${(o.amount||0).toLocaleString()}`}</div>
        </label>
      `).join('')}
    </div>
  `;
}

