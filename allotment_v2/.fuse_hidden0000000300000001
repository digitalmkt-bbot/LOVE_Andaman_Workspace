}
function bkV2RenderLocks(){
  const esc = s => String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
  const f = _bkV2LockForm;
  const routeName = rid => (typeof ROUTES!=='undefined' ? (ROUTES.find(r=>r.id===rid)?.name||rid) : rid);
  // KPI
  const active = SB_SEAT_LOCKS.filter(l=>l.status==='active');
  const heldRem = active.reduce((s,l)=>s+bkV2LockRemaining(l),0);
  const lockedQty = SB_SEAT_LOCKS.reduce((s,l)=>s+(l.qty||0),0);
  const usedQty = SB_SEAT_LOCKS.reduce((s,l)=>s+(l.used||0),0);
  const conv = lockedQty ? Math.round(usedQty/lockedQty*100) : 0;
  const kpi = `
    <div class="bkv2-stats" style="grid-template-columns:repeat(4,1fr)">
      <div class="bkv2-stat hero"><div class="s-lab">Active locks</div><div class="s-val">${active.length}</div><div class="s-foot">${heldRem} seats held now</div></div>
      <div class="bkv2-stat"><div class="s-lab">Locked (all time)</div><div class="s-val">${lockedQty}</div><div class="s-foot">seats reserved</div></div>
      <div class="bkv2-stat success"><div class="s-lab">Converted</div><div class="s-val">${usedQty}</div><div class="s-foot">drawn into bookings</div></div>
      <div class="bkv2-stat"><div class="s-lab">Conversion</div><div class="s-val">${conv}%</div><div class="s-foot">used / locked</div></div>
    </div>`;
  // Create form (fields shared with the Calendar inline modal · bkV2LockFormFields)
  const createForm = `
    <div class="bkv2-nb-sec" style="margin:12px 12px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm)">
      <div class="bkv2-nb-sec-h">&#9679; Lock seats <em style="font-weight:500;color:var(--ink-soft);font-style:normal;font-size:11px">· hold a pool of seats</em></div>
      ${bkV2LockFormFields()}
      <div style="margin-top:11px"><button class="bkv2-newbtn2" onclick="bkV2LockCreateSubmit()" style="font-size:12px">+ Create lock</button></div>
    </div>`;
  // Locks grouped by trip · day-scope by route+date · month-scope by route+month
  const keyOf = l => l.scope==='month' ? (l.routeId+'|M:'+(l.monthFrom||l.month)+'_'+(l.monthTo||l.monthFrom||l.month)) : (l.routeId+'|'+l.date);
  const sorted = [...SB_SEAT_LOCKS].sort((a,b)=> ((a.date||a.month||'')).localeCompare(b.date||b.month||'') || (a.routeId||'').localeCompare(b.routeId||''));
  const tripKeys = [...new Set(sorted.map(keyOf))];
  const stChip = st => {
    const m = { active:['#0F6E56','#E1F5EE'], depleted:['#64748B','#F1F5F9'], released:['#A05A1A','#FBEFD9'], expired:['#A32D2D','#FDECEA'] };
    const c = m[st]||['#64748B','#F1F5F9'];
    return `<span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:${c[0]};background:${c[1]};padding:2px 7px;border-radius:5px">${st}</span>`;
  };
  const groups = tripKeys.map(k => {
    const locks = sorted.filter(l=>keyOf(l)===k);
    const first = locks[0];
    const rid = first.routeId;
    const monthScope = first.scope==='month';
    const date = monthScope ? '' : first.date;
    const mFrom = first.monthFrom||first.month, mTo = first.monthTo||mFrom;
    const monthLabel = (mFrom===mTo) ? (mFrom+' · whole month') : (mFrom+' → '+mTo);
    let availBar;
    if(monthScope){
      const lockedRem = locks.reduce((s,l)=>s+bkV2LockRemaining(l),0);
      const rangeTxt = (mFrom===mTo) ? esc(mFrom) : (esc(mFrom)+' → '+esc(mTo));
