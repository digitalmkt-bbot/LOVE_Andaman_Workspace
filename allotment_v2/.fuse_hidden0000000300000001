    locMap[k].props.push(p);
  });
  const totalSpareGb=spareGbs.length;
  const totalSpareProp=spareProps.length;

  // Group locations by type
  const piers=[],boats=[],shops=[],unknowns=[];
  Object.entries(locMap).forEach(([k,v])=>{
    if(k===UNKNOWN_LOC){unknowns.push([k,v]);return;}
    const t=flParseSpareLoc(k).type;
    if(t==='pier')piers.push([k,v]);
    else if(t==='boat')boats.push([k,v]);
    else if(t==='shop')shops.push([k,v]);
  });

  // SVG icons for assets and locations
  const SVG_GB_ICON=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l3 3M16 16l3 3M5 19l3-3M16 8l3-3"/></svg>`;
  const SVG_PROP_ICON=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="2" fill="currentColor"/><path d="M12 2c2 0 3.5 1.5 3.5 4 0 2-1 3-3.5 4-2.5-1-3.5-2-3.5-4 0-2.5 1.5-4 3.5-4z"/><path d="M22 12c0 2-1.5 3.5-4 3.5-2 0-3-1-4-3.5 1-2.5 2-3.5 4-3.5 2.5 0 4 1.5 4 3.5z"/><path d="M12 22c-2 0-3.5-1.5-3.5-4 0-2 1-3 3.5-4 2.5 1 3.5 2 3.5 4 0 2.5-1.5 4-3.5 4z"/><path d="M2 12c0-2 1.5-3.5 4-3.5 2 0 3 1 4 3.5-1 2.5-2 3.5-4 3.5-2.5 0-4-1.5-4-3.5z"/></svg>`;
  const SVG_BOX=`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`;
  const SVG_PLUS=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;

  // Type metadata for section headers
  const sectionMeta={
    pier:{label:'คลังท่าเรือ',color:'#0e6b87'},
    boat:{label:'Boat',color:'#1c4e7e'},
    shop:{label:'อู่ซ่อม',color:'#b76e00'},
  };

  // Build flat row for an item
  // Asset-type colors matching stat cards above
  const KIND_COLORS={
    gearbox:{accent:'#6c5ce7',bg:'#ede9ff',text:'#4a3fb5'},
    propeller:{accent:'#d48a14',bg:'#fef6df',text:'#92560f'},
  };

  const buildRow=(item,kind,locColor)=>{
    const iconSvg=kind==='gearbox'?SVG_GB_ICON:SVG_PROP_ICON;
    const isFixing=item.status==='fixing';
    const kc=KIND_COLORS[kind];
    // Icon: use kind color always (purple for gearbox, amber for prop)
    const iconBg=kc.bg;
    const iconColor=kc.accent;
    // Right label: status if fixing/not-spare; otherwise show size for prop, "spare" for gb
    let rightLabel,rightStyle;
    if(isFixing){
      rightLabel='fixing';
      rightStyle='background:#fef6df;color:#a06a00';
    }else if(kind==='gearbox'){
      rightLabel=item.status;
      rightStyle=`background:${kc.bg};color:${kc.text}`;
    }else{
      rightLabel=item.size||'—';
      rightStyle=`background:${kc.bg};color:${kc.text}`;
    }
    const sub=kind==='gearbox'
      ?(item.brand+' '+(item.model||'').replace(' Gearbox',''))
      :(`${item.brand||''} · ${item.size||'—'} · ${item.rotation||'—'}${item.propPos?' · '+item.propPos:''}`);
    return`<tr onclick="flOpenMoveSpare('${kind}','${item.id}')" onmouseover="this.style.background='rgba(0,0,0,.02)'" onmouseout="this.style.background='transparent'" style="cursor:pointer;transition:background .12s;border-top:0.5px solid rgba(26,35,50,.06)">
      <td style="padding:6px 8px 6px 18px;width:18px"><span style="display:inline-flex;width:18px;height:18px;border-radius:4px;background:${iconBg};color:${iconColor};align-items:center;justify-content:center">${iconSvg}</span></td>
      <td style="padding:6px 0"><span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;color:var(--ink)">${item.serial}</span><span style="color:var(--ink-soft);font-size:10px;margin-left:8px">${sub}</span></td>
      <td style="text-align:right;padding:6px 4px 6px 8px"><span style="font-size:9px;${rightStyle};padding:2px 6px;border-radius:3px;font-family:'DM Mono',monospace;font-weight:500">${rightLabel}</span></td>
    </tr>`;
  };

  // Build a section (pier/boat/shop) — returns complete column block (header + table)
  const buildSection=(type,entries,customLabel)=>{
    if(!entries.length)return'<div></div>'; // empty placeholder so column grid stays aligned
    const meta=sectionMeta[type];
    const label=customLabel||meta.label;
    const sectionHd=`<div style="display:flex;align-items:center;gap:6px;padding:0 0 6px;font-size:10px;font-weight:600;color:${meta.color};text-transform:uppercase;letter-spacing:.05em">
      <span style="display:inline-block;width:3px;height:11px;background:${meta.color};border-radius:2px"></span>${label}
      <span style="font-family:'DM Mono',monospace;color:var(--ink-soft);font-size:10px;font-weight:500;margin-left:4px">· ${entries.length}</span>
    </div>`;
    const locBlocks=entries.map(([k,v])=>{
      const isUnknown=k===UNKNOWN_LOC;
      const info=isUnknown?{label:'ไม่ระบุคลัง', short:'ไม่ระบุคลัง'}:flParseSpareLoc(k);
      const total=v.gbs.length+v.props.length;
      // For boat type, show name only ("Aluminous1") instead of "บนเรือ Aluminous1"
      const locName=type==='boat'?info.short:info.label;
      const locHd=`<tr><td colspan="3" style="padding:6px 0 2px 0"><div style="display:flex;align-items:center;gap:8px;font-size:11px;color:${meta.color};font-weight:500">${locName}${isUnknown?'<span style="font-size:9px;background:#FAEEDA;color:#854F0B;padding:1px 6px;border-radius:5px;font-weight:600">⚠ ตั้งค่าคลัง</span>':''}<span style="font-family:'DM Mono',monospace;color:var(--ink-soft);font-size:10px;font-weight:400">· ${total}</span></div></td></tr>`;
      const gbRows=v.gbs.map(g=>buildRow(g,'gearbox',meta.color)).join('');
      const prRows=v.props.map(p=>buildRow(p,'propeller',meta.color)).join('');
      return locHd+gbRows+prRows;
    }).join('');
    return`<div>${sectionHd}<table style="width:100%;border-collapse:collapse;font-size:11px">${locBlocks}</table></div>`;
  };

  // Combine shop entries into "อื่นๆ" column
  const otherEntries=[...shops, ...unknowns]; // shops + ไม่ระบุคลัง

  const colsHtml=`<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;align-items:start">
    <div style="padding-right:14px;border-right:1px solid var(--border)">${buildSection('pier',piers)}</div>
    <div style="padding:0 14px;border-right:1px solid var(--border)">${buildSection('boat',boats)}</div>
    <div style="padding-left:14px">${buildSection('shop',otherEntries,'อื่นๆ')}</div>
  </div>`;

  const spareHtml=`<div style="background:linear-gradient(to right, #FFF5EC 0%, #FBEAF0 40%, #FCE5EC 70%, #F5DDE6 100%);border:1px solid rgba(0,0,0,.04);border-radius:var(--r);padding:12px 14px;margin-bottom:14px">
    <div style="display:flex;align-items:center;gap:10px;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,.06);margin-bottom:10px">
      <div style="width:26px;height:26px;border-radius:6px;background:var(--ink);color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0">${SVG_BOX}</div>
      <div style="flex:1">
        <div style="font-size:12px;font-weight:600;color:var(--ink)">Spare Inventory</div>
        <div style="font-size:10px;color:var(--ink-soft);margin-top:1px">รวม <b style="color:var(--ink);font-family:'DM Mono',monospace">${totalSpareGb}</b> เกียร์ · <b style="color:var(--ink);font-family:'DM Mono',monospace">${totalSpareProp}</b> ใบจักร</div>
      </div>
      <div style="display:flex;gap:5px">
        <button style="font-size:10px;padding:5px 10px;background:rgba(0,0,0,.08);color:var(--ink);border:none;border-radius:14px;cursor:pointer;display:inline-flex;align-items:center;gap:3px;font-weight:600;font-family:'DM Sans',sans-serif" onclick="flOpenAddSpare('gearbox')">${SVG_PLUS}เกียร์</button>
        <button style="font-size:10px;padding:5px 10px;background:var(--ink);color:white;border:none;border-radius:14px;cursor:pointer;display:inline-flex;align-items:center;gap:3px;font-weight:600;font-family:'DM Sans',sans-serif" onclick="flOpenAddSpare('propeller')">${SVG_PLUS}ใบจักร</button>
      </div>
    </div>
    ${(piers.length+boats.length+shops.length+unknowns.length)===0
      ?`<div style="text-align:center;padding:40px 0;color:var(--ink-soft);font-size:12px">ยังไม่มีสแปร์ในระบบ — เริ่มต้นโดยกดปุ่ม "+ เกียร์" หรือ "+ ใบจักร"</div>`
      :colsHtml}
  </div>`;

  // ── List view: each boat row with engines/gearboxes/propellers stacked ──
  // Exclude charter boats — only company assets
  const listHtml=BOATS.filter(b=>b.ownership!=='charter'&&!b.retired).map(b=>{
    const engs=FL_ENGINES.filter(e=>e.boatId===b.id).sort((a,b)=>{
      const order={'Port':1,'C.Port':2,'Center':3,'C.Std':4,'Std':5};
      return (order[a.pos]||9)-(order[b.pos]||9);
    });
    const st=getCurStatus(b,TODAY_STR);
    const stColor=st.s==='available'?'var(--green)':st.s==='fixing'?'var(--amber)':'var(--red)';

    // Build 3 rows: engines, gearboxes, propellers — each cell aligned to engine pos
    const cellWidth='minmax(0,1fr)';
    const cols=engs.length||1;
    const gridStyle=`display:grid;grid-template-columns:80px repeat(${cols},${cellWidth});gap:4px;align-items:stretch`;

    // Engine row
    const engCells=engs.map(eng=>{
      const stPill=eng.status==='ready'?'':eng.status==='fixing'?'<span style="font-size:9px;padding:1px 4px;border-radius:3px;background:var(--amber-light,#fef3c7);color:var(--amber-dark,#92400e);margin-left:4px">fixing</span>':eng.status==='spare'?'<span style="font-size:9px;padding:1px 4px;border-radius:3px;background:var(--sand);color:var(--ink-soft);margin-left:4px">spare</span>':'';
      return`<div onclick="flGoToAsset('engines','${eng.id}')" onmouseover="this.style.borderColor='var(--ocean)';this.style.background='var(--ocean-50)'" onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--white)'" style="background:var(--white);border:1px solid var(--border);border-radius:6px;padding:6px 8px;display:flex;flex-direction:column;gap:2px;min-width:0;cursor:pointer;transition:all .12s">
        <div style="display:flex;align-items:center;gap:4px">
          <span style="font-size:9px;font-weight:700;padding:1px 6px;border-radius:3px;background:var(--ocean);color:white;font-family:'DM Mono',monospace;flex-shrink:0">${eng.pos}</span>
          <span style="font-size:10px;color:var(--ink-mid);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${eng.brand} ${eng.model}</span>
          ${stPill}
        </div>
        <div style="font-family:'DM Mono',monospace;font-size:11px;font-weight:700;color:var(--navy);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${eng.serial}">${eng.serial}</div>
        ${eng.note?`<div style="font-size:9px;color:var(--ink-soft);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${eng.note}">${eng.note}</div>`:''}
      </div>`;
    }).join('');

    // Gearbox row
    const gbCells=engs.map(eng=>{
      const gb=FL_GEARBOXES.find(g=>g.engineId===eng.id);
      if(!gb)return`<div style="background:var(--sand);border:1px dashed var(--border);border-radius:6px;padding:6px 8px;font-size:10px;color:var(--ink-soft);text-align:center">—</div>`;
      const sBg=gb.status==='ready'?'var(--white)':'var(--sand)';
      const sBd=gb.status==='ready'?'var(--border)':'var(--amber)';
      return`<div onclick="flGoToAsset('gearboxes','${gb.id}')" onmouseover="this.style.borderColor='#6c5ce7';this.style.background='#f5f3ff'" onmouseout="this.style.borderColor='${sBd}';this.style.background='${sBg}'" style="background:${sBg};border:1px solid ${sBd};border-radius:6px;padding:6px 8px;display:flex;flex-direction:column;gap:2px;min-width:0;cursor:pointer;transition:all .12s">
        <div style="font-size:9px;color:var(--ink-soft);font-weight:500">🔩 Gearbox</div>
        <div style="font-family:'DM Mono',monospace;font-size:10px;font-weight:600;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${gb.serial}">${gb.serial}</div>
      </div>`;
    }).join('');

    // Propeller row
    const propCells=engs.map(eng=>{
      const gb=FL_GEARBOXES.find(g=>g.engineId===eng.id);
      const props=gb?FL_PROPELLERS.filter(p=>p.gearboxId===gb.id):[];
      if(!props.length)return`<div style="background:var(--sand);border:1px dashed var(--border);border-radius:6px;padding:6px 8px;font-size:10px;color:var(--ink-soft);text-align:center">—</div>`;
      // Sort: Front first, then Rear (for dual-prop), single props default order
      const sorted=props.slice().sort((a,b)=>{
        const ord={'Front':1,'Rear':2};
        return (ord[a.propPos]||0)-(ord[b.propPos]||0);
      });
      // For single propeller, click whole cell. For multi (dual-prop), click each line
      const isSingle=sorted.length===1;
      const propLines=sorted.map(p=>{
        const rotMark=p.rotation==='Counter'?'↺':'↻';
        const posBadge=p.propPos?`<span style="font-size:8px;font-weight:700;padding:0 4px;border-radius:2px;background:${p.propPos==='Front'?'var(--ocean)':'var(--navy)'};color:white;font-family:'DM Mono',monospace;flex-shrink:0">${p.propPos==='Front'?'F':'R'}</span>`:'';
        const lineClick=isSingle?'':`onclick="event.stopPropagation();flGoToAsset('propellers','${p.id}')" style="cursor:pointer;border-radius:3px;padding:1px 2px" onmouseover="this.style.background='#fdf3e8'" onmouseout="this.style.background='transparent'"`;
        return`<div ${lineClick?lineClick:'style="display:flex;align-items:center;gap:4px;min-width:0"'} ${lineClick?'class="prop-line"':''}>
          <div style="display:flex;align-items:center;gap:4px;min-width:0">
            ${posBadge}
            <span style="font-size:9px;color:var(--ink-soft)">${rotMark}</span>
            <span style="font-family:'DM Mono',monospace;font-size:10px;font-weight:600;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${p.serial} · ${p.size} · ${p.material}">${p.size}</span>
          </div>
        </div>`;
      }).join('');
      const cellClick=isSingle?`onclick="flGoToAsset('propellers','${sorted[0].id}')"`:'';
      return`<div ${cellClick} onmouseover="this.style.borderColor='#d48a14';this.style.background='#fef9ed'" onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--white)'" style="background:var(--white);border:1px solid var(--border);border-radius:6px;padding:6px 8px;display:flex;flex-direction:column;gap:3px;min-width:0;${isSingle?'cursor:pointer;':''}transition:all .12s">
        <div style="font-size:9px;color:var(--ink-soft);font-weight:500">⚙️ Propeller${props.length>1?` (${props.length})`:''}</div>
        ${propLines}
      </div>`;
    }).join('');

    const labelCell=(text,bg)=>`<div style="display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:10px;color:var(--ink-soft);font-weight:500;text-transform:uppercase;letter-spacing:.05em">${text}</div>`;

    return`<div style="background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;box-shadow:var(--shadow);margin-bottom:8px">
      <!-- Boat header -->
      <div onclick="flGoToAsset('boats','${b.id}')" onmouseover="this.style.background='var(--sand)'" onmouseout="this.style.background='transparent'" style="display:flex;align-items:center;gap:10px;margin-bottom:10px;padding:6px 4px 8px;border-bottom:1px solid var(--border);cursor:pointer;border-radius:4px;transition:background .12s;margin-left:-4px;margin-right:-4px;margin-top:-4px">
        <div style="width:6px;height:24px;border-radius:3px;background:${stColor};flex-shrink:0"></div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span style="font-size:14px;font-weight:600;color:var(--ink)">${b.name}</span>
            ${flStatusPill(st.s)}
            ${(()=>{const sp=flGetBoatSpares(b.id);if(!sp.total)return'';return`<span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;background:rgba(28,78,126,.08);border:1px solid rgba(28,78,126,.2);font-size:10px;font-weight:500;color:#1c4e7e" title="${sp.gearboxes.map(g=>g.serial).concat(sp.propellers.map(p=>p.serial)).join(', ')}">📦 พกสแปร์: ${sp.gearboxes.length?`${sp.gearboxes.length}🔩`:''}${sp.propellers.length?` ${sp.propellers.length}⚙️`:''}</span>`;})()}
          </div>
          <div style="font-size:10px;color:var(--ink-soft);margin-top:2px">${b.type} · ${b.cap} PAX · ${b.pier==='tublamu'?'Tub Lamu':'Visit Panwa'} · ${engs.length} เครื่อง</div>
        </div>
        <span style="font-size:11px;color:var(--ink-soft);flex-shrink:0">→</span>
      </div>
      ${engs.length?`
        <!-- 3-row aligned grid -->
        <div style="${gridStyle};margin-bottom:4px">
          ${labelCell('Engine')}
          ${engCells}
        </div>
        <div style="${gridStyle};margin-bottom:4px">
          ${labelCell('Gearbox')}
          ${gbCells}
        </div>
        <div style="${gridStyle}">
          ${labelCell('Propeller')}
          ${propCells}
        </div>
        ${(()=>{
          const sp=flGetBoatSpares(b.id);
          if(!sp.total)return'';
          const items=[
            ...sp.gearboxes.map(g=>({kind:'gearbox',id:g.id,serial:g.serial,sub:g.brand+' '+(g.model||'').replace(' Gearbox',''),accent:'#6c5ce7',bg:'#ede9ff',icon:'🔩',tab:'gearboxes'})),
            ...sp.propellers.map(p=>({kind:'propeller',id:p.id,serial:p.serial,sub:`${p.size||'—'}${p.rotation?' · '+p.rotation:''}${p.propPos?' · '+p.propPos:''}`,accent:'#d48a14',bg:'#fef6df',icon:'⚙️',tab:'propellers'}))
          ];
          const itemsHtml=items.map(it=>`<div onclick="flGoToAsset('${it.tab}','${it.id}')" onmouseover="this.style.background='${it.bg}';this.style.borderColor='${it.accent}'" onmouseout="this.style.background='var(--white)';this.style.borderColor='var(--border)'" style="display:inline-flex;align-items:center;gap:6px;background:var(--white);border:1px solid var(--border);border-radius:5px;padding:4px 8px;cursor:pointer;transition:all .12s;min-width:0">
            <span style="display:inline-flex;width:16px;height:16px;border-radius:3px;background:${it.bg};color:${it.accent};align-items:center;justify-content:center;font-size:9px;flex-shrink:0">${it.icon}</span>
            <span style="font-family:'DM Mono',monospace;font-size:10px;font-weight:600;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${it.serial}">${it.serial}</span>
            <span style="font-size:9px;color:var(--ink-soft);flex-shrink:0">${it.sub}</span>
          </div>`).join('');
          return`<div style="display:flex;align-items:flex-start;gap:6px;margin-top:4px;padding-top:6px;border-top:1px dashed var(--border)">
            <div style="width:80px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:10px;color:#1c4e7e;font-weight:600;text-transform:uppercase;letter-spacing:.05em;flex-shrink:0">📦 Spare</div>
            <div style="flex:1;display:flex;flex-wrap:wrap;gap:4px">${itemsHtml}</div>
          </div>`;
        })()}
      `:`<div style="font-size:11px;color:var(--ink-soft);padding:6px 0">ยังไม่มีเครื่องยนต์</div>`}
    </div>`;
  }).join('');

  // ── Retired fleet section ──
  const retiredBoats=BOATS.filter(b=>b.retired);
  let retiredHtml='';
  if(retiredBoats.length){
    const retiredRows=retiredBoats.map(b=>{
      const engs=FL_ENGINES.filter(e=>e.boatId===b.id);
      const initials=(b.name||'?').slice(0,2).toUpperCase();
      return `<div onclick="flGoToAsset('boats','${b.id}')" style="background:white;border:1px solid rgba(0,0,0,.04);border-radius:10px;padding:12px 14px;cursor:pointer;display:flex;align-items:center;gap:10px;opacity:.85" onmouseover="this.style.opacity='1';this.style.borderColor='#1A1A1A'" onmouseout="this.style.opacity='.85';this.style.borderColor='rgba(0,0,0,.04)'">
        <div style="width:36px;height:36px;border-radius:50%;background:#888;color:white;font-size:11px;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0">${initials}</div>
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
