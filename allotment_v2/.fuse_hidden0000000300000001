function flCancelPropCascade(){
  // ผู้ใช้ปิดหรือกด "ข้าม" → ใบจักรยังผูกกับ gearbox เดิม (ไม่เปลี่ยนแปลง)
  const ctx=flPropCascadeCtx;
  closeModal('fl-modal-prop-cascade');
  flPropCascadeCtx={incId:null,damagedGbId:null,spareGbId:null,propIds:[],engHours:null};
  if(ctx.incId) flShowInc(ctx.incId);
}

function flConfirmPropCascade(){
  const ctx=flPropCascadeCtx;
  if(!ctx.incId){closeModal('fl-modal-prop-cascade');return;}
  const inc=FL_INCIDENTS.find(x=>x.id===ctx.incId);
  const damagedGb=FL_GEARBOXES.find(g=>g.id===ctx.damagedGbId);
  const spareGb=FL_GEARBOXES.find(g=>g.id===ctx.spareGbId);
  const repairShop=damagedGb?.spareLocation||'shop:honda-phuket';
  const boatName=damagedGb?(damagedGb._boatNameSnapshot||''):'';
  const summary={keep:0,stock:0,repair:0};
  ctx.propIds.forEach(pid=>{
    const p=FL_PROPELLERS.find(x=>x.id===pid);
    if(!p) return;
    const radio=document.querySelector(`input[name="cascade-${pid}"]:checked`);
    const choice=radio?.value||'keep';
    if(!Array.isArray(p.log)) p.log=[];
    if(choice==='keep'){
      // ย้ายไปติดกับ spare gearbox
      const prevGb=p.gearboxId;
      p.gearboxId=ctx.spareGbId;
      p.log.push({
        date:TODAY_STR, type:'transfer',
        desc:`ถอดจากเกียร์ ${damagedGb?.serial||prevGb} ใส่เข้าเกียร์ ${spareGb?.serial||ctx.spareGbId} (Quick Swap)`,
        engineHours:ctx.engHours, incidentId:ctx.incId
      });
      summary.keep++;
    } else if(choice==='stock'){
      // ถอดเก็บคลัง
      const pierSel=document.querySelector(`select[data-stock-pier="${pid}"]`);
      const targetPier=pierSel?.value||'pier:tublamu';
      const pierLabel={'pier:tublamu':'Tub Lamu','pier:panwa':'Visit Panwa','pier:ranong':'Ranong','pier:central':'คลังกลาง'}[targetPier]||targetPier;
      p.boatId=null;
      p.gearboxId=null;
      p.status='spare';
      p.spareLocation=targetPier;
      p.note=`ถอดจากเกียร์ ${damagedGb?.serial||''} เก็บที่ ${pierLabel}`;
      p.log.push({
        date:TODAY_STR, type:'remove',
        desc:`ถอดจากเกียร์ ${damagedGb?.serial||''} → เก็บคลัง ${pierLabel}`,
        engineHours:ctx.engHours, incidentId:ctx.incId
      });
      summary.stock++;
    } else { // repair
      // ส่งซ่อมตามไปกับ gearbox
      p.boatId=null;
      p.gearboxId=null;
      p.status='fixing';
      p.spareLocation=repairShop;
      p.note=`ส่งซ่อมพร้อมเกียร์ ${damagedGb?.serial||''}`;
      p.log.push({
        date:TODAY_STR, type:'transfer',
        desc:`ส่งซ่อม → ${repairShop.replace('shop:','').replace(/-/g,' ')} (ติดไปกับเกียร์ ${damagedGb?.serial||''})`,
        engineHours:ctx.engHours, incidentId:ctx.incId
      });
      summary.repair++;
    }
  });
  // เพิ่ม progress log ลง incident
  if(inc){
    if(!Array.isArray(inc.progressLog)) inc.progressLog=[];
    const parts=[];
    if(summary.keep) parts.push(`🔄 ย้ายใบจักร ${summary.keep} ใบไปติด ${spareGb?.serial||''}`);
    if(summary.stock) parts.push(`📦 ถอดเก็บคลัง ${summary.stock} ใบ`);
    if(summary.repair) parts.push(`🔧 ส่งซ่อมพร้อมเกียร์ ${summary.repair} ใบ`);
    if(parts.length){
      inc.progressLog.push({date:TODAY_STR, text:'⚙️ จัดการใบจักรหลัง swap: '+parts.join(' · '), by:'ระบบ Quick Swap'});
    }
  }
  flSave();
  closeModal('fl-modal-prop-cascade');
  const incId=ctx.incId;
  flPropCascadeCtx={incId:null,damagedGbId:null,spareGbId:null,propIds:[],engHours:null};
  flShowInc(incId);
}

