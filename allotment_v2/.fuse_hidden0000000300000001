function rtSaveDraft(){
  if(!_rtDraft) return;
  const d = _rtDraft;
  if(!d.code || !d.code.trim()){ alert('Please enter a Code'); return; }
  if(!d.name || !d.name.trim()){ alert('Please enter a Name'); return; }
  if(d.validFrom && d.validTo && d.validFrom > d.validTo){ alert('Valid from must be earlier than Valid to'); return; }
  // Cleanup: keep seatRates only for selected routes
  const routes = d.routes || [];
  Object.keys(d.seatRates||{}).forEach(rId => { if(!routes.includes(rId)) delete d.seatRates[rId]; });
  Object.keys(d.charterRates||{}).forEach(rId => { if(!routes.includes(rId)) delete d.charterRates[rId]; });
  // Apply
  if(_rtDraftIsNew){
    SB_RATE_TYPES.push(_rtCloneDeep(d));
  } else {
    const idx = SB_RATE_TYPES.findIndex(x => x.id === d.id);
    if(idx >= 0) SB_RATE_TYPES[idx] = _rtCloneDeep(d);
  }
  rtPersist();
  rtModalClose();
  _rtSelected = d.id;
  rtRenderCards();
  rtRenderDetail(d.id);
}

function rtDeleteRT(rtId){
  const using = (SB_AGENTS||[]).filter(a => a.rateTypeId === rtId);
  if(using.length > 0){
    if(!confirm('Rate Type นี้ใช้กับ '+using.length+' agent — ลบจะปลดออกจาก agents ด้วย ยืนยัน?')) return;
    using.forEach(a => { delete a.rateTypeId; });
  } else {
    if(!confirm('ลบ Rate Type นี้?')) return;
  }
  SB_RATE_TYPES = SB_RATE_TYPES.filter(x => x.id !== rtId);
  rtPersist();
  rtModalClose();
  _rtSelected = null;
  rtRenderCards();
  rtRenderDetail(null);
}

function rtPersist(){
  // Read-modify-write to loveandaman_v2 — NEVER clobber other keys (CLAUDE.md §6.2)
  try {
    const raw = localStorage.getItem('loveandaman_v2');
    const obj = raw ? JSON.parse(raw) : {};
    obj.sb_rate_types = SB_RATE_TYPES;
    // Persist agent.rateTypeId changes too (in case deletes detached agents)
    obj.sb_agents_rate_bindings = (SB_AGENTS||[]).map(a => ({id:a.id, rateTypeId:a.rateTypeId||null}));
    localStorage.setItem('loveandaman_v2', JSON.stringify(obj));
  } catch(e){ console.warn('[rtPersist] failed:', e); }
}

// Restore from localStorage on load
(function _rtRestore(){
  try {
    const raw = localStorage.getItem('loveandaman_v2');
    if(!raw) return;
    const obj = JSON.parse(raw);
    if(Array.isArray(obj.sb_rate_types) && obj.sb_rate_types.length){
      SB_RATE_TYPES = obj.sb_rate_types;
      // Migration: old charter shape {high,low} -> new {starterPrice,starterIncludes,extraPerPax}
      let migrated = 0;
      SB_RATE_TYPES.forEach(rt => {
        if(rt.active === undefined) rt.active = true;
        const cr = rt.charterRates || {};
        Object.keys(cr).forEach(rId => {
          const byBt = cr[rId];
          Object.keys(byBt).forEach(bt => {
            const ch = byBt[bt];
            if(ch && (ch.high !== undefined || ch.low !== undefined) && ch.starterPrice === undefined){
              // Convert: use low as starter, leave extras 0
              byBt[bt] = { starterPrice: ch.low || ch.high || 0, starterIncludes: 4, extraPerPax: 0 };
              migrated++;
            }
          });
        });
        // Migration: old privateTransfer shape {PK:{sedan,van}, KL:{...}} -> per-route+zone
        if(rt.addOns && rt.addOns.privateTransfer){
          const pt = rt.addOns.privateTransfer;
          // Detect old shape: top-level keys are zones (PK, KL) with sedan/van directly
          const topKeys = Object.keys(pt).filter(k => k !== 'unit');
          const looksLikeOldShape = topKeys.length > 0 && topKeys.every(k => /^(PK|KL)$/.test(k) && pt[k] && (pt[k].sedan !== undefined || pt[k].van !== undefined));
          if(looksLikeOldShape){
            const newPt = {unit: pt.unit || 'per trip'};
            // Apply old zone prices to all routes the RT covers
            (rt.routes||[]).forEach(rId => {
              newPt[rId] = {};
              topKeys.forEach(zone => {
                newPt[rId][zone] = { sedan: pt[zone].sedan||0, van: pt[zone].van||0 };
              });
            });
            rt.addOns.privateTransfer = newPt;
            migrated++;
          }
        }
      });
      if(migrated > 0) console.log('[rtRestore] Migrated', migrated, 'old charter/transfer entries to new shape');
    }
    if(Array.isArray(obj.sb_agents_rate_bindings)){
      const map = {};
      obj.sb_agents_rate_bindings.forEach(b => { map[b.id] = b.rateTypeId; });
      (SB_AGENTS||[]).forEach(a => { if(map.hasOwnProperty(a.id)) a.rateTypeId = map[a.id]; });
    }
  } catch(e){ console.warn('[rtRestore] failed:', e); }
})();

function agRenderFilters(){
  const inkColor = '#1a1a1a';

  // Build a single chip — returns HTML string
  // C1 structure: first <span> is the dot (becomes pill with count when .on)
  function buildChip(opts){
    const {isOn, color, label, count, onclick, dataAttr} = opts;
    if(isOn){
      // Active: dot grows into pill containing count, inline style for bg color
      return `<span class="fp on" ${dataAttr} onclick="${onclick}"><span style="background:${color};color:#fff;padding:2px 7px;border-radius:10px;font-size:9px;font-weight:700;font-variant-numeric:tabular-nums;line-height:1.3;display:inline-flex;align-items:center;justify-content:center;min-width:22px">${count}</span>${label}</span>`;
    } else {
      // Inactive: small dot 10px + label + count outside
      return `<span class="fp" ${dataAttr} onclick="${onclick}"><span style="background:${color};width:10px;height:10px;border-radius:50%;display:inline-block;flex-shrink:0"></span>${label} <span class="fp-cnt">${count}</span></span>`;
    }
  }

  // Market chips
  const mktHost = document.getElementById('ag-mkt-filter');
  if(mktHost){
    const counts = {};
    SB_AGENTS.forEach(a=>{ counts[a.market]=(counts[a.market]||0)+1; });
    let html = buildChip({
      isOn: _agMktFilter==='all', color: inkColor, label:'ทั้งหมด',
      count: SB_AGENTS.length, dataAttr:'data-mkt="all"',
      onclick:"agSetMktFilter('all')"
    });
    const shortMap = {
      'Online Travel Agent':'OTA',
      'Counter Tour Phuket':'Counter PK',
      'Counter Tour Khao Lak':'Counter KL',
      'Hotel Phuket':'Hotel PK',
      'Hotel Khao Lak':'Hotel KL',
      'Asia Pacific':'Asia-Pac',
      'Russian Market':'Russian',
      'World Wide':'WW',
    };
    SB_MARKETS.forEach(m=>{
      const c = counts[m.id]||0;
      if(c===0) return;
      const shortName = shortMap[m.name] || m.name;
      html += buildChip({
        isOn: _agMktFilter===m.id, color: m.color || '#7a8fa3',
        label: shortName, count: c,
        dataAttr: `data-mkt="${m.id}"`,
        onclick: `agSetMktFilter('${m.id}')`
      });
    });
    mktHost.innerHTML = html;
  }
  // Sales chips
  const salesHost = document.getElementById('ag-sales-filter');
  if(salesHost){
    const counts = {};
    SB_AGENTS.forEach(a=>{ counts[a.sales]=(counts[a.sales]||0)+1; });
    let html = buildChip({
      isOn: _agSalesFilter==='all', color: inkColor, label:'ทั้งหมด',
      count: SB_AGENTS.length, dataAttr:'data-sales="all"',
      onclick:"agSetSalesFilter('all')"
    });
    SB_SALES.forEach(s=>{
      const c = counts[s.id]||0;
      html += buildChip({
        isOn: _agSalesFilter===s.id, color: s.color,
        label: s.name, count: c,
        dataAttr: `data-sales="${s.id}"`,
        onclick: `agSetSalesFilter('${s.id}')`
      });
    });
    salesHost.innerHTML = html;
  }
}

