            ${stockBadge}
            ${locLbl?'<span>· '+locLbl+'</span>':''}
            ${inv.supplier?'<span>· '+inv.supplier+'</span>':''}
            ${inv.partNo?'<span style="font-family:monospace">· '+inv.partNo+'</span>':''}
          </div>
        </div>
        <div style="font-family:monospace;font-size:11px;font-weight:600;color:#9F1B4F;flex-shrink:0">฿${(inv.cost||0).toLocaleString()}</div>
      </div>`;
  }).join('');
  // Add "create new" option if query doesn't match exactly
  const exactMatch = matches.some(m => (m.inv.name||'').toLowerCase() === q);
  const createNewOpt = (q.length > 0 && !exactMatch) ? `
    <div style="padding:8px 12px;cursor:pointer;background:#FFF8E1;border-left:3px solid #BA7517"
      onmousedown="event.preventDefault();memoCreateNewFromQuery('${q.replace(/'/g,"\\'")}')">
      <div style="font-size:10px;font-weight:600;color:#854F0B">➕ เพิ่มใหม่: "${query}"</div>
      <div style="font-size:9px;color:#854F0B;margin-top:1px">${_memoType==='labor'?'ค่าแรง · ไม่ลงทะเบียนเข้า Inventory':'🆕 จะลงทะเบียนเข้า Inventory อัตโนมัติ'}</div>
    </div>` : '';
  dd.innerHTML = html + createNewOpt;
  dd.style.display = 'block';
}

function memoSelectInv(invId){
  const inv = (FL_INVENTORY||[]).find(x => x.id === invId);
  if(!inv) return;
  _memoSelectedInv = inv;
  document.getElementById('memo-new-name').value = inv.name;
  document.getElementById('memo-new-price').value = inv.cost || 0;
  memoUpdateInvPill();
  memoCloseDropdown();
  // ตั้ง supplier auto ถ้า memo ยังว่าง
  const supField = document.getElementById('memo-supplier');
