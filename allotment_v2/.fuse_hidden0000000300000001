function memoCalcTotal(){
  // Per-item discount: gross = qty*price, lineAfter = gross * (1 - itemDisc/100)
  let sub=0, lineDiscSum=0;
  _memoItems.forEach(it=>{
    const lineGross=(it.qty||1)*(it.price||0);
    const lineAfter=lineGross*(1-(it.discountPct||0)/100);
    sub+=lineGross;
    lineDiscSum+=(lineGross-lineAfter);
  });
  const memoDiscPct=parseFloat(document.getElementById('memo-discount-pct')?.value)||0;
  const memoDiscAmt=parseFloat(document.getElementById('memo-discount-amt')?.value)||0;
  // Apply memo-level discount on (sub - lineDiscSum) so it's a 2nd-level discount
  const subAfterLineDisc=sub-lineDiscSum;
  const memoDiscount=Math.round(subAfterLineDisc*memoDiscPct/100)+memoDiscAmt;
  const discTotal=lineDiscSum+memoDiscount;
  const afterDisc=Math.max(0,sub-discTotal);
  const vatEnabled=document.getElementById('memo-vat-enabled')?.checked!==false;
  const vatRate=vatEnabled?(parseFloat(document.getElementById('memo-vat-rate')?.value)||0):0;
  const vat=Math.round(afterDisc*vatRate/100*100)/100;
  const total=afterDisc+vat;
  const subEl=document.getElementById('memo-sub');
  const discEl=document.getElementById('memo-disc');
  const vatEl=document.getElementById('memo-vat');
  const totalEl=document.getElementById('memo-total');
  if(subEl) subEl.textContent='฿'+sub.toLocaleString();
  if(discEl){
    if(discTotal>0){
      const parts=[];
      if(lineDiscSum>0) parts.push('฿'+lineDiscSum.toLocaleString(undefined,{maximumFractionDigits:2})+' (ราย item)');
      if(memoDiscount>0) parts.push('฿'+memoDiscount.toLocaleString()+' (memo)');
      discEl.innerHTML='-฿'+discTotal.toLocaleString(undefined,{maximumFractionDigits:2})+(parts.length>1?`<div style="font-size:9px;color:var(--ink-soft);font-weight:400">${parts.join(' + ')}</div>`:'');
    } else {
      discEl.textContent='฿0';
    }
  }
  if(vatEl) vatEl.textContent=vatEnabled?'฿'+vat.toLocaleString(undefined,{maximumFractionDigits:2}):'ไม่คิด VAT';
  if(totalEl) totalEl.textContent='฿'+total.toLocaleString(undefined,{maximumFractionDigits:2});
  return{sub,discTotal,afterDisc,vat,vatRate,vatEnabled,total};
}
