function aosUsedBy(svcId){
  // Count agents that have this service in their addonServices (placeholder for Phase 2.2)
  return (SB_AGENTS||[]).filter(a=>(a.addonServices||[]).some(s=>s.svcId===svcId)).length;
}

function renderAddonSvc(){
  const host = document.getElementById('aos-list');
  if(SB_ADDON_SVCS.length===0){
    host.innerHTML = '<div class="aos-empty">ยังไม่มี Service — กดปุ่ม "เพิ่ม Service ใหม่" ด้านบนขวา</div>';
    return;
  }
  host.innerHTML = SB_ADDON_SVCS.map(svc=>{
    const usedCount = aosUsedBy(svc.id);
    return `
      <div class="aos-svc-card">
        <div class="aos-svc-hd">
          <div class="aos-svc-hd-l">
            <div class="aos-svc-icon ${svc.icon||'other'}">${AOS_ICONS[svc.icon||'other']}</div>
            <div class="aos-svc-info">
              <div class="aos-svc-ttl">${svc.name} <span class="aos-svc-cnt">· ${svc.variants.length} variant${svc.variants.length===1?'':'s'}</span></div>
