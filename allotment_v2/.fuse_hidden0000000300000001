  if(!item){alert('Item not found');return;}
  const fromLoc = document.getElementById('transfer-from').value;
  const toLoc = document.getElementById('transfer-to').value;
  if(!fromLoc){alert('กรุณาเลือกคลังต้นทาง');return;}
  if(!toLoc){alert('กรุณาเลือกคลังปลายทาง');return;}
  if(fromLoc === toLoc){alert('คลังต้นทางและปลายทางต้องต่างกัน');return;}
  const qty = parseFloat(document.getElementById('transfer-qty').value)||0;
  if(qty <= 0){alert('กรุณาระบุจำนวน > 0');return;}
  const available = invQtyAt(item, fromLoc);
  if(qty > available){alert(`คลัง ${fromLoc} มีเพียง ${available} ${item.unit||''}`);return;}
  const date = document.getElementById('transfer-date').value || TODAY_STR;
