// Populate Supplier autocomplete datalist (called when opening memo form)
function memoPopulateSupplierList(){
  const dl=document.getElementById('memo-supplier-suggestions');
  if(!dl) return;
  const suppliers=new Set();
  // From existing memos
  (FL_MEMOS||[]).forEach(m=>{ if(m.supplier&&m.supplier.trim()) suppliers.add(m.supplier.trim()); });
  // From inventory
  (FL_INVENTORY||[]).forEach(i=>{ if(i.supplier&&i.supplier.trim()) suppliers.add(i.supplier.trim()); });
  const sorted=[...suppliers].sort((a,b)=>a.localeCompare(b));
  dl.innerHTML=sorted.map(s=>`<option value="${s.replace(/"/g,'&quot;')}">`).join('');
}

