function flMaintAddLog(jobId){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m)return;
  const text=document.getElementById('maint-log-text-'+jobId)?.value.trim();
  if(!text)return;
  const by=document.getElementById('maint-log-by-'+jobId)?.value.trim()||'';
  // Read date from input (default to TODAY if empty)
  const dateInput=document.getElementById('maint-log-date-'+jobId);
  const date=(dateInput && dateInput.value) ? dateInput.value : TODAY_STR;
  if(!m.progressLog) m.progressLog=[];
  // Store createdAt (audit trail) — distinct from user-input date
  const entry={date, text, by};
  if(date !== TODAY_STR) entry.createdAt = TODAY_STR;  // backdated indicator
  m.progressLog.push(entry);
  // also push to linked incident
  flPushLog(jobId,text,by,date);
  flSave();flRenderMaintDetail(jobId);
}

// ── Auto-log helper: push log to linked Incident ──
function flPushLog(mjId, text, by, date){
  const mj=FL_MAINT.find(x=>x.id===mjId);if(!mj)return;
  // find linked incident
  const inc=FL_INCIDENTS.find(i=>i.maintId===mjId||i.id===mj.incidentId);
  if(!inc)return;
  if(!inc.progressLog) inc.progressLog=[];
  const logDate = date || TODAY_STR;
  const entry={date:logDate,text,by:by||'ระบบ'};
  if(logDate !== TODAY_STR) entry.createdAt = TODAY_STR;
  inc.progressLog.push(entry);
}

