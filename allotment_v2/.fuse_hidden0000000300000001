#view-booking .bkv2-mx th.dh.today{background:#EAF1FE;color:#2952C8;border-radius:3px;box-shadow:inset 0 -2px 0 #9DBFF6}
#view-booking .bkv2-mx th.dh.today .dnum{color:#2952C8}
