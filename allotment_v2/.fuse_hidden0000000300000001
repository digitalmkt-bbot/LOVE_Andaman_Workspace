#view-agents .agi-sig-card.pending .agi-sig-role{color:#854F0B}
#view-agents .agi-sig-name{font-size:14px;font-weight:700;margin-bottom:2px;letter-spacing:-0.005em}
#view-agents .agi-sig-card.signed .agi-sig-name{color:#0F6E56}
#view-agents .agi-sig-card.pending .agi-sig-name{color:#854F0B}
#view-agents .agi-sig-pos{font-size:11px;color:var(--fd-ink-mid);font-variant-numeric:tabular-nums;margin-bottom:8px}
#view-agents .agi-sig-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}

/* ══════════ AGENT EDIT MODAL ══════════ */
#view-agents .ag-edit-modal{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center}
