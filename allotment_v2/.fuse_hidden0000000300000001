  const matShort=(m)=>{
    if(!m)return'—';
    if(m.includes('อลูมิ')||m.toLowerCase().includes('alumin'))return'Aluminum';
    if(m.includes('ไฟเบอร์')||m.toLowerCase().includes('fiber')||m.toLowerCase().includes('frp')||m.toLowerCase().includes('grp'))return'Fiberglass';
