#view-agents .ct-arch-validity-val{font-size:15px;font-weight:700;color:var(--fd-ink);font-variant-numeric:tabular-nums;letter-spacing:-0.005em}
#view-agents .ct-arch-validity-sep{font-size:14px;color:#8a7548;font-weight:700}
#view-agents .ct-arch-validity-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em;margin-top:2px}

/* Programs list (compact for archived view) */
