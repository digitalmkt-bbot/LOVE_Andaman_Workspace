/* Step 2 — carry-over checklist */
#view-agents .ct-carry-list{display:flex;flex-direction:column;gap:6px}
#view-agents .ct-carry-row{display:flex;align-items:center;gap:10px;padding:11px 12px;background:#fff;border-radius:11px;border:1px solid var(--fd-line);font-size:12px;cursor:pointer;transition:all .12s}
