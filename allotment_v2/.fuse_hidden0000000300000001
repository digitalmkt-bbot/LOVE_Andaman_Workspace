function flSaveEditBoatStatus(){
  const jobId = _ebsJobId;
  if(!jobId){alert('No job');return;}
  const m = FL_MAINT.find(x=>x.id===jobId);
  if(!m){alert('Job not found');return;}
  const newSt = _ebsNewStatus;
  if(!newSt){alert('กรุณาเลือก status');return;}
  const oldSt = m.boatStatus || (m.setFixing===false ? 'available' : 'fixing');
  if(newSt === oldSt){alert('Status ใหม่เหมือนปัจจุบัน');return;}
  const effDate = document.getElementById('ebs-date').value;
  if(!effDate){alert('กรุณาระบุวันที่');return;}
  const reason = (newSt==='unavailable') ? document.getElementById('ebs-reason').value : '';
  if(newSt==='unavailable' && !reason){alert('กรุณาเลือกเหตุผล');return;}
  const note = document.getElementById('ebs-note').value.trim();
  
  // 1. Update MJ
  m.boatStatus = newSt;
  m.boatStatusReason = reason;
  m.setFixing = (newSt === 'fixing' || newSt === 'unavailable');
  
  // 2. Update boat log
  const b = getBoat(m.boatId);
  if(b){
    if(!b.log) b.log = [];
    // Close any open log entry from this MJ on effDate
    b.log.forEach(l=>{
      if(!l.to && l.note && l.note.includes(m.no)){
        l.to = effDate;
      }
    });
    // If newSt is not available, push new log entry
    if(newSt !== 'available'){
      b.log.push({
        id: 'sl' + Date.now(),
        s: newSt,
        from: effDate, to: null,
        loc: m.location || '',
        note: `Maintenance Job ${m.no} (status changed)`,
        reason: reason
      });
    } else {
      // newSt === 'available' → close any open fixing/unavailable logs
      // (already done above) · also push an explicit available entry for visibility
      b.log.push({
        id: 'sl' + Date.now(),
        s: 'available',
        from: effDate, to: null,
        loc: '',
        note: `${m.no} · เรือกลับมาใช้งานได้${note?' · '+note:''}`,
        reason: ''
      });
    }
  }
  
  // 3. Progress log
  if(!m.progressLog) m.progressLog = [];
  const lblMap = {available:'🟢 Available', fixing:'🟡 Fixing', unavailable:'🔴 Unavailable'};
  m.progressLog.push({
    date: effDate,
    text: `⚙️ เปลี่ยน Boat Status: ${lblMap[oldSt]||oldSt} → ${lblMap[newSt]||newSt}${reason?' · '+reason:''}${note?' · "'+note+'"':''}`,
    by: 'ผู้ใช้'
  });
  
  flSave();
  closeModal('fl-modal-edit-boat-status');
  if(typeof flRenderMaintDetail==='function') flRenderMaintDetail(jobId);
  if(typeof flRenderMaint==='function') flRenderMaint();
  if(typeof renderBoats==='function') renderBoats();
  flShowToast(`Boat status: ${lblMap[oldSt]||oldSt} → ${lblMap[newSt]||newSt}`);
  _ebsJobId = null;
  _ebsNewStatus = null;
}

function flShowItemHistory(id){
  const item=FL_INVENTORY.find(x=>x.id===id);if(!item)return;
  const MONTHS=['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  const fmtD=s=>{if(!s)return'—';const d=new Date(s);return`${d.getDate()} ${MONTHS[d.getMonth()]} ${d.getFullYear()+543}`;};
  const isLow=item.qty<(item.minQty||0);
