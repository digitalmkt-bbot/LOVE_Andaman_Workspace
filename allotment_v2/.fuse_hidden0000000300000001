function flMaintTogglePin(id, event){
  if(event) event.stopPropagation();
  const m = FL_MAINT.find(x=>x.id===id);
  if(!m) return;
  if(m.pinned){
    m.pinned = false;
    m.pinnedAt = null;
    flShowToast(`Unpinned: ${m.no}`);
  } else {
    m.pinned = true;
    m.pinnedAt = TODAY_STR;
    flShowToast(`📌 Pinned: ${m.no}`);
