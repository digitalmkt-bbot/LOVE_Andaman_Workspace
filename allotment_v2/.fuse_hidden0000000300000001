  padding:12px 22px;display:flex;align-items:center;justify-content:space-between;gap:14px;
}
#view-agents .ct-banner.warn{background:linear-gradient(90deg, #fbeaea 0%, transparent 50%);border-left-color:#A32D2D}
#view-agents .ct-banner-l{display:flex;align-items:center;gap:12px;min-width:0}
#view-agents .ct-banner-icon{
  width:34px;height:34px;border-radius:50%;background:rgba(133,79,11,.15);color:#854F0B;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
#view-agents .ct-banner.warn .ct-banner-icon{background:rgba(163,45,45,.15);color:#A32D2D}
