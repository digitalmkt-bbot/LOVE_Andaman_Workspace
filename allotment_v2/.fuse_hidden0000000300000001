/* Shared module palette */
:root{
  --sb-pink:#d44a7f;--sb-pink-light:#fde6ee;--sb-pink-dark:#8c2d52;
  --sb-bg:#faf7f4;
  /* Core Panel indigo palette — for Agent List redesign */
  --cp-accent:#5B6CFF;
  --cp-accent-soft:#eef0ff;
  --cp-accent-lavender:#e5e8ff;
  --cp-accent-deep:#4250e0;
  --cp-bg:#f7f7fb;
  --cp-card:#ffffff;
  --cp-border:#eceef2;
  --cp-border-soft:#f2f3f7;
  --cp-ink:#1a1d2e;
  --cp-ink-mid:#4a4f63;
  --cp-ink-soft:#9ea4b5;
  --cp-ink-faint:#c9cdd9;
  --cp-green:#22b07a;
  --cp-green-soft:#dff5e9;
  --cp-red:#e85959;
  --cp-red-soft:#fae0e0;
  --cp-amber:#e8a32c;
  --cp-amber-soft:#fcf2db;
  --cp-shadow:0 1px 3px rgba(28,30,40,.04), 0 1px 2px rgba(28,30,40,.03);
  --cp-shadow-md:0 4px 12px rgba(28,30,40,.06);
}

/* ══════════ AGENT LIST — Financial Dashboard (FinDash) Visual Language ══════════ */
/* Bento style, coral accent, big numbers, dot+name minimal filters, white chips on near-white bg */

:root{
  --fd-bg:#fafaf8;
  --fd-card:#ffffff;
  --fd-line:rgba(0,0,0,.05);
  --fd-line-soft:rgba(0,0,0,.04);
  --fd-ink:#1a1a1a;
  --fd-ink-mid:#5a5a5a;
  --fd-ink-soft:#999;
  --fd-ink-faint:#cccccc;
  --fd-coral:#ff6b47;
  --fd-coral-soft:#fde4dc;
  --fd-coral-veryfaint:#fef5f0;
  --fd-coral-deep:#d44521;
  --fd-r:22px;
  --fd-r-md:18px;
}

/* Page surface — near-white bleed */
#view-agents{background:var(--fd-bg);margin:-22px;padding:24px 26px 32px;min-height:calc(100vh - 44px);color:var(--fd-ink);font-family:Manrope,-apple-system,system-ui,sans-serif}
/* Force Manrope on all descendants — overrides any inherited 'DM Sans' / 'DM Mono' from global rules */
#view-agents,
#view-agents *,
#view-agents input,
#view-agents button,
#view-agents select,
#view-agents textarea,
#view-agents table,
#view-agents th,
#view-agents td{font-family:Manrope,-apple-system,system-ui,sans-serif}

/* Page header */
#view-agents .page-hd{margin-bottom:18px;padding:6px 4px 14px;border-bottom:none;display:flex;align-items:center;justify-content:space-between;gap:14px}
#view-agents .page-hd > div:first-child{display:flex;align-items:center;gap:14px}
#view-agents .page-hd h1{font-size:24px;font-weight:700;letter-spacing:-0.02em;line-height:1.1;color:var(--fd-ink)}
#view-agents .page-hd h1 span{font-size:11px!important;font-weight:500;color:var(--fd-ink-soft)!important;background:#fff;padding:3px 10px;border-radius:14px;border:1px solid var(--fd-line);margin-left:8px!important;text-transform:uppercase;letter-spacing:.06em;vertical-align:middle}
#view-agents .page-hd p{font-size:13px;color:var(--fd-ink-soft);margin-top:3px;font-weight:400}

/* Buttons */
#view-agents .page-actions{display:flex;gap:8px}
#view-agents .page-actions .btn{font-family:inherit;border-radius:24px;font-size:12px;font-weight:600;padding:9px 18px;letter-spacing:0;transition:all .12s;border:none}
#view-agents .page-actions .btn-ghost{background:#fff;color:var(--fd-ink);border:1px solid var(--fd-line);box-shadow:none}
#view-agents .page-actions .btn-ghost:hover{background:#fafaf8}
#view-agents .page-actions .btn-pink{background:var(--fd-coral);color:#fff;padding:9px 20px;box-shadow:none}
#view-agents .page-actions .btn-pink:hover{background:var(--fd-coral-deep)}

/* ═══ KPI ROW — first card = Daily Report style ═══ */
#view-agents .sb-kpi-row{display:grid;grid-template-columns:1.7fr 1fr 1fr 1fr;gap:12px;margin-bottom:14px;align-items:stretch}

/* First KPI — daily-report (hero) style */
#view-agents .sb-kpi:nth-child(1){
  background:transparent;border:none;padding:14px 22px 14px 6px;box-shadow:none;
  display:flex;flex-direction:column;justify-content:space-between;gap:4px;
  border-right:1px solid var(--fd-line);overflow:visible;
}
#view-agents .sb-kpi:nth-child(1)::after{display:none}
#view-agents .sb-kpi:nth-child(1) .sb-kpi-lbl{font-size:14px;font-weight:500;color:var(--fd-ink-faint);letter-spacing:-0.01em;line-height:1.1;text-transform:none;margin-bottom:0}
#view-agents .sb-kpi:nth-child(1) .sb-kpi-val{font-size:54px;font-weight:700;letter-spacing:-0.04em;color:var(--fd-ink);line-height:.95;font-variant-numeric:tabular-nums;display:inline-block;margin:4px 0 0}
#view-agents .sb-kpi:nth-child(1) .sb-kpi-val::after{content:'AGENTS';font-size:24px;font-weight:600;color:var(--fd-ink-faint);letter-spacing:-0.015em;margin-left:10px;display:inline-block}
#view-agents .sb-kpi:nth-child(1) .sb-kpi-sub{font-size:13px;color:var(--fd-ink-soft);font-weight:500;letter-spacing:-0.005em;line-height:1.3;font-family:Manrope,-apple-system,system-ui,sans-serif;margin-top:8px}

/* Other KPI cards — solid white with coral icon */
#view-agents .sb-kpi:nth-child(n+2){background:var(--fd-card);border:1px solid var(--fd-line);border-radius:var(--fd-r);padding:18px 20px;box-shadow:none;position:relative;display:flex;flex-direction:column}
#view-agents .sb-kpi:nth-child(n+2)::after{display:none}
#view-agents .sb-kpi.k-blue{background:linear-gradient(135deg, var(--fd-coral-soft) 0%, #fff 100%);border-color:var(--fd-coral-soft)}
#view-agents .sb-kpi.k-blue .sb-kpi-val{color:var(--fd-coral-deep)}
#view-agents .sb-kpi:nth-child(n+2) .sb-kpi-lbl{font-size:11px;color:var(--fd-ink-soft);font-weight:500;letter-spacing:0;text-transform:none;margin-bottom:0}
#view-agents .sb-kpi:nth-child(n+2) .sb-kpi-val{font-size:28px;font-weight:700;letter-spacing:-0.02em;color:var(--fd-ink);line-height:1.05;margin-top:3px;font-variant-numeric:tabular-nums;font-family:Manrope,-apple-system,system-ui,sans-serif}
#view-agents .sb-kpi:nth-child(n+2) .sb-kpi-sub{font-size:11px;color:var(--fd-ink-soft);margin-top:10px;font-family:Manrope,-apple-system,system-ui,sans-serif;letter-spacing:0;font-weight:400}

/* ═══ FILTER BAR ═══ — C1 minimal dot style, white pills on near-white bg */
#view-agents .ag-filter-bar{background:transparent;border:none;border-radius:0;padding:0;box-shadow:none;margin-bottom:14px;display:flex;flex-direction:column;gap:8px}
#view-agents .ag-filter-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;background:#fff;border:1px solid var(--fd-line);border-radius:18px;padding:10px 14px}
#view-agents .ag-filter-lbl{font-size:11px;color:var(--fd-ink-soft);font-weight:600;min-width:50px;text-transform:lowercase;letter-spacing:0;padding-right:6px;border-right:1px solid var(--fd-line-soft);margin-right:2px}
#view-agents .ag-filter-bar .filter-pills{background:transparent;border:none;border-radius:0;padding:0;display:flex;gap:5px;flex-wrap:wrap;flex:1}

/* Inactive chip — transparent on white card, hover = subtle */
#view-agents .ag-filter-bar .fp{padding:5px 12px 5px 8px;border-radius:18px;font-size:11px;color:var(--fd-ink-mid);background:transparent;border:none;font-weight:500;display:inline-flex;align-items:center;gap:8px;cursor:pointer;transition:all .12s}
#view-agents .ag-filter-bar .fp:hover{background:var(--fd-bg)}
#view-agents .ag-filter-bar .fp.on{font-weight:700;color:var(--fd-ink);background:#eeece6}
#view-agents .ag-filter-bar .fp.on::after{content:''}

/* Count chip (small) — shown only when inactive */
#view-agents .ag-filter-bar .fp-cnt{font-size:9px;font-variant-numeric:tabular-nums;color:var(--fd-ink-soft);font-weight:600;background:transparent;padding:0;margin:0}
#view-agents .ag-filter-bar .fp.on .fp-cnt{display:none}

/* The dot in front — inactive = small circle, active = pill with count */
#view-agents .ag-filter-bar .fp > span:first-child{display:inline-flex;align-items:center;justify-content:center;width:10px;height:10px;border-radius:50%;flex-shrink:0;color:transparent;font-size:0;transition:all .15s;margin-right:0}

/* ═══ LAYOUT ═══ — 320px sidebar + detail */
#view-agents .sb-wrap{display:grid;grid-template-columns:340px 1fr;gap:14px;align-items:flex-start}

/* ═══ SIDEBAR ═══ */
#view-agents .sb-side{background:var(--fd-card);border:1px solid var(--fd-line);border-radius:var(--fd-r);box-shadow:none;overflow:hidden;position:sticky;top:14px;max-height:calc(100vh - 60px);display:flex;flex-direction:column;padding:0}
#view-agents .sb-side-hd{padding:16px 18px 12px;border-bottom:1px solid var(--fd-line-soft);background:transparent;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
#view-agents .sb-side-hd-ttl{font-size:14px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.01em;text-transform:none}
#view-agents #ag-list-count{font-variant-numeric:tabular-nums!important;font-size:10px!important;color:var(--fd-coral-deep)!important;font-weight:600!important;background:var(--fd-coral-soft)!important;padding:2px 9px!important;border-radius:10px!important;border:none!important;margin:0!important}
#view-agents #ag-search{background:var(--fd-bg);border:none!important;padding:6px 12px!important;width:130px!important;font-size:11px!important;color:var(--fd-ink);border-radius:20px!important;font-family:Manrope,-apple-system,system-ui,sans-serif;outline:none!important}
#view-agents #ag-search:focus{background:#fff;box-shadow:0 0 0 1px var(--fd-line)!important}

#view-agents .sb-side-body{padding:8px 10px;flex:1;overflow-y:auto}

/* A-Z headers */
#view-agents .sb-az-hd{padding:14px 8px 6px;font-size:11px;font-weight:700;color:var(--fd-ink-faint);background:transparent;letter-spacing:.04em;font-variant-numeric:tabular-nums;border-bottom:1px solid var(--fd-line-soft);position:static;display:flex;align-items:center;gap:6px;margin-bottom:4px}
#view-agents .sb-az-hd::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--fd-ink-faint);display:inline-block}

/* Agent row */
#view-agents .sb-ag-row{padding:9px 10px;font-size:13px;color:var(--fd-ink);display:flex;align-items:center;gap:11px;border:1px solid transparent;border-radius:14px;margin-top:3px;cursor:pointer;transition:background .12s;background:transparent}
#view-agents .sb-ag-row:hover{background:var(--fd-bg)}
#view-agents .sb-ag-row.sel{background:var(--fd-coral-soft);border-color:rgba(255,107,71,.25)}
#view-agents .sb-ag-row.sel::before{display:none}

/* Avatar — circular 34px FinDash style */
#view-agents .sb-ag-dot{width:34px!important;height:34px!important;border-radius:50%!important;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;font-family:Manrope,-apple-system,system-ui,sans-serif;letter-spacing:-0.01em;flex-shrink:0;box-shadow:none}

#view-agents .sb-ag-row .sb-ag-row-name-wrap{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
#view-agents .sb-ag-row .sb-ag-row-name-wrap > div:first-child{display:flex;align-items:center;gap:6px}
#view-agents .sb-ag-row .sb-ag-row-name-wrap > div:first-child > span{font-size:13px;font-weight:600;color:var(--fd-ink);letter-spacing:-0.005em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#view-agents .sb-ag-row .sb-ag-row-name-wrap > div:last-child{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em;text-transform:none;font-weight:400}
#view-agents .sb-ag-row.sel .sb-ag-row-name-wrap > div:last-child{color:var(--fd-coral-deep)}

/* Sales badge */
#view-agents .sb-sales-badge{flex-shrink:0;font-size:9px!important;font-weight:700!important;letter-spacing:.04em!important;padding:3px 8px!important;border-radius:10px!important;font-variant-numeric:tabular-nums!important;text-transform:uppercase}

/* Chevron */
#view-agents .sb-ag-row::after{content:'›';color:var(--fd-ink-faint);font-size:16px;flex-shrink:0;margin-left:2px;padding-left:2px}
#view-agents .sb-ag-row.sel::after{color:var(--fd-coral-deep)}
/* ── List row · sharper details (market color · payment · programs · contract status) ── */
#view-agents .sb-ag-row{padding:8px 10px}
#view-agents .sb-ag-row .sb-ag-row-name-wrap > div:first-child > span{font-size:13.5px;font-weight:600;letter-spacing:-.01em}
#view-agents .ag-row-meta{display:flex;align-items:center;gap:6px;flex-wrap:nowrap;overflow:hidden}
#view-agents .ag-row-mkt{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap}
#view-agents .ag-row-sub{font-size:9px;color:var(--fd-ink-faint);text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
#view-agents .ag-pay-chip{font-size:8px;font-weight:700;letter-spacing:.03em;padding:1px 5px;border-radius:4px;font-family:'DM Mono',monospace;white-space:nowrap;flex-shrink:0}
#view-agents .ag-prog-chip{font-size:8px;font-weight:700;color:var(--fd-ink-soft);background:#EEF0F3;border-radius:4px;padding:1px 5px;font-family:'DM Mono',monospace;white-space:nowrap;flex-shrink:0}
#view-agents .ag-ct-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;display:inline-block;box-shadow:0 0 0 2px rgba(255,255,255,.7)}

/* ═══ DETAIL PANEL ═══ */
#view-agents .sb-main{background:var(--fd-card);border:1px solid var(--fd-line);border-radius:var(--fd-r);box-shadow:none;overflow:hidden;min-height:500px;padding:0}
#view-agents .sb-main-hd{padding:18px 22px 18px 26px;border-bottom:1px solid var(--fd-line-soft);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;background:#fff}
#view-agents .sb-main-ttl{font-size:18px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.01em;display:flex;align-items:center;gap:10px}
#view-agents .sb-main-ttl .sb-chip{font-size:10px!important;font-weight:600!important;color:var(--fd-coral-deep)!important;background:var(--fd-coral-soft)!important;padding:3px 9px!important;border-radius:10px!important;font-variant-numeric:tabular-nums!important;letter-spacing:.04em}
#view-agents .sb-main-sub{font-size:12px;color:var(--fd-ink-soft);margin-top:3px;font-family:Manrope,-apple-system,system-ui,sans-serif;letter-spacing:0;text-transform:none;font-weight:400}
#view-agents .sb-main-hd .btn{font-family:inherit;border-radius:50%;width:34px;height:34px;padding:0;font-size:0;border:1px solid var(--fd-line);background:#fff;color:var(--fd-ink-mid);display:inline-flex;align-items:center;justify-content:center}
#view-agents .sb-main-hd .btn:hover{background:var(--fd-bg)}
#view-agents .sb-main-hd .btn.btn-danger:hover{background:#FCEBEB;border-color:#A32D2D;color:#A32D2D}
#view-agents .sb-main-hd .btn svg{width:13px;height:13px}

/* Tabs */
#view-agents .sb-tabs{padding:0 22px;background:#fff;border-bottom:1px solid var(--fd-line-soft);gap:0}
#view-agents .sb-tab{padding:12px 16px;font-size:12px;font-weight:500;color:var(--fd-ink-soft);border-bottom:2px solid transparent;letter-spacing:0;text-transform:none;background:transparent}
#view-agents .sb-tab:hover{color:var(--fd-ink)}
#view-agents .sb-tab.on{color:var(--fd-ink);border-bottom-color:var(--fd-coral);font-weight:700}

#view-agents .sb-main-body{padding:18px 22px}
#view-agents .sb-main .sb-empty{padding:80px 22px;color:var(--fd-ink-soft);font-size:13px;text-align:center}

/* ═══ Contract Document Wizard (Phase 1: shell) ═══ */
.ct-doc-modal{position:fixed;inset:0;z-index:2100;display:flex;align-items:center;justify-content:center}
.ct-doc-backdrop{position:absolute;inset:0;background:rgba(15,20,25,.55)}
.ct-doc-card{position:relative;width:96%;max-width:1400px;height:92vh;background:#fff;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.3);font-family:Manrope,-apple-system,system-ui,sans-serif}
.ct-doc-hd{padding:14px 22px;background:#fff;border-bottom:1px solid #E0DED8;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-shrink:0}
.ct-doc-hd-l{display:flex;align-items:center;gap:14px;flex:1;min-width:0}
.ct-doc-hd-icon{width:34px;height:34px;border-radius:8px;background:#1A2B43;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ct-doc-hd-icon svg{width:16px;height:16px}
.ct-doc-hd-ttl{font-size:15px;font-weight:700;color:#0F1419;letter-spacing:-0.01em}
.ct-doc-hd-sub{font-size:11px;color:#7a7770;margin-top:2px;font-variant-numeric:tabular-nums}
.ct-doc-hd-actions{display:flex;align-items:center;gap:8px;flex-shrink:0}
.ct-doc-lang{display:inline-flex;background:#F5F4EE;border-radius:18px;padding:3px;gap:2px}
.ct-doc-lang-btn{background:transparent;border:none;border-radius:14px;padding:5px 14px;font-size:11px;font-weight:600;color:#5F5E5A;cursor:pointer;font-family:inherit}
.ct-doc-lang-btn.on{background:#fff;color:#0F1419;font-weight:700;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.ct-doc-act{background:#fff;border:1px solid #E0DED8;border-radius:18px;padding:6px 14px;font-size:11px;font-weight:600;color:#1a1a1a;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px}
.ct-doc-act:hover{background:#FAFAF6}
.ct-doc-act.primary{background:#1A2B43;color:#fff;border-color:#1A2B43}
.ct-doc-act.primary:hover{background:#0F1929}
.ct-doc-x{background:transparent;border:1px solid #E0DED8;border-radius:50%;width:32px;height:32px;cursor:pointer;color:#5F5E5A;display:inline-flex;align-items:center;justify-content:center;font-family:inherit;font-size:14px}
.ct-doc-x:hover{background:#FCEBEB;color:#A32D2D;border-color:#A32D2D}

.ct-doc-body{display:flex;flex:1;min-height:0;overflow:hidden}
.ct-doc-side{width:340px;background:#F5F4EE;border-right:1px solid #E0DED8;overflow-y:auto;padding:18px 14px;flex-shrink:0}
.ct-doc-side-hd{font-size:10px;font-weight:700;color:#5F5E5A;letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;padding:0 4px}
.ct-doc-sec{background:#fff;border:1px solid #E0DED8;border-radius:10px;padding:10px 12px;margin-bottom:6px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:border-color .12s,background .12s;font-family:inherit}
.ct-doc-sec:hover{border-color:#9b9590}
.ct-doc-sec.on{border-color:#0F6E56;background:#F4FBF7}
.ct-doc-sec.required{border-color:#185FA5;background:#F4F8FB;cursor:not-allowed}
.ct-doc-sec-cb{width:16px;height:16px;border-radius:3px;border:1.5px solid #9b9590;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:#fff}
.ct-doc-sec.on .ct-doc-sec-cb{background:#0F6E56;border-color:#0F6E56;color:#fff}
.ct-doc-sec.required .ct-doc-sec-cb{background:#185FA5;border-color:#185FA5;color:#fff}
.ct-doc-sec-cb::after{content:'';width:5px;height:9px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg);margin-bottom:2px;opacity:0}
.ct-doc-sec.on .ct-doc-sec-cb::after,
.ct-doc-sec.required .ct-doc-sec-cb::after{opacity:1}
.ct-doc-sec-name{flex:1;min-width:0;font-size:12px;font-weight:600;color:#0F1419;letter-spacing:-0.005em}
.ct-doc-sec-num{font-size:9px;font-weight:700;color:#9b9590;font-variant-numeric:tabular-nums;letter-spacing:.04em;text-transform:uppercase}
.ct-doc-sec-meta{font-size:9.5px;color:#7a7770;margin-top:1px}
.ct-doc-sec-tag{font-size:9px;font-weight:700;color:#185FA5;letter-spacing:.04em;text-transform:uppercase;flex-shrink:0;background:#E6F1FB;padding:2px 7px;border-radius:6px}
.ct-doc-sec.required .ct-doc-sec-tag{background:#185FA5;color:#fff}
.ct-doc-side-divider{height:1px;background:#E0DED8;margin:14px 4px}

.ct-doc-preview{flex:1;min-width:0;overflow-y:auto;background:#E5E2D9;padding:30px 40px;display:flex;flex-direction:column;align-items:center;gap:20px}
.ct-doc-page{width:100%;max-width:794px;background:#fff;box-shadow:0 4px 20px rgba(0,0,0,.12);padding:0;border-radius:2px;position:relative;min-height:1080px;display:flex;flex-direction:column;flex-shrink:0}
.ct-doc-page-num{position:absolute;bottom:14px;right:24px;font-size:9.5px;color:#9b9590;font-family:Manrope,monospace;font-variant-numeric:tabular-nums}
.ct-doc-page-foot{position:absolute;bottom:14px;left:24px;font-size:9.5px;color:#9b9590}

/* Editable text in Phase 3 · dashed outline + edit cursor when wizard is in Edit mode */
.ct-doc-edit{outline:1px dashed transparent;outline-offset:3px;border-radius:3px;padding:1px 4px;margin:0 -4px;transition:outline-color .12s,background .12s;cursor:text}
.ct-doc-edit:hover{outline-color:#A8773B;background:#FFF7E8}
.ct-doc-edit:focus{outline:1.5px solid #A8773B;background:#FFF7E8}
.ct-doc-clause-card{background:#FAFAF6;border:1px solid #E0DED8;border-radius:6px;padding:14px 18px;margin-bottom:10px;position:relative}
