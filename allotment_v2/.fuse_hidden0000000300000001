function flParseSpareLoc(loc){
  if(!loc) return {icon:'❓',label:'ไม่ระบุ',short:'ไม่ระบุ',type:'unknown',color:'#6b7280',key:''};
  // boat:bX
  if(typeof loc==='string'&&loc.startsWith('boat:')){
    const bid=loc.slice(5);
    const b=BOATS.find(x=>x.id===bid);
    return {icon:'🚢',label:`บนเรือ ${b?b.name:bid}`,short:b?b.name:bid,type:'boat',color:'#1c4e7e',key:loc,boatId:bid};
  }
  // known label
  if(SPARE_LOC_LABELS[loc]) return {...SPARE_LOC_LABELS[loc],key:loc};
  // Legacy string
  return {icon:'📦',label:loc,short:loc,type:'other',color:'#6b7280',key:loc};
}
function flGetBoatSpares(bid){
  const gbs=FL_GEARBOXES.filter(g=>g.spareLocation===`boat:${bid}`);
  const props=FL_PROPELLERS.filter(p=>p.spareLocation===`boat:${bid}`);
  return {gearboxes:gbs,propellers:props,total:gbs.length+props.length};
}

