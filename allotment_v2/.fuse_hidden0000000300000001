    const b = (typeof BOATS!=='undefined') ? BOATS.find(x=>x.id===bid) : null;
    return {id:bid, name:b?b.name:bid, count:boatJobCnt[bid], cost:boatJobCost[bid]||0};
  }).sort((a,b)=>b.count - a.count);
  const fmtK = (n) => {
    if(n >= 1000000) return (n/1000000).toFixed(1)+'M';
    if(n >= 1000) return Math.round(n/1000)+'K';
    return Math.round(n).toString();
  };
  const boatBtn = (val, label, count, cost) => {
    const isOn = _maintBoatFilter === val;
    if(val === 'all'){
      return `<button onclick="maintSetBoat('${val}')" style="background:${isOn?dim.ink:'transparent'};color:${isOn?'white':dim.ink2};border:${isOn?'none':'1px solid rgba(0,0,0,.08)'};border-radius:12px;padding:4px 9px;font-size:10px;font-weight:${isOn?600:500};cursor:pointer;display:inline-flex;align-items:center;gap:4px">${label}<span style="opacity:${isOn?'.85':'.6'};font-family:'DM Mono',monospace">${count}</span></button>`;
    }
    const c = (typeof getBoatColor==='function') ? getBoatColor(val) : {bg:'#F4F2EE',text:'#666'};
    const costPill = cost > 0 ? `<span style="opacity:${isOn?'.75':'.55'};font-family:'DM Mono',monospace;font-size:9px;font-weight:500;padding-left:5px;border-left:1px solid ${isOn?'rgba(255,255,255,.3)':'rgba(0,0,0,.1)'};margin-left:2px">฿${fmtK(cost)}</span>` : '';
    return `<button onclick="maintSetBoat('${val}')" style="background:${isOn?c.text:c.bg};color:${isOn?'white':c.text};border:${isOn?'none':'1px solid '+c.bg};border-radius:12px;padding:4px 9px;font-size:10px;font-weight:${isOn?600:500};cursor:pointer;display:inline-flex;align-items:center;gap:4px">${label}<span style="opacity:${isOn?'.85':'.65'};font-family:'DM Mono',monospace">${count}</span>${costPill}</button>`;
  };
  const boatFilter = `${boatBtn('all','All boats',baseJobs.length,null)}${boatsWithJobs.map(b=>boatBtn(b.id,b.name,b.count,b.cost)).join('')}`;

  // Active filter count (Type + Boat only — Status เห็นเสมอ ไม่นับ)
  const advFilterCnt = (_maintTypeFilter!=='all'?1:0) + (_maintBoatFilter!=='all'?1:0);
  const hasAnyFilter = _maintStFilter!=='all' || advFilterCnt > 0;

  const filterToggleBtn = `<button onclick="maintToggleFilterPanel()" style="background:${_maintFilterExpand||advFilterCnt?SVG_PINK.soft:'transparent'};color:${_maintFilterExpand||advFilterCnt?SVG_PINK.text:dim.ink3};border:1px solid ${_maintFilterExpand||advFilterCnt?'rgba(255,107,71,.3)':'rgba(0,0,0,.08)'};border-radius:12px;padding:4px 10px;font-size:10px;font-weight:${advFilterCnt?600:500};cursor:pointer;display:inline-flex;align-items:center;gap:5px;margin-left:auto">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    Filter${advFilterCnt?` <span style="background:${SVG_PINK.accent};color:white;border-radius:8px;padding:0 5px;font-size:9px;font-family:'DM Mono',monospace">${advFilterCnt}</span>`:''}
    <span style="display:inline-block;transition:transform .15s;transform:rotate(${_maintFilterExpand?'180':'0'}deg);font-size:8px">▼</span>
  </button>`;

  const resetBtn = hasAnyFilter ? `<button onclick="maintResetFilters()" style="background:transparent;border:none;color:${dim.ink3};padding:3px 6px;font-size:9px;cursor:pointer;text-decoration:underline">Clear all</button>` : '';

  // Collapsible panel: Type + Boat
  const advancedPanel = _maintFilterExpand ? `<div style="background:#FBFAF7;border-radius:10px;padding:10px 12px;margin-bottom:8px;border:1px solid rgba(0,0,0,.04)">
    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;align-items:center">
      <span style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600;width:36px">Type</span>
      ${typeFilter}
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:4px;align-items:center">
      <span style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600;width:36px">Boat</span>
      ${boatFilter}
    </div>
  </div>` : '';

  // Split jobs into pinned + regular (only in active tab)
  let listHtml = '';
  if(jobs.length === 0){
    listHtml = `<div style="font-size:12px;color:${dim.ink3};text-align:center;padding:20px">No jobs match filter</div>`;
  } else if(_maintArchiveTab === 'active'){
    const pinnedJobs = jobs.filter(j=>j.pinned).sort((a,b)=>(b.pinnedAt||'').localeCompare(a.pinnedAt||''));
    const regularJobs = jobs.filter(j=>!j.pinned);
    let html = '';
    if(pinnedJobs.length){
      html += `<div style="background:#FBEAF0;border-radius:8px;padding:8px;margin-bottom:8px;border-left:3px solid #D4537E">
        <div style="display:flex;align-items:center;gap:5px;margin-bottom:6px;padding:0 4px">
          <span style="font-size:13px;color:#993556">📌</span>
          <span style="font-size:10px;font-weight:600;color:#993556;letter-spacing:.05em;text-transform:uppercase">Pinned</span>
          <span style="font-size:10px;color:#993556;opacity:.6;font-family:'DM Mono',monospace">${pinnedJobs.length}</span>
        </div>
        ${pinnedJobs.map(buildJobRow).join('')}
      </div>`;
    }
    if(regularJobs.length){
      if(pinnedJobs.length){
        html += `<div style="font-size:10px;font-weight:600;color:${dim.ink3};letter-spacing:.05em;text-transform:uppercase;padding:6px 4px 4px">Active</div>`;
      }
      html += regularJobs.map(buildJobRow).join('');
    }
    listHtml = html;
  } else {
    listHtml = jobs.map(buildJobRow).join('');
  }
  const listPanel=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};max-height:calc(100vh - 360px);overflow-y:auto">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,.06)">
      <span style="font-size:12px;font-weight:600;flex:1">Jobs</span>
      ${resetBtn}
      <span style="font-size:10px;color:${dim.ink3}">${jobs.length}/${totalJobs}</span>
    </div>
    ${tabBar}
    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;align-items:center">
      ${subFilter}
      ${filterToggleBtn}
    </div>
    ${advancedPanel}
    ${listHtml}
  </div>`;

  const detailPanel=`<div id="fl-maint-detail-mount" style="background:white;border-radius:14px;border:1px solid ${dim.line};overflow:hidden;min-height:400px"></div>`;

  wrap.innerHTML=`${headerBar}${kpiStrip}<div style="display:grid;grid-template-columns:340px 1fr;gap:12px;align-items:start">${listPanel}${detailPanel}</div>`;

  flRenderMaintDetailPink();
}

function flSelMaint(id){_selMaintId=id;flRenderMaint();}
function maintFilterSt(v){_maintStFilter=v;flRenderMaint();}
function maintSetArchive(t){
  _maintArchiveTab=t;
  _maintStFilter='all'; // reset sub-filter on tab switch
  _maintTypeFilter='all';
  _maintBoatFilter='all';
  flRenderMaint();
}
function maintSetType(v){_maintTypeFilter=v;flRenderMaint();}
function maintSetBoat(v){_maintBoatFilter=v;flRenderMaint();}
function maintToggleFilterPanel(){_maintFilterExpand=!_maintFilterExpand;flRenderMaint();}
function maintResetFilters(){
  _maintStFilter='all'; _maintTypeFilter='all'; _maintBoatFilter='all';
  flRenderMaint();
}

// ── COST ANALYTICS PAGE ──
let _costTimeFilter='all'; // 'all' | 'ytd' | 'month' | 'last30'
function costSetFilter(v){_costTimeFilter=v;flRenderCostAnalytics();}

function flRenderCostAnalytics(){
  const wrap=document.getElementById('fl-cost-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};
  const calcCost=(m)=>typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0);
  const fmt=(n)=>'฿'+(Math.round(n||0)).toLocaleString();
  const fmtShort=(n)=>{if(!n)return'฿0';if(n>=1000000)return'฿'+(n/1000000).toFixed(1)+'M';if(n>=1000)return'฿'+Math.round(n/1000)+'k';return'฿'+n;};

  const todayD=new Date(TODAY_STR);
  const yr=todayD.getFullYear();
  const ytdStr=yr+'-01-01';
  const thisMonth=TODAY_STR.slice(0,7);
  const last30=new Date(todayD);last30.setDate(last30.getDate()-30);
  const last30Str=last30.toISOString().slice(0,10);

  const allDone=FL_MAINT.filter(m=>m.status==='done');
  let scoped=allDone;
  if(_costTimeFilter==='ytd')scoped=allDone.filter(m=>(m.endDate||m.startDate||'')>=ytdStr);
  else if(_costTimeFilter==='month')scoped=allDone.filter(m=>(m.endDate||m.startDate||'').startsWith(thisMonth));
  else if(_costTimeFilter==='last30')scoped=allDone.filter(m=>(m.endDate||m.startDate||'')>=last30Str);

  const totalAll=allDone.reduce((s,m)=>s+calcCost(m),0);
  const totalScoped=scoped.reduce((s,m)=>s+calcCost(m),0);
  const cntScoped=scoped.length;
  const avgScoped=cntScoped?totalScoped/cntScoped:0;
  const boatsScoped=new Set(scoped.map(m=>m.boatId).filter(Boolean)).size;

  // By boat
  const byBoat={};
  scoped.forEach(m=>{
    if(!m.boatId)return;
    if(!byBoat[m.boatId])byBoat[m.boatId]={count:0,cost:0};
    byBoat[m.boatId].count++;
    byBoat[m.boatId].cost+=calcCost(m);
  });
  const boatRanking=Object.entries(byBoat).map(([bid,v])=>{
    const b=getBoat(bid);
    return{id:bid,name:b?b.name:'?',count:v.count,cost:v.cost};
  }).sort((a,z)=>z.cost-a.cost);

  // By type
  const byType={corrective:0,preventive:0,scheduled:0};
  const byTypeCnt={corrective:0,preventive:0,scheduled:0};
  scoped.forEach(m=>{
    const t=m.type||'corrective';
    if(byType[t]!=null){byType[t]+=calcCost(m);byTypeCnt[t]++;}
  });

  // By month (last 12 months for full view)
  const monthsArr=[];
  for(let i=11;i>=0;i--){
    const d=new Date(TODAY_STR);d.setMonth(d.getMonth()-i);
    const k=d.toISOString().slice(0,7);
    monthsArr.push({key:k,label:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()],year:d.getFullYear(),cost:0,count:0});
  }
  allDone.forEach(m=>{
    const k=(m.endDate||m.startDate||'').slice(0,7);
    const ent=monthsArr.find(x=>x.key===k);
    if(ent){ent.cost+=calcCost(m);ent.count++;}
  });
  const maxMonth=Math.max(1,...monthsArr.map(m=>m.cost));

  // By outcome
  const byOutcome={success:0,limited:0,rework:0,decommission:0,cancelled:0};
  const byOutcomeCnt={success:0,limited:0,rework:0,decommission:0,cancelled:0};
  scoped.forEach(m=>{
    const o=m.outcome||'success';
    if(byOutcome[o]!=null){byOutcome[o]+=calcCost(m);byOutcomeCnt[o]++;}
  });
  const hasNonSuccess=Object.entries(byOutcome).filter(([k,v])=>k!=='success'&&v>0).length>0;

  // Top engines
  const engCost={};const engCnt={};
  scoped.forEach(m=>{
    (m.assets||[]).forEach(a=>{
      if(a.type==='engine'&&a.engId){
        const jc=calcCost(m);
        const ac=(m.assets||[]).length||1;
        engCost[a.engId]=(engCost[a.engId]||0)+jc/ac;
        engCnt[a.engId]=(engCnt[a.engId]||0)+1;
      }
    });
  });
  const topEngines=Object.entries(engCost).map(([eid,cost])=>{
    const e=(typeof FL_ENGINES!=='undefined'?FL_ENGINES:[]).find(x=>x.id===eid);
    const b=e?getBoat(e.boatId):null;
    return{id:eid,label:e?e.serial:'?',pos:e?e.pos:'',brand:e?e.brand:'',boat:b?b.name:'',cost,cnt:engCnt[eid]||0};
  }).sort((a,z)=>z.cost-a.cost).slice(0,10);

  // ─── HEADER + KPI ───
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>
      </div>
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex">
      ${[['all','All time'],['ytd','YTD '+yr],['last30','Last 30 days'],['month','This month']].map(([k,lbl])=>{
        const on=_costTimeFilter===k;
        return `<button onclick="costSetFilter('${k}')" style="background:${on?dim.ink:'transparent'};color:${on?'white':dim.ink2};border:none;border-radius:14px;padding:5px 14px;font-size:11px;font-weight:${on?600:500};cursor:pointer">${lbl}</button>`;
      }).join('')}
    </div>
  </div>`;

  // KPI strip
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 0.85fr 0.85fr 0.85fr 1fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Total Maintenance Spend</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${fmtShort(totalScoped)}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">spent</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.accent};color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${cntScoped} jobs</span>
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${boatsScoped} boats serviced · avg ${fmt(avgScoped)}/job · all-time ${fmt(totalAll)}</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Corrective</div>
      <div style="font-size:14px;font-weight:700;line-height:1.2;font-family:'DM Mono',monospace;color:#A32D2D;margin-top:3px">${fmtShort(byType.corrective)}</div>
      <div style="font-size:11px;color:${dim.ink3};margin-top:6px">${byTypeCnt.corrective} jobs</div>
    </div>

    <div style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Preventive</div>
      <div style="font-size:14px;font-weight:700;line-height:1.2;font-family:'DM Mono',monospace;color:#BA7517;margin-top:3px">${fmtShort(byType.preventive)}</div>
      <div style="font-size:11px;color:${dim.ink3};margin-top:6px">${byTypeCnt.preventive} jobs</div>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Scheduled</div>
      <div style="font-size:14px;font-weight:700;line-height:1.2;font-family:'DM Mono',monospace;color:#185FA5;margin-top:3px">${fmtShort(byType.scheduled)}</div>
      <div style="font-size:11px;color:${dim.ink3};margin-top:6px">${byTypeCnt.scheduled} jobs</div>
    </div>

    <div style="grid-column:5;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px">
      <div style="font-size:10px;color:#aaa">By outcome</div>
      <div style="display:flex;flex-direction:column;gap:2px;margin-top:4px">
        <div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Success</span><span style="font-size:11px;font-weight:600;color:white;font-family:'DM Mono',monospace">${fmtShort(byOutcome.success)}</span></div>
        ${byOutcome.limited?`<div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Limited</span><span style="font-size:11px;font-weight:600;color:#FFAA66;font-family:'DM Mono',monospace">${fmtShort(byOutcome.limited)}</span></div>`:''}
        ${byOutcome.rework?`<div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Rework</span><span style="font-size:11px;font-weight:600;color:#FF8FA8;font-family:'DM Mono',monospace">${fmtShort(byOutcome.rework)}</span></div>`:''}
        ${byOutcome.decommission?`<div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:10px;color:#aaa">Decom</span><span style="font-size:11px;font-weight:600;color:white;font-family:'DM Mono',monospace">${fmtShort(byOutcome.decommission)}</span></div>`:''}
      </div>
    </div>
  </div>`;

  // ─── Monthly chart (full width) ───
  const chartH=120;
  const monthBars=monthsArr.map(mo=>{
    const h=mo.cost>0?Math.max(4,(mo.cost/maxMonth)*chartH):2;
    const isCur=mo.key===thisMonth;
    return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;min-width:0">
      <div style="font-size:9px;font-family:'DM Mono',monospace;color:${dim.ink3};white-space:nowrap;min-height:12px">${mo.cost>0?fmtShort(mo.cost):''}</div>
      <div style="width:75%;height:${h}px;background:${isCur?SVG_PINK.accent:'#cdc8c1'};border-radius:4px 4px 0 0;transition:all .15s" title="${mo.cost?fmt(mo.cost)+' · '+mo.count+' jobs':'no jobs'}"></div>
      <div style="font-size:9px;color:${isCur?SVG_PINK.text:dim.ink3};font-weight:${isCur?600:400};font-family:'DM Mono',monospace;text-align:center">${mo.label}<br><span style="opacity:.7;font-size:8px">'${String(mo.year).slice(-2)}</span></div>
    </div>`;
  }).join('');
  const chartSection=`<div style="background:white;border-radius:14px;border:1px solid ${dim.line};padding:14px 16px;margin-bottom:12px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <span style="font-size:13px;font-weight:600">Monthly spend trend</span>
      <span style="font-size:10px;color:${dim.ink3}">Last 12 months · all jobs</span>
    </div>
    <div style="display:flex;align-items:flex-end;gap:6px;height:${chartH+40}px;padding:0 4px">${monthBars}</div>
  </div>`;

  // ─── By Boat ranking + By Type bars + By Engine top ───
  const boatRows=boatRanking.slice(0,10).map((b,i)=>{
    const pct=totalScoped?Math.round(b.cost/totalScoped*100):0;
    const barPct=totalScoped?(b.cost/totalScoped*100):0;
    return `<div onclick="if(typeof flGoToAsset==='function')flGoToAsset('boats','${b.id}')" style="cursor:pointer;padding:8px 0;${i<Math.min(boatRanking.length,10)-1?'border-bottom:0.5px solid rgba(0,0,0,.04)':''}" onmouseover="this.style.background='${SVG_PINK.soft}'" onmouseout="this.style.background='transparent'">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span style="font-size:11px;font-family:'DM Mono',monospace;color:${dim.ink3};width:20px;font-weight:600">#${i+1}</span>
        <span style="font-size:12px;font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${b.name}</span>
        <span style="font-size:10px;color:${dim.ink3};font-family:'DM Mono',monospace">${b.count} jobs</span>
        <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:${SVG_PINK.text};min-width:75px;text-align:right">${fmt(b.cost)}</span>
        <span style="font-size:10px;color:${dim.ink3};font-family:'DM Mono',monospace;width:30px;text-align:right">${pct}%</span>
      </div>
      <div style="background:rgba(0,0,0,.04);border-radius:3px;height:4px;overflow:hidden;margin-left:28px">
        <div style="background:${SVG_PINK.accent};height:100%;width:${barPct.toFixed(1)}%;border-radius:3px"></div>
      </div>
    </div>`;
  }).join('')||`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:30px">No maintenance data in this period</div>`;

  const boatPanel=`<div style="background:white;border-radius:14px;border:1px solid ${dim.line};padding:14px 16px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <span style="font-size:13px;font-weight:600">Top boats by spend</span>
      <span style="font-size:10px;color:${dim.ink3}">Click for detail</span>
    </div>
    <div>${boatRows}</div>
  </div>`;

  // Engine top
  const engRows=topEngines.map((e,i)=>{
    return `<div onclick="if(typeof flGoToAsset==='function')flGoToAsset('engines','${e.id}')" style="cursor:pointer;padding:8px 0;${i<topEngines.length-1?'border-bottom:0.5px solid rgba(0,0,0,.04)':''};display:flex;align-items:center;gap:8px" onmouseover="this.style.background='${SVG_PINK.soft}'" onmouseout="this.style.background='transparent'">
      <span style="font-size:11px;font-family:'DM Mono',monospace;color:${dim.ink3};width:20px;font-weight:600">#${i+1}</span>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px">
          <span style="font-size:11px;font-family:'DM Mono',monospace;font-weight:600">${e.label}</span>
          ${e.pos?`<span style="font-size:8px;background:#E6F1FB;color:#185FA5;padding:1px 5px;border-radius:4px;font-weight:600">${e.pos}</span>`:''}
        </div>
        <div style="font-size:9px;color:${dim.ink3}">${e.brand||''}${e.boat?' · '+e.boat:''}</div>
      </div>
      <span style="font-size:9px;color:${dim.ink3};font-family:'DM Mono',monospace">${e.cnt} job${e.cnt>1?'s':''}</span>
      <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:${SVG_PINK.text};min-width:75px;text-align:right">${fmt(Math.round(e.cost))}</span>
    </div>`;
  }).join('')||`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:30px">No engine data tracked yet</div>`;

  const enginePanel=`<div style="background:white;border-radius:14px;border:1px solid ${dim.line};padding:14px 16px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <span style="font-size:13px;font-weight:600">Top engines by repair cost</span>
      <span style="font-size:10px;color:${dim.ink3}">Click for detail</span>
    </div>
    <div>${engRows}</div>
  </div>`;

  // By outcome detailed (if hasNonSuccess) + Type bars
  const OUT_STYLE={success:{color:'#1D9E75',label:'Success'},limited:{color:'#BA7517',label:'Limited use'},rework:{color:'#E03B7E',label:'Rework needed'},decommission:{color:'#1A1A1A',label:'Decommissioned'},cancelled:{color:'#A32D2D',label:'Cancelled'}};
  const outDetailRows=['success','limited','rework','decommission','cancelled'].filter(o=>byOutcome[o]>0||byOutcomeCnt[o]>0).map(o=>{
    const os=OUT_STYLE[o];
    const cnt=byOutcomeCnt[o];
    const cost=byOutcome[o];
    const avg=cnt?cost/cnt:0;
    const pct=totalScoped?(cost/totalScoped*100):0;
    return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:0.5px solid rgba(0,0,0,.04)">
      <span style="width:10px;height:10px;border-radius:50%;background:${os.color};flex-shrink:0"></span>
      <div style="flex:1">
        <div style="font-size:11px;font-weight:600">${os.label}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px">avg ${fmt(avg)}/job · ${pct.toFixed(0)}% of total</div>
      </div>
      <span style="font-size:10px;color:${dim.ink3};font-family:'DM Mono',monospace">${cnt}</span>
      <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink};min-width:75px;text-align:right">${fmt(cost)}</span>
    </div>`;
  }).join('');
  const outcomePanel=hasNonSuccess||byOutcomeCnt.success?`<div style="background:white;border-radius:14px;border:1px solid ${dim.line};padding:14px 16px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <span style="font-size:13px;font-weight:600">By outcome</span>
      <span style="font-size:10px;color:${dim.ink3}">Quality breakdown</span>
    </div>
    <div>${outDetailRows}</div>
  </div>`:'';

  wrap.innerHTML=`${headerBar}${kpiStrip}${chartSection}<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">${boatPanel}${enginePanel}</div>${outcomePanel}`;
}

