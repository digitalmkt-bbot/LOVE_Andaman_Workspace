#view-agents .ct-banner-text{display:flex;flex-direction:column;gap:2px;min-width:0}
#view-agents .ct-banner-ttl{font-size:13px;font-weight:700;color:#854F0B;letter-spacing:-0.005em}
#view-agents .ct-banner.warn .ct-banner-ttl{color:#A32D2D}
