    <!-- KPI grid · 3 cols x 2 rows -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px">
      ${kpiTile('clipboard',  P.blueSoft, P.blue,    'Projects · total',  TY.count,      LY.count,      '',    delta(TY.count, LY.count, true))}
      ${kpiTile('checkCircle',P.mintSoft, P.mintInk, 'Completed',         TY.completed,  LY.completed,  '',    delta(TY.completed, LY.completed, true))}
      ${kpiTile('coin',       '#F3E8FF',  P.purple,  'YTD Spend',         '฿'+(TY.totalSpend>=1000?(TY.totalSpend/1000).toFixed(0)+'K':TY.totalSpend), '฿'+(LY.totalSpend>=1000?(LY.totalSpend/1000).toFixed(0)+'K':LY.totalSpend), '', delta(TY.totalSpend, LY.totalSpend, false))}
