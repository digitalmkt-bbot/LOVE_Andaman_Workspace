// ── Schedule profiles · seasonal validity wrapper around per-area pickup times ──
// SCHEMA (current): profile.times[routeId][areaId] = 'HH:MM-HH:MM'
// LEGACY: profile.times[routeId][timeGroup] = 'HH:MM-HH:MM' (auto-migrated below)
let SB_PICKUP_TIME_PROFILES = [];

// Expand a legacy timeGroup-keyed times object into areaId-keyed
// e.g. { r5: { 'pk-w2': '06:00-06:15' } } → { r5: { 'pk-patong':'06:00-06:15', 'pk-karon':'06:00-06:15', 'pk-kata':'06:00-06:15' } }
function _psuExpandTimesToAreas(times){
  const out = {};
  Object.keys(times||{}).forEach(rid => {
    out[rid] = {};
    Object.keys(times[rid]||{}).forEach(key => {
      const val = times[rid][key];
      // Check if key is an area id (matches an area directly) or a timeGroup (legacy)
      const directArea = (SB_PICKUP_AREAS||[]).find(a => a.id === key);
      if(directArea){
        // Already an areaId
        out[rid][key] = val;
      } else {
        // Treat as timeGroup · expand to all areas in this group
        const members = (SB_PICKUP_AREAS||[]).filter(a => a.timeGroup === key);
        members.forEach(a => { out[rid][a.id] = val; });
      }
    });
  });
  return out;
}

// Migrate on first load: wrap existing SB_PICKUP_TIMES into a default profile
(function _migratePickupTimesToProfile(){
  if(SB_PICKUP_TIME_PROFILES.length > 0) return;
  if(!SB_PICKUP_TIMES || Object.keys(SB_PICKUP_TIMES).length === 0) return;
  SB_PICKUP_TIME_PROFILES.push({
    id: 'prof-default-2026',
    name: 'Default 2026',
    from: '2026-01-01',
    to: '2026-12-31',
    notes: 'Initial profile · migrated from legacy schedule (expanded to per-area). Each route now maps each area independently.',
    clonedFrom: null,
    times: _psuExpandTimesToAreas(SB_PICKUP_TIMES),
    createdAt: new Date().toISOString()
  });
})();

// ── Helpers ──
function bkV2GetArea(areaId){
  return (SB_PICKUP_AREAS||[]).find(a => a.id === areaId);
}
// Resolve the profile that applies for a given date (YYYY-MM-DD)
// Tiebreaker: narrower range wins (more specific) · then newer createdAt
function psuResolveProfile(dateStr){
  if(!dateStr) dateStr = new Date().toISOString().slice(0,10);
  const matches = (SB_PICKUP_TIME_PROFILES||[]).filter(p => p.from && p.to && p.from <= dateStr && dateStr <= p.to);
  if(matches.length === 0) return null;
  matches.sort((a,b) => {
    const aSpan = new Date(a.to) - new Date(a.from);
    const bSpan = new Date(b.to) - new Date(b.from);
    if(aSpan !== bSpan) return aSpan - bSpan;  // narrower wins
    return String(b.createdAt||'').localeCompare(String(a.createdAt||''));  // then newer wins
  });
  return matches[0];
}
function bkV2GetPickupTime(routeId, areaId, dateStr){
  const area = bkV2GetArea(areaId);
  if(!area || !routeId) return null;
  // 1. Try profile · look up by areaId (preferred · new schema)
  const prof = psuResolveProfile(dateStr);
  if(prof?.times?.[routeId]){
    if(prof.times[routeId][areaId]) return prof.times[routeId][areaId];
    // Backward compat: legacy timeGroup fallback if area isn't keyed directly
    if(area.timeGroup && prof.times[routeId][area.timeGroup]) return prof.times[routeId][area.timeGroup];
  }
  // 2. Legacy flat SB_PICKUP_TIMES (timeGroup-keyed)
  if(area.timeGroup && SB_PICKUP_TIMES?.[routeId]?.[area.timeGroup]) return SB_PICKUP_TIMES[routeId][area.timeGroup];
  return null;
}

