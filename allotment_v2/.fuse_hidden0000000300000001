#view-agents .ct-wiz-ft-r{display:flex;gap:8px}
#view-agents .ct-wiz-btn-sec{background:#fff;border:1px solid var(--fd-line);border-radius:18px;padding:8px 16px;font-size:12px;font-weight:600;color:var(--fd-ink);cursor:pointer;font-family:inherit}
#view-agents .ct-wiz-btn-sec:hover{background:var(--fd-bg)}
#view-agents .ct-wiz-btn-pri{background:var(--fd-coral);border:none;border-radius:18px;padding:8px 18px;font-size:12px;font-weight:600;color:#fff;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:6px}
