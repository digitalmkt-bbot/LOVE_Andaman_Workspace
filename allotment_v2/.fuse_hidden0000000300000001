      } else {
        mainText=h.note||h.desc||'-';
        rightText=`<span style="font-size:11px;font-weight:500;color:${isIn?'var(--green)':'var(--red)'};font-family:'DM Mono',monospace">${isIn?'+':'-'}${h.qty||0} ${item.unit||''}</span>`;
      }
      return`<div style="display:flex;gap:8px;padding:7px 0;border-bottom:${isLast?'none':'0.5px solid var(--border)'}">
        <div style="position:relative;flex-shrink:0">
          <div style="width:8px;height:8px;border-radius:50%;background:${dotColor};margin-top:4px"></div>
          ${!isLast?`<div style="position:absolute;left:3.5px;top:12px;bottom:-7px;width:1px;background:var(--border)"></div>`:''}
        </div>
        <div style="font-size:10px;font-family:'DM Mono',monospace;color:var(--ink-soft);min-width:60px;flex-shrink:0">${fmtD(h.date)}</div>
        <div style="flex:1"><div style="font-size:11px;color:var(--ink)">${mainText}</div>
        ${h.by?`<div style="font-size:10px;color:var(--ink-soft)">${h.by}</div>`:''}</div>
        <div style="flex-shrink:0">${rightText}</div>
      </div>`;
    }).join('')
    :'<div style="font-size:11px;color:var(--ink-soft)">ยังไม่มีประวัติ</div>';
  const panel=document.getElementById('inv-hist-panel');
  const grid=document.getElementById('inv-grid-wrap');
  panel.style.display='block';
  grid.style.gridTemplateColumns='1fr 330px';
