function flPrevMeter(engId,dateStr){
  let max=null,maxDate='';
  Object.entries(FL_DAILY).forEach(([ds,dayBoats])=>{
    if(ds>=dateStr)return;
    Object.values(dayBoats).forEach(bd=>{
      Object.values(bd.trips||{}).forEach(trip=>{
        const v=trip.engines?.[engId];
        if(v!=null&&ds>maxDate){maxDate=ds;max=v;}
      });
    });
  });
  if(max!=null)return max;
  const e=flGetEng(engId);return e?e.baseHours:null;
}
function flSaveFuel(ds,bid,val){
  if(!FL_DAILY[ds])FL_DAILY[ds]={};
  if(!FL_DAILY[ds][bid])FL_DAILY[ds][bid]={trips:{}};
  FL_DAILY[ds][bid].fuel=parseFloat(val)||null;flSave();
}
function flSaveMeter(ds,bid,type,engId,val){
  if(!FL_DAILY[ds])FL_DAILY[ds]={};
  if(!FL_DAILY[ds][bid])FL_DAILY[ds][bid]={fuel:null,trips:{}};
  if(!FL_DAILY[ds][bid].trips[type])FL_DAILY[ds][bid].trips[type]={engines:{}};
  const v=parseFloat(val);FL_DAILY[ds][bid].trips[type].engines[engId]=isNaN(v)?null:v;flSave();
}

