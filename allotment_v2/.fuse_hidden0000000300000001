#view-booking .bkv2-locks .bkv2-nb-input:focus{border-color:#C0392B}

/* ===== Matrix · empty (open · available) cells -> soft green · clickable ===== */
#view-booking .bkv2-mx td.cell.empty{background:#E9F7EF;color:#3E9B6E;font-weight:500;cursor:pointer}
#view-booking .bkv2-mx td.cell.empty:hover{background:#D6F0E1;color:#2E8159}
#view-booking .bkv2-mx td.cell.empty.sel{outline:2px solid #3A6FF7;outline-offset:-1px}
/* day-of-month header · clickable to select that date */
#view-booking .bkv2-mx th.dh{cursor:pointer}
#view-booking .bkv2-mx th.dh:hover{background:#EEF3FF;border-radius:3px}
#view-booking .bkv2-mx th.dh:hover .dnum{color:#3A6FF7}

/* ===== Today vs Selected · make them clearly different =====
   Today  = soft tint + blue ring (a marker, not a pick)
   Select = solid filled blue (the active click)  */
