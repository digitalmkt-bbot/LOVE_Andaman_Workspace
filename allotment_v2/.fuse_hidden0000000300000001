#view-booking .bkv2-routes-sub{font-size:11px;color:var(--ink-soft);font-style:italic}
#view-booking .bkv2-mode{display:inline-flex;background:var(--sand-mid);border-radius:14px;padding:2px;margin-left:auto;gap:1px}
#view-booking .bkv2-mode-btn{padding:3px 10px;font-size:10px;font-weight:600;color:var(--ink-soft);background:transparent;border:none;border-radius:12px;cursor:pointer;font-family:inherit;letter-spacing:.02em}
#view-booking .bkv2-mode-btn.on{background:var(--bk-navy);color:var(--white)}
#view-booking .bkv2-routes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:8px}
#view-booking .bkv2-route-card{background:#FFFCF5;border:1px solid #F0E5C8;border-radius:var(--r-sm);padding:10px 12px;display:flex;flex-direction:column;border-left:3px solid var(--bk-navy)}
#view-booking .bkv2-route-card .rc-name{font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;color:var(--ink);line-height:1.2}
#view-booking .bkv2-route-card .rc-meta{font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-soft);margin-top:2px}
#view-booking .bkv2-route-card .rc-val{font-family:'DM Sans',sans-serif;font-size:22px;font-weight:700;color:var(--ink);text-align:right;margin-top:6px;letter-spacing:-.01em}
#view-booking .bkv2-route-card .rc-unit{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft);text-align:right;letter-spacing:.04em;font-weight:500}
#view-booking .bkv2-route-card .rc-row{display:flex;align-items:baseline;justify-content:space-between;margin-top:4px}

/* Split layout (Calendar left + Selected Day right) */
#view-booking .bkv2-split{display:grid;grid-template-columns:1fr 360px;gap:0;align-items:start}
#view-booking .bkv2-cal{padding:12px}
#view-booking .bkv2-selday{background:var(--white);border-left:1px solid var(--border);padding:14px 16px;min-height:520px;align-self:stretch}
#view-booking .bkv2-selday-lab{font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);font-weight:600;margin-bottom:3px}
#view-booking .bkv2-selday-ttl{font-family:'DM Sans',sans-serif;font-size:20px;font-weight:700;color:var(--ink);letter-spacing:-.015em;line-height:1.15;display:flex;align-items:center;gap:8px}
#view-booking .bkv2-selday-today{background:var(--bk-navy);color:var(--white);font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 9px;border-radius:11px;display:inline-block}
#view-booking .bkv2-week-summary{background:#FFFCF5;border:1px solid #F0E5C8;border-radius:var(--r-sm);padding:12px 14px;margin:12px 0 14px;display:flex;align-items:center;justify-content:space-between;gap:10px}
#view-booking .bkv2-week-summary .ws-lab{font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;color:var(--ink)}
#view-booking .bkv2-week-summary .ws-meta{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft);margin-top:2px}
#view-booking .bkv2-week-summary .ws-total{font-family:'DM Sans',sans-serif;font-size:24px;font-weight:700;color:var(--bk-navy);letter-spacing:-.015em;line-height:1}
#view-booking .bkv2-week-summary .ws-totlab{font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-soft);text-align:right;margin-top:2px;letter-spacing:.04em}
#view-booking .bkv2-selday-empty{font-size:12px;color:var(--ink-soft);font-style:italic;padding:32px 8px;text-align:center}
#view-booking .bkv2-rd-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:8px;border-left:3px solid var(--bk-navy)}
#view-booking .bkv2-rd-hd{display:flex;align-items:baseline;justify-content:space-between;gap:8px}
#view-booking .bkv2-rd-name{font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:var(--ink);line-height:1.2}
#view-booking .bkv2-rd-val{font-family:'DM Sans',sans-serif;font-size:18px;font-weight:700;color:var(--ink);letter-spacing:-.01em}
#view-booking .bkv2-rd-meta{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft);margin-top:3px;line-height:1.5}
#view-booking .bkv2-rd-meta .lab{color:var(--ink-soft);opacity:.7}
#view-booking .bkv2-rd-meta .val{color:var(--ink);font-weight:600}
#view-booking .bkv2-rd-meta .val.foc{color:#ba7517}
#view-booking .bkv2-rd-foc{display:inline-block;background:#faeeda;color:#633806;font-family:'DM Mono',monospace;font-size:9px;padding:1px 6px;border-radius:3px;margin-left:6px;font-weight:600}
#view-booking .bkv2-rd-card.foc{background:#FFFBF0}
#view-booking .bkv2-rd-card.muted{opacity:.45}
#view-booking .bkv2-rd-card.muted .bkv2-rd-name{font-style:italic;font-weight:500}
#view-booking .bkv2-rd-empty-msg{font-size:11px;color:var(--ink-soft);font-style:italic}
#view-booking .bkv2-rd-zone{margin-top:6px;display:flex;gap:10px;font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft)}
#view-booking .bkv2-rd-zone .z-val{color:var(--ink);font-weight:600}
#view-booking .bkv2-rd-actions{display:flex;gap:6px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}
#view-booking .bkv2-rd-actions button{flex:1;padding:7px 10px;font-family:inherit;font-size:11px;font-weight:600;border-radius:var(--r-sm);cursor:pointer;border:1px solid var(--border);background:var(--white);color:var(--ink)}
#view-booking .bkv2-rd-actions button.pri{background:var(--bk-navy);color:var(--white);border-color:var(--bk-navy)}
#view-booking .bkv2-rd-actions button.pri:hover{background:var(--bk-navy-deep)}
#view-booking .bkv2-cal-wdrow{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:6px;font-family:'DM Sans',sans-serif;background:var(--sand-mid);border-radius:var(--r-sm);padding:2px;gap:2px}
#view-booking .bkv2-cal-wd{text-align:center;font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);padding:6px 0;background:transparent}
#view-booking .bkv2-cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
/* Cells · crisper borders + better hierarchy */
#view-booking .bkv2-cal-cell{min-height:118px;border-radius:var(--r-sm);background:var(--white);border:1px solid var(--border);padding:6px 5px 5px;cursor:pointer;transition:all .15s;position:relative;display:flex;flex-direction:column}
#view-booking .bkv2-cal-cell:hover{border-color:var(--bk-navy-mid);box-shadow:0 2px 10px rgba(27,42,85,.15)}
#view-booking .bkv2-cal-cell.empty{background:transparent;border:1px dashed var(--border);opacity:.35;cursor:default}
#view-booking .bkv2-cal-cell.today{border:2px solid var(--bk-navy);background:var(--bk-navy-50);padding:5px 4px 4px}
#view-booking .bkv2-cal-cell.sel{border:2px solid var(--bk-navy);background:var(--bk-navy-light);box-shadow:0 3px 12px rgba(27,42,85,.22);padding:5px 4px 4px}
#view-booking .bkv2-cal-cell.weekend{background:#fbfaf6}
#view-booking .bkv2-cal-cell.weekend.today{background:var(--bk-navy-50)}
#view-booking .bkv2-cal-daynum{font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;color:var(--ink-soft);line-height:1;margin-bottom:5px;display:flex;align-items:center;padding:0 2px}
#view-booking .bkv2-cal-cell.today .bkv2-cal-daynum{color:var(--bk-navy);font-weight:700}
#view-booking .bkv2-cal-cell.sel .bkv2-cal-daynum{color:var(--bk-navy-deep);font-weight:700}
#view-booking .bkv2-cal-foc{margin-left:auto;width:6px;height:6px;background:#ba7517;border-radius:50%}
/* Chips · full route names · crisp text */
#view-booking .bkv2-cal-chip{display:flex;align-items:center;justify-content:space-between;border-radius:3px;padding:3px 6px 3px 7px;margin-bottom:2px;border-left:3px solid transparent;font-size:11px;background:#f5f3ef;gap:5px;min-height:19px}
#view-booking .bkv2-cal-chip-name{font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:'DM Sans',sans-serif;flex:1;min-width:0;letter-spacing:-0.005em;line-height:1.25}
#view-booking .bkv2-cal-chip-pax{font-family:'DM Mono',monospace;font-weight:700;font-size:12px;flex-shrink:0;letter-spacing:-.02em}
#view-booking .bkv2-cal-chip.foc{background:#fff6e5}
#view-booking .bkv2-cal-chip.empty{background:transparent;border-left-style:dashed;border-left-width:2px}
#view-booking .bkv2-cal-chip.empty .bkv2-cal-chip-name{font-weight:500;opacity:.7}
#view-booking .bkv2-cal-more{font-size:9px;color:var(--ink-soft);font-style:italic;margin-top:3px;letter-spacing:.02em;padding-left:5px}
/* Matrix view (Tab 1 Matrix) */
#view-booking .bkv2-mx{padding:12px 12px 4px;background:var(--white);overflow-x:auto}
#view-booking .bkv2-mx table{width:100%;border-collapse:separate;border-spacing:1px;font-family:'DM Mono',monospace;table-layout:fixed}
#view-booking .bkv2-mx col.label{width:230px}
#view-booking .bkv2-mx col.day{width:auto}
#view-booking .bkv2-mx th.rowh{font-family:'DM Sans',sans-serif;text-align:left;padding:5px 8px;color:var(--ink-soft);font-weight:500;font-size:9px;letter-spacing:.04em;width:230px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#view-booking .bkv2-mx td.rowh{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:230px}
#view-booking .bkv2-mx th.dh{padding:3px 0;font-size:8px;font-weight:500;color:var(--ink-soft);text-align:center}
#view-booking .bkv2-mx th.dh.weekend{color:#b4b2a9}
#view-booking .bkv2-mx th.dh.today{background:var(--bk-navy);color:var(--white);border-radius:3px}
#view-booking .bkv2-mx th.dh .dnum{display:block;font-size:11px;color:var(--ink);font-weight:500;margin-top:1px}
#view-booking .bkv2-mx th.dh.weekend .dnum{color:var(--ink-soft)}
#view-booking .bkv2-mx th.dh.today .dnum{color:var(--white)}
#view-booking .bkv2-mx td.cell{text-align:center;padding:4px 0;font-weight:500;font-size:10px;cursor:pointer;border-radius:3px}
#view-booking .bkv2-mx td.cell.empty{background:var(--sand-mid);color:#b4b2a9;cursor:default;font-weight:400}
#view-booking .bkv2-mx td.cell.closed{background:repeating-linear-gradient(45deg,#f0ebe0,#f0ebe0 3px,transparent 3px,transparent 6px);color:#b4b2a9;cursor:default;font-weight:400}
#view-booking .bkv2-mx td.cell.closed-with-data{background:repeating-linear-gradient(45deg,#fdecea,#fdecea 3px,transparent 3px,transparent 6px);color:#A32D2D;cursor:pointer;font-weight:500}
#view-booking .bkv2-mx td.cell.lo{background:var(--white);color:var(--ink);border:1px solid var(--border)}
#view-booking .bkv2-mx td.cell.mid{background:var(--bk-navy-50);color:var(--bk-navy-deep)}
#view-booking .bkv2-mx td.cell.hi{background:var(--bk-navy-light);color:var(--bk-navy-deep)}
#view-booking .bkv2-mx td.cell.peak{background:var(--bk-navy);color:var(--white)}
#view-booking .bkv2-mx td.cell.foc{background:#faeeda;color:#633806}
#view-booking .bkv2-mx td.cell.sel{outline:2px solid var(--bk-navy);outline-offset:-1px}
#view-booking .bkv2-mx td.cell.focdot{position:relative}
#view-booking .bkv2-mx td.cell.focdot::after{content:'';position:absolute;top:1px;right:2px;width:4px;height:4px;background:#ba7517;border-radius:50%}
#view-booking .bkv2-mx tr.tot td{background:var(--sand-mid);color:var(--ink-soft);font-weight:500;font-size:10px;text-align:center;padding:6px 0}
#view-booking .bkv2-mx tr.tot td.rowh{text-align:left;font-family:'DM Sans',sans-serif;font-size:9px;letter-spacing:.04em;text-transform:uppercase;padding:6px 8px}
#view-booking .bkv2-mx tr.tot td.today{background:var(--bk-navy);color:var(--white)}
/* Family parent rows + sub-rows for grouping */
#view-booking .bkv2-mx tr.fam td.rowh{cursor:pointer;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;color:var(--ink);padding:8px 6px 8px 8px;border-left:3px solid #c0392b;background:transparent;letter-spacing:-.005em;line-height:1.25;text-transform:none}
#view-booking .bkv2-mx tr.fam td.rowh .caret{display:inline-block;color:var(--ink-soft);margin-right:6px;font-size:10px;width:10px}
#view-booking .bkv2-mx tr.fam.expanded td.rowh{background:var(--bk-navy-50)}
#view-booking .bkv2-mx tr.fam.expanded td.rowh .caret{color:var(--bk-navy);font-weight:700}
#view-booking .bkv2-mx tr.fam .subc{font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-soft);font-weight:500;margin-left:6px;letter-spacing:.02em}
#view-booking .bkv2-mx tr.sub td.rowh{padding:4px 4px 4px 28px;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;color:var(--ink-soft);background:#FAFBFD;border-left:2px solid var(--border);text-transform:none;letter-spacing:0;line-height:1.2}
#view-booking .bkv2-mx tr.sub td.cell{font-size:10px;font-weight:600;color:var(--ink-soft)}
#view-booking .bkv2-mx tr.sub td.cell.lo,#view-booking .bkv2-mx tr.sub td.cell.mid,#view-booking .bkv2-mx tr.sub td.cell.hi,#view-booking .bkv2-mx tr.sub td.cell.peak{background:transparent;color:var(--ink)}
#view-booking .bkv2-mx-toolbar{display:flex;align-items:center;gap:8px;padding:0 4px 8px;font-size:10px;color:var(--ink-soft)}
#view-booking .bkv2-mx-toolbar button{font-family:inherit;background:transparent;border:1px solid var(--border);color:var(--ink-soft);padding:3px 9px;border-radius:var(--r-sm);font-size:10px;font-weight:500;cursor:pointer}
#view-booking .bkv2-mx-toolbar button:hover{border-color:var(--bk-navy-mid);color:var(--bk-navy)}
/* Detail panel (shared between Calendar + Matrix) */
#view-booking .bkv2-detail{margin:0 12px 12px;background:var(--white);border:2px solid var(--bk-navy);border-radius:var(--r-sm);padding:13px 16px}
#view-booking .bkv2-detail-hd{display:flex;align-items:center;gap:10px;margin-bottom:10px}
#view-booking .bkv2-detail-lab{font-family:'DM Sans',sans-serif;font-size:9px;color:var(--ink-soft);letter-spacing:.06em;text-transform:uppercase;font-weight:500}
#view-booking .bkv2-detail-ttl{font-size:14px;font-weight:500;color:var(--ink);margin-top:1px}
#view-booking .bkv2-detail-chip{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;background:#faeeda;color:#633806;border-radius:4px;font-size:11px;font-weight:500}
#view-booking .bkv2-detail-chip .dot{width:6px;height:6px;border-radius:50%;background:#ba7517}
#view-booking .bkv2-detail-open{padding:6px 12px;border:1px solid var(--bk-navy);background:var(--bk-navy);color:var(--white);font-size:11px;border-radius:var(--r-sm);font-weight:500;cursor:pointer;font-family:inherit}
#view-booking .bkv2-detail-open:hover{background:var(--bk-navy-deep)}
#view-booking .bkv2-detail-row{display:grid;grid-template-columns:96px 1fr;gap:12px 16px;padding:6px 0;border-top:1px solid var(--border);font-size:11px;align-items:center}
#view-booking .bkv2-detail-row.first{border-top:1px solid var(--border)}
#view-booking .bkv2-detail-rname{font-family:'DM Sans',sans-serif;font-weight:500;color:var(--ink);font-size:12px}
#view-booking .bkv2-detail-rname.muted{color:var(--ink-soft);font-weight:400}
#view-booking .bkv2-detail-stats{display:flex;gap:12px;font-family:'DM Mono',monospace;align-items:center;flex-wrap:wrap}
#view-booking .bkv2-detail-stats .sep{color:var(--border)}
#view-booking .bkv2-detail-stats .lab{color:var(--ink-soft)}
#view-booking .bkv2-detail-stats .val{color:var(--ink);font-weight:500}
#view-booking .bkv2-detail-stats .val.foc{color:#ba7517}
#view-booking .bkv2-detail-stats .val.big{font-size:13px}
#view-booking .bkv2-detail-foot{display:flex;justify-content:space-between;align-items:baseline;padding-top:10px;margin-top:6px;border-top:1px solid var(--border)}
#view-booking .bkv2-detail-foot .lab{font-family:'DM Sans',sans-serif;font-size:9px;color:var(--ink-soft);letter-spacing:.06em;text-transform:uppercase;font-weight:500}
#view-booking .bkv2-detail-foot .stats{display:flex;gap:14px;font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--ink)}
#view-booking .bkv2-detail-foot .stats .sep{color:var(--border)}
/* Tab 2 — by trip + date (filter chip + reuse table) */
#view-booking .bkv2-filterchip{display:inline-flex;align-items:center;gap:8px;background:var(--bk-navy-50);border:1px solid var(--bk-navy-mid);color:var(--bk-navy);padding:4px 11px;border-radius:var(--r-sm);font-size:12px;font-weight:500}
#view-booking .bkv2-filterchip .clear{background:transparent;border:none;color:var(--bk-navy);cursor:pointer;font-size:14px;padding:0;line-height:1;font-family:inherit}
/* Tab 3 reuses KPI/filter/table from old design — restore tokens to DM Sans/Mono */
#view-booking .bkv2-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid var(--border);background:var(--white)}
#view-booking .bkv2-kpi{padding:13px 18px;border-right:1px solid var(--border)}
#view-booking .bkv2-kpi:last-child{border-right:none}
#view-booking .bkv2-kpi-lab{font-family:'DM Sans',sans-serif;font-size:10px;color:var(--ink-soft);letter-spacing:.06em;text-transform:uppercase;margin-bottom:3px;font-weight:500}
#view-booking .bkv2-kpi-val{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;letter-spacing:-.005em;color:var(--ink);font-variant-numeric:tabular-nums;line-height:1.1}
#view-booking .bkv2-kpi-foot{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft);margin-top:3px}
#view-booking .bkv2-kpi.warn .bkv2-kpi-val{color:#ba7517}
#view-booking .bkv2-filterbar{display:flex;align-items:center;gap:8px;padding:11px 18px;background:var(--white);border-bottom:1px solid var(--border);flex-wrap:wrap}
#view-booking .bkv2-pill{padding:4px 11px;border-radius:var(--r-sm);font-size:12px;font-weight:500;background:var(--sand-mid);color:var(--ink-soft);border:1px solid transparent;cursor:pointer;display:inline-flex;align-items:center;gap:5px;font-family:inherit}
#view-booking .bkv2-pill.on{background:var(--bk-navy);color:var(--white)}
#view-booking .bkv2-pill .dot{width:6px;height:6px;border-radius:50%;background:var(--ink-soft)}
#view-booking .bkv2-pill.on .dot{background:var(--white)}
#view-booking .bkv2-pill[data-st="confirmed"] .dot{background:#1d9e75}
#view-booking .bkv2-pill[data-st="pending_foc"] .dot{background:#ba7517}
#view-booking .bkv2-pill[data-st="quote"] .dot{background:var(--ink-soft)}
#view-booking .bkv2-pill[data-st="rejected"] .dot{background:#a32d2d}
#view-booking .bkv2-pill[data-st="completed"] .dot{background:var(--bk-navy)}
#view-booking .bkv2-search{margin-left:auto;background:var(--sand-mid);border:1px solid var(--border);border-radius:var(--r-sm);padding:5px 11px;font-size:12px;font-family:inherit;color:var(--ink);width:220px;outline:none}
#view-booking .bkv2-search:focus{border-color:var(--bk-navy-mid);background:var(--white)}
#view-booking .bkv2-tbl{width:100%;border-collapse:collapse;font-size:12px;background:var(--white)}
#view-booking .bkv2-tbl thead th{font-family:'DM Mono',monospace;font-size:9px;color:var(--ink-soft);font-weight:500;letter-spacing:.04em;text-transform:uppercase;text-align:left;padding:9px 14px;background:var(--sand-mid);border-bottom:1px solid var(--border)}
#view-booking .bkv2-tbl thead th.num{text-align:right}
#view-booking .bkv2-tbl tbody td{padding:11px 14px;border-bottom:1px solid var(--border);vertical-align:middle;font-size:12px}
#view-booking .bkv2-tbl tbody tr{cursor:pointer}
#view-booking .bkv2-tbl tbody tr:hover td{background:var(--sand-mid)}
#view-booking .bkv2-tbl .num{text-align:right;font-variant-numeric:tabular-nums}
#view-booking .bkv2-tbl .bk-id{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft);font-variant-numeric:tabular-nums}
#view-booking .bkv2-tbl .agent-name{font-family:'DM Sans',sans-serif;font-weight:500;color:var(--ink)}
