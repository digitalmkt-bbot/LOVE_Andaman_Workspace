      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Capacity</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px;color:#185FA5">${b.cap||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">PAX · company</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Build year</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${b.year||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">${age!==null?age+' years old':''}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Documents</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px;color:${expiringDocs?SVG_PINK.text:dim.ink}">${docs.length}</div>
      <div style="font-size:10px;color:${dim.ink2}">${expiringDocs?expiringDocs+' expiring':'all valid'}</div>
    </div>
  </div>`;

  // General info
  const infoField=(label,val,mono)=>`<div><div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">${label}</div><div style="font-size:12px;font-weight:500;margin-top:2px${mono?";font-family:'DM Mono',monospace":''}">${val||'—'}</div></div>`;
  const generalInfo=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">General info</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;background:#FBFAF7;border-radius:10px;padding:12px">
      ${infoField('Brand / Model',b.brand&&b.model?b.brand+' / '+b.model:b.brand||b.model)}
      ${infoField('Registration',b.reg,true)}
      ${infoField('Call sign',b.callsign,true)}
      ${infoField('IMO number',b.imo,true)}
      ${infoField('Use type',b.use)}
      ${infoField('Hull material',b.material)}
      ${infoField('Build year',b.year)}
      ${infoField('Registered at',b.homeportCity)}
      ${infoField('Engine layout',b.engineCount?(typeof getEngPositions==='function'?getEngPositions(b.engineCount).join(' / '):b.engineCount+' engines'):'—')}
    </div>
  </div>`;

  // Dimensions + Passenger
  const hasDims=b.gt||b.nt||b.dwt||b.loa||b.beam||b.depth||b.draft||b.bhp;
  const hasPax=b.crew||b.totalcap||b.licensePax||b.fishcrew;
  const dimField=(label,val,unit)=>val!=null?`<div><div style="font-size:9px;color:${dim.ink3};text-transform:uppercase">${label}</div><div style="font-size:13px;font-weight:600;font-family:'DM Mono',monospace">${val}${unit?' '+unit:''}</div></div>`:'';
  const dims=hasDims?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Dimensions</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:12px;display:grid;grid-template-columns:repeat(2,1fr);gap:8px">
      ${dimField('GT (gross)',b.gt)}
      ${dimField('NT (net)',b.nt)}
      ${dimField('DWT',b.dwt,'tons')}
      ${dimField('LOA (length)',b.loa,'m')}
      ${dimField('Beam (width)',b.beam,'m')}
      ${dimField('Depth',b.depth,'m')}
      ${dimField('Draft',b.draft,'m')}
      ${dimField('BHP',b.bhp,'HP')}
    </div>
  </div>`:'';
  const paxBlock=hasPax?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Passengers</div>
    <div style="background:#E6F1FB;border:1px solid #b5d4f4;border-radius:10px;padding:10px 12px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between">
      <div><div style="font-size:10px;color:#185FA5;font-weight:600">Company capacity</div><div style="font-size:9px;color:${dim.ink2}">used for Allotment</div></div>
      <div style="font-size:24px;font-weight:700;color:#185FA5;font-family:'DM Mono',monospace">${b.cap||'—'}<span style="font-size:11px;font-weight:400;color:${dim.ink2}"> PAX</span></div>
    </div>
    <div style="font-size:9px;color:${dim.ink3};margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">Per Marine Dept license</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:10px;display:grid;grid-template-columns:repeat(2,1fr);gap:6px">
      ${b.licensePax!=null?`<div><div style="font-size:9px;color:${dim.ink3}">Passengers</div><div style="font-size:13px;font-weight:600">${b.licensePax} PAX</div></div>`:''}
      ${b.crew!=null?`<div><div style="font-size:9px;color:${dim.ink3}">Crew</div><div style="font-size:13px;font-weight:600">${b.crew} crew</div></div>`:''}
      ${b.fishcrew!=null?`<div><div style="font-size:9px;color:${dim.ink3}">Fishing crew</div><div style="font-size:13px;font-weight:600">${b.fishcrew}</div></div>`:''}
      ${b.totalcap!=null?`<div><div style="font-size:9px;color:${dim.ink3}">Total</div><div style="font-size:13px;font-weight:600">${b.totalcap} PAX</div></div>`:''}
    </div>
  </div>`:'';
  const dimsAndPax=(hasDims||hasPax)?`<div style="display:grid;grid-template-columns:${hasDims&&hasPax?'1fr 1fr':'1fr'};gap:14px">${dims}${paxBlock}</div>`:'';

  // Engines section
  const engineCards=engs.length?engs.map(e=>{
    const curH=typeof flEngHours==='function'?flEngHours(e.id):0;
    const isSuzuki=e.brand==='Suzuki';
    const posBg=isSuzuki?'#A32D2D':'#185FA5';
    return`<div style="display:flex;align-items:center;gap:8px;padding:8px;background:white;border-radius:8px;border:0.5px solid ${dim.line}">
      <span style="font-size:9px;font-weight:700;color:white;background:${posBg};padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${e.pos}</span>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:600">${e.brand} ${e.model}</div>
        <div style="font-size:9px;color:${dim.ink3};font-family:'DM Mono',monospace">SN: ${e.serial}</div>
      </div>
      <span style="font-size:10px;color:#0F6E56;font-weight:600;font-family:'DM Mono',monospace;flex-shrink:0">${curH.toLocaleString()}h</span>
      <div style="display:flex;flex-direction:column;gap:3px;flex-shrink:0">
        <button onclick="flOpenAssignEngModal('${b.id}','${e.id}')" title="เปลี่ยนเครื่อง (Swap)" style="background:#FDF2F8;border:1px solid #F0C0D0;border-radius:6px;padding:3px 8px;font-size:9px;color:#9F1B4F;cursor:pointer;font-weight:600">⇄ Swap</button>
        <button onclick="flUnassignEng('${e.id}','${b.id}')" title="ถอดเครื่องออกจากเรือ" style="background:white;border:1px solid rgba(0,0,0,.12);border-radius:6px;padding:3px 8px;font-size:9px;color:#A32D2D;cursor:pointer;font-weight:600">↓ Unassign</button>
      </div>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No engines assigned</div>`;
  const enginesSection=`<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">Engines <span style="color:${dim.ink3};font-weight:400">${engs.length}</span></span>
      <button onclick="flOpenAssignEngModal('${b.id}',null)" style="background:${dim.bg};border:none;border-radius:14px;padding:4px 11px;font-size:10px;color:${dim.ink2};cursor:pointer">+ Assign</button>
    </div>
    <div style="background:#FBFAF7;border-radius:10px;padding:8px;display:grid;grid-template-columns:repeat(2,1fr);gap:6px">
      ${engineCards}
    </div>
  </div>`;

  // Documents
  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtDocDate=(s)=>{if(!s)return'—';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};
  const docsHtml=docs.length?docs.map((doc,i)=>{
    const isLast=i===docs.length-1;
    const isExp=doc.exp&&doc.exp<TODAY_STR;
    const isWarn=doc.exp&&!isExp&&doc.exp<=ninetyStr;
    const expColor=isExp?'#A32D2D':isWarn?'#854F0B':'#0F6E56';
    const expIcon=isExp?'✕':isWarn?'⚠':'';
    return`<div style="display:grid;grid-template-columns:1fr auto;gap:10px;padding:10px 14px;align-items:center;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="font-size:11px;font-weight:500">${doc.name}</div>
      <span style="font-size:10px;font-family:'DM Mono',monospace;color:${expColor};font-weight:500">${fmtDocDate(doc.exp)} ${expIcon}</span>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No documents</div>`;
  const docsSection=`<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">Documents <span style="color:${dim.ink3};font-weight:400">${docs.length}</span></span>
    </div>
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${docsHtml}</div>
  </div>`;

  // Repair history
  const maints=FL_MAINT.filter(m=>m.boatId===b.id&&m.status==='done').sort((a,z)=>(z.startDate||'').localeCompare(a.startDate||'')).slice(0,4);
  const repairHtml=maints.length?maints.map((m,i)=>{
    const isLast=i===maints.length-1;
    return`<div style="display:flex;gap:8px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="width:8px;height:8px;border-radius:50%;background:#1D9E75;flex-shrink:0;margin-top:5px"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500">${m.title||m.detail||'Repair work'}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${fmtDocDate(m.startDate)}${m.cost?' · ฿'+m.cost.toLocaleString():''}</div>
      </div>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No repair history</div>`;
  const repairSection=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Recent repairs</div>
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${repairHtml}</div>
  </div>`;

  // Incidents history (Job Assignments)
  const SEV_STYLE={
    critical:{bg:'#FCEBEB',color:'#A32D2D',label:'CRITICAL',stripe:'#A32D2D'},
    major:{bg:'#FAEEDA',color:'#854F0B',label:'MAJOR',stripe:'#BA7517'},
    minor:{bg:'#F4F2EE',color:'#666',label:'MINOR',stripe:'#666'}
  };
  const INC_ST_STYLE={
    open:{bg:'#FCEBEB',color:'#A32D2D',label:'OPEN'},
    pending:{bg:'#FAEEDA',color:'#854F0B',label:'PENDING JOB'},
    inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROGRESS'},
    resolved:{bg:'#1D9E75',color:'white',label:'RESOLVED'}
  };
  const boatIncidents=(FL_INCIDENTS||[]).filter(i=>i.boatId===b.id).sort((a,z)=>(z.date||'').localeCompare(a.date||'')).slice(0,5);
  const incHtml=boatIncidents.length?boatIncidents.map((inc,i,arr)=>{
    const isLast=i===arr.length-1;
    const mj=inc.maintId?FL_MAINT.find(m=>m.id===inc.maintId):null;
    let st='open';
    // Direct status override (Quick Fix / manually resolved without MJ)
    if(inc.status==='resolved'){
      st='resolved';
    } else if(mj){
      if(mj.status==='pending')st='pending';
      else if(mj.status==='inprogress')st='inprogress';
      else if(mj.status==='done')st='resolved';
    }
    const sev=SEV_STYLE[inc.severity||'minor']||SEV_STYLE.minor;
    const ss=INC_ST_STYLE[st]||INC_ST_STYLE.open;
    const assetCount=(inc.damagedAssets||[]).length;
    // Quick Fix marker — shown instead of MJ link
    const linkChip = mj
      ? `<span style="font-size:9px;color:#185FA5">→ ${mj.no}${mj.status==='done'?' ✓':''}</span>`
      : (inc.quickFix ? `<span style="font-size:9px;color:#0F6E56;font-weight:600">⚡ Quick Fix</span>` : '');
    return`<div onclick="nav(document.querySelector('[data-view=fl-incident]'));setTimeout(()=>{if(typeof flSelIncident==='function')flSelIncident('${inc.id}')},100)" style="display:flex;gap:10px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'};cursor:pointer">
      <div style="width:3px;background:${sev.stripe};border-radius:2px;flex-shrink:0;align-self:stretch"></div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:5px;margin-bottom:2px;flex-wrap:wrap">
          <span style="font-size:10px;font-family:'DM Mono',monospace;color:${dim.ink3};font-weight:600">${inc.no||'—'}</span>
          <span style="background:${sev.bg};color:${sev.color};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600">${sev.label}</span>
          ${linkChip}
        </div>
        <div style="font-size:11px;font-weight:500;color:${dim.ink}">${inc.title||'—'}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${inc.date||''}${assetCount?' · '+assetCount+' asset'+(assetCount>1?'s':''):''}</div>
      </div>
      <span style="background:${ss.bg};color:${ss.color};padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600;align-self:flex-start;flex-shrink:0">${ss.label}</span>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No incidents on record</div>`;
  const incidentsSection=`<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">Incidents history <span style="color:${dim.ink3};font-weight:400">${boatIncidents.length}</span></span>
      ${boatIncidents.length>=5?`<span style="font-size:10px;color:${dim.ink3}">Showing 5 most recent</span>`:''}
    </div>
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${incHtml}</div>
  </div>`;

  // Owner / Homeport
  const hasOwner=b.owner||b.homeport||b.ownerAddr;
  const ownerSection=hasOwner?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Owner / Homeport</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:12px;display:grid;grid-template-columns:1fr 1fr;gap:10px">
      ${b.owner?`<div><div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Owner</div><div style="font-size:12px;font-weight:500;margin-top:2px">${b.owner}</div></div>`:''}
      ${b.homeport?`<div><div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Homeport</div><div style="font-size:12px;font-weight:500;margin-top:2px">${b.homeport}</div></div>`:''}
      ${b.ownerAddr?`<div style="grid-column:1/-1"><div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Address</div><div style="font-size:11px;color:${dim.ink2};margin-top:2px">${b.ownerAddr}</div></div>`:''}
    </div>
  </div>`:'';

  // Note
  const noteSection=b.note?`<div style="font-size:11px;color:${dim.ink2};font-style:italic;background:#FBFAF7;border-radius:10px;padding:10px 12px"><span style="color:${dim.ink3};font-weight:600">Note: </span>${b.note}</div>`:'';

  // Pier Assignments section
  const activeAsn = typeof getActiveAssignment==='function'?getActiveAssignment(b):null;
  const plannedAsns = typeof getPlannedAssignments==='function'?getPlannedAssignments(b):[];
  const pastAsns = typeof getPastAssignments==='function'?getPastAssignments(b):[];
  const ASN_TYPE_LABEL={temporary:'Temporary',permanent:'Permanent'};
  const renderAsnCard=(a,statusLabel,statusColor,statusBg)=>{
    const fromLbl=PIER_LABELS[a.fromPier]||a.fromPier;
    const toLbl=PIER_LABELS[a.toPier]||a.toPier;
    return `<div style="background:#FBFAF7;border-radius:10px;padding:10px 12px;border-left:3px solid ${statusColor}">
      <div style="display:flex;justify-content:space-between;align-items:start;gap:8px">
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;font-weight:600">${fromLbl} → ${toLbl}</div>
          <div style="font-size:10px;color:${dim.ink2};margin-top:2px">${a.startDate} – ${a.endDate} · ${ASN_TYPE_LABEL[a.type]||a.type}</div>
          ${a.reason?`<div style="font-size:10px;color:${dim.ink3};margin-top:3px;font-style:italic">${a.reason}</div>`:''}
          ${a.cost?`<div style="font-size:10px;color:${dim.ink3};margin-top:2px;font-family:'DM Mono',monospace">Cost: ฿${a.cost.toLocaleString()}</div>`:''}
        </div>
        <div style="display:flex;flex-direction:column;gap:4px;align-items:end;flex-shrink:0">
          <span style="background:${statusBg};color:${statusColor};padding:2px 8px;border-radius:8px;font-size:9px;font-weight:600">${statusLabel}</span>
          ${a.status!=='cancelled'?`<button onclick="flCancelAssignment('${b.id}','${a.id}')" style="background:none;border:none;color:${dim.ink3};font-size:9px;cursor:pointer;padding:0">Cancel</button>`:''}
        </div>
      </div>
    </div>`;
  };
  const assignmentSection = `<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">📍 Pier Assignments <span style="color:${dim.ink3};font-weight:400">${(b.assignments||[]).filter(a=>a.status!=='cancelled').length}</span></span>
      <button onclick="flOpenNewAssignment('${b.id}')" style="background:#1F4D2C;color:white;border:none;border-radius:10px;padding:4px 10px;font-size:10px;font-weight:600;cursor:pointer">+ New</button>
    </div>
    ${activeAsn?`<div style="margin-bottom:8px"><div style="font-size:10px;color:#0F6E56;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">🟢 Active</div>${renderAsnCard(activeAsn,'Active','#0F6E56','#E0F5EC')}</div>`:''}
    ${plannedAsns.length>0?`<div style="margin-bottom:8px"><div style="font-size:10px;color:#854F0B;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">📅 Planned (${plannedAsns.length})</div><div style="display:flex;flex-direction:column;gap:4px">${plannedAsns.map(a=>renderAsnCard(a,'Planned','#854F0B','#FAEEDA')).join('')}</div></div>`:''}
    ${pastAsns.length>0?`<div><div style="font-size:10px;color:${dim.ink3};font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Past (${pastAsns.length})</div><div style="display:flex;flex-direction:column;gap:4px">${pastAsns.slice(0,3).map(a=>renderAsnCard(a,'Completed','#999','#F0EEEA')).join('')}</div></div>`:''}
    ${!activeAsn&&plannedAsns.length===0&&pastAsns.length===0?`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:10px;background:#FBFAF7;border-radius:10px">ไม่มีประวัติย้ายท่า · กด + New เพื่อสร้าง</div>`:''}
  </div>`;

  mount.innerHTML=`${headerStrip}<div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px;max-height:calc(100vh - 280px);overflow-y:auto">
    ${statCards}
    ${generalInfo}
    ${dimsAndPax}
    ${enginesSection}
    ${ownerSection}
    ${assignmentSection}
    <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:14px">${docsSection}${repairSection}</div>
    ${incidentsSection}
    ${noteSection}
  </div>`;
}

