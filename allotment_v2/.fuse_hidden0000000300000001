// FOC approve/reject
function bkV2FocApprove(bookingId){
  const bk = SB_BOOKINGS.find(b => b.id === bookingId);
  if(!bk || !bk.focApproval) return;
  if(bk.focApproval.status !== 'pending'){ alert('FOC is not pending'); return; }
  if(!confirm(`Approve ${bk.focApproval.count} FOC pax for ${bk.id}?\n\nReason: ${bk.focApproval.reason||'(none)'}`)) return;
  bk.focApproval.status = 'approved';
  bk.focApproval.approvedAt = new Date().toISOString();
  bk.focApproval.approvedBy = 'RM';
  bk.status = 'confirmed';
  bkV2AddHistory(bk,'foc','FOC approved · '+bk.focApproval.count+' pax · booking confirmed','FOC');
  // Persist
  try { sbPersist?.(); } catch(e){ try { save(); } catch(e2){} }
  bkV2Render();
}
function bkV2FocReject(bookingId){
  const bk = SB_BOOKINGS.find(b => b.id === bookingId);
  if(!bk || !bk.focApproval) return;
  if(bk.focApproval.status !== 'pending'){ alert('FOC is not pending'); return; }
  const reason = prompt('Reason for rejecting FOC:', '');
  if(reason === null) return; // cancel
  bk.focApproval.status = 'rejected';
  bk.focApproval.rejectReason = reason || '';
  bk.focApproval.approvedAt = new Date().toISOString();
  bk.focApproval.approvedBy = 'RM';
  bk.status = 'rejected';
  bkV2AddHistory(bk,'foc','FOC rejected · '+bk.focApproval.count+' pax'+(reason?' · '+reason:''),'FOC');
  try { sbPersist?.(); } catch(e){ try { save(); } catch(e2){} }
  bkV2Render();
}

// Cancel booking from detail view
function bkV2DetailCancel(bookingId){
  const bk = SB_BOOKINGS.find(b => b.id === bookingId);
