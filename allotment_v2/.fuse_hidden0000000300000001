function flProjCleanupV3(d){
  d = d || JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  if(d._fl_proj_cleanup_v3_open) return 0;
  let cleared = 0;
  (FL_PROJECTS||[]).forEach(p=>{
    if(!p.planFrom || !p.planTo) return;
    // Skip if user has edited (deliberate date set)
    const wasEdited = (p.log||[]).some(l=>l.text && (l.text.includes('Project edited')||l.text.indexOf('Edit')===0));
    if(wasEdited) return;
    // Only clean projects that were auto-generated
    const firstLog = (p.log||[])[0];
    if(!firstLog) return;
    const isAuto = firstLog.by==='migration' || firstLog.by==='auto-create' || firstLog.by==='resync';
    if(!isAuto) return;
    // Check if planTo - planFrom is exactly 30 days (the old default)
    const from = new Date(p.planFrom);
    const to   = new Date(p.planTo);
    const diffDays = Math.round((to-from)/86400000);
    if(diffDays!==30) return;
    // Clear it
    p.planTo = null;
    if(!p.log) p.log=[];
    p.log.push({date:TODAY_STR, text:`Auto-cleanup: end date set to Open (was +30d default)`, by:'cleanup-v3'});
    cleared++;
  });
  d._fl_proj_cleanup_v3_open = true;
  d.fleet_projects = FL_PROJECTS;
  localStorage.setItem(LS_KEY, JSON.stringify(d));
  if(cleared) console.log(`[Projects cleanup v3] cleared default +30d end date from ${cleared} project(s)`);
  return cleared;
}

function flProjMigrate(force){
  const d = JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  // Cleanup v2 — unlinks non-scheduled MJs (one-shot per browser)
  flProjCleanupV2(d);
  // Cleanup v3 — clear default +30d planTo from auto-created projects (one-shot)
  flProjCleanupV3(d);
  // Cleanup v4 — backfill originalPlanTo baseline (one-shot)
  flProjCleanupV4(d);
  // Resync — links unlinked scheduled MJs to EXISTING projects (overlap on same boat)
  flProjResyncMJLinks();
  // Auto-create — for any STILL-unlinked scheduled MJ, create a fresh Project from MJ data
  // (covers MJs whose boat log isn't dry_dock, so step 1 migration didn't create a project)
  flProjAutoCreateForScheduledMJs();
  if(!force && d._fl_proj_migrated_v1) return {created:0, linked:0, skipped:'already migrated · resync + auto-create + cleanup ran'};
  if(!Array.isArray(FL_PROJECTS)) FL_PROJECTS=[];
  let created=0, linked=0;
  const today = new Date(TODAY_STR);
  (BOATS||[]).forEach(b=>{
    const log = b.log||[];
    if(!log.length) return;
    // Pick log entries that represent a dry-dock / major project state
    log.forEach(entry=>{
      const isDryDock = entry.reason==='dry_dock';
      const startDate = entry.from || entry.start || null;
      const endDate   = entry.to   || entry.end   || null;
      if(!startDate) return;
      // Long unavailable >= 14 days counts as project too
      const isLongUnavailable = entry.s==='unavailable' && (function(){
        const a = new Date(startDate);
        const b2 = endDate ? new Date(endDate) : today;
        return (b2-a)/86400000 >= 14;
      })();
      if(!isDryDock && !isLongUnavailable) return;
      // Skip if already linked (entry has projectId)
      if(entry.projectId) return;
      // Build project
      const yr  = startDate.slice(0,4);
      const seq = (FL_PROJECTS.length+1).toString().padStart(3,'0');
      const pid = `proj_${yr}_${b.id}_${seq}`;
      const status = endDate ? 'completed' : (new Date(startDate)<=today ? 'inprogress' : 'planned');
      const name = isDryDock
        ? `Annual Drydock · ${b.name}`
        : `Major Service · ${b.name}`;
      const _migPt = endDate || flProjGuessEnd(startDate);
      const proj = {
        id: pid,
        no: `PRJ-${seq}`,
        name,
        boatId: b.id,
        type: isDryDock ? 'drydock' : 'overhaul',
        vendor: entry.loc || '',
        planFrom: startDate,
        planTo: _migPt,
        originalPlanTo: _migPt, // BASELINE
        actualFrom: startDate,
        actualTo: endDate,
        status,
        plannedBudget: 0,
        notes: entry.note || '',
        log: [
          {date: startDate, text:`+ Auto-created from boat log entry (${entry.reason||entry.s})`, by:'migration'}
        ],
        createdAt: TODAY_STR,
        createdBy: 'migration'
      };
      FL_PROJECTS.push(proj);
      // Tag the boat log entry so we never re-migrate it
      entry.projectId = pid;
      created++;
      // Link existing scheduled MJs whose date range overlaps this project (same boat)
      // Only `scheduled` type — corrective/preventive are independent jobs
      (FL_MAINT||[]).forEach(m=>{
        if(m.boatId!==b.id) return;
        if(m.type!=='scheduled') return;
        if(m.parentProjectId) return;
        if(!m.startDate) return;
        const ms = new Date(m.startDate);
        const me = m.endDate ? new Date(m.endDate) : today;
        const ps = new Date(proj.planFrom);
        const pe = new Date(proj.planTo);
        // Overlap test
        if(ms<=pe && me>=ps){
          m.parentProjectId = pid;
          linked++;
        }
      });
    });
  });
  // Persist
  d._fl_proj_migrated_v1 = true;
  d.boats = BOATS;
  d.fleet_projects = FL_PROJECTS;
  d.fleet_maintenance = FL_MAINT;
  localStorage.setItem(LS_KEY, JSON.stringify(d));
  console.log(`[Projects migration] created=${created} · linked MJs=${linked}`);
  return {created, linked};
}
function flProjGuessEnd(startStr){
  // Default = Open (no fixed end) · user can edit later to set explicit date
  return null;
}

// ── Phase definitions per project type ──
const PROJ_PHASES = {
  drydock:    [{k:'planning',label:'Planning'},{k:'liftout',label:'Lift-out'},{k:'hull',label:'Hull / Paint'},{k:'mechanical',label:'Mechanical'},{k:'sea_trial',label:'Sea Trial'},{k:'handover',label:'Handover'}],
  overhaul:   [{k:'planning',label:'Planning'},{k:'disassembly',label:'Disassembly'},{k:'install',label:'Install'},{k:'test',label:'Bench Test'},{k:'sea_trial',label:'Sea Trial'},{k:'handover',label:'Handover'}],
  refit:      [{k:'planning',label:'Planning'},{k:'strip',label:'Strip-out'},{k:'rebuild',label:'Rebuild'},{k:'finishing',label:'Finishing'},{k:'handover',label:'Handover'}],
  scheduled:  [{k:'planning',label:'Planning'},{k:'service',label:'Service'},{k:'test',label:'Test'},{k:'handover',label:'Handover'}],
  other:      [{k:'planning',label:'Planning'},{k:'execute',label:'Execute'},{k:'verify',label:'Verify'},{k:'handover',label:'Handover'}]
};
function flProjPhasesFor(p){ return PROJ_PHASES[p.type] || PROJ_PHASES.other; }
function flProjCurrentPhaseIdx(p){
  const phases = flProjPhasesFor(p);
  if(p.status==='completed') return phases.length-1;
  if(p.status==='cancelled') return -1;
  if(p.phase){
    const idx = phases.findIndex(x=>x.k===p.phase);
    if(idx>=0) return idx;
  }
  // Default: if inprogress and no phase set → index 1 (after planning), else planning
  return p.status==='inprogress' ? 1 : 0;
}
function flProjSetPhase(projId, phaseKey){
  const p = flProjGetById(projId); if(!p) return;
  const phases = flProjPhasesFor(p);
  const newPhase = phases.find(x=>x.k===phaseKey);
  if(!newPhase) return;
  const oldLabel = p.phase ? (phases.find(x=>x.k===p.phase)?.label||p.phase) : '(none)';
  p.phase = phaseKey;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`Phase: ${oldLabel} → ${newPhase.label}`, by:'user'});
  flSave();
  flRenderProjects();
}

// ── Health score · derived from cost variance + schedule adherence ──
function flProjHealth(p){
  if(p.status==='completed') return {key:'completed', label:'COMPLETED', color:'#0E7A5C', bg:'#E6F7F1', score:100};
  if(p.status==='cancelled') return {key:'cancelled', label:'CANCELLED', color:'#A32D2D', bg:'#FCEBEB', score:0};
  const budget = p.plannedBudget||0;
  const cost = (typeof flProjCalcCost==='function')?flProjCalcCost(p.id):0;
  const budgetPct = budget? (cost/budget*100) : 0;
  // Schedule progress · skip if planTo is Open (null)
  const ps = p.planFrom ? new Date(p.planFrom) : null;
  const pe = p.planTo   ? new Date(p.planTo)   : null;
  const today = new Date(TODAY_STR);
  let timePct = 0, schedOver = 0;
  if(ps && pe){
    const total = Math.max(1, (pe-ps)/86400000);
    const elapsed = Math.max(0, (today-ps)/86400000);
    timePct = Math.min(150, elapsed/total*100);
    if(today>pe) schedOver = (today-pe)/86400000;
  }
  // Open-ended projects don't get schedule penalty
  // Open MJ ratio
  const kids = flProjChildMJs(p.id);
  const openRatio = kids.length ? kids.filter(m=>m.status!=='done').length/kids.length : 0;
  // Score
  let score = 100;
  if(budget && budgetPct>100) score -= Math.min(40, (budgetPct-100)*1.5);
  if(budget && budgetPct>=80 && budgetPct<=100) score -= 5;
  if(schedOver>0) score -= Math.min(35, schedOver*2);
  if(timePct>80 && openRatio>0.5) score -= 15;
  if(p.status==='on_hold') score -= 10;
  score = Math.max(0, Math.min(100, Math.round(score)));
  // Bucket
  let key='ontrack', label='ON TRACK', color='#0E7A5C', bg='#E6F7F1';
  if(score<40){ key='critical'; label='CRITICAL'; color='#A32D2D'; bg='#FCEBEB'; }
  else if(score<70){ key='atrisk'; label='AT RISK'; color='#996A14'; bg='#FFF4E1'; }
  return {key, label, color, bg, score, budgetPct, schedOver, openRatio};
}

// ── YoY Analysis · compute year-over-year stats from FL_PROJECTS ──
function flProjYoYStats(yearTY){
  yearTY = yearTY || new Date(TODAY_STR).getFullYear();
  const yearLY = yearTY - 1;
  const projForYear = (yr) => (FL_PROJECTS||[]).filter(p=>{
    const ref = p.actualTo || p.planFrom || p.createdAt || '';
    return ref.startsWith(String(yr));
  });
  const calc = (projs) => {
    const completed = projs.filter(p=>p.status==='completed');
    const cancelled = projs.filter(p=>p.status==='cancelled');
    const totalSpend = projs.reduce((s,p)=>s+(typeof flProjCalcCost==='function'?flProjCalcCost(p.id):0), 0);
    const avgCost = completed.length ? Math.round(totalSpend/completed.length) : 0;
    // Avg duration in days for completed projects
    let durSum = 0, durCount = 0;
    completed.forEach(p=>{
      if(p.actualFrom && p.actualTo){
        const d = Math.max(0, (new Date(p.actualTo) - new Date(p.actualFrom))/86400000);
        durSum += d; durCount++;
      }
    });
    const avgDuration = durCount ? Math.round(durSum/durCount) : 0;
    // On-time = actualTo <= ORIGINAL plan (baseline · not editable)
    // Falls back to current planTo if no baseline (legacy)
    const baselineFor = p => p.originalPlanTo || p.planTo;
    const onTime = completed.filter(p=>p.actualTo && baselineFor(p) && p.actualTo<=baselineFor(p)).length;
    const onTimePct = completed.length ? Math.round(onTime/completed.length*100) : 0;
    // Schedule slip · days · negative = finished early · positive = late
    let slipSum = 0, slipCount = 0;
    completed.forEach(p=>{
      const base = baselineFor(p);
      if(p.actualTo && base){
        const d = Math.round((new Date(p.actualTo) - new Date(base))/86400000);
        slipSum += d; slipCount++;
      }
    });
    const avgSlip = slipCount ? Math.round(slipSum/slipCount) : 0;
    // Per-type counts
    const byType = {drydock:0, overhaul:0, refit:0, scheduled:0, other:0};
    projs.forEach(p=>{ const t=p.type||'other'; if(byType[t]!==undefined) byType[t]++; else byType.other++; });
    // Monthly spend (12 months)
    const monthSpend = Array(12).fill(0);
    completed.forEach(p=>{
      const ref = p.actualTo || p.planTo || '';
      if(!ref) return;
      const m = parseInt(ref.slice(5,7))-1;
      if(m>=0 && m<12) monthSpend[m] += (typeof flProjCalcCost==='function'?flProjCalcCost(p.id):0);
    });
    return {
      count: projs.length,
      completed: completed.length,
      cancelled: cancelled.length,
      totalSpend, avgCost, avgDuration, onTimePct, avgSlip,
      byType, monthSpend
    };
  };
  return { yearTY, yearLY, TY: calc(projForYear(yearTY)), LY: calc(projForYear(yearLY)) };
}

// ── Schedule slip KPI tile · negative = early (green) · positive = late (red) ──
function flProjRenderSlipTile(tySlip, lySlip, yearLY, P){
  const slipColor = (s) => s<0 ? P.mintInk : s>0 ? P.red : P.ink3;
  const slipLabel = (s) => s===0 ? 'on baseline' : s<0 ? `${Math.abs(s)} day${Math.abs(s)===1?'':'s'} early` : `${s} day${s===1?'':'s'} late`;
  const slipBg = (s) => s<0 ? P.mintSoft : s>0 ? P.redSoft : P.bg;
  const slipIcon = (s) => s<0 ? 'checkCircle' : s>0 ? 'alert' : 'target';
  // Delta: smaller (more negative or less positive) = better
  let deltaText = '—', deltaInk = P.ink3;
  if(tySlip !== lySlip){
    const diff = tySlip - lySlip;
    deltaText = diff<0 ? `↓ ${Math.abs(diff)}d better` : `↑ ${diff}d worse`;
    deltaInk = diff<0 ? P.mintInk : P.red;
  }
  return `
    <div style="background:white;border:1px solid ${P.line};border-radius:14px;padding:16px 18px;box-shadow:${P.shadow}">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
        <div style="width:36px;height:36px;border-radius:10px;background:${slipBg(tySlip)};color:${slipColor(tySlip)};display:flex;align-items:center;justify-content:center;flex-shrink:0">${flProjIcon(slipIcon(tySlip),18,slipColor(tySlip),1.8)}</div>
        <div style="font-size:11px;color:${P.ink2};font-weight:600">Schedule Slip</div>
      </div>
      <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap;margin-bottom:6px">
        <span style="font-size:30px;font-weight:800;color:${slipColor(tySlip)};letter-spacing:-.7px;line-height:1;font-variant-numeric:tabular-nums">${tySlip>0?'+':''}${tySlip}</span>
        <span style="font-size:12px;color:${P.ink3};font-weight:500">days</span>
        <span style="background:${deltaInk}22;color:${deltaInk};padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;margin-left:auto">${deltaText}</span>
      </div>
      <div style="font-size:11px;color:${P.ink3}">${slipLabel(tySlip)} · vs <span style="font-weight:600;color:${P.ink2}">${lySlip>0?'+':''}${lySlip}d</span> in ${yearLY}</div>
    </div>`;
}

