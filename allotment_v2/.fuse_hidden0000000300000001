    </div>
    <div class="nav-item" data-view="teammkt" onclick="nav(this)" style="border-left:2px solid rgba(200,180,255,.25);padding-left:9px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11h-6M22 8h-6M22 14h-6"/></svg>
      Team &amp; Markets
