function memoParseImport(){
  const raw=document.getElementById('memo-paste-input').value;
  const lines=raw.split('\n').filter(l=>l.trim());
  let added=0;
  lines.forEach(line=>{
    const parts=line.split(/\t|,/).map(s=>s.trim());
    if(parts.length>=1&&parts[0]){
      const name=parts[0].replace(/^\d+\.\s*/,'').trim();
      const qty=parseFloat(parts[1])||1;
      const price=parseFloat((parts[2]||parts[1]||'0').replace(/,/g,''))||0;
      if(name) {_memoItems.push({name,qty,price,fromInventory:false,category:(_memoType==='mixed'?'parts':_memoType)});added++;}
    }
  });
  document.getElementById('memo-paste-input').value='';
  memoRenderItems();
  if(added) alert(`เพิ่ม ${added} รายการแล้ว`);
}
