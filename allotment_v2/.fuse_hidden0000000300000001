// Pad / trim passengers[] · types: AD (excl. lead) → CHD → INF → FOC
function bkV2SyncPassengers(){
  if(!_bkV2.newBooking) return;
  const d = _bkV2.newBooking;
  let totAd = 0, totChd = 0, totInf = 0, totFoc = 0;
  d.trips.forEach(t => {
    totAd  += bkV2PaxTot(t.pax,'ad');
    totChd += bkV2PaxTot(t.pax,'chd');
    totInf += bkV2PaxTot(t.pax,'inf');
    totFoc += bkV2PaxTot(t.pax,'foc');
  });
  // Lead is always #1 (adult). Build expected types for #2 onwards
  const additionalAd = Math.max(0, totAd - 1);
  const expected = [];
  for(let i=0; i<additionalAd; i++) expected.push('AD');
  for(let i=0; i<totChd; i++) expected.push('CHD');
  for(let i=0; i<totInf; i++) expected.push('INF');
  for(let i=0; i<totFoc; i++) expected.push('FOC');

  if(!Array.isArray(d.passengers)) d.passengers = [];
  while(d.passengers.length < expected.length){ d.passengers.push({ name:'', nationality:'', type: expected[d.passengers.length] }); }
  while(d.passengers.length > expected.length){ d.passengers.pop(); }
  // Refresh type tags based on current composition (preserves names by index)
  d.passengers.forEach((p, i) => { p.type = expected[i]; });
}
