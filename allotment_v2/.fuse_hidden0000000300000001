            </td>
            <td><div class="t2-paywrap">${bkV2PayChip(bk)}${_cot.chip}</div></td>
            <td class="t2-r t2-mono">&#3647;${bkV2FmtTHB(r.subtotal)}</td>
            <td class="t2-c"><button class="t2-vcbtn" onclick="event.stopPropagation();bkV2OpenDetail('${esc(bk.id)}')" title="View voucher / booking detail">Voucher</button></td>
            ${wxClosed?`<td class="t2-c" style="background:#FBE8E4">${bkV2WeatherInlineCell(bk.id)}</td>`:''}
