function bkV2LockRemaining(l){ return Math.max(0, (l.qty||0) - (l.used||0)); }
// Auto-release locks past expiry (called on load)
function bkV2LockExpireSweep(){
  const today = (typeof bkV2LocalYMD==='function') ? bkV2LocalYMD(new Date()) : new Date().toISOString().slice(0,10);
  let changed = false;
  SB_SEAT_LOCKS.forEach(l => {
    if(l.status==='active' && l.expiry && l.expiry < today){
      l.status='expired'; (l.log=l.log||[]).push({date:today,type:'expire'}); changed=true;
    }
  });
  if(changed) sbSeatLocksPersist();
}
// Active locks on a trip · day-scope match exact date · month-scope match the month
function bkV2LocksFor(routeId, date){
  const ym = String(date).slice(0,7);
  return SB_SEAT_LOCKS.filter(l => {
    if(l.routeId!==routeId || l.status!=='active') return false;
    if(l.scope==='month'){
      const from = l.monthFrom || l.month, to = l.monthTo || l.month || from;
      return from && ym >= from && ym <= to;
    }
    return l.date===date;
  });
}
// Locks a given booking/agent may draw from · agent's own + office + global
function bkV2LocksForAgent(routeId, date, agentId){
  return bkV2LocksFor(routeId, date).filter(l => l.holderType==='office' || l.holderType==='global' || (l.holderType==='agent' && l.holderId===agentId));
}
function bkV2LockedTotal(routeId, date){ return bkV2LocksFor(routeId,date).reduce((s,l)=>s+bkV2LockRemaining(l),0); }
function bkV2CreateLock(o){
  const today = (typeof bkV2LocalYMD==='function') ? bkV2LocalYMD(new Date()) : new Date().toISOString().slice(0,10);
  const mFrom = o.monthFrom||o.month||'';
  const l = { id:'lk'+Date.now().toString(36), scope:o.scope||'day', routeId:o.routeId, date:o.date||'',
    monthFrom:mFrom, monthTo:o.monthTo||mFrom, month:mFrom, boatId:o.boatId||null,
    holderType:o.holderType||'office', holderId:o.holderId||null, qty:Number(o.qty)||0, used:0,
    reason:o.reason||'', expiry:o.expiry||'', status:'active', createdAt:today, createdBy:'RM',
    log:[{date:today,type:'create',qty:Number(o.qty)||0}] };
  SB_SEAT_LOCKS.push(l); sbSeatLocksPersist(); return l;
}
function bkV2DrawLock(lockId, qty, bookingId){
  const l = SB_SEAT_LOCKS.find(x=>x.id===lockId); if(!l) return 0;
  const n = Math.min(Math.max(0, qty|0), bkV2LockRemaining(l)); if(n<=0) return 0;
  const today = (typeof bkV2LocalYMD==='function') ? bkV2LocalYMD(new Date()) : new Date().toISOString().slice(0,10);
  l.used = (l.used||0) + n; (l.log=l.log||[]).push({date:today,type:'draw',qty:n,bookingId:bookingId||''});
  if(bkV2LockRemaining(l) <= 0) l.status='depleted';
  sbSeatLocksPersist(); return n;
}
// Release seats back to pool · qty omitted = release all remaining · partial keeps lock active
function bkV2ReleaseLock(lockId, qty){
  const l = SB_SEAT_LOCKS.find(x=>x.id===lockId); if(!l) return;
  const today = (typeof bkV2LocalYMD==='function') ? bkV2LocalYMD(new Date()) : new Date().toISOString().slice(0,10);
  const rem = bkV2LockRemaining(l);
  const n = (qty==null) ? rem : Math.min(Math.max(0, qty|0), rem);
  if(n <= 0) return;
  l.qty = Math.max(l.used||0, (l.qty||0) - n);   // return n held seats · never below used
  (l.log=l.log||[]).push({date:today, type:'release', qty:n});
  if(bkV2LockRemaining(l) <= 0) l.status = (l.used>0) ? 'depleted' : 'released';
  sbSeatLocksPersist();
}
// KPI · per agent · locked vs converted (drawn)
function bkV2LockKpiByAgent(agentId){
  const ls = SB_SEAT_LOCKS.filter(l => l.holderType==='agent' && l.holderId===agentId);
  const lockedQty = ls.reduce((s,l)=>s+(l.qty||0),0);
  const usedQty   = ls.reduce((s,l)=>s+(l.used||0),0);
  return { lockCount:ls.length, lockedQty, usedQty,
    conversion: lockedQty ? Math.round(usedQty/lockedQty*100) : 0,
    active: ls.filter(l=>l.status==='active').length,
    released: ls.filter(l=>l.status==='released').length,
    expired: ls.filter(l=>l.status==='expired').length };
}
