const WAREHOUSE_LOCATIONS = ['คลัง Tub Lamu', 'คลัง Visit Panwa', 'คลัง Ranong'];

// Sync legacy fields (qty, location) from stocks[]
function invSyncLegacy(item){
  if(!item) return;
  if(!item.stocks || !Array.isArray(item.stocks)){
    item.stocks = [{location: item.location||'คลัง Tub Lamu', qty: item.qty||0, minQty: item.minQty||0}];
  }
  // computed total
  item.totalQty = item.stocks.reduce((s,x)=>s+(x.qty||0), 0);
  item.qty = item.totalQty;
  // primary = location with most stock
  const sorted = [...item.stocks].sort((a,b)=>(b.qty||0)-(a.qty||0));
  item.primaryLocation = sorted[0]?.location || 'คลัง Tub Lamu';
  item.location = item.primaryLocation;
}

// Get qty at a specific location
function invQtyAt(item, location){
  if(!item || !item.stocks) return 0;
  const s = item.stocks.find(x=>x.location===location);
  return s?.qty || 0;
}

// Add qty to a location (creates entry if not exists)
function invAddAt(item, location, qty){
  if(!item) return;
  if(!item.stocks) item.stocks = [];
  let s = item.stocks.find(x=>x.location===location);
  if(!s){
    s = {location, qty:0, minQty:0};
    item.stocks.push(s);
  }
  s.qty = (s.qty||0) + qty;
  invSyncLegacy(item);
}

// Remove qty from a location (returns false if insufficient)
function invRemoveAt(item, location, qty){
  if(!item || !item.stocks) return false;
  const s = item.stocks.find(x=>x.location===location);
  if(!s || (s.qty||0) < qty) return false;
  s.qty -= qty;
  invSyncLegacy(item);
  return true;
}

// Transfer between warehouses (returns false if insufficient)
function invTransfer(item, fromLoc, toLoc, qty, date, note){
  if(!item) return false;
  if(!invRemoveAt(item, fromLoc, qty)) return false;
  invAddAt(item, toLoc, qty);
  if(!item.history) item.history = [];
  item.history.push({
    date: date || TODAY_STR,
    type: 'transfer-out',
    qty,
    location: fromLoc,
    note: `ย้ายไป ${toLoc}` + (note?` · ${note}`:''),
    by: ''
  });
  item.history.push({
    date: date || TODAY_STR,
    type: 'transfer-in',
    qty,
    location: toLoc,
    note: `ย้ายจาก ${fromLoc}` + (note?` · ${note}`:''),
    by: ''
  });
  return true;
}


