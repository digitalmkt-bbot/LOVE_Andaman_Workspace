function flBoatInitials(name){
  if(!name) return '?';
  const w = name.split(/\s+/);
  if(w.length>=2) return (w[0][0]+w[1][0]).toUpperCase();
  if(name.length>=2 && /\d/.test(name)) return (name.match(/[A-Z]/g)?.[0]||name[0]) + name.slice(-1);
  return name.slice(0,2).toUpperCase();
}
function flBoatMeta(boat){
  // Build "Speedboat · 65 PAX · 4 EN" style meta line
  if(!boat) return '';
  const parts = [];
  if(boat.type) parts.push(boat.type);
