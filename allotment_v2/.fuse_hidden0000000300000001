// ── Job Choice Modal (single vs split per asset) ──
function flOpenJobChoiceModal(inc){
  const N = (inc.damagedAssets||[]).length;
  const cntEl = document.getElementById('fl-jc-count');
  const cntEl2 = document.getElementById('fl-jc-count-2');
  if(cntEl) cntEl.textContent = N;
  if(cntEl2) cntEl2.textContent = N;
  // Preview of assets
  const _ENG=typeof FL_ENGINES!=='undefined'?FL_ENGINES:[];
  const _GB=typeof FL_GEARBOXES!=='undefined'?FL_GEARBOXES:[];
  const _PR=typeof FL_PROPELLERS!=='undefined'?FL_PROPELLERS:[];
  const labelFor=(a)=>{
    if(a.type==='engine'){const e=a.id?_ENG.find(x=>x.id===a.id):null;return e?e.serial+' · '+(e.pos||''):(a.label||'Engine');}
    if(a.type==='gearbox'){const g=a.id?_GB.find(x=>x.id===a.id):null;return g?g.serial+(g.note?' · '+g.note:''):(a.label||'Gearbox');}
    if(a.type==='propeller'){const p=a.id?_PR.find(x=>x.id===a.id):null;return p?p.serial+(p.note?' · '+p.note:''):(a.label||'Propeller');}
    return a.label||'Hull';
  };
  const preview = document.getElementById('fl-jc-assets-preview');
  if(preview){
    const list = (inc.damagedAssets||[]).map(a => `<span style="display:inline-block;background:#fff;border:1px solid #F0C8B0;padding:2px 8px;border-radius:7px;margin:2px;font-family:'DM Mono',monospace;font-size:10px">${labelFor(a)}</span>`).join('');
    preview.innerHTML = `<strong>Affected assets:</strong> ${list}`;
  }
  openModal('fl-modal-job-choice');
}

