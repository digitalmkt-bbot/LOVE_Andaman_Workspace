    dd.innerHTML = filtered.slice(0, 50).map((o, i) =>
      `<div class="bkv2-nb-dd-item${i === _bkV2AgentDDActive ? ' active' : ''}" data-label="${String(o.label).replace(/"/g,'&quot;')}" onmousedown="event.preventDefault();bkV2AgentDDPick(this.dataset.label)">
