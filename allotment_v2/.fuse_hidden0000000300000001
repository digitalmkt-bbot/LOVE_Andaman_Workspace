  const note=document.getElementById('fl-gb-note').value.trim();
  const status=flStValues[flSelSts.gb];
  const engineId=document.getElementById('fl-gb-engine-sel').value||null;
  // spareLocation logic:
  //   - status='spare' → ใช้ค่าจาก dropdown
  //   - status อื่น + ยังเป็น orphan (ไม่มี engineId) → เก็บค่าเดิมไว้ (อย่าทำลาย)
  //   - status อื่น + มี engineId (ติดเครื่อง) → set null
  let spareLocation;
  if(status==='spare'){
    spareLocation=document.getElementById('fl-gb-spare-loc')?.value||null;
  } else if(engineId){
    spareLocation=null;  // ติดเครื่องแล้ว ไม่ใช่ spare
  } else {
    // orphan แต่ status เป็น ready/fixing/broken → เก็บค่าเดิม
    const _curGb=flEditGbId?flGetGb(flEditGbId):null;
    spareLocation=_curGb?.spareLocation||null;
  }
  // new fields
  const modelSuffix=document.getElementById('fl-gb-suffix').value.trim();
  const shaftLength=document.getElementById('fl-gb-shaft').value;
  const rotation=document.getElementById('fl-gb-rotation').value;
  const gearRatio=document.getElementById('fl-gb-ratio').value;
  const oilCapacity=document.getElementById('fl-gb-oil-cap').value;
  const serviceInterval=parseInt(document.getElementById('fl-gb-svc-interval').value)||100;
  const lastServiceDate=document.getElementById('fl-gb-last-svc').value||null;
  const data={brand,model,serial,buyDate,baseHours,note,status,engineId,spareLocation,modelSuffix,shaftLength,rotation,gearRatio,oilCapacity,serviceInterval,lastServiceDate};
  if(flEditGbId){const g=flGetGb(flEditGbId);if(g)Object.assign(g,data);}
  else FL_GEARBOXES.push({id:'g'+Date.now(),...data});
  flSave();closeModal('fl-modal-gearbox');
