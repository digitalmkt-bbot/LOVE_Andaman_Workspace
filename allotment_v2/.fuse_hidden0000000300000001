function psuPersist(){
  // Read-modify-write to loveandaman_v2 (CLAUDE.md §6.2)
  try {
    const raw = localStorage.getItem('loveandaman_v2');
    const obj = raw ? JSON.parse(raw) : {};
    obj.sb_pickup_areas = SB_PICKUP_AREAS;
    obj.sb_pickup_times = SB_PICKUP_TIMES;
    obj.sb_pickup_time_profiles = SB_PICKUP_TIME_PROFILES;
    localStorage.setItem('loveandaman_v2', JSON.stringify(obj));
  } catch(e){ console.warn('[psuPersist] failed:', e); }
}

(function _psuRestore(){
  try {
    const raw = localStorage.getItem('loveandaman_v2');
    if(!raw) return;
    const obj = JSON.parse(raw);
    if(Array.isArray(obj.sb_pickup_areas) && obj.sb_pickup_areas.length){
      SB_PICKUP_AREAS = obj.sb_pickup_areas;
    }
    if(obj.sb_pickup_times && typeof obj.sb_pickup_times === 'object'){
      SB_PICKUP_TIMES = obj.sb_pickup_times;
    }
    if(Array.isArray(obj.sb_pickup_time_profiles) && obj.sb_pickup_time_profiles.length){
      SB_PICKUP_TIME_PROFILES = obj.sb_pickup_time_profiles;
      // Migrate any legacy timeGroup-keyed times → areaId-keyed (idempotent · safe to re-run)
      let migrated = 0;
      SB_PICKUP_TIME_PROFILES.forEach(p => {
        if(!p.times) return;
        const hasLegacyKey = Object.values(p.times).some(byRoute => Object.keys(byRoute||{}).some(k => !(SB_PICKUP_AREAS||[]).find(a => a.id === k)));
        if(hasLegacyKey){
          p.times = _psuExpandTimesToAreas(p.times);
          migrated++;
        }
      });
      if(migrated > 0){
        console.log('[psuRestore] expanded', migrated, 'profile(s) to per-area schema');
        try { psuPersist(); } catch(e){}
      }
    }
  } catch(e){ console.warn('[psuRestore] failed:', e); }
})();

