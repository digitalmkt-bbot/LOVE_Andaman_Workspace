function flSaveAssignment(){
  const boatId = _pierAsnBoatId;
  if(!boatId){alert('No boat selected');return;}
  const b = BOATS.find(x=>x.id===boatId);
  if(!b){alert('Boat not found');return;}
  const fromPier = document.getElementById('asn-from').value;
  const toPier = document.getElementById('asn-to').value;
  if(fromPier === toPier){alert('From และ To ต้องต่างกัน');return;}
  const type = document.getElementById('asn-type').value;
  const startDate = document.getElementById('asn-start').value;
  const endDate = document.getElementById('asn-end').value;
  if(!startDate || !endDate){alert('กรุณาระบุวันเริ่ม-วันจบ');return;}
  if(endDate < startDate){alert('วันจบต้องหลังวันเริ่ม');return;}
  const reason = document.getElementById('asn-reason').value.trim();
  const cost = parseFloat(document.getElementById('asn-cost').value) || 0;
  
  if(!b.assignments) b.assignments = [];
  const newId = 'asn_' + Date.now();
  // Determine initial status
  let status = 'planned';
  if(startDate <= TODAY_STR && endDate >= TODAY_STR) status = 'active';
  else if(endDate < TODAY_STR) status = 'completed';
  
  b.assignments.push({
    id: newId,
    type,
    fromPier,
    toPier,
    startDate,
    endDate,
    reason,
    cost,
    status,
    createdDate: TODAY_STR
  });
  
  // If permanent and active, update home pier
  if(type === 'permanent' && status === 'active'){
    b.pier = toPier;
  }
  
  // Save to localStorage
  const ls = JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  if(ls.boats){
    const bls = ls.boats.find(x=>x.id===boatId);
    if(bls){
      bls.assignments = b.assignments;
      if(type === 'permanent' && status === 'active') bls.pier = toPier;
    }
    localStorage.setItem(LS_KEY, JSON.stringify(ls));
  }
  
  closeModal('fl-modal-assignment');
  // Re-render boat detail (works in both Asset>Boats and Boat Status views)
  if(typeof flRenderBoatDetailPink === 'function') flRenderBoatDetailPink();
  if(typeof renderBoats === 'function') renderBoats();
  if(typeof renderBoatDetailPink === 'function') renderBoatDetailPink();
  flShowToast(`บันทึก Assignment: ${PIER_LABELS[fromPier]} → ${PIER_LABELS[toPier]} (${status})`);
  _pierAsnBoatId = null;
}

function flCancelAssignment(boatId, asnId){
  if(!confirm('ยกเลิก assignment นี้?')) return;
  const b = BOATS.find(x=>x.id===boatId);
  if(!b || !b.assignments) return;
  const a = b.assignments.find(x=>x.id===asnId);
  if(!a) return;
  a.status = 'cancelled';
  // Save to localStorage
  const ls = JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  if(ls.boats){
    const bls = ls.boats.find(x=>x.id===boatId);
    if(bls && bls.assignments){
      const aLs = bls.assignments.find(x=>x.id===asnId);
      if(aLs) aLs.status = 'cancelled';
    }
    localStorage.setItem(LS_KEY, JSON.stringify(ls));
  }
  if(typeof flRenderBoatDetailPink === 'function') flRenderBoatDetailPink();
  if(typeof renderBoats === 'function') renderBoats();
  if(typeof renderBoatDetailPink === 'function') renderBoatDetailPink();
  flShowToast('ยกเลิก Assignment เรียบร้อย');
}

// Auto-update assignment statuses on load (planned→active→completed)
function flAutoUpdateAssignments(){
  const today = TODAY_STR;
  let changed = false;
  BOATS.forEach(b=>{
    if(!b.assignments) return;
    b.assignments.forEach(a=>{
      if(a.status === 'cancelled') return;
      const newStatus = (a.startDate <= today && a.endDate >= today) ? 'active'
        : (a.endDate < today) ? 'completed' : 'planned';
      if(a.status !== newStatus){
        a.status = newStatus;
        changed = true;
      }
    });
  });
  if(changed){
    const ls = JSON.parse(localStorage.getItem(LS_KEY)||'{}');
    if(ls.boats){
      ls.boats.forEach(blS=>{
        const b = BOATS.find(x=>x.id===blS.id);
        if(b && b.assignments) blS.assignments = b.assignments;
      });
      localStorage.setItem(LS_KEY, JSON.stringify(ls));
    }
  }
}

