function flProjSaveModal(){
  const editId = document.getElementById('fl-proj-edit-id').value;
  const name   = document.getElementById('fl-proj-name').value.trim();
  const boatId = document.getElementById('fl-proj-boat').value;
  const type   = document.getElementById('fl-proj-type').value;
  const vendor = document.getElementById('fl-proj-vendor').value.trim();
  const planFrom = document.getElementById('fl-proj-from').value;
  const planTo   = document.getElementById('fl-proj-to').value;
  const budget = parseInt(document.getElementById('fl-proj-budget').value)||0;
  const notes  = document.getElementById('fl-proj-notes').value.trim();
  if(!name){ alert('Project name is required'); return; }
  if(!boatId){ alert('Boat is required'); return; }
  if(!planFrom){ alert('Planned start is required'); return; }
  // planTo optional · null = Open (no fixed end · ongoing)
  if(planTo && planTo<planFrom){ alert('Planned end must be after start'); return; }

  if(editId){
    const p = flProjGetById(editId);
    if(!p){ alert('Project disappeared'); return; }
    const oldBoat = p.boatId;
    const oldPlanTo = p.planTo;
    p.name=name; p.boatId=boatId; p.type=type; p.vendor=vendor;
    p.planFrom=planFrom; p.planTo=planTo||null; p.plannedBudget=budget; p.notes=notes;
    // originalPlanTo is BASELINE · never touched once set. Ensure it exists for older projects.
    if(p.originalPlanTo===undefined) p.originalPlanTo = oldPlanTo || null;
    if(!p.log) p.log=[];
    const planChanged = oldPlanTo !== p.planTo;
    p.log.push({date:TODAY_STR, text:`Project edited${oldBoat!==boatId?` · boat changed`:''}${planChanged?` · planTo ${oldPlanTo||'Open'} → ${p.planTo||'Open'}`:''}`, by:'user'});
    flSave();
    closeModal('fl-modal-project');
    flRenderProjects();
    flShowToast(`Project ${p.no} updated`);
    return;
  }
  // New
  const seq = (FL_PROJECTS.length+1).toString().padStart(3,'0');
  const yr = planFrom.slice(0,4);
  const _pt = planTo||null;
  const proj = {
    id: `proj_${yr}_${boatId}_${seq}`,
    no: `PRJ-${seq}`,
    name, boatId, type, vendor,
    planFrom, planTo: _pt,
    originalPlanTo: _pt,  // BASELINE · snapshot at creation · never edited
    actualFrom: null, actualTo: null,
    status: 'planned',
    plannedBudget: budget,
    notes,
    log: [{date:TODAY_STR, text:'+ Project created', by:'user'}],
    createdAt: TODAY_STR,
    createdBy: 'user'
  };
  FL_PROJECTS.push(proj);
  flSave();
  closeModal('fl-modal-project');
  _projTab='planned';
  flRenderProjects();
  flShowToast(`Project ${proj.no} created`);
}

// ── MJ ↔ Project linking helpers (used in flRenderMaintDetailPink) ──
function flMaintLinkProjectPick(mjId){
  const m = FL_MAINT.find(x=>x.id===mjId);
  if(!m){ alert('MJ not found'); return; }
  if(m.type!=='scheduled'){
    alert('Only Scheduled MJs can be linked to a Project.\n\nCorrective / Preventive jobs are independent.');
    return;
  }
  const candidates = (FL_PROJECTS||[]).filter(p=>p.boatId===m.boatId && p.status!=='completed');
  if(!candidates.length){ alert('No open projects for this boat. Create one from the Projects page first.'); return; }
  const list = candidates.map((p,i)=>`${i+1}. ${p.no} · ${p.name} (${p.status})`).join('\n');
  const pick = prompt(`Link ${m.no||m.id} to which project?\n\n${list}\n\nEnter number:`);
  if(!pick) return;
  const proj = candidates[parseInt(pick)-1];
  if(!proj){ alert('Invalid choice'); return; }
  m.parentProjectId = proj.id;
  if(!proj.log) proj.log=[];
  proj.log.push({date:TODAY_STR, text:`+ Linked MJ ${m.no} · ${m.title||''}`, by:'user'});
  if(!m.progressLog) m.progressLog=[];
  m.progressLog.push({date:TODAY_STR, text:`🔗 Linked to project ${proj.no} · ${proj.name}`, by:'user'});
  flSave();
  flRenderMaintDetailPink();
  flShowToast(`Linked to ${proj.no}`);
}
function flMaintUnlinkProject(mjId){
  const m = FL_MAINT.find(x=>x.id===mjId);
  if(!m||!m.parentProjectId) return;
  const proj = (FL_PROJECTS||[]).find(p=>p.id===m.parentProjectId);
  if(!confirm(`Unlink ${m.no||m.id} from project ${proj?proj.no:''}?`)) return;
  const projNo = proj?proj.no:m.parentProjectId;
  if(proj){
    if(!proj.log) proj.log=[];
    proj.log.push({date:TODAY_STR, text:`− Unlinked MJ ${m.no}`, by:'user'});
  }
  m.parentProjectId = null;
  if(!m.progressLog) m.progressLog=[];
  m.progressLog.push({date:TODAY_STR, text:`🔗 Unlinked from project ${projNo}`, by:'user'});
  flSave();
  flRenderMaintDetailPink();
  flShowToast(`Unlinked from ${projNo}`);
}

