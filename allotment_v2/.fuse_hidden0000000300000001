      Daily Report
    </div>
    <div class="nav-item" data-view="fl-incident" onclick="nav(this)" style="border-left:2px solid rgba(255,190,80,.25);padding-left:9px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/></svg>
      Job Assignment
    </div>

    <!-- ─── Work ─── -->
    <div class="nav-section" style="color:rgba(255,190,80,.45);display:flex;align-items:center;gap:6px;padding:10px 10px 4px;font-size:9px">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4.5 4.5 0 1 1 6 6L9 24l-3-3L17.7 9.3"/></svg>
      Work
    </div>
    <div class="nav-item" data-view="fl-projects" onclick="nav(this)" style="border-left:2px solid rgba(255,190,80,.25);padding-left:9px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l7-3 7 3z"/><path d="M9 9h6M9 13h4"/></svg>
