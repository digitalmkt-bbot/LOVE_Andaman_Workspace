  document.getElementById('inv-edit-id').value=id;
  document.getElementById('inv-edit-name').value=item.name||'';
  document.getElementById('inv-edit-partno').value=item.partNo||'';
  document.getElementById('inv-edit-cat').value=item.category||'general';
  document.getElementById('inv-edit-supplier').value=item.supplier||'';
  document.getElementById('inv-edit-location').value=item.location||'';
  document.getElementById('inv-edit-qty').value=item.qty||0;
  document.getElementById('inv-edit-unit').value=item.unit||'ชิ้น';
  document.getElementById('inv-edit-min').value=item.minQty||0;
  document.getElementById('inv-edit-cost').value=item.cost||0;
  // Detect engine model from note (BF250D/BF250A/DF250W/DF325A) — split out for dropdown
  const fullNote=item.note||'';
  const engineMatch=fullNote.match(/^(BF250D|BF250A|DF250W|DF325A)\b/i);
  const detectedEngine=engineMatch?engineMatch[1].toUpperCase():'';
  const remainingNote=detectedEngine?fullNote.replace(/^(BF250D|BF250A|DF250W|DF325A)\s*·?\s*/i,'').trim():fullNote;
  document.getElementById('inv-edit-engine').value=detectedEngine;
  document.getElementById('inv-edit-note').value=remainingNote;
  document.getElementById('inv-edit-warn').style.display='none';
  // Render audit history (filter to 'edit' + 'receive' types)
  const hist=(item.history||[]).slice().reverse(); // newest first
  const histEl=document.getElementById('inv-edit-history');
  if(hist.length===0){
    histEl.innerHTML='<div style="color:#aaa;font-style:italic;font-size:11px;text-align:center;padding:8px">ยังไม่มีประวัติการแก้ไข</div>';
  } else {
    histEl.innerHTML='<div style="font-weight:600;color:#666;margin-bottom:6px;font-size:10px;text-transform:uppercase;letter-spacing:.05em">ประวัติการเปลี่ยนแปลง</div>'+
      hist.slice(0,10).map(h=>{
        const dateStr=h.date||'';
        if(h.type==='edit' && h.changes){
          const changesHtml=h.changes.map(ch=>`<div style="margin-left:8px;font-size:10.5px;color:#666"><strong>${ch.field}:</strong> <span style="color:#A32D2D;text-decoration:line-through">${ch.from||'(ว่าง)'}</span> → <span style="color:#0F6E56">${ch.to||'(ว่าง)'}</span></div>`).join('');
          return `<div style="margin-bottom:6px;padding:6px 8px;background:#FBFAF7;border-radius:6px"><div style="display:flex;justify-content:space-between;font-size:10.5px;font-weight:500"><span>📝 แก้ไข</span><span style="color:#aaa;font-family:'DM Mono',monospace">${dateStr}</span></div>${changesHtml}${h.note?`<div style="margin-top:3px;font-size:10px;font-style:italic;color:#888">"${h.note}"</div>`:''}</div>`;
        } else if(h.type==='receive'){
          return `<div style="margin-bottom:6px;padding:6px 8px;background:#F1F5EE;border-radius:6px;font-size:10.5px"><div style="display:flex;justify-content:space-between"><span>📥 รับของ +${h.qty}</span><span style="color:#aaa;font-family:'DM Mono',monospace">${dateStr}</span></div>${h.note?`<div style="font-size:10px;color:#666;margin-top:2px">${h.note}</div>`:''}</div>`;
        } else {
          return `<div style="margin-bottom:4px;font-size:10.5px;color:#888">${h.type||''} ${dateStr}</div>`;
        }
      }).join('')+
      (hist.length>10?`<div style="text-align:center;color:#aaa;font-size:10px;margin-top:4px">+${hist.length-10} more entries</div>`:'');
  }
  openModal('fl-modal-inv-edit');
