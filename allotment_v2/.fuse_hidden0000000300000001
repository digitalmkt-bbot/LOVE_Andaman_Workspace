// HELPERS
// ══════════════════════════════════════
function getCurStatus(boat,ds){
  const sorted=[...boat.log].sort((a,b)=>b.from.localeCompare(a.from));
  return sorted.find(e=>e.from<=ds&&(!e.to||e.to>=ds))||{s:'available',loc:'-'};
}
function getBoat(id){return BOATS.find(b=>b.id===id);}

