// ── Lifecycle actions ──
function flProjStart(id){
  const p = flProjGetById(id);
  if(!p) return;
  if(p.status!=='planned'){ flShowToast('Project already started'); return; }
  p.status='inprogress';
  p.actualFrom = p.actualFrom || TODAY_STR;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:'▶ Project started · boat status → unavailable', by:'user'});
  // Push boat log entry: unavailable
  const boat = BOATS.find(b=>b.id===p.boatId);
  if(boat){
    if(!boat.log) boat.log=[];
    boat.log.push({
      id:'sl_'+Date.now(),
      s:'unavailable',
      from: TODAY_STR,
      to: null,
      loc: p.vendor||'',
      note: `Project ${p.no} · ${p.name}`,
      reason: p.type==='drydock'?'dry_dock':'overhaul',
      projectId: p.id
    });
  }
  flSave(); save();
  flRenderProjects();
  flShowToast('Project started · boat removed from operation');
}

function flProjHold(id){
  const p = flProjGetById(id); if(!p) return;
  if(p.status!=='inprogress'){ flShowToast('Only In Progress projects can be put on hold'); return; }
  const reason = prompt('Reason for holding (e.g. รออะไหล่ · vendor ลา · weather):', p.holdReason||'');
  if(reason===null) return; // cancel
  if(!reason.trim()){ alert('Reason required'); return; }
  p.status = 'on_hold';
  p.holdReason = reason.trim();
  p.holdSince = TODAY_STR;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`⏸ Project on hold · ${reason.trim()}`, by:'user'});
  flSave();
  flRenderProjects();
  flShowToast('Project paused');
}
function flProjResume(id){
  const p = flProjGetById(id); if(!p) return;
  if(p.status!=='on_hold'){ flShowToast('Only on-hold projects can be resumed'); return; }
  p.status = 'inprogress';
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`▶ Resumed${p.holdReason?` (was on hold: ${p.holdReason})`:''}`, by:'user'});
  // Clear hold meta (keep history in log)
  p.holdReason = null;
  p.holdSince = null;
  flSave();
  flRenderProjects();
  flShowToast('Project resumed');
}
function flProjCancel(id){
  const p = flProjGetById(id); if(!p) return;
  if(p.status==='completed'){ flShowToast('Completed projects cannot be cancelled'); return; }
  if(p.status==='cancelled'){ flShowToast('Already cancelled'); return; }
  const reason = prompt('Reason for cancelling:', '');
  if(reason===null) return;
  if(!reason.trim()){ alert('Reason required'); return; }
  const kids = flProjChildMJs(p.id);
  const openKids = kids.filter(m=>m.status!=='done');
  const wasInProgress = (p.status==='inprogress' || p.status==='on_hold');
  let unlinkMJs = false;
  if(openKids.length){
    unlinkMJs = confirm(`This project has ${openKids.length} open child MJ(s).\n\nUnlink them so they continue as standalone jobs?\n\n(OK = unlink · Cancel = keep linked but project will be cancelled)`);
  }
  if(unlinkMJs){
    openKids.forEach(m=>{
      m.parentProjectId = null;
      if(!m.progressLog) m.progressLog=[];
      m.progressLog.push({date:TODAY_STR, text:`Unlinked from cancelled project ${p.no}`, by:'user'});
    });
  }
  p.status = 'cancelled';
  p.cancelReason = reason.trim();
  p.cancelledOn = TODAY_STR;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`✕ Project cancelled · ${reason.trim()}${unlinkMJs?` · ${openKids.length} MJ unlinked`:''}`, by:'user'});
  // If boat was in unavailable state for this project, close that log entry + return boat to available
  if(wasInProgress){
    const boat = BOATS.find(b=>b.id===p.boatId);
    if(boat && boat.log){
      boat.log.forEach(e=>{
        if(e.projectId===p.id && !e.to){
          e.to = TODAY_STR;
          e.note = (e.note||'')+' · project cancelled';
        }
      });
      boat.log.push({
        id:'sl_'+Date.now(),
        s:'available',
        from: TODAY_STR,
        to: null,
        note: `Returned · Project ${p.no} cancelled`
      });
    }
    save();
  }
  flSave();
  flRenderProjects();
  flShowToast(`Project ${p.no} cancelled`);
}
function flProjReopen(id){
  const p = flProjGetById(id); if(!p) return;
  if(p.status!=='cancelled'){ flShowToast('Only cancelled projects can be reopened'); return; }
  p.status = 'planned';
  p.cancelReason = null;
  p.cancelledOn = null;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`↻ Reopened (back to planned)`, by:'user'});
  flSave();
  flRenderProjects();
  flShowToast('Project reopened · status = Scheduled');
}

function flProjMarkComplete(id){
  const p = flProjGetById(id);
  if(!p) return;
  if(p.status==='completed'){ flShowToast('Already completed'); return; }
  const kids = flProjChildMJs(p.id);
  const openKids = kids.filter(m=>m.status!=='done');
  const msg = openKids.length
    ? `Mark project complete?\n\nThis will:\n- Close ${openKids.length} open child MJ(s)\n- Set boat status → available\n- Set project status → completed\n\nContinue?`
    : `Mark project complete?\n\nThis will set boat status → available and project status → completed.`;
  if(!confirm(msg)) return;
  // Cascade close child MJs
  openKids.forEach(m=>{
    m.status='done';
    m.endDate = m.endDate || TODAY_STR;
    if(!m.progressLog) m.progressLog=[];
    m.progressLog.push({date:TODAY_STR, text:`✓ Auto-closed by parent project ${p.no} mark-complete`, by:'cascade'});
  });
  // Update project
  p.status='completed';
  p.actualTo = p.actualTo || TODAY_STR;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`✓ Project completed · cascade closed ${openKids.length} MJ(s) · boat → available`, by:'user'});
  // Update boat log: close the unavailable entry + add available entry
  const boat = BOATS.find(b=>b.id===p.boatId);
  if(boat && boat.log){
    boat.log.forEach(e=>{
      if(e.projectId===p.id && !e.to){
        e.to = TODAY_STR;
      }
    });
    boat.log.push({
      id:'sl_'+Date.now(),
      s:'available',
      from: TODAY_STR,
      to: null,
      note: `Returned from Project ${p.no}`
    });
  }
  flSave(); save();
  flRenderProjects();
  flShowToast(`Project ${p.no} completed · ${openKids.length} MJ auto-closed · boat returned`);
}

