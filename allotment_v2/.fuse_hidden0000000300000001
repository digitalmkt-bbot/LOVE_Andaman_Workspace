      </div>` : '';

    // ── Rescheduled-away bookings · faint ghost rows kept on the original date (weather reschedule) ──
    const _ghosts = wxClosed ? (SB_BOOKINGS||[]).filter(b=> b.weatherResolve && b.weatherResolve.event===(rid+'|'+date) && b.weatherResolve.outcome==='reschedule' && b.weatherResolve.newDate) : [];
