            <td class="t2-req">
              ${reqBadges.length?`<div class="t2-rbwrap">${reqBadges.join('')}</div>`:''}
              ${allergTxt?`<div class="t2-allerg">Allergy: ${esc(allergTxt)}</div>`:''}
              ${_note?`<div class="t2-note">${esc(_note)}</div>`:''}
