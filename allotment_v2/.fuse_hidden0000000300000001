function insightIcon(key, size, color){
  const s = size || 16;
  const svg = INSIGHT_ICONS[key] || INSIGHT_ICONS.circle_filled;
  return svg.replace('<svg ', `<svg width="${s}" height="${s}" style="color:${color||'currentColor'};flex-shrink:0" `);
