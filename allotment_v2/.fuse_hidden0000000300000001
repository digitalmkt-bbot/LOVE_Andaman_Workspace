function flProjStatusPillStyle(status, P){
  P = P || PROJ_PALETTE;
  if(status==='completed') return {bg:P.mintSoft, color:P.mintInk, label:'COMPLETED'};
  if(status==='inprogress') return {bg:P.amberSoft, color:P.amber, label:'IN PROGRESS'};
  if(status==='on_hold') return {bg:'#FFF4E1', color:'#996A14', label:'ON HOLD'};
  if(status==='cancelled') return {bg:P.redSoft, color:P.red, label:'CANCELLED'};
  return {bg:P.blueSoft, color:P.blue, label:'SCHEDULED'};
}

function flProjRowCard(p){
  const P = PROJ_PALETTE;
  const kids = flProjChildMJs(p.id);
  const openKids = kids.filter(m=>m.status!=='done').length;
  const cost = flProjCalcCost(p.id);
  const boatName = flProjBoatName(p);
  const sp = flProjStatusPillStyle(p.status, P);
  const statusPill = `<span style="background:${sp.bg};color:${sp.color};padding:3px 10px;border-radius:12px;font-size:10px;font-weight:700">${sp.label}</span>`;
  const health = flProjHealth(p);
  const healthPill = `<span style="background:${health.bg};color:${health.color};padding:3px 8px;border-radius:10px;font-size:9px;font-weight:700" title="Health ${health.score}/100">${health.label}</span>`;
  const budget = p.plannedBudget||0;
  const variance = cost - budget;
  const varianceColor = budget ? (cost>budget?P.red:P.mintInk) : P.ink3;
  const variancePct = budget ? Math.round(variance/budget*100) : 0;
  // Phase chip
  const phases = flProjPhasesFor(p);
  const cIdx = flProjCurrentPhaseIdx(p);
  const phaseChip = (cIdx>=0 && phases[cIdx]) ? `<span style="background:${P.bg};color:${P.ink2};padding:2px 8px;border-radius:8px;font-size:9px;font-weight:600;letter-spacing:.02em">Phase ${cIdx+1}/${phases.length} · ${phases[cIdx].label}</span>` : '';
  const dur = (function(){
    if(!p.planFrom) return '—';
    const a = new Date(p.planFrom);
    const b = new Date(p.planTo||p.actualTo||TODAY_STR);
    const days = Math.max(1, Math.ceil((b-a)/86400000));
    return `${days}d`;
  })();
  const typeBadge = (function(){
    const map = {drydock:'DD', overhaul:'OV', refit:'RF', scheduled:'SC', other:'PR'};
    return map[p.type]||'PR';
  })();
  // Icon color by type
  const typeColor = (function(){
    if(p.type==='drydock')  return {bg:'#EEF3FF', ink:P.blue};
    if(p.type==='overhaul') return {bg:'#FFF7E6', ink:P.amberInk};
    if(p.type==='refit')    return {bg:'#F3E8FF', ink:P.purple};
    if(p.type==='scheduled')return {bg:P.mintSoft, ink:P.mintInk};
    return {bg:P.bg, ink:P.ink2};
  })();
  return `
    <div onclick="flProjOpen('${p.id}')" style="background:white;border:1px solid ${P.line};border-radius:16px;padding:16px 18px;cursor:pointer;display:grid;grid-template-columns:auto 2.2fr 1.3fr 0.9fr 0.9fr 1.1fr auto;gap:14px;align-items:center;transition:all .15s;box-shadow:${P.shadow}" onmouseover="this.style.boxShadow='${P.shadowLg}';this.style.transform='translateY(-1px)'" onmouseout="this.style.boxShadow='${P.shadow}';this.style.transform='translateY(0)'">
      <div style="width:44px;height:44px;border-radius:12px;background:${typeColor.bg};color:${typeColor.ink};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;letter-spacing:.04em">${typeBadge}</div>
      <div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:13px;font-weight:700;color:${P.navy}">${p.name}</span>
          ${healthPill}
        </div>
        <div style="font-size:11px;color:${P.ink3};margin-top:2px;display:flex;align-items:center;gap:6px;flex-wrap:wrap">
          <span>${p.no} · ${boatName} · ${p.vendor||'—'}</span>
          ${phaseChip}
        </div>
      </div>
      <div>
        <div style="font-size:10px;color:${P.ink4};text-transform:uppercase;letter-spacing:.6px">Schedule</div>
        <div style="font-size:11px;color:${P.ink2};margin-top:2px;font-variant-numeric:tabular-nums">${p.planFrom||'—'} → ${p.planTo||`<span style="color:${P.blue};font-weight:600">Open</span>`}</div>
        <div style="font-size:10px;color:${P.ink3}">${p.planTo?dur:'open-ended'} · ${kids.length} MJ${openKids?` (${openKids} open)`:''}</div>
      </div>
      <div>
        <div style="font-size:10px;color:${P.ink4};text-transform:uppercase;letter-spacing:.6px">Budget</div>
        <div style="font-size:13px;color:${P.navy};font-weight:700;margin-top:1px;font-variant-numeric:tabular-nums">${budget?`฿${(budget/1000).toFixed(0)}K`:'—'}</div>
      </div>
      <div>
        <div style="font-size:10px;color:${P.ink4};text-transform:uppercase;letter-spacing:.6px">Actual</div>
        <div style="font-size:13px;color:${P.navy};font-weight:700;margin-top:1px;font-variant-numeric:tabular-nums">${cost?`฿${(cost/1000).toFixed(0)}K`:'฿0'}</div>
      </div>
      <div>
        <div style="font-size:10px;color:${P.ink4};text-transform:uppercase;letter-spacing:.6px">Variance</div>
        <div style="font-size:13px;color:${varianceColor};font-weight:700;margin-top:1px;font-variant-numeric:tabular-nums">${budget?`${variance>0?'+':''}฿${Math.abs(variance/1000).toFixed(0)}K`:'—'}</div>
        <div style="font-size:10px;color:${varianceColor}">${budget?`${variance>0?'+':''}${variancePct}%`:'no budget'}</div>
      </div>
      <div>${statusPill}</div>
    </div>`;
}

