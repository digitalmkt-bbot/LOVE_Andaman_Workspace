  const doneJobs=FL_MAINT.filter(m=>m.boatId===b.id&&m.status==='done').sort((a,b)=>(b.endDate||b.startDate||'').localeCompare(a.endDate||a.startDate||''));
  const lastServiceLabel=doneJobs.length?(()=>{
