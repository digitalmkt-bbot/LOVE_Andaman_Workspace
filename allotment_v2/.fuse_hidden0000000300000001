function flSaveGearbox(){
  const brand=document.getElementById('fl-gb-brand').value;
  const model=document.getElementById('fl-gb-model').value.trim();
  const serial=document.getElementById('fl-gb-serial').value.trim();
  const buyDate=document.getElementById('fl-gb-buydate').value||null;
