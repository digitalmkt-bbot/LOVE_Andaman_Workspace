#view-agents .agi-info-val.muted{color:var(--fd-ink-soft);font-weight:400}
#view-agents .agi-info-val.multi{font-size:12px;font-weight:500;line-height:1.5}
#view-agents .agi-info-sub{font-size:10px;color:var(--fd-ink-soft);font-weight:400;margin-top:2px;font-variant-numeric:tabular-nums;letter-spacing:.02em}
/* ── Detail panel · sharper section titles + crisper info cells (label/value contrast) ── */
#view-agents .agi-sect-ttl{font-size:14px;font-weight:800;letter-spacing:-.01em}
#view-agents .agi-sect-ttl::before{height:15px;width:4px}
#view-agents .agi-sect-desc{font-size:11px;color:var(--fd-ink-faint)}
#view-agents .agi-info-card{background:#fff;border:1px solid var(--fd-line-soft);box-shadow:0 1px 2px rgba(15,23,42,.03);padding:12px 15px}
#view-agents .agi-info-lbl{font-size:9.5px;font-weight:700;letter-spacing:.07em;color:#98a1ab}
#view-agents .agi-info-val{font-weight:600;color:var(--fd-ink);letter-spacing:-.008em}
