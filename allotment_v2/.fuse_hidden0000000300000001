      ${pill((m.vegan||0)>0, m.vegan||0, 'Vegan', '#1f8a4a', 'vegan', "bkV2ToggleMealOn('vegan',this.checked)", "bkV2SetMealQty('vegan',this.value)")}
      ${pill((m.halal||0)>0, m.halal||0, 'Halal', '#8a5b1f', 'halal', "bkV2ToggleMealOn('halal',this.checked)", "bkV2SetMealQty('halal',this.value)")}
