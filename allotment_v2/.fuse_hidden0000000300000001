    // Pick majority supplier among selected items
    if(suppliers.length === 1){
      _supBulk.value = suppliers[0];
    } else if(suppliers.length > 1){
      // Count items per supplier, pick majority
      const counts = {};
      selectedItems.forEach(it=>{ if(it.supplier) counts[it.supplier]=(counts[it.supplier]||0)+1; });
      const top = Object.entries(counts).sort((a,b)=>b[1]-a[1])[0];
      if(top) _supBulk.value = top[0];
    }
  }
  openModal('fl-modal-memo');
}

