function flMaintAddAsset(jobId,type){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m)return;
  if(!m.assets)m.assets=[];
  let label='',detail='',engId=null,gbId=null,propId=null;
  const dtlEl=document.getElementById(`asset-dtl-${jobId}-${type}`);
  detail=dtlEl?.value.trim()||'';

  if(type==='engine'){
    const sel=document.getElementById(`asset-sel-${jobId}-${type}`);
    const eid=sel?.value;if(!eid){alert('กรุณาเลือกเครื่องยนต์');return;}
    const eng=flGetEng(eid);if(!eng)return;
    engId=eng.id;
    const curH=flEngHours(eng.id);
    label=`${eng.serial} · ${eng.pos||'Spare'}`;
    detail=detail||`${eng.brand} ${eng.model}`;
    if(!eng.log)eng.log=[];
    eng.log.push({date:TODAY_STR,type:'status',desc:`ถอดเพื่อซ่อม · Job ${m.no} · ${getBoat(eng.boatId)?.name||'?'} (${eng.pos})`,hours:curH});
    eng.status='fixing';
    flPushLog(m.id,`🔧 ถอดเครื่องยนต์ ${eng.serial} (${eng.pos}) → Fixing · ${curH}h`);
    if(!m.progressLog)m.progressLog=[];
    m.progressLog.push({date:TODAY_STR,text:`🔧 ถอดเครื่องยนต์ ${eng.serial} (${eng.pos}) → Fixing · เครื่อง ${curH}h`,by:'ระบบ'});

  } else {
    const sel=document.getElementById(`asset-sel-${jobId}-${type}`);
    const lblEl=document.getElementById(`asset-lbl-${jobId}-${type}`);
    if(sel){
      const selId=sel.value;if(!selId){alert('กรุณาเลือก');return;}
      if(type==='gearbox'){
        const gb=FL_GEARBOXES.find(g=>g.id===selId);if(!gb)return;
        gbId=gb.id;
        const linkedEng=flGetEng(gb.engineId);
        const removeH=linkedEng?flEngHours(linkedEng.id):0;
        const usedH=Math.max(0,removeH-(gb.installHours||gb.baseHours||0));
        label=gb.serial;
        detail=detail||`${gb.brand} ${gb.model}${gb.shaftLength?' · '+gb.shaftLength:''}${gb.rotation?' · '+gb.rotation:''}`;
        if(!gb.log)gb.log=[];
        gb.log.push({date:TODAY_STR,type:'remove',
          desc:`ถอดเพื่อซ่อม · Job ${m.no} · ${getBoat(m.boatId)?.name||''}`,
          engineHours:removeH,usedHours:usedH});
        gb.status='fixing';
        flPushLog(m.id,`⚙️ ถอดเกียร์ ${gb.serial} → Fixing · เครื่อง ${removeH}h · เกียร์ใช้งาน ${usedH}h`);
        if(!m.progressLog)m.progressLog=[];
        m.progressLog.push({date:TODAY_STR,text:`⚙️ ถอดเกียร์ ${gb.serial} · เครื่อง ${removeH}h · เกียร์ ${usedH}h`,by:'ระบบ'});

      } else if(type==='propeller'){
        const p=FL_PROPELLERS.find(x=>x.id===selId);if(!p)return;
        propId=p.id;
        label=p.serial;detail=detail||`${p.brand} ${p.size} · ${p.blades} blade · ${p.material}`;
        if(!p.log)p.log=[];
        p.log.push({date:TODAY_STR,type:'remove',desc:`ถอดเพื่อซ่อม · Job ${m.no}`});
        p.status='fixing';
        flPushLog(m.id,`🌀 ถอดใบจักร ${p.serial} → Fixing`);
        if(!m.progressLog)m.progressLog=[];
        m.progressLog.push({date:TODAY_STR,text:`🌀 ถอดใบจักร ${p.serial} → Fixing`,by:'ระบบ'});
      }
    } else {
      label=lblEl?.value.trim()||'';
      if(!label){alert('กรุณากรอกชื่อ/รายละเอียด');return;}
      const typeLabel={gearbox:'เกียร์',propeller:'ใบจักร',hull:'ตัวเรือ'}[type]||type;
      flPushLog(m.id,`+ เพิ่ม ${typeLabel}: ${label}${detail?' — '+detail:''}`);
      if(!m.progressLog)m.progressLog=[];
      m.progressLog.push({date:TODAY_STR,text:`+ เพิ่ม ${typeLabel}: ${label}${detail?' — '+detail:''}`,by:'ระบบ'});
    }
  }

  m.assets.push({type,label,detail,engId,gbId,propId,status:'fixing',addDate:TODAY_STR});
  flSave();flRenderMaintDetail(jobId);flRenderEngList&&flRenderEngList();
}

function flMaintRemoveAsset(jobId,idx){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m||!m.assets)return;
  const a=m.assets[idx];
  if(a.engId){
    const eng=flGetEng(a.engId);
    if(eng){if(!eng.log)eng.log=[];eng.log.push({date:TODAY_STR,type:'status',desc:`ถอดออกจาก Job ${m.no}`,hours:flEngHours(eng.id)});}
    flPushLog(m.id,`− ลบ asset: ${a.label} ออกจาก Job`);
  }
  m.assets.splice(idx,1);
  flSave();flRenderMaintDetail(jobId);
