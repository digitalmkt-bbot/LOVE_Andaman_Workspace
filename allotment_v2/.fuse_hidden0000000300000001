function flMaintClose(id,outcome,note,awaitInvoice){
  const m=FL_MAINT.find(x=>x.id===id);if(!m)return;
  outcome=outcome||'success'; note=note||'';
  m.status='done';m.endDate=TODAY_STR;
  m.outcome=outcome;
  if(note) m.closeNote=note;
  if(awaitInvoice) m.awaitingInvoice = true;
  const b=getBoat(m.boatId);
  const totalCost=flMaintCalcCost(id);

  // Outcome metadata
  const OUTCOME={
    success:    {label:'สำเร็จ',         engStatus:'ready',  gbStatus:'ready',  prStatus:'active',     boatStatus:'available', icon:'✓', tag:''},
    limited:    {label:'ใช้งานจำกัด',     engStatus:'limited',gbStatus:'limited',prStatus:'limited',    boatStatus:'available', icon:'⚠', tag:' · ใช้งานจำกัด'},
    rework:     {label:'ต้องซ่อมซ้ำ',     engStatus:'fixing', gbStatus:'fixing', prStatus:'fixing',     boatStatus:'fixing',    icon:'↻', tag:' · ต้องซ่อมซ้ำ'},
    decommission:{label:'ปลดระวาง',       engStatus:'broken', gbStatus:'broken', prStatus:'broken',     boatStatus:'fixing',    icon:'✕', tag:' · ปลดระวาง'},
    cancelled:  {label:'ยกเลิก',          engStatus:null,     gbStatus:null,     prStatus:null,         boatStatus:'available', icon:'⊘', tag:' · ยกเลิก Job'}
  };
  const out=OUTCOME[outcome]||OUTCOME.success;
  const noteTxt=note?` · "${note}"`:'';

  // restore boat status + log repair to boat history
  if(b){
    const cur=getCurStatus(b,TODAY_STR);
    // Auto-close any open log entries (e.g. fixing from Start Job) before pushing new entry
    if(typeof autoClosePrevLog==='function') autoClosePrevLog(b,TODAY_STR);
    
    // Check if there are OTHER active MJs for this boat (still inprogress)
    const otherActiveMjs = FL_MAINT.filter(x => 
      x.id !== m.id && 
      x.boatId === b.id && 
      x.status === 'inprogress'
    );
    
    let finalBoatStatus = out.boatStatus;
    let finalNote = `ปิด Job ${m.no}${out.tag}`;
    let finalReason = '';
    let skipBoatLog = false;  // flag: ถ้า MJ นี้ไม่เคยแตะ boat status → ไม่ต้อง log การเปลี่ยน

    // ─── เคารพเจตนาเดิมของ MJ ───
    // ถ้า MJ มี setFixing:false (เรือยังใช้งานได้ระหว่างซ่อม) → ตอนปิดก็ไม่ควร force boat status
    // กรณีเดียวที่จะ override คือ outcome=decommission (เรือเสียหายถาวร)
    if(m.setFixing===false && outcome!=='decommission'){
      // เก็บ boat status ปัจจุบันไว้ (ไม่ override)
      finalBoatStatus = cur.s || 'available';
      finalReason = cur.reason || '';
      // ถ้า status ปัจจุบันเหมือนกับ status ใหม่ → ไม่ต้อง log ใหม่ (เพราะไม่เปลี่ยน)
      if(cur.s === finalBoatStatus){
        skipBoatLog = true;
      }
      finalNote = `ปิด Job ${m.no}${out.tag} · ไม่แตะสถานะเรือ (Job นี้ทำขนานกับการใช้งาน)`;
    } else if(otherActiveMjs.length > 0){
      // Pick the "strictest" status among remaining MJs
      // unavailable > fixing > available
      const others = otherActiveMjs.map(mj => ({
        status: mj.boatStatus || (mj.setFixing===false ? 'available' : 'fixing'),
        reason: mj.boatStatusReason || '',
        no: mj.no, mj: mj
      }));
      // Priority: unavailable > fixing > available
      const hasUnavail = others.find(o => o.status === 'unavailable');
      const hasFixing = others.find(o => o.status === 'fixing');
      const carryOver = hasUnavail || hasFixing || others[0];
      finalBoatStatus = carryOver.status;
      finalReason = carryOver.reason;
      finalNote = `ปิด Job ${m.no}${out.tag} · ยังคงสถานะ ${finalBoatStatus==='fixing'?'Fixing':finalBoatStatus==='unavailable'?'Unavailable':'Available'} จาก Job ${carryOver.no}`;
    }
    
    if(!skipBoatLog){
      b.log.push({
        id:'sl'+Date.now(),
        s:finalBoatStatus,
        from:TODAY_STR, to:null,
        loc:cur.loc||'',
        note:finalNote,
        reason:finalReason
      });
    }
    if(!b.repairHistory) b.repairHistory=[];
    b.repairHistory.push({
      date:TODAY_STR,jobNo:m.no,title:m.title,detail:m.detail||'',
      type:m.type,location:m.location||'',cost:totalCost,
      assets:(m.assets||[]).map(a=>a.label),startDate:m.startDate,endDate:TODAY_STR,
      outcome,closeNote:note
    });
  }

  // log repair details to each asset (apply status based on outcome)
  (m.assets||[]).forEach(a=>{
    if(a.type==='engine'&&a.engId){
      const eng=flGetEng(a.engId);
      if(eng){
        if(!eng.log)eng.log=[];
        eng.log.push({date:TODAY_STR,type:outcome==='cancelled'?'service-cancelled':outcome==='rework'?'rework':'repair',
          desc:`${out.icon} ${out.label} · ${m.no} · ${m.title}${m.location?' @ '+m.location:''}${noteTxt}`,
          detail:m.detail||'',cost:totalCost,hours:flEngHours(eng.id),outcome});
        if(out.engStatus) eng.status=out.engStatus;
        else if(eng.status==='fixing') eng.status='ready';
      }
    }
    if(a.type==='gearbox'&&a.gbId){
      const gb=FL_GEARBOXES.find(g=>g.id===a.gbId);
      if(gb){
        const linkedEng=flGetEng(gb.engineId);
        const installH=linkedEng?flEngHours(linkedEng.id):0;
        if(!gb.log)gb.log=[];
        gb.log.push({date:TODAY_STR,type:outcome==='cancelled'?'service-cancelled':outcome==='rework'?'rework':'install',
          desc:`${out.icon} ${out.label} · Job ${m.no}${noteTxt}`,
          engineHours:installH,outcome});
        if(outcome==='success'||outcome==='limited') gb.installHours=installH;
        if(out.gbStatus) gb.status=out.gbStatus;
        else if(gb.status==='fixing') gb.status='ready';
      }
    }
    if(a.type==='propeller'&&a.propId){
      const p=FL_PROPELLERS.find(x=>x.id===a.propId);
      if(p){
        if(!p.log)p.log=[];
        p.log.push({date:TODAY_STR,type:outcome==='cancelled'?'service-cancelled':outcome==='rework'?'rework':'install',
          desc:`${out.icon} ${out.label} · Job ${m.no}${noteTxt}`,outcome});
        if(out.prStatus) p.status=out.prStatus;
        else if(p.status==='fixing') p.status='active';
      }
    }
    if(a.type==='gearbox'&&!a.gbId){
      const gb=FL_GEARBOXES.find(g=>g.serial===a.label||a.label.startsWith(g.serial));
      if(gb){
        if(!gb.log)gb.log=[];
        gb.log.push({date:TODAY_STR,type:'repair',desc:`${out.icon} ${out.label} · ${m.no} · ${m.title}${noteTxt}`,cost:totalCost,outcome});
        if(out.gbStatus) gb.status=out.gbStatus;
        else if(gb.status==='fixing') gb.status='ready';
      }
    }
  });

  flPushLog(m.id,`${out.icon} ปิด Job ${m.no} · ${out.label} · ฿${totalCost.toLocaleString()}${noteTxt}${b?' · '+b.name+' = '+out.boatStatus:''}`);
  if(!m.progressLog)m.progressLog=[];
  m.progressLog.push({date:TODAY_STR,text:`${out.icon} ปิด Job · ${out.label} · ฿${totalCost.toLocaleString()}${noteTxt}${b?' · '+b.name+' = '+out.boatStatus:''}`,by:'ระบบ'});

  // ── Auto-close linked INC ถ้า MJ ทั้งหมดของ INC นั้น done แล้ว (ยกเว้น outcome=cancelled) ──
  if(m.incidentId && outcome !== 'cancelled'){
    const inc = FL_INCIDENTS.find(i=>i.id===m.incidentId);
    if(inc && inc.status !== 'closed'){
      const allLinkedMjs = FL_MAINT.filter(x => x.incidentId === inc.id);
      const allDone = allLinkedMjs.every(x => x.status === 'done' || x.id === m.id);
      if(allDone){
        inc.status = 'closed';
        inc.closedDate = TODAY_STR;
        if(!Array.isArray(inc.progressLog)) inc.progressLog = [];
        inc.progressLog.push({
          date:TODAY_STR,
          text:`✓ ปิด Incident · MJ ${m.no} ${out.label}${noteTxt}`,
          by:'ระบบ'
        });
      }
    }
  }

  flSave();flRenderMaint();renderBoats();flRenderEngList&&flRenderEngList();

  // ─── Auto-prompt to retire boat on decommission ───
  if(outcome==='decommission'&&b&&!b.retired){
    setTimeout(()=>{
      if(confirm(`เรือ ${b.name} ถูกปิด Job ด้วยสถานะ "ปลดระวาง"\n\nต้องการ Mark เรือเป็น Retired (ออกจากระบบใช้งาน) หรือไม่?\n\n• เรือจะไม่แสดงใน Boat Status calendar\n• ไม่นับใน Fleet Dashboard\n• ประวัติยังเก็บไว้ดูย้อนหลังได้\n\n(กด OK เพื่อปลดระวางเรือ · Cancel เพื่อเก็บไว้)`)){
        flRetireBoat(b.id,note);
      }
    },300);
  }
}

