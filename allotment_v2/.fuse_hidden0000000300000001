// ════ Data Integrity Helpers (Layer 2 + Layer 4) ════
// Layer 2: ตรวจเลขรันซ้ำก่อน push · throw ถ้าซ้ำ (กัน silent overwrite)
function flAssertUniqueNo(arr, no, type){
  if(!Array.isArray(arr) || !no) return;
  const dup = arr.find(x => x.no === no);
  if(dup){
    const msg = `[Duplicate ${type}] เลข ${no} มีอยู่แล้วในระบบ (id เดิม: ${dup.id||'?'}) · กรุณาลองใหม่`;
    console.error(msg, 'existing:', dup);
    alert(msg);
    throw new Error(msg);
  }
}

// Layer 4: ตรวจ data integrity หลัง load · warn ใน console ถ้ามี anomaly
function flValidateDataIntegrity(){
  const checks = [
    {arr: typeof FL_MAINT     !== 'undefined' ? FL_MAINT     : [], type: 'MJ',  prefix:'MJ-'},
    {arr: typeof FL_MEMOS     !== 'undefined' ? FL_MEMOS     : [], type: 'MO',  prefix:'MO-'},
    {arr: typeof FL_INCIDENTS !== 'undefined' ? FL_INCIDENTS : [], type: 'INC', prefix:'INC-'}
  ];
  const allWarnings = [];
  checks.forEach(({arr, type, prefix})=>{
    const seenNos = new Map();
    const seenIds = new Map();
    arr.forEach(item => {
      // Duplicate no?
      if(item.no && seenNos.has(item.no)){
        allWarnings.push(`⚠️ Duplicate ${type} no: ${item.no} · ids: ${seenNos.get(item.no)} + ${item.id}`);
      } else if(item.no) seenNos.set(item.no, item.id);
      // Duplicate id?
      if(item.id && seenIds.has(item.id)){
        allWarnings.push(`⚠️ Duplicate ${type} id: ${item.id}`);
      } else if(item.id) seenIds.set(item.id, item.no);
      // Out-of-pattern no?
      if(item.no && !item.no.startsWith(prefix)){
        allWarnings.push(`⚠️ ${type} no format wrong: ${item.no} (expected ${prefix}XXX)`);
      }
    });
    // Gap analysis (informational · ไม่ใช่ error)
    const nums = arr.map(x => parseInt(String(x.no||'').replace(prefix,''))||0).filter(n=>n>0).sort((a,b)=>a-b);
    if(nums.length){
      const maxN = nums[nums.length-1];
      const expected = nums.length;
      if(maxN > expected){
        // มี gap = ปกติ (user ลบไปแล้ว) · log info เฉยๆ
        console.log(`[Data] ${type}: ${nums.length} items, max no = ${prefix}${String(maxN).padStart(3,'0')} (gap of ${maxN-expected})`);
      }
    }
  });
  if(allWarnings.length){
    console.warn('[Data Integrity Warnings]');
    allWarnings.forEach(w => console.warn('  '+w));
  }
}

function flSaveMemo(){
  const subject=document.getElementById('memo-subject').value.trim();
  if(!subject){alert('กรุณากรอกเรื่อง');return;}
  const memoDate = document.getElementById('memo-date')?.value || TODAY_STR;
  if(!memoDate){alert('กรุณาระบุวันที่');return;}
  const m=_memoMaintId?FL_MAINT.find(x=>x.id===_memoMaintId):null;
  const {sub,discTotal,afterDisc,vat,vatRate,vatEnabled,total}=memoCalcTotal();
  // ใช้ max(MO-XXX) + 1 (ไม่ใช่ length+1) เพื่อป้องกันเลขซ้ำเมื่อมี memo ถูกลบ
  // หรือเมื่อ sequence มี gap
  const _moMaxNo = FL_MEMOS.length
    ? Math.max(0, ...FL_MEMOS.map(m => parseInt(String(m.no||'').replace(/^MO-/,'')) || 0))
    : 0;
  const no='MO-'+String(_moMaxNo+1).padStart(3,'0');
  const memo={
    id:'m'+Date.now(),no,title:subject,
    to:document.getElementById('memo-to').value,
    from:document.getElementById('memo-from').value,
    proposer:document.getElementById('memo-proposer').value,
    supplier:(document.getElementById('memo-supplier')?.value||'').trim(),
    note:document.getElementById('memo-note')?.value.trim()||'',
    boatId:(_memoScope==='general')?null:(m?.boatId|| (_memoProjectId?(FL_PROJECTS||[]).find(x=>x.id===_memoProjectId)?.boatId : null) || null),
    maintId:_memoMaintId,
    projectId:_memoProjectId||null,  // Project-level memo (direct link · no MJ in between)
    scope:_memoScope||'vessel',
    generalCategory:(_memoScope==='general')?(document.getElementById('memo-general-cat')?.value||''):'',
    items:[..._memoItems],
