  const cost = flProjCalcCost(p.id);
  const boat = BOATS.find(b=>b.id===p.boatId);
  const boatName = boat?boat.name:'(unknown)';
  const sp = flProjStatusPillStyle(p.status, P);
  const statusPill = `<span style="background:${sp.bg};color:${sp.color};padding:4px 12px;border-radius:14px;font-size:11px;font-weight:700">${sp.label}</span>`;
