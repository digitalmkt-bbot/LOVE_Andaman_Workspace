function flRenderEngList(){
  const wrap=document.getElementById('fl-engs-pink-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  // Apply filters
  let engs=FL_ENGINES;
  if(flEngBrand!=='all')engs=engs.filter(e=>e.brand===flEngBrand);
  if(flEngStatus!=='all')engs=engs.filter(e=>(e.status||'ready')===flEngStatus);
  if(flEngLocation==='boat')engs=engs.filter(e=>e.boatId);
  else if(flEngLocation==='spare')engs=engs.filter(e=>!e.boatId);

  const all=FL_ENGINES;
  const totalEng=all.length;
  const honda=all.filter(e=>e.brand==='Honda').length;
  const suzuki=all.filter(e=>e.brand==='Suzuki').length;
  const ready=all.filter(e=>(e.status||'ready')==='ready').length;
  const fixing=all.filter(e=>e.status==='fixing').length;
  const broken=all.filter(e=>e.status==='broken').length;
  // Spare = status==='spare' OR no boat assigned (orphan) — covers both UI status-flag and unassign-flow
  const spareEngs=all.filter(e=>e.status==='spare' || !e.boatId).length;

  const totalHours=all.reduce((s,e)=>s+(typeof flEngHours==='function'?flEngHours(e.id):(e.baseHours||0)),0);
  const avgHours=all.length?Math.round(totalHours/all.length):0;

  // Service due: engines >=80% interval
  const dueEngs=all.filter(e=>{
    if(!e.serviceInterval)return false;
    const curH=typeof flEngHours==='function'?flEngHours(e.id):(e.baseHours||0);
    const cyc=curH%e.serviceInterval;
    return cyc/e.serviceInterval>=0.8;
  });

  // Models breakdown
  const modelCounts={};
  all.forEach(e=>{const k=e.model;if(k)modelCounts[k]=(modelCounts[k]||0)+1;});
  const modelList=Object.entries(modelCounts).sort((a,b)=>b[1]-a[1]).slice(0,3).map(([m])=>m).join(' · ');
  const modelCount=Object.keys(modelCounts).length;

  // Header bar
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#185FA5;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">HN</div><span style="font-size:12px;font-weight:500">Honda · ${honda}</span></div>
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#A32D2D;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">SZ</div><span style="font-size:12px;font-weight:500">Suzuki · ${suzuki}</span></div>
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">E</div>
    </div>
    <button onclick="flOpenAddEngineModal()" style="background:white;border:1px solid rgba(0,0,0,.08);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;cursor:pointer">+ Add Engine</button>
  </div>`;

  // KPI strip
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 1fr 0.85fr 0.85fr 0.85fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Engine Fleet</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${totalEng}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">engines</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.accent};color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${ready} ready</span>
        ${fixing?`<span style="display:inline-flex;align-items:center;background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${fixing} fixing</span>`:''}
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${honda} Honda · ${suzuki} Suzuki · ${spareEngs} spare</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Total hours</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2">${totalHours.toLocaleString()}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">h</span></div>
      <div style="font-size:11px;color:${dim.ink2};margin-top:6px">avg ${avgHours.toLocaleString()} h/eng</div>
    </div>

    <div style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${SVG_PINK.accent}">
      <div style="font-size:10px;color:${dim.ink3}">Service due</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${SVG_PINK.accent};color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${dueEngs.length}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">engines</span></div>
      <div style="font-size:11px;color:${SVG_PINK.text};margin-top:7px;font-weight:600">≥80% interval</div>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Models</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:#185FA5">${modelCount}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">types</span></div>
      <div style="font-size:11px;color:#185FA5;margin-top:6px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${modelList}</div>
    </div>

    <div style="grid-column:5;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px">
      <div style="font-size:10px;color:#aaa">Issues</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:${(fixing+broken)?'#FF8FA8':'white'}">${fixing+broken}</span><span style="font-size:11px;color:#aaa;font-weight:500">need attention</span></div>
      <div style="font-size:11px;color:#aaa;margin-top:6px">${fixing} fixing · ${broken} broken</div>
    </div>
  </div>`;

  // Filter bar
  const brandBtn=(val,label)=>`<button onclick="flSetEngBrand('${val}')" style="background:${flEngBrand===val?dim.ink:'transparent'};color:${flEngBrand===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 14px;font-size:11px;font-weight:${flEngBrand===val?600:500};cursor:pointer">${label}</button>`;
  const stBtn=(val,label,activeBg)=>`<button onclick="flSetEngStatus('${val}')" style="background:${flEngStatus===val?(activeBg||dim.ink):'transparent'};color:${flEngStatus===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flEngStatus===val?600:500};cursor:pointer">${label}</button>`;
  const locBtn=(val,label)=>`<button onclick="flSetEngLocation('${val}')" style="background:${flEngLocation===val?dim.ink:'transparent'};color:${flEngLocation===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flEngLocation===val?600:500};cursor:pointer">${label}</button>`;

  const filterBar=`<div style="display:flex;gap:6px;margin-bottom:14px;align-items:center;flex-wrap:wrap">
    <span style="font-size:11px;color:${dim.ink3};margin-right:6px;font-weight:500">filter</span>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex">
      ${brandBtn('all','All brands')}${brandBtn('Honda','Honda')}${brandBtn('Suzuki','Suzuki')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${stBtn('all','All')}
      ${stBtn('ready','Ready','#1D9E75')}
      ${stBtn('fixing','Fixing','#BA7517')}
      ${stBtn('spare','Spare')}
      ${stBtn('broken','Broken','#A32D2D')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${locBtn('all','All')}
      ${locBtn('boat','On boat')}
      ${locBtn('spare','Spare')}
    </div>
  </div>`;

  // Group engines by brand+model
  const STATUS_STYLE={
    ready:{bg:'#1D9E75',color:'white',label:'READY'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };

  const buildEngRow=(e)=>{
    const isSel=e.id===flSelEngId;
    const b=getBoat(e.boatId);
    const ss=STATUS_STYLE[e.status||'ready']||STATUS_STYLE.ready;
    const isSuzuki=e.brand==='Suzuki';
    const posBg=e.boatId?(isSuzuki?'#A32D2D':'#185FA5'):'#999';
    const posLbl=e.boatId?(e.pos||'EN'):'SPARE';
    const curH=typeof flEngHours==='function'?flEngHours(e.id):(e.baseHours||0);
    const next=e.serviceInterval?Math.ceil(curH/e.serviceInterval)*e.serviceInterval:null;
    const left=next?+(next-curH).toFixed(0):null;
    const svcLbl=left==null?'':(left<0?`over ${Math.abs(left)}h`:`${left}h to svc`);
    const svcColor=left==null?dim.ink3:(left<30?'#A32D2D':left<100?'#854F0B':dim.ink3);
    const locText=b?`${b.name} · ${e.pos}`:(e.spareLocation||'Workshop');
    const rowBg=isSel?SVG_PINK.soft:(e.status==='fixing'?'#FBF5E8':(e.status==='broken'?'#FBEDED':(!e.boatId?'#FBFAF7':'transparent')));
    const border=isSel?'1px solid #F0C0D0':'1px solid transparent';
    const topBorder=isSel?'':`border-top:0.5px solid ${dim.line};margin-top:2px;`;
    return`<div onclick="flSelEng('${e.id}')" style="display:flex;align-items:center;gap:10px;padding:9px 8px;border-radius:8px;cursor:pointer;${isSel?`background:${rowBg};border:${border};`:`${topBorder}background:${rowBg};`}">
      <span style="font-size:9px;font-weight:700;color:white;background:${posBg};padding:3px 8px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${posLbl}</span>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px"><span style="font-size:12px;font-weight:600;font-family:'DM Mono',monospace">${e.serial}</span><span style="background:${ss.bg};color:${ss.color};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600">${ss.label}</span></div>
        <div style="font-size:10px;color:${isSel?SVG_PINK.text:dim.ink3};margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${locText}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:11px;font-weight:700;font-family:'DM Mono',monospace;color:${isSel?SVG_PINK.text:(svcColor!==dim.ink3?svcColor:dim.ink)}">${curH.toLocaleString()}h</div>
        ${svcLbl?`<div style="font-size:9px;color:${svcColor}">${svcLbl}</div>`:''}
      </div>
    </div>`;
  };

  // Group by brand+model
  const groups={};
  engs.forEach(e=>{
    const k=`${e.brand} ${e.model}`;
    if(!groups[k])groups[k]=[];
    groups[k].push(e);
  });
  const sortedGroups=Object.entries(groups).sort((a,b)=>b[1].length-a[1].length);

  let listHtml='';
  if(sortedGroups.length===0){
    listHtml=`<div style="font-size:12px;color:${dim.ink3};text-align:center;padding:20px">No engines match filter</div>`;
  } else {
    sortedGroups.forEach(([key,list])=>{
      const isSuzuki=key.startsWith('Suzuki');
      const headerColor=isSuzuki?'#A32D2D':'#185FA5';
      const headerBg=isSuzuki?'#FCEBEB':'#E6F1FB';
      listHtml+=`<div style="display:flex;align-items:center;gap:6px;margin:10px 0 6px;padding:0 4px 8px;border-bottom:1px solid rgba(0,0,0,.06)">
        <span style="font-size:11px;font-weight:600;color:${headerColor}">${key}</span>
        <span style="background:${headerBg};color:${headerColor};padding:1px 8px;border-radius:9px;font-size:10px;font-weight:600">${list.length}</span>
      </div>`;
      list.forEach(e=>{listHtml+=buildEngRow(e);});
    });
  }

  const listPanel=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};max-height:calc(100vh - 360px);overflow-y:auto">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
      <span style="font-size:12px;font-weight:600;flex:1">All engines</span>
      <span style="font-size:10px;color:${dim.ink3}">${engs.length}/${all.length}</span>
    </div>
    ${listHtml}
  </div>`;

  const detailPanel=`<div id="fl-eng-detail-mount" style="background:white;border-radius:14px;border:1px solid ${dim.line};overflow:hidden;min-height:400px"></div>`;

  wrap.innerHTML=`${headerBar}${kpiStrip}${filterBar}<div style="display:grid;grid-template-columns:380px 1fr;gap:12px;align-items:start">${listPanel}${detailPanel}</div>`;

  flRenderEngDetailPink();
}

function flSetEngBrand(v){flEngBrand=v;flRenderEngList();}
function flSetEngStatus(v){flEngStatus=v;flRenderEngList();}
function flSetEngLocation(v){flEngLocation=v;flRenderEngList();}

function flSelEng(id){
  flSelEngId=id;
  flRenderEngList();
  // Scroll selected item back into view (keeps user oriented after re-render)
  setTimeout(()=>{
    const el = document.querySelector(`[onclick*="flSelEng('${id}')"]`);
    if(el) el.scrollIntoView({block:'nearest', behavior:'instant'});
  }, 0);
}

function flRenderEngDetailPink(){
  const mount=document.getElementById('fl-eng-detail-mount');
  if(!mount)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  if(!flSelEngId){
    mount.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:400px;padding:40px;color:${dim.ink3};gap:10px;text-align:center">
      <div style="font-size:36px;opacity:.25">⚙</div>
      <div style="font-size:13px;color:${dim.ink2};font-weight:500">Select an engine to see details</div>
      <div style="font-size:11px;color:${dim.ink3}">Click on the engine list to see hours, history, and service</div>
    </div>`;
    return;
  }

  const e=flGetEng(flSelEngId);
  if(!e){mount.innerHTML='';return;}

  const b=getBoat(e.boatId);
  const curH=typeof flEngHours==='function'?flEngHours(flSelEngId):(e.baseHours||0);
  const next=e.serviceInterval?Math.ceil(curH/e.serviceInterval)*e.serviceInterval:null;
  const left=next?+(next-curH).toFixed(1):null;
  const pct=next?(curH%e.serviceInterval)/e.serviceInterval*100:0;
  const isSuzuki=e.brand==='Suzuki';
  const ac=b?(isSuzuki?'#A32D2D':'#185FA5'):'#999';

  const STATUS_STYLE={
    ready:{bg:'#1D9E75',color:'white',label:'READY'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };
  const ss=STATUS_STYLE[e.status||'ready']||STATUS_STYLE.ready;

  // Last update
  let lastDate='';
  Object.keys(FL_DAILY).forEach(ds=>{
    Object.values(FL_DAILY[ds]||{}).forEach(bday=>{
      Object.values(bday.trips||{}).forEach(trip=>{
        if(trip.engines?.[flSelEngId]!=null&&ds>lastDate)lastDate=ds;
      });
    });
  });
  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtD=(s)=>{if(!s)return'—';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};

  // Linked gearbox
  const gb=FL_GEARBOXES.find(g=>g.engineId===flSelEngId);

  // Header strip
  const posLbl=e.pos||(b?'EN':'SPARE');
  const headerStrip=`<div style="padding:16px 20px;border-bottom:1px solid rgba(0,0,0,.06);background:linear-gradient(to right,#FFF5EC 0%,#FBEAF0 60%,#F5DDE6 100%)">
    <div style="display:flex;align-items:center;gap:10px">
      <div style="width:50px;height:50px;border-radius:12px;background:${ac};color:white;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace">
        <span style="font-size:9px;opacity:.85">${posLbl}</span>
        <span style="font-size:13px;font-weight:700;line-height:1">EN</span>
      </div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:20px;font-weight:700;font-family:'DM Mono',monospace;letter-spacing:.02em">${e.serial}</span>
          <span style="background:${ss.bg};color:${ss.color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600;letter-spacing:.04em">${ss.label}</span>
        </div>
        <div style="font-size:11px;color:${dim.ink2};margin-top:3px">${e.brand} ${e.model}${e.hp?` · ${e.hp} HP`:''}${b?` · ${b.name} · ${e.pos} position`:' · Spare'}</div>
      </div>
      <button onclick="flOpenEditEngModal('${flSelEngId}')" style="background:${dim.ink};color:white;border:none;border-radius:20px;padding:7px 16px;font-size:11px;font-weight:600;cursor:pointer;flex-shrink:0">Edit</button>
    </div>
  </div>`;

  // Hours card
  const barColor=pct>=80?SVG_PINK.accent:pct>=60?'#BA7517':'#1D9E75';
  const leftPill=left!=null?(left<0?`<span style="margin-left:auto;font-size:11px;color:#A32D2D;font-weight:600;background:#FCEBEB;padding:3px 10px;border-radius:12px">over ${Math.abs(left).toFixed(0)}h</span>`:`<span style="margin-left:auto;font-size:11px;color:${left<30?'#A32D2D':left<100?'#854F0B':SVG_PINK.text};font-weight:600;background:${left<30?'#FCEBEB':left<100?'#FAEEDA':SVG_PINK.soft};padding:3px 10px;border-radius:12px">${left.toFixed(0)}h to next service</span>`):'';
  const hoursCard=`<div style="background:linear-gradient(135deg,${SVG_PINK.soft} 0%,#FFFAFB 100%);border-radius:14px;padding:16px 18px">
    <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px">
      <span style="font-size:32px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${curH.toLocaleString()}</span>
      <span style="font-size:14px;color:${dim.ink2};font-weight:500">h</span>
      ${leftPill}
    </div>
    ${next?`<div style="display:flex;justify-content:space-between;font-size:9px;color:${dim.ink3};margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em">
      <span>Base ${(e.baseHours||0).toLocaleString()} h</span>
      <span>Next service ${next.toLocaleString()} h</span>
    </div>
    <div style="background:rgba(0,0,0,.06);border-radius:6px;height:8px;overflow:hidden">
      <div style="background:${barColor};height:100%;width:${Math.min(pct,100).toFixed(1)}%;border-radius:6px"></div>
    </div>`:'<div style="font-size:10px;color:'+dim.ink3+';font-style:italic">No service interval set</div>'}
    <div style="display:flex;align-items:center;gap:14px;margin-top:10px;font-size:10px;color:${dim.ink2};flex-wrap:wrap">
      <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:#1D9E75"></span>0–60% safe</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:#BA7517"></span>60–80% plan svc</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:${SVG_PINK.accent}"></span>≥80% urgent</span>
      <span style="margin-left:auto;font-family:'DM Mono',monospace;color:${dim.ink}">Last update: ${lastDate?fmtD(lastDate):'—'}</span>
    </div>
  </div>`;

  // Stat cards
  const statCards=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Brand</div>
      <div style="font-size:14px;font-weight:700;margin-top:2px">${e.brand||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">${e.model||''}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Power</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${e.hp||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">HP</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Service interval</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${e.serviceInterval?e.serviceInterval.toLocaleString():'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">h</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Position</div>
      <div style="font-size:14px;font-weight:700;margin-top:2px;color:${b?ac:dim.ink3}">${e.pos||'SPARE'}</div>
      <div style="font-size:10px;color:${dim.ink2}">${b?b.name:(e.spareLocation||'Workshop')}</div>
    </div>
  </div>`;

  // Status section removed — status changes via Edit button to prevent accidental clicks

  // Linked gearbox
  const gbBoat = gb ? getBoat(gb.boatId) : null;
  const gbPos = gb ? (gb.note || '') : '';
  const gbAvatarBg = gbBoat ? (getBoatColor(gbBoat.id).text || ac) : dim.ink5;
  const gbSection=gb?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Linked gearbox</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;border:1px solid rgba(0,0,0,.04)" onclick="flGoToAsset('gearboxes','${gb.id}')">
      ${gbBoat ? `<div style="width:36px;height:36px;border-radius:8px;background:${gbAvatarBg};color:white;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace">
        <span style="font-size:8px;opacity:.85">${gbPos||'—'}</span>
        <span style="font-size:11px;font-weight:700;line-height:1">GB</span>
      </div>` : `<div style="width:36px;height:36px;border-radius:8px;background:${dim.ink5};color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace;font-size:9px;font-weight:600">SPARE</div>`}
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
          <span style="font-size:12px;font-weight:600">${gb.serial}</span>
          <span style="font-size:10px;color:${dim.ink3}">·</span>
          <span style="font-size:10px;color:${dim.ink2}">${gb.brand}${gb.model?' · '+gb.model.replace(gb.brand+' ',''):''}</span>
        </div>
        <div style="font-size:10px;color:${dim.ink2};margin-top:3px">${gbBoat ? `🚤 <strong>${gbBoat.name}</strong> · ${gbPos||'—'} position` : '📦 Spare'+(gb.spareLocation?' · '+gb.spareLocation:'')}<span style="color:${dim.ink5}"> · Base ${(gb.baseHours||0).toLocaleString()}h</span></div>
      </div>
      <span style="background:${(STATUS_STYLE[gb.status]||STATUS_STYLE.ready).bg};color:${(STATUS_STYLE[gb.status]||STATUS_STYLE.ready).color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600">${(STATUS_STYLE[gb.status]||STATUS_STYLE.ready).label}</span>
      <span style="color:${dim.ink5};font-size:14px">›</span>
    </div>
  </div>`:'';

  // Engine history
  const history=e.log||[];
  const histHtml=history.length?[...history].reverse().slice(0,5).map((h,i,arr)=>{
    const isLast=i===arr.length-1;
    const dotColor=h.type==='assign'?'#185FA5':h.type==='repair'?'#BA7517':h.type==='unassign'?'#999':'#1D9E75';
    return`<div style="display:flex;gap:8px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="width:8px;height:8px;border-radius:50%;background:${dotColor};flex-shrink:0;margin-top:5px"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500">${h.desc||''}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${fmtD(h.date)}${h.hours!=null?' · '+h.hours.toLocaleString()+'h':''}${h.cost?' · ฿'+h.cost.toLocaleString():''}</div>
        ${h.detail?`<div style="font-size:10px;color:${dim.ink2};margin-top:1px">${h.detail}</div>`:''}
      </div>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No history</div>`;
  const historySection=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Engine history</div>
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${histHtml}</div>
  </div>`;

  // Maintenance jobs linked to this engine — use explicit asset link only
  // Don't filter by boatId (engine may have moved boats after repair)
  // (m.detail.includes(serial) was matching incorrectly when serial appeared in narrative)
  const allEngJobs=FL_MAINT.filter(m=>
    (m.assets||[]).some(a=>a.engId===flSelEngId)
  );
  const doneJobs=allEngJobs.filter(m=>m.status==='done');
  const lifetimeCost=doneJobs.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);
  const ytdJobs=doneJobs.filter(m=>(m.endDate||'').startsWith(String(new Date(TODAY_STR).getFullYear())));
  const ytdCost=ytdJobs.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);
  const avgPerJob=doneJobs.length?Math.round(lifetimeCost/doneJobs.length):0;
  const maintJobs=allEngJobs.sort((a,z)=>(z.startDate||'').localeCompare(a.startDate||'')).slice(0,5);
  const M_STATUS={done:{bg:'#1D9E75',color:'white',label:'DONE'},inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROG'},pending:{bg:'#F4F2EE',color:'#666',label:'PENDING'},cancelled:{bg:'#FCEBEB',color:'#A32D2D',label:'CANCEL'}};
  const maintHtml=maintJobs.length?maintJobs.map((m,i)=>{
    const isLast=i===maintJobs.length-1;
    const ms=M_STATUS[m.status]||M_STATUS.pending;
    const totalCost=m.status==='done'&&typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):null;
    const stripeColor=m.status==='done'?'#1D9E75':m.status==='inprogress'?'#BA7517':'#999';
    return`<div style="display:flex;gap:8px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="width:3px;background:${stripeColor};border-radius:2px;flex-shrink:0;align-self:stretch"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500">${m.no?m.no+' · ':''}${m.title||m.detail||'Repair'}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${fmtD(m.startDate)}${m.endDate?' → '+fmtD(m.endDate):''}${totalCost?' · ฿'+totalCost.toLocaleString():(m.cost?' · ฿'+m.cost.toLocaleString():'')}</div>
      </div>
      <span style="background:${ms.bg};color:${ms.color};padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600;align-self:flex-start;flex-shrink:0">${ms.label}</span>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No service records</div>`;
  const maintSection=`<div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <span style="font-size:13px;font-weight:600">Service & repair</span>
      <span style="font-size:10px;color:${dim.ink3}">${doneJobs.length} done · ${maintJobs.length}/${allEngJobs.length} shown</span>
    </div>
    ${doneJobs.length?`<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px">
      <div style="background:${SVG_PINK.soft};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${SVG_PINK.text};text-transform:uppercase;letter-spacing:.05em;font-weight:600">Lifetime cost</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${SVG_PINK.text};margin-top:1px">฿${lifetimeCost.toLocaleString()}</div>
      </div>
      <div style="background:${dim.bg};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600">YTD</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink};margin-top:1px">฿${ytdCost.toLocaleString()}</div>
      </div>
      <div style="background:${dim.bg};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600">Avg/job</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink};margin-top:1px">฿${avgPerJob.toLocaleString()}</div>
      </div>
    </div>`:''}
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${maintHtml}</div>
  </div>`;

  // Note
  const noteSection=e.note?`<div style="font-size:11px;color:${dim.ink2};font-style:italic;background:${SVG_PINK.soft};border-radius:10px;padding:10px 12px"><span style="color:${SVG_PINK.text};font-weight:600">Note: </span>${e.note}</div>`:'';

  mount.innerHTML=`${headerStrip}<div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px;max-height:calc(100vh - 280px);overflow-y:auto">
    ${hoursCard}
    ${statCards}
    ${gbSection}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">${historySection}${maintSection}</div>
    ${noteSection}
  </div>`;
}

// Legacy detail (kept for backward compat)
function flRenderEngDetail(id){
  if(typeof flRenderEngDetailPink==='function')flRenderEngDetailPink();
}

function flChangeEngStatus(id, newSt){
  const e=flGetEng(id);if(!e)return;
  const oldSt=e.status;
  e.status=newSt;
  if(!e.log) e.log=[];
  e.log.push({date:TODAY_STR,type:'status',desc:`Status: ${oldSt} → ${newSt}`,hours:flEngHours(id)});
  flSave();flRenderEngList();
}

function flRenderGbList(){
  const wrap=document.getElementById('fl-gbs-pink-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  let gbs=FL_GEARBOXES;
  if(flGbBrand!=='all')gbs=gbs.filter(g=>g.brand===flGbBrand);
  if(flGbStatus!=='all')gbs=gbs.filter(g=>(g.status||'ready')===flGbStatus);
  if(flGbLocation==='installed')gbs=gbs.filter(g=>g.engineId);
  else if(flGbLocation==='spare')gbs=gbs.filter(g=>!g.engineId);

  const all=FL_GEARBOXES;
  const totalGb=all.length;
  const honda=all.filter(g=>g.brand==='Honda').length;
  const suzuki=all.filter(g=>g.brand==='Suzuki').length;
  const installed=all.filter(g=>g.engineId).length;
  const spareCount=all.filter(g=>!g.engineId).length;
  const fixing=all.filter(g=>g.status==='fixing').length;
  const broken=all.filter(g=>g.status==='broken').length;

  // Lifetime hours for each GB
  const calcLifetime=(g)=>{
    const eng=flGetEng(g.engineId);
    const curH=eng?Math.max(0,(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0))-(g.baseHours||0)):0;
    const removeLogs=(g.log||[]).filter(l=>l.type==='remove');
    const prevUsed=removeLogs.reduce((s,l)=>s+(l.usedHours||0),0);
    return prevUsed+curH;
  };
  const totalLifetime=all.reduce((s,g)=>s+calcLifetime(g),0);
  const avgLifetime=all.length?Math.round(totalLifetime/all.length):0;

  // Service due
  const dueGbs=all.filter(g=>{
    if(!g.serviceInterval||!g.engineId)return false;
    const eng=flGetEng(g.engineId);
    if(!eng)return false;
    const curH=Math.max(0,(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0))-(g.baseHours||0));
    return (curH/g.serviceInterval)>=0.8;
  });

  // Spare locations
  const spareTL=all.filter(g=>!g.engineId&&(g.spareLocation||'').toLowerCase().includes('tub')).length;
  const spareVP=all.filter(g=>!g.engineId&&(g.spareLocation||'').toLowerCase().includes('panwa')).length;

  // Header bar
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#185FA5;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">HN</div><span style="font-size:12px;font-weight:500">Honda · ${honda}</span></div>
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:#A32D2D;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">SZ</div><span style="font-size:12px;font-weight:500">Suzuki · ${suzuki}</span></div>
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">G</div>
    </div>
    <button onclick="flOpenAddGearboxModal()" style="background:white;border:1px solid rgba(0,0,0,.08);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;cursor:pointer">+ Add Gearbox</button>
  </div>`;

  // KPI strip
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 1fr 0.85fr 0.85fr 0.85fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Gearbox Fleet</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${totalGb}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">gearboxes</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.accent};color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${installed} installed</span>
        ${spareCount?`<span style="display:inline-flex;align-items:center;background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${spareCount} spare</span>`:''}
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${honda} Honda · ${suzuki} Suzuki · linked to engines</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Total lifetime</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2">${totalLifetime.toLocaleString()}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">h</span></div>
      <div style="font-size:11px;color:${dim.ink2};margin-top:6px">avg ${avgLifetime.toLocaleString()} h/gb</div>
    </div>

    <div style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${SVG_PINK.accent}">
      <div style="font-size:10px;color:${dim.ink3}">Service due</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${SVG_PINK.accent};color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${dueGbs.length}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">gearboxes</span></div>
      <div style="font-size:11px;color:${SVG_PINK.text};margin-top:7px;font-weight:600">≥80% interval</div>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Spare</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:#185FA5">${spareCount}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">on shelf</span></div>
      <div style="font-size:11px;color:#185FA5;margin-top:6px;font-weight:600">${spareTL} TL · ${spareVP} VP</div>
    </div>

    <div style="grid-column:5;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px">
      <div style="font-size:10px;color:#aaa">Issues</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:${(fixing+broken)?'#FF8FA8':'white'}">${fixing+broken}</span><span style="font-size:11px;color:#aaa;font-weight:500">need attention</span></div>
      <div style="font-size:11px;color:#aaa;margin-top:6px">${fixing} fixing · ${broken} broken</div>
    </div>
  </div>`;

  // Filter bar
  const brandBtn=(val,label)=>`<button onclick="flSetGbBrand('${val}')" style="background:${flGbBrand===val?dim.ink:'transparent'};color:${flGbBrand===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 14px;font-size:11px;font-weight:${flGbBrand===val?600:500};cursor:pointer">${label}</button>`;
  const stBtn=(val,label,activeBg)=>`<button onclick="flSetGbStatus('${val}')" style="background:${flGbStatus===val?(activeBg||dim.ink):'transparent'};color:${flGbStatus===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flGbStatus===val?600:500};cursor:pointer">${label}</button>`;
  const locBtn=(val,label)=>`<button onclick="flSetGbLocation('${val}')" style="background:${flGbLocation===val?dim.ink:'transparent'};color:${flGbLocation===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flGbLocation===val?600:500};cursor:pointer">${label}</button>`;

  const filterBar=`<div style="display:flex;gap:6px;margin-bottom:14px;align-items:center;flex-wrap:wrap">
    <span style="font-size:11px;color:${dim.ink3};margin-right:6px;font-weight:500">filter</span>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex">
      ${brandBtn('all','All brands')}${brandBtn('Honda','Honda')}${brandBtn('Suzuki','Suzuki')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${stBtn('all','All')}
      ${stBtn('ready','Ready','#1D9E75')}
      ${stBtn('fixing','Fixing','#BA7517')}
      ${stBtn('spare','Spare')}
      ${stBtn('broken','Broken','#A32D2D')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${locBtn('all','All')}
      ${locBtn('installed','Installed')}
      ${locBtn('spare','Spare')}
    </div>
  </div>`;

  // Status styles
  const STATUS_STYLE={
    ready:{bg:'#1D9E75',color:'white',label:'READY'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };

  // Build gb row
  const buildGbRow=(g)=>{
    const isSel=g.id===flSelGbId;
    const eng=flGetEng(g.engineId);
    const b=eng?getBoat(eng.boatId):null;
    const ss=STATUS_STYLE[g.status||'ready']||STATUS_STYLE.ready;
    const isSuzuki=g.brand==='Suzuki';
    const posBg=g.engineId?(isSuzuki?'#A32D2D':'#185FA5'):'#999';
    const posLbl=g.engineId?(g.shaftLength||'GB'):'SPARE';
    const curH=eng?Math.max(0,+(((typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0))-(g.baseHours||0)).toFixed(0))):0;
    const rotIcon=g.rotation==='Counter'?'↺':g.rotation==='Selective'?'⇄':'↻';
    const rotLbl=g.rotation==='Counter'?'Counter':g.rotation==='Selective'?'Sel':'Std';
    const locText=eng?`${eng.serial} · ${b?b.name:'?'}`:(g.spareLocation||'Workshop');
    const rowBg=isSel?SVG_PINK.soft:(g.status==='fixing'?'#FBF5E8':(g.status==='broken'?'#FBEDED':(!g.engineId?'#FBFAF7':'transparent')));
    const border=isSel?'1px solid #F0C0D0':'1px solid transparent';
    const topBorder=isSel?'':`border-top:0.5px solid ${dim.line};margin-top:2px;`;
    return`<div onclick="flSelGb('${g.id}')" style="display:flex;align-items:center;gap:10px;padding:9px 8px;border-radius:8px;cursor:pointer;${isSel?`background:${rowBg};border:${border};`:`${topBorder}background:${rowBg};`}">
      <span style="font-size:9px;font-weight:700;color:white;background:${posBg};padding:3px 8px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${posLbl}</span>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px"><span style="font-size:12px;font-weight:600;font-family:'DM Mono',monospace">${g.serial}</span><span style="background:${ss.bg};color:${ss.color};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600">${ss.label}</span></div>
        <div style="font-size:10px;color:${isSel?SVG_PINK.text:dim.ink3};margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${locText}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:11px;font-weight:700;font-family:'DM Mono',monospace;color:${isSel?SVG_PINK.text:dim.ink}">${curH.toLocaleString()}h</div>
        <div style="font-size:9px;color:${isSel?SVG_PINK.text:dim.ink3}">${rotIcon} ${rotLbl}</div>
      </div>
    </div>`;
  };

  // Group by engine model
  const groups={};
  gbs.forEach(g=>{
    const eng=flGetEng(g.engineId);
    const k=eng?`${eng.brand} ${eng.model}`:`Spare ${g.brand}`;
    if(!groups[k])groups[k]=[];
    groups[k].push(g);
  });
  const sortedGroups=Object.entries(groups).sort((a,b)=>b[1].length-a[1].length);

  let listHtml='';
  if(sortedGroups.length===0){
    listHtml=`<div style="font-size:12px;color:${dim.ink3};text-align:center;padding:20px">No gearboxes match filter</div>`;
  } else {
    sortedGroups.forEach(([key,list])=>{
      const isSuzuki=key.toLowerCase().includes('suzuki');
      const headerColor=isSuzuki?'#A32D2D':(key.startsWith('Spare')?'#666':'#185FA5');
      const headerBg=isSuzuki?'#FCEBEB':(key.startsWith('Spare')?'#F4F2EE':'#E6F1FB');
      listHtml+=`<div style="display:flex;align-items:center;gap:6px;margin:10px 0 6px;padding:0 4px 8px;border-bottom:1px solid rgba(0,0,0,.06)">
        <span style="font-size:11px;font-weight:600;color:${headerColor}">${key}</span>
        <span style="background:${headerBg};color:${headerColor};padding:1px 8px;border-radius:9px;font-size:10px;font-weight:600">${list.length}</span>
      </div>`;
      list.forEach(g=>{listHtml+=buildGbRow(g);});
    });
  }

  const listPanel=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};max-height:calc(100vh - 360px);overflow-y:auto">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
      <span style="font-size:12px;font-weight:600;flex:1">All gearboxes</span>
      <span style="font-size:10px;color:${dim.ink3}">${gbs.length}/${all.length}</span>
    </div>
    ${listHtml}
  </div>`;

  const detailPanel=`<div id="fl-gb-detail-mount" style="background:white;border-radius:14px;border:1px solid ${dim.line};overflow:hidden;min-height:400px"></div>`;

  wrap.innerHTML=`${headerBar}${kpiStrip}${filterBar}<div style="display:grid;grid-template-columns:380px 1fr;gap:12px;align-items:start">${listPanel}${detailPanel}</div>`;

  flRenderGbDetailPink();
}

function flSetGbBrand(v){flGbBrand=v;flRenderGbList();}
function flSetGbStatus(v){flGbStatus=v;flRenderGbList();}
function flSetGbLocation(v){flGbLocation=v;flRenderGbList();}
function flSelGb(id){
  flSelGbId=id;
  flRenderGbList();
  setTimeout(()=>{
    const el = document.querySelector(`[onclick*="flSelGb('${id}')"]`);
    if(el) el.scrollIntoView({block:'nearest', behavior:'instant'});
  }, 0);
}

function flRenderGbDetailPink(){
  const mount=document.getElementById('fl-gb-detail-mount');
  if(!mount)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  if(!flSelGbId){
    mount.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:400px;padding:40px;color:${dim.ink3};gap:10px;text-align:center">
      <div style="font-size:36px;opacity:.25">⚙</div>
      <div style="font-size:13px;color:${dim.ink2};font-weight:500">Select a gearbox to see details</div>
      <div style="font-size:11px;color:${dim.ink3}">Click on the gearbox list to see hours, history, and propellers</div>
    </div>`;
    return;
  }

  const g=flGetGb(flSelGbId);
  if(!g){mount.innerHTML='';return;}

  const eng=flGetEng(g.engineId);
  const b=eng?getBoat(eng.boatId):null;
  const isSuzuki=g.brand==='Suzuki';
  const ac=eng?(isSuzuki?'#A32D2D':'#185FA5'):'#999';

  const STATUS_STYLE={
    ready:{bg:'#1D9E75',color:'white',label:'READY'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };
  const ss=STATUS_STYLE[g.status||'ready']||STATUS_STYLE.ready;

  // Hours calculation
  const curH=eng?Math.max(0,+((typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0))-(g.baseHours||0)).toFixed(1)):0;
  const removeLogs=(g.log||[]).filter(l=>l.type==='remove');
  const repairCount=removeLogs.length;
  const installCount=(g.log||[]).filter(l=>l.type==='install').length;
  const prevUsed=removeLogs.reduce((s,l)=>s+(l.usedHours||0),0);
  const lifetimeH=prevUsed+Math.max(curH,0);
  const svcPct=g.serviceInterval?Math.min(curH/g.serviceInterval*100,100):0;
  const svcLeft=g.serviceInterval?(g.serviceInterval-curH).toFixed(0):null;

  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtD=(s)=>{if(!s)return'—';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};

  const rotIcon=g.rotation==='Counter'?'↺':g.rotation==='Selective'?'⇄':'↻';
  const posLbl=g.shaftLength||'GB';

  // Header strip
  const headerStrip=`<div style="padding:16px 20px;border-bottom:1px solid rgba(0,0,0,.06);background:linear-gradient(to right,#FFF5EC 0%,#FBEAF0 60%,#F5DDE6 100%)">
    <div style="display:flex;align-items:center;gap:10px">
      <div style="width:50px;height:50px;border-radius:12px;background:${ac};color:white;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace">
        <span style="font-size:9px;opacity:.85">${posLbl}</span>
        <span style="font-size:13px;font-weight:700;line-height:1">GB</span>
      </div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:20px;font-weight:700;font-family:'DM Mono',monospace;letter-spacing:.02em">${g.serial}</span>
          <span style="background:${ss.bg};color:${ss.color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600;letter-spacing:.04em">${ss.label}</span>
        </div>
        <div style="font-size:11px;color:${dim.ink2};margin-top:3px">${g.brand} ${g.model||''}${g.shaftLength?` · ${g.shaftLength} shaft`:''}${g.rotation?` · ${rotIcon} ${g.rotation} rotation`:''}${g.gearRatio?` · ${g.gearRatio} ratio`:''}</div>
      </div>
      <button onclick="flOpenAddGearboxModal('${flSelGbId}')" style="background:${dim.ink};color:white;border:none;border-radius:20px;padding:7px 16px;font-size:11px;font-weight:600;cursor:pointer;flex-shrink:0">Edit</button>
    </div>
  </div>`;

  // Hours cards (2 cols)
  const barColor=svcPct>=90?'#A32D2D':svcPct>=70?'#BA7517':'#1D9E75';
  const leftPill=svcLeft!=null?(parseInt(svcLeft)<0?`<span style="margin-left:auto;font-size:10px;color:#A32D2D;font-weight:600;background:#FCEBEB;padding:2px 8px;border-radius:10px">over ${Math.abs(parseInt(svcLeft))}h</span>`:`<span style="margin-left:auto;font-size:10px;color:${parseInt(svcLeft)<30?'#A32D2D':parseInt(svcLeft)<100?'#854F0B':SVG_PINK.text};font-weight:600;background:${parseInt(svcLeft)<30?'#FCEBEB':parseInt(svcLeft)<100?'#FAEEDA':SVG_PINK.soft};padding:2px 8px;border-radius:10px">${svcLeft}h to svc</span>`):'';
  const hoursCards=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    <div style="background:linear-gradient(135deg,${SVG_PINK.soft} 0%,#FFFAFB 100%);border-radius:14px;padding:14px 16px">
      <div style="font-size:10px;color:${SVG_PINK.text};text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:6px">Current cycle</div>
      <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px">
        <span style="font-size:28px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${curH>0?curH.toLocaleString():0}</span>
        <span style="font-size:13px;color:${dim.ink2};font-weight:500">h</span>
        ${leftPill}
      </div>
      ${g.serviceInterval?`<div style="display:flex;justify-content:space-between;font-size:9px;color:${dim.ink3};margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em">
        <span>${g.lastServiceDate?'Last svc '+fmtD(g.lastServiceDate):'Since install'}</span>
        <span>Service at ${g.serviceInterval}h</span>
      </div>
      <div style="background:rgba(0,0,0,.06);border-radius:6px;height:8px;overflow:hidden">
        <div style="background:${barColor};height:100%;width:${Math.min(svcPct,100).toFixed(1)}%;border-radius:6px"></div>
      </div>`:'<div style="font-size:10px;color:'+dim.ink3+';font-style:italic">No service interval set</div>'}
      <div style="font-size:10px;color:${dim.ink2};margin-top:6px">Counted from last installation</div>
    </div>

    <div style="background:#FBFAF7;border-radius:14px;padding:14px 16px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:6px">Lifetime hours</div>
      <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px">
        <span style="font-size:28px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${lifetimeH.toLocaleString()}</span>
        <span style="font-size:13px;color:${dim.ink2};font-weight:500">h</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px;font-size:10px;color:${dim.ink2};flex-wrap:wrap">
        <span style="display:flex;align-items:center;gap:4px"><span style="width:6px;height:6px;border-radius:50%;background:#1D9E75"></span>${repairCount} service rounds</span>
        <span style="display:flex;align-items:center;gap:4px"><span style="width:6px;height:6px;border-radius:50%;background:#185FA5"></span>${installCount} installations</span>
      </div>
      <div style="font-size:10px;color:${dim.ink3};margin-top:6px">Current ${curH>0?curH.toLocaleString():0}h + previous ${prevUsed.toLocaleString()}h</div>
    </div>
  </div>`;

  // 4 spec cards
  const specCards=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Shaft</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${g.shaftLength||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">length</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Rotation</div>
      <div style="font-size:14px;font-weight:700;margin-top:2px;color:#185FA5">${rotIcon} ${g.rotation||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">${g.rotation==='Counter'?'CCW direction':g.rotation==='Selective'?'either way':'CW direction'}</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Gear ratio</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${g.gearRatio||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">reduction</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Oil capacity</div>
      <div style="font-size:18px;font-weight:700;font-family:'DM Mono',monospace;margin-top:2px">${g.oilCapacity||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">cc gear oil</div>
    </div>
  </div>`;

  // Linked engine
  const engSection=eng?`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Linked engine</div>
    <div onclick="flGoToAsset('engines','${eng.id}')" style="background:#FBFAF7;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;cursor:pointer">
      <span style="font-size:9px;font-weight:700;color:white;background:${ac};padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${eng.pos||'EN'}</span>
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:600;font-family:'DM Mono',monospace">${eng.serial}</div>
        <div style="font-size:10px;color:${dim.ink3};margin-top:2px">${eng.brand} ${eng.model}${b?' · '+b.name:''}${eng.id?` · ${(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0)).toLocaleString()}h current`:''}</div>
      </div>
      <span style="background:${(STATUS_STYLE[eng.status]||STATUS_STYLE.ready).bg};color:${(STATUS_STYLE[eng.status]||STATUS_STYLE.ready).color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600">${(STATUS_STYLE[eng.status]||STATUS_STYLE.ready).label}</span>
      <span style="color:${dim.ink5};font-size:14px">›</span>
    </div>
  </div>`:`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Storage</div>
    <div style="background:#FBFAF7;border-radius:10px;padding:10px 14px">
      <div style="font-size:11px;color:${dim.ink2}">${g.spareLocation||'Not specified'}</div>
    </div>
  </div>`;

  // Propellers
  const props=FL_PROPELLERS.filter(p=>p.gearboxId===flSelGbId);
  const PROP_STYLE={active:{bg:'#1D9E75',color:'white',label:'ACTIVE'},fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'},spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'}};
  const propsHtml=props.length?props.map(p=>{
    const ps=PROP_STYLE[p.status]||PROP_STYLE.active;
    const propPos=p.position||(props.length===1?'PROP':'');
    return`<div style="display:flex;align-items:center;gap:8px;padding:8px;background:white;border-radius:8px;border:0.5px solid ${dim.line}">
      ${propPos?`<span style="font-size:9px;font-weight:700;color:white;background:${ac};padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${propPos}</span>`:''}
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:600;font-family:'DM Mono',monospace">${p.serial}</div>
        <div style="font-size:9px;color:${dim.ink3}">${p.brand||''} ${p.size||''}${p.blades?` · ${p.blades} blade`:''}${p.material?' · '+p.material:''}</div>
      </div>
      <span style="background:${ps.bg};color:${ps.color};padding:1px 6px;border-radius:6px;font-size:8px;font-weight:600;flex-shrink:0">${ps.label}</span>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No propellers attached</div>`;
  const propSection=`<div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;justify-content:space-between">
      <span style="font-size:13px;font-weight:600">Propellers <span style="color:${dim.ink3};font-weight:400">${props.length}</span></span>
    </div>
    <div style="background:#FBFAF7;border-radius:10px;padding:8px;display:grid;grid-template-columns:repeat(${props.length>=2?2:1},1fr);gap:6px">
      ${propsHtml}
    </div>
  </div>`;

  // Move/install history
  const log=g.log||[];
  const histHtml=log.length?[...log].reverse().slice(0,5).map((l,i,arr)=>{
    const isLast=i===arr.length-1;
    const dotColor=l.type==='install'?'#185FA5':l.type==='remove'?'#BA7517':l.type==='repair'?'#A32D2D':'#999';
    return`<div style="display:flex;gap:8px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="width:8px;height:8px;border-radius:50%;background:${dotColor};flex-shrink:0;margin-top:5px"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500">${l.desc||''}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${fmtD(l.date)}${l.engineHours!=null?' · eng '+l.engineHours+'h':''}${l.usedHours!=null?' · used '+l.usedHours+'h':''}${l.cost?' · ฿'+l.cost.toLocaleString():''}</div>
      </div>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No history</div>`;
  const historySection=`<div>
    <div style="font-size:13px;font-weight:600;margin-bottom:8px">Move / install history</div>
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${histHtml}</div>
  </div>`;

  // Maintenance jobs
  const allGbJobs=FL_MAINT.filter(m=>(m.assets||[]).some(a=>a.gbId===flSelGbId||(a.type==='gearbox'&&a.label&&a.label.includes(g.serial))));
  const gbDoneJobs=allGbJobs.filter(m=>m.status==='done');
  const gbLifetimeCost=gbDoneJobs.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);
  const gbYtdJobs=gbDoneJobs.filter(m=>(m.endDate||'').startsWith(String(new Date(TODAY_STR).getFullYear())));
  const gbYtdCost=gbYtdJobs.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);
  const gbAvgPerJob=gbDoneJobs.length?Math.round(gbLifetimeCost/gbDoneJobs.length):0;
  const maintJobs=allGbJobs.sort((a,z)=>(z.startDate||'').localeCompare(a.startDate||'')).slice(0,5);
  const M_STATUS={done:{bg:'#1D9E75',color:'white',label:'DONE'},inprogress:{bg:'#FAEEDA',color:'#854F0B',label:'IN PROG'},pending:{bg:'#F4F2EE',color:'#666',label:'PENDING'},cancelled:{bg:'#FCEBEB',color:'#A32D2D',label:'CANCEL'}};
  const maintHtml=maintJobs.length?maintJobs.map((m,i)=>{
    const isLast=i===maintJobs.length-1;
    const ms=M_STATUS[m.status]||M_STATUS.pending;
    const totalCost=m.status==='done'&&typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):null;
    const stripeColor=m.status==='done'?'#1D9E75':m.status==='inprogress'?'#BA7517':'#999';
    return`<div style="display:flex;gap:8px;padding:10px 14px;${isLast?'':'border-bottom:0.5px solid rgba(0,0,0,.06)'}">
      <div style="width:3px;background:${stripeColor};border-radius:2px;flex-shrink:0;align-self:stretch"></div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:500">${m.no?m.no+' · ':''}${m.title||m.detail||'Repair'}</div>
        <div style="font-size:9px;color:${dim.ink3};margin-top:1px;font-family:'DM Mono',monospace">${fmtD(m.startDate)}${m.endDate?' → '+fmtD(m.endDate):''}${totalCost?' · ฿'+totalCost.toLocaleString():(m.cost?' · ฿'+m.cost.toLocaleString():'')}</div>
      </div>
      <span style="background:${ms.bg};color:${ms.color};padding:1px 7px;border-radius:8px;font-size:9px;font-weight:600;align-self:flex-start;flex-shrink:0">${ms.label}</span>
    </div>`;
  }).join(''):`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:14px">No service records</div>`;
  const maintSection=`<div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <span style="font-size:13px;font-weight:600">Service & repair</span>
      <span style="font-size:10px;color:${dim.ink3}">${gbDoneJobs.length} done · ${maintJobs.length}/${allGbJobs.length} shown</span>
    </div>
    ${gbDoneJobs.length?`<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px">
      <div style="background:${SVG_PINK.soft};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${SVG_PINK.text};text-transform:uppercase;letter-spacing:.05em;font-weight:600">Lifetime cost</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${SVG_PINK.text};margin-top:1px">฿${gbLifetimeCost.toLocaleString()}</div>
      </div>
      <div style="background:${dim.bg};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600">YTD</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink};margin-top:1px">฿${gbYtdCost.toLocaleString()}</div>
      </div>
      <div style="background:${dim.bg};border-radius:8px;padding:8px 10px">
        <div style="font-size:9px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600">Avg/job</div>
        <div style="font-size:14px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink};margin-top:1px">฿${gbAvgPerJob.toLocaleString()}</div>
      </div>
    </div>`:''}
    <div style="background:#FBFAF7;border-radius:10px;overflow:hidden">${maintHtml}</div>
  </div>`;

  mount.innerHTML=`${headerStrip}<div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px;max-height:calc(100vh - 280px);overflow-y:auto">
    ${hoursCards}
    ${specCards}
    ${engSection}
    ${propSection}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">${historySection}${maintSection}</div>
  </div>`;
}

function flRenderGbDetail(id){
  if(typeof flRenderGbDetailPink==='function')flRenderGbDetailPink();
}


function flRenderPropList(){
  const wrap=document.getElementById('fl-props-pink-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  let props=FL_PROPELLERS;
  if(flPropBrand!=='all')props=props.filter(p=>p.brand===flPropBrand);
  if(flPropStatus!=='all')props=props.filter(p=>(p.status||'active')===flPropStatus);
  if(flPropLocation==='installed')props=props.filter(p=>p.gearboxId);
  else if(flPropLocation==='spare')props=props.filter(p=>!p.gearboxId);

  const all=FL_PROPELLERS;
  const totalProp=all.length;
  const brandCounts={};
  all.forEach(p=>{if(p.brand)brandCounts[p.brand]=(brandCounts[p.brand]||0)+1;});
  const brandsArr=Object.entries(brandCounts).sort((a,b)=>b[1]-a[1]);
  const top1=brandsArr[0]||['',0];
  const top2=brandsArr[1]||['',0];
  const active=all.filter(p=>(p.status||'active')==='active').length;
  const fixing=all.filter(p=>p.status==='fixing').length;
  const broken=all.filter(p=>p.status==='broken').length;
  const spareCount=all.filter(p=>!p.gearboxId).length;

  // Lifetime hours
  const calcLifetime=(p)=>{
    const gb=flGetGb(p.gearboxId);const eng=gb?flGetEng(gb.engineId):null;
    const curEngH=eng?(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0)):0;
    const curH=Math.max(0,curEngH-(p.installHours||0));
    const removeLogs=(p.log||[]).filter(l=>l.type==='remove');
    const prevUsed=removeLogs.reduce((s,l)=>s+(l.usedHours||0),0);
    return prevUsed+curH;
  };
  const totalLifetime=all.reduce((s,p)=>s+calcLifetime(p),0);
  const avgLifetime=all.length?Math.round(totalLifetime/all.length):0;

  // Sizes
  const sizeCounts={};
  all.forEach(p=>{if(p.size)sizeCounts[p.size]=(sizeCounts[p.size]||0)+1;});
  const sizesArr=Object.entries(sizeCounts).sort((a,b)=>b[1]-a[1]);
  const sizeCount=sizesArr.length;
  const topSizes=sizesArr.slice(0,3).map(([s])=>s).join(' · ');

  // Spare locations
  const spareTL=all.filter(p=>!p.gearboxId&&(p.spareLocation||'').toLowerCase().includes('tub')).length;
  const spareVP=all.filter(p=>!p.gearboxId&&(p.spareLocation||'').toLowerCase().includes('panwa')).length;

  // Header bar
  const brandPill=(name,count,color)=>`<div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px"><div style="width:24px;height:24px;border-radius:50%;background:${color};color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">${name.slice(0,2).toUpperCase()}</div><span style="font-size:12px;font-weight:500">${name} · ${count}</span></div>`;
  const brand1Color='#185FA5',brand2Color='#A32D2D';
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      ${top1[0]?brandPill(top1[0],top1[1],brand1Color):''}
      ${top2[0]?brandPill(top2[0],top2[1],brand2Color):''}
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">P</div>
    </div>
    <button onclick="flOpenAddPropModal()" style="background:white;border:1px solid rgba(0,0,0,.08);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:500;cursor:pointer">+ Add Propeller</button>
  </div>`;

  // KPI strip
  const brandSummary=brandsArr.map(([n,c])=>`${c} ${n}`).join(' · ');
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 1fr 0.85fr 0.85fr 0.85fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Propeller Fleet</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${totalProp}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">propellers</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.accent};color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${active} active</span>
        ${spareCount?`<span style="display:inline-flex;align-items:center;background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${spareCount} spare</span>`:''}
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${brandSummary||'no propellers'}</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Total lifetime</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2">${totalLifetime.toLocaleString()}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">h</span></div>
      <div style="font-size:11px;color:${dim.ink2};margin-top:6px">avg ${avgLifetime.toLocaleString()} h/prop</div>
    </div>

    <div style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Sizes</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:#185FA5">${sizeCount}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">types</span></div>
      <div style="font-size:11px;color:#185FA5;margin-top:6px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${topSizes||'—'}</div>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Spare</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:#185FA5">${spareCount}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">on shelf</span></div>
      <div style="font-size:11px;color:#185FA5;margin-top:6px;font-weight:600">${spareTL} TL · ${spareVP} VP</div>
    </div>

    <div style="grid-column:5;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px">
      <div style="font-size:10px;color:#aaa">Issues</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2;color:${(fixing+broken)?'#FF8FA8':'white'}">${fixing+broken}</span><span style="font-size:11px;color:#aaa;font-weight:500">need attention</span></div>
      <div style="font-size:11px;color:#aaa;margin-top:6px">${fixing} fixing · ${broken} broken</div>
    </div>
  </div>`;

  // Filter bar
  const brands=brandsArr.map(([n])=>n);
  const brandBtn=(val,label)=>`<button onclick="flSetPropBrand('${val}')" style="background:${flPropBrand===val?dim.ink:'transparent'};color:${flPropBrand===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 14px;font-size:11px;font-weight:${flPropBrand===val?600:500};cursor:pointer">${label}</button>`;
  const stBtn=(val,label,activeBg)=>`<button onclick="flSetPropStatus('${val}')" style="background:${flPropStatus===val?(activeBg||dim.ink):'transparent'};color:${flPropStatus===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flPropStatus===val?600:500};cursor:pointer">${label}</button>`;
  const locBtn=(val,label)=>`<button onclick="flSetPropLocation('${val}')" style="background:${flPropLocation===val?dim.ink:'transparent'};color:${flPropLocation===val?'white':dim.ink2};border:none;border-radius:14px;padding:5px 12px;font-size:11px;font-weight:${flPropLocation===val?600:500};cursor:pointer">${label}</button>`;

  const filterBar=`<div style="display:flex;gap:6px;margin-bottom:14px;align-items:center;flex-wrap:wrap">
    <span style="font-size:11px;color:${dim.ink3};margin-right:6px;font-weight:500">filter</span>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex">
      ${brandBtn('all','All brands')}${brands.map(b=>brandBtn(b,b)).join('')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${stBtn('all','All')}
      ${stBtn('active','Active','#1D9E75')}
      ${stBtn('fixing','Fixing','#BA7517')}
      ${stBtn('spare','Spare')}
      ${stBtn('broken','Broken','#A32D2D')}
    </div>
    <div style="background:white;border:1px solid ${dim.line};border-radius:24px;padding:2px;display:flex;margin-left:6px">
      ${locBtn('all','All')}
      ${locBtn('installed','Installed')}
      ${locBtn('spare','Spare')}
    </div>
  </div>`;

  const STATUS_STYLE={
    active:{bg:'#1D9E75',color:'white',label:'ACTIVE'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };

  const matShort=(m)=>{
    if(!m)return'—';
    if(/stainless|ss/i.test(m))return'SS';
    if(/alu/i.test(m))return'Alu';
    return m.slice(0,4);
  };

  const buildPropRow=(p)=>{
    const isSel=p.id===flSelPropId;
    const gb=flGetGb(p.gearboxId);
    const eng=gb?flGetEng(gb.engineId):null;
    const b=eng?getBoat(eng.boatId):null;
    const ss=STATUS_STYLE[p.status||'active']||STATUS_STYLE.active;
    const isSuzuki=eng&&eng.brand==='Suzuki';
    const posBg=p.gearboxId?(isSuzuki?'#A32D2D':'#185FA5'):'#999';
    const posLbl=p.gearboxId?(p.position||'PROP'):'SPARE';
    const curEngH=eng?(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0)):0;
    const curH=Math.max(0,curEngH-(p.installHours||0));
    const locText=gb?`${gb.serial} · ${b?b.name:'?'}`:(p.spareLocation||'Workshop');
    const rowBg=isSel?SVG_PINK.soft:(p.status==='fixing'?'#FBF5E8':(p.status==='broken'?'#FBEDED':(!p.gearboxId?'#FBFAF7':'transparent')));
    const border=isSel?'1px solid #F0C0D0':'1px solid transparent';
    const topBorder=isSel?'':`border-top:0.5px solid ${dim.line};margin-top:2px;`;
    return`<div onclick="flSelProp('${p.id}')" style="display:flex;align-items:center;gap:10px;padding:9px 8px;border-radius:8px;cursor:pointer;${isSel?`background:${rowBg};border:${border};`:`${topBorder}background:${rowBg};`}">
      <span style="font-size:9px;font-weight:700;color:white;background:${posBg};padding:3px 8px;border-radius:5px;font-family:'DM Mono',monospace;flex-shrink:0">${posLbl}</span>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px"><span style="font-size:12px;font-weight:600;font-family:'DM Mono',monospace">${p.serial}</span><span style="background:${ss.bg};color:${ss.color};padding:1px 6px;border-radius:7px;font-size:9px;font-weight:600">${ss.label}</span></div>
        <div style="font-size:10px;color:${isSel?SVG_PINK.text:dim.ink3};margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${locText}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:11px;font-weight:700;font-family:'DM Mono',monospace;color:${isSel?SVG_PINK.text:dim.ink}">${curH.toLocaleString()}h</div>
        <div style="font-size:9px;color:${isSel?SVG_PINK.text:dim.ink3}">${p.blades||'—'} · ${matShort(p.material)}</div>
      </div>
    </div>`;
  };

  // Group by brand+size
  const groups={};
  props.forEach(p=>{
    const k=`${p.brand||'—'} ${p.size||'—'}`;
    if(!groups[k])groups[k]=[];
    groups[k].push(p);
  });
  const sortedGroups=Object.entries(groups).sort((a,b)=>b[1].length-a[1].length);

  let listHtml='';
  if(sortedGroups.length===0){
    listHtml=`<div style="font-size:12px;color:${dim.ink3};text-align:center;padding:20px">No propellers match filter</div>`;
  } else {
    sortedGroups.forEach(([key,list])=>{
      const headerColor='#185FA5';
      const headerBg='#E6F1FB';
      listHtml+=`<div style="display:flex;align-items:center;gap:6px;margin:10px 0 6px;padding:0 4px 8px;border-bottom:1px solid rgba(0,0,0,.06)">
        <span style="font-size:11px;font-weight:600;color:${headerColor}">${key}</span>
        <span style="background:${headerBg};color:${headerColor};padding:1px 8px;border-radius:9px;font-size:10px;font-weight:600">${list.length}</span>
      </div>`;
      list.forEach(p=>{listHtml+=buildPropRow(p);});
    });
  }

  const listPanel=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};max-height:calc(100vh - 360px);overflow-y:auto">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
      <span style="font-size:12px;font-weight:600;flex:1">All propellers</span>
      <span style="font-size:10px;color:${dim.ink3}">${props.length}/${all.length}</span>
    </div>
    ${listHtml}
  </div>`;

  const detailPanel=`<div id="fl-prop-detail-mount" style="background:white;border-radius:14px;border:1px solid ${dim.line};overflow:hidden;min-height:400px"></div>`;

  wrap.innerHTML=`${headerBar}${kpiStrip}${filterBar}<div style="display:grid;grid-template-columns:380px 1fr;gap:12px;align-items:start">${listPanel}${detailPanel}</div>`;

  flRenderPropDetailPink();
}

function flSetPropBrand(v){flPropBrand=v;flRenderPropList();}
function flSetPropStatus(v){flPropStatus=v;flRenderPropList();}
function flSetPropLocation(v){flPropLocation=v;flRenderPropList();}
function flSelProp(id){
  flSelPropId=id;
  flRenderPropList();
  setTimeout(()=>{
    const el = document.querySelector(`[onclick*="flSelProp('${id}')"]`);
    if(el) el.scrollIntoView({block:'nearest', behavior:'instant'});
  }, 0);
}

function flRenderPropDetailPink(){
  const mount=document.getElementById('fl-prop-detail-mount');
  if(!mount)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};

  if(!flSelPropId){
    mount.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:400px;padding:40px;color:${dim.ink3};gap:10px;text-align:center">
      <div style="font-size:36px;opacity:.25">⚓</div>
      <div style="font-size:13px;color:${dim.ink2};font-weight:500">Select a propeller to see details</div>
      <div style="font-size:11px;color:${dim.ink3}">Click on the propeller list to see hours, history, and linked gearbox</div>
    </div>`;
    return;
  }

  const p=FL_PROPELLERS.find(x=>x.id===flSelPropId);
  if(!p){mount.innerHTML='';return;}

  const gb=flGetGb(p.gearboxId);
  const eng=gb?flGetEng(gb.engineId):null;
  const b=eng?getBoat(eng.boatId):null;
  const isSuzuki=eng&&eng.brand==='Suzuki';
  const ac=gb?(isSuzuki?'#A32D2D':'#185FA5'):'#999';

  const STATUS_STYLE={
    active:{bg:'#1D9E75',color:'white',label:'ACTIVE'},
    fixing:{bg:'#FAEEDA',color:'#854F0B',label:'FIXING'},
    spare:{bg:'#F4F2EE',color:'#666',label:'SPARE'},
    broken:{bg:'#FCEBEB',color:'#A32D2D',label:'BROKEN'}
  };
  const ss=STATUS_STYLE[p.status||'active']||STATUS_STYLE.active;

  const curEngH=eng?(typeof flEngHours==='function'?flEngHours(eng.id):(eng.baseHours||0)):0;
  const curH=Math.max(0,+(curEngH-(p.installHours||0)).toFixed(1));
  const removeLogs=(p.log||[]).filter(l=>l.type==='remove');
  const repairCount=removeLogs.length;
  const installCount=(p.log||[]).filter(l=>l.type==='install').length;
  const prevUsed=removeLogs.reduce((s,l)=>s+(l.usedHours||0),0);
  const lifetimeH=prevUsed+curH;

  // Last install date
  const lastInstall=[...(p.log||[])].reverse().find(l=>l.type==='install');
  const installDate=lastInstall?lastInstall.date:null;

  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const fmtD=(s)=>{if(!s)return'—';const d=new Date(s);return`${MONTHS_EN[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;};

  const matLong=(m)=>{
    if(!m)return'—';
    if(/stainless|ss/i.test(m))return'Stainless';
    if(/alu/i.test(m))return'Aluminium';
    return m;
  };

  const posLbl=p.position||(gb?'PROP':'SPARE');

  // Header strip
  const headerStrip=`<div style="padding:16px 20px;border-bottom:1px solid rgba(0,0,0,.06);background:linear-gradient(to right,#FFF5EC 0%,#FBEAF0 60%,#F5DDE6 100%)">
    <div style="display:flex;align-items:center;gap:10px">
      <div style="width:50px;height:50px;border-radius:12px;background:${ac};color:white;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace">
        <span style="font-size:9px;opacity:.85">${posLbl}</span>
        <span style="font-size:13px;font-weight:700;line-height:1">PR</span>
      </div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:20px;font-weight:700;font-family:'DM Mono',monospace;letter-spacing:.02em">${p.serial}</span>
          <span style="background:${ss.bg};color:${ss.color};padding:2px 9px;border-radius:11px;font-size:10px;font-weight:600;letter-spacing:.04em">${ss.label}</span>
        </div>
        <div style="font-size:11px;color:${dim.ink2};margin-top:3px">${p.brand||'—'} ${p.size||''}${p.blades?` · ${p.blades} blade`:''}${p.material?` · ${matLong(p.material)}`:''}${gb?` · ${gb.serial}`:''}${b?' · '+b.name:''}</div>
      </div>
      <button onclick="flOpenAddPropModal('${flSelPropId}')" style="background:${dim.ink};color:white;border:none;border-radius:20px;padding:7px 16px;font-size:11px;font-weight:600;cursor:pointer;flex-shrink:0">Edit</button>
    </div>
  </div>`;

  // Hours cards
  const runningPill=p.gearboxId?(p.status==='active'?`<span style="margin-left:auto;font-size:10px;color:#0F6E56;font-weight:600;background:#E1F5EE;padding:2px 8px;border-radius:10px">running</span>`:''):'';
  const hoursCards=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    <div style="background:linear-gradient(135deg,${SVG_PINK.soft} 0%,#FFFAFB 100%);border-radius:14px;padding:14px 16px">
      <div style="font-size:10px;color:${SVG_PINK.text};text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:6px">Current cycle</div>
      <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px">
        <span style="font-size:28px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${curH>0?curH.toLocaleString():0}</span>
        <span style="font-size:13px;color:${dim.ink2};font-weight:500">h</span>
        ${runningPill}
      </div>
      <div style="font-size:10px;color:${dim.ink2}">Counted from last installation</div>
      ${installDate?`<div style="font-size:10px;color:${dim.ink3};margin-top:2px;font-family:'DM Mono',monospace">Installed: ${fmtD(installDate)}</div>`:''}
    </div>

    <div style="background:#FBFAF7;border-radius:14px;padding:14px 16px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:6px">Lifetime hours</div>
      <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px">
        <span style="font-size:28px;font-weight:700;font-family:'DM Mono',monospace;color:${dim.ink}">${lifetimeH.toLocaleString()}</span>
        <span style="font-size:13px;color:${dim.ink2};font-weight:500">h</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px;font-size:10px;color:${dim.ink2};flex-wrap:wrap">
        <span style="display:flex;align-items:center;gap:4px"><span style="width:6px;height:6px;border-radius:50%;background:#1D9E75"></span>${repairCount} service rounds</span>
        <span style="display:flex;align-items:center;gap:4px"><span style="width:6px;height:6px;border-radius:50%;background:#185FA5"></span>${installCount} installations</span>
      </div>
      <div style="font-size:10px;color:${dim.ink3};margin-top:6px">Current ${curH>0?curH.toLocaleString():0}h + previous ${prevUsed.toLocaleString()}h</div>
    </div>
  </div>`;

  // 4 spec cards
  const specCards=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px">
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Brand</div>
      <div style="font-size:14px;font-weight:700;margin-top:2px">${p.brand||'—'}</div>
      <div style="font-size:10px;color:${dim.ink2}">manufacturer</div>
    </div>
    <div style="background:${dim.bg};border-radius:10px;padding:10px 12px">
      <div style="font-size:10px;color:${dim.ink3};text-transform:uppercase;letter-spacing:.05em">Size</div>
