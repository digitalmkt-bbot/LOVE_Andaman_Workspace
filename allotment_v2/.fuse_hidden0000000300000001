.dep-title{font-size:11px;font-weight:600;color:var(--ink);margin-bottom:8px;border-bottom:1px solid var(--border);padding-bottom:6px}
.dep-row{display:flex;flex-direction:column;gap:3px;margin-bottom:8px}
.dep-lbl{font-size:10px;color:var(--ink-soft);font-weight:500}
.dep-status-grid{display:flex;gap:4px;margin-bottom:8px}
.dep-st{flex:1;padding:5px 4px;border-radius:5px;border:1px solid var(--border);text-align:center;font-size:10px;font-weight:500;cursor:pointer;color:var(--ink-soft);background:var(--white)}
.dep-st.active-exp{background:#fde8e6;border-color:#b93428;color:#b93428}
.dep-st.active-processing{background:#e6f1fb;border-color:#378add;color:#0c447c}
.dep-st.active-ok{background:#d6f0e5;border-color:#2d8a5e;color:#1a5c3d}
.dep-actions{display:flex;gap:6px;justify-content:flex-end;margin-top:8px;border-top:1px solid var(--border);padding-top:8px}
.h-bar{height:4px;background:rgba(26,35,50,.08);border-radius:2px;overflow:hidden;margin-top:3px}
.h-bar-inner{height:100%;border-radius:2px}
.section-title{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft)}
/* Filter bar (above sidebar+main) */
.ag-filter-bar{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;box-shadow:var(--shadow);margin-bottom:14px;display:flex;flex-direction:column;gap:8px}
.ag-filter-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.ag-filter-lbl{font-size:10px;font-weight:600;color:var(--ink-soft);letter-spacing:.06em;text-transform:uppercase;min-width:50px}
.ag-filter-bar .filter-pills{display:flex;gap:5px;flex-wrap:wrap}
.ag-filter-bar .fp{padding:3px 9px;border-radius:14px;font-size:11px;color:var(--ink-mid);background:var(--sand);border:1px solid var(--border);cursor:pointer;font-weight:500;transition:all .12s;display:inline-flex;align-items:center;gap:0}
.ag-filter-bar .fp:hover{background:var(--sand-dark)}
.ag-filter-bar .fp.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.ag-filter-bar .fp-cnt{margin-left:5px;padding:0 5px;font-size:9px;font-family:'DM Mono',monospace;background:rgba(0,0,0,.08);border-radius:8px;line-height:1.5}
.ag-filter-bar .fp.on .fp-cnt{background:rgba(255,255,255,.2)}

/* A-Z letter headers */
.sb-az-hd{padding:6px 14px 3px;font-size:10px;font-weight:600;color:var(--sb-pink-dark);background:linear-gradient(to right,var(--sb-pink-light) 0%, transparent 100%);letter-spacing:.05em;font-family:'DM Mono',monospace;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:1}

/* Sales badge in agent row */
.sb-sales-badge{flex-shrink:0;font-size:9px;font-weight:600;letter-spacing:.04em;padding:2px 6px;border-radius:8px;font-family:'DM Mono',monospace}

/* Sales avatar in detail */
.sales-avatar{width:34px;height:34px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600;letter-spacing:.02em;font-family:'DM Mono',monospace;flex-shrink:0}

/* ── Team & Markets module ── */
.tm-row{display:grid;grid-template-columns:42px 1fr auto;gap:12px;align-items:center;padding:12px 16px;border-bottom:0.5px solid var(--border);transition:all .12s}
.tm-row:hover{background:var(--sand)}
.tm-row:last-child{border-bottom:none}
.tm-color-chip{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600;font-family:'DM Mono',monospace;letter-spacing:.02em;flex-shrink:0;box-shadow:inset 0 0 0 1px rgba(0,0,0,.1)}
.tm-row-info{min-width:0;display:flex;flex-direction:column;gap:2px}
.tm-row-name{font-size:13px;font-weight:500;color:var(--ink);display:flex;align-items:center;gap:8px}
.tm-row-meta{font-size:10px;color:var(--ink-soft);font-family:'DM Mono',monospace;letter-spacing:.04em}
.tm-row-meta-pill{display:inline-block;padding:1px 6px;font-size:9px;background:var(--sand-dark);border-radius:8px;color:var(--ink-mid);margin-right:3px;font-family:'DM Mono',monospace}
.tm-row-actions{display:flex;gap:4px;flex-shrink:0;opacity:.4;transition:opacity .12s}
.tm-row:hover .tm-row-actions{opacity:1}
.tm-icon-btn{width:26px;height:26px;border-radius:5px;background:transparent;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--ink-mid);transition:all .12s}
.tm-icon-btn:hover{background:var(--ocean-50);border-color:var(--ocean-mid);color:var(--ocean)}
.tm-icon-btn.danger:hover{background:var(--red-light);border-color:var(--red);color:var(--red)}
.tm-icon-btn svg{width:12px;height:12px}
.tm-empty{padding:30px 18px;text-align:center;color:var(--ink-soft);font-size:12px}

/* Modal */
.tm-modal{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center}
.tm-modal-backdrop{position:absolute;inset:0;background:rgba(15,31,46,0.5);backdrop-filter:blur(2px)}
.tm-modal-card{position:relative;background:#fff;border-radius:14px;box-shadow:0 10px 40px rgba(0,0,0,.18);width:420px;max-width:90vw;max-height:90vh;display:flex;flex-direction:column;overflow:hidden}
.tm-modal-hd{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.tm-modal-ttl{font-size:14px;font-weight:600;color:var(--ink)}
.tm-modal-x{background:transparent;border:none;font-size:18px;cursor:pointer;color:var(--ink-soft);padding:0;width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:50%}
.tm-modal-x:hover{background:var(--sand)}
.tm-modal-body{padding:18px;overflow-y:auto;flex:1}
.tm-modal-actions{padding:12px 18px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;background:var(--sand-mid)}

.tm-fld{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.tm-fld-lbl{font-size:10px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-soft)}
.tm-fld input,.tm-fld textarea{padding:8px 10px;font-size:12px;font-family:'DM Sans',sans-serif;border:1px solid var(--border);border-radius:var(--r-sm);outline:none;transition:all .12s;color:var(--ink)}
.tm-fld input:focus,.tm-fld textarea:focus{border-color:var(--sb-pink);box-shadow:0 0 0 3px var(--sb-pink-light)}
.tm-color-picker{display:grid;grid-template-columns:repeat(8,1fr);gap:6px;margin-top:4px}
.tm-color-sw{width:28px;height:28px;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:all .12s;position:relative}
.tm-color-sw:hover{transform:scale(1.08)}
.tm-color-sw.on{border-color:var(--ink);box-shadow:0 0 0 2px #fff inset}
.tm-color-sw.custom{background:linear-gradient(135deg,#ff6b6b,#feca57,#48dbfb,#a55eea);display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:600}
.tm-color-hex{margin-top:8px;display:flex;align-items:center;gap:8px}
.tm-color-hex .preview{width:32px;height:32px;border-radius:6px;border:1px solid var(--border)}
.tm-color-hex input{flex:1;font-family:'DM Mono',monospace;font-size:12px}

/* Sales row fullname display */
.tm-row-fullname{font-size:11px;color:var(--ink-mid);margin-top:1px;font-weight:500}
.tm-row-fullname-pos{font-size:10px;color:var(--ink-soft);font-weight:400;letter-spacing:.02em}

/* Signature upload */
.tm-sig-upload{margin-top:4px}
.tm-sig-drop{
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;
  padding:18px 14px;border:1.5px dashed var(--border);border-radius:var(--r-sm);
  background:var(--sand);cursor:pointer;transition:all .15s;color:var(--ink-soft);
  font-size:11px;font-weight:500;
}
.tm-sig-drop:hover{border-color:var(--sb-pink);background:var(--sb-pink-light);color:var(--sb-pink-dark)}
.tm-sig-drop svg{width:22px;height:22px;stroke:currentColor}
.tm-sig-preview{
  position:relative;background:#fff;border:1px solid var(--border);border-radius:var(--r-sm);
  padding:10px;display:flex;align-items:center;justify-content:center;min-height:80px;
}
.tm-sig-preview img{max-height:80px;max-width:100%;object-fit:contain}
.tm-sig-remove{
  position:absolute;top:6px;right:6px;
  width:22px;height:22px;border-radius:50%;border:none;
  background:rgba(0,0,0,.5);color:#fff;cursor:pointer;
  display:inline-flex;align-items:center;justify-content:center;
}
.tm-sig-remove:hover{background:#A32D2D}
.tm-sig-remove svg{width:11px;height:11px}

