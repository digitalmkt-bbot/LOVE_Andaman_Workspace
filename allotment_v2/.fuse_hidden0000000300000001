  //   Step 2: Close · outcome=success · note="ใช้งานปกติ"
  if(d._app_hooks && !d._app_hooks.mj024_withdraw_close_v1){
    if(d.fleet_maintenance && d.fleet_inventory){
      const mj = d.fleet_maintenance.find(m=>m.no === 'MJ-024');
      const i62 = d.fleet_inventory.find(x=>x.id === 'i62');
      
      if(mj && mj.status === 'inprogress' && i62){
        const ACTION_DATE = '2026-05-13';  // วันรับของ + ติดตั้ง
        const CLOSE_DATE = '2026-05-13';
        
        // STEP 1: Withdraw ไดร์ชาร์จ 1 ชิ้น
        const wdQty = 1;
        const wdLocation = 'คลัง Tub Lamu';
        
        // Deduct from inventory (multi-warehouse)
        if(i62.stocks){
          const stockEntry = i62.stocks.find(s=>s.location === wdLocation);
          if(stockEntry && stockEntry.qty >= wdQty){
            stockEntry.qty -= wdQty;
            // Recompute legacy
            const total = i62.stocks.reduce((s,x)=>s+(x.qty||0), 0);
            i62.qty = total;
            i62.totalQty = total;
            const sorted = [...i62.stocks].sort((a,b)=>(b.qty||0)-(a.qty||0));
            i62.primaryLocation = sorted[0]?.location || wdLocation;
            i62.location = i62.primaryLocation;
          }
        }
        // Log withdraw to inventory history
        if(!i62.history) i62.history = [];
        i62.history.push({
          date: ACTION_DATE,
          type: 'withdraw',
          qty: wdQty,
          location: wdLocation,
          note: `เบิกใช้งาน ${mj.no} · ${mj.title}`,
          by: 'ระบบ',
          jobId: mj.id
        });
        
        // Add to job parts
        if(!mj.parts) mj.parts = [];
        mj.parts.push({
          invId: i62.id,
          name: i62.name,
          qty: wdQty,
          unit: i62.unit,
          cost: i62.cost,
          location: wdLocation
        });
        
        // Recompute MJ cost (parts only · no labor in this case)
        mj.cost = mj.parts.reduce((s,p)=>s+(p.qty*p.cost), 0);
        
        // Progress log: withdraw
        if(!mj.progressLog) mj.progressLog = [];
        mj.progressLog.push({
          date: ACTION_DATE,
          text: `📦 เบิก ${i62.name} ${wdQty} ${i62.unit} (฿${(wdQty*i62.cost).toLocaleString()})`,
          by: 'ระบบ'
        });
        
        // STEP 2: Close · outcome=success
        mj.status = 'done';
        mj.endDate = CLOSE_DATE;
        mj.outcome = 'success';
        mj.closeNote = 'ใช้งานปกติ';
        mj.awaitingInvoice = false;
        
        // Update boat log — outcome=success means boat status returns to 'available'
        // (but boat was already 'available' during this MJ, so no change needed visually)
        // Still push a "closed" log entry for history
        const b = d.boats?.find(x=>x.id === mj.boatId);
        if(b){
          if(!b.log) b.log = [];
          // Push closing log
          const lastLog = b.log[b.log.length-1];
          // Close any open log entry
          if(lastLog && !lastLog.to){
            lastLog.to = CLOSE_DATE;
          }
          // Add new "available" entry from CLOSE_DATE
          b.log.push({
            id: 'sl'+Date.now(),
            s: 'available',
            from: CLOSE_DATE, to: null,
            loc: lastLog?.loc || '',
            note: `ปิด Job ${mj.no}`,
            reason: ''
          });
          // Repair history
          if(!b.repairHistory) b.repairHistory = [];
          b.repairHistory.push({
            date: CLOSE_DATE,
            jobNo: mj.no,
            title: mj.title,
            detail: '',
            type: mj.type,
            location: '',
            cost: mj.cost,
            assets: (mj.assets||[]).map(a=>a.label),
            startDate: mj.startDate,
            endDate: CLOSE_DATE,
            outcome: 'success',
            closeNote: 'ใช้งานปกติ'
          });
        }
        
        // Reset engine assets back to ready (outcome=success)
        (mj.assets||[]).forEach(a=>{
          if(a.type === 'engine' && a.engId && d.fleet_engines){
            const eng = d.fleet_engines.find(e=>e.id===a.engId);
            if(eng){
              eng.status = 'ready';   // outcome=success
              if(!eng.log) eng.log = [];
              eng.log.push({
                date: CLOSE_DATE,
                type: 'service-end',
                desc: `✓ ปิด Job · ${mj.no} · ${mj.title} · ใช้งานปกติ`,
                detail: 'ใช้งานปกติ',
                hours: eng.baseHours || 0
              });
            }
          }
        });
        
        // Close linked incident
        if(mj.incidentId && d.fleet_incidents){
          const inc = d.fleet_incidents.find(i=>i.id === mj.incidentId);
          if(inc && inc.status === 'open'){
            inc.status = 'closed';
            inc.closedDate = CLOSE_DATE;
            if(!inc.progressLog) inc.progressLog = [];
            inc.progressLog.push({
              date: CLOSE_DATE,
              text: `✓ ปิด Incident · Job ${mj.no} เสร็จ · ใช้งานปกติ`,
              by: 'ระบบ'
            });
          }
        }
        
        // Final progress log
        mj.progressLog.push({
          date: CLOSE_DATE,
          text: `✓ ปิด Job · สำเร็จ — ใช้งานปกติ · ค่าใช้จ่ายรวม ฿${mj.cost.toLocaleString()}`,
          by: 'ระบบ'
        });
      }
    }
    d._app_hooks.mj024_withdraw_close_v1 = true;
    localStorage.setItem(LS_KEY,JSON.stringify(d));
  }
  
