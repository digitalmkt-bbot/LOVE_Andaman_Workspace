    const stBg=m.status==='pending'?dim.ink:'#FAEEDA';
    const stText=m.status==='pending'?'white':'#854F0B';
    if(isFirst){
      const chips=[];
      if(m.assets&&m.assets.length)chips.push(`${m.assets.length} ${m.assets[0].type}${m.assets.length>1?'s':''} 🔥`);
      if(m.incidentId){const inc=FL_INCIDENTS.find(i=>i.id===m.incidentId);if(inc)chips.push(`linked ${inc.no}`);}
      const chipsHtml=chips.map(c=>`<span style="background:${SVG_PINK.soft};border-radius:14px;padding:3px 10px;font-size:10px;color:${SVG_PINK.text};font-weight:500">${c}</span>`).join('');
      return`<tr style="background:${SVG_PINK.soft}" onclick="${goMaint(m.id)}"><td style="padding:9px 6px;border-radius:8px 0 0 8px;cursor:pointer"><div style="display:flex;align-items:center;gap:6px"><div style="width:22px;height:22px;border-radius:50%;background:${SVG_PINK.accent};color:white;font-size:9px;display:flex;align-items:center;justify-content:center;font-weight:700">M</div><span style="font-weight:600;color:${SVG_PINK.text};font-family:'DM Mono',monospace;font-size:10px">${m.no}</span></div></td><td style="color:${SVG_PINK.text};font-weight:600">${b?b.name:'—'}</td><td style="text-align:right;color:${SVG_PINK.text};font-weight:600">฿${(m.cost||0).toLocaleString()}</td><td style="text-align:right;border-radius:0 8px 8px 0"><span style="background:${stBg};color:${stText};padding:2px 8px;border-radius:9px;font-size:10px;font-weight:600">${m.status}</span></td></tr>
        ${chips.length?`<tr><td colspan="4" style="padding:8px 6px 4px"><div style="display:flex;gap:6px;flex-wrap:wrap">${chipsHtml}</div></td></tr>`:''}`;
    }
    return`<tr style="border-top:1px solid ${dim.line2}"><td colspan="4" style="padding:0;height:0"></td></tr>
      <tr onclick="${goMaint(m.id)}" style="cursor:pointer"><td style="padding:9px 0"><div style="display:flex;align-items:center;gap:6px"><div style="width:22px;height:22px;border-radius:50%;background:#BA7517;color:white;font-size:9px;display:flex;align-items:center;justify-content:center;font-weight:700">M</div><span style="font-weight:500;font-family:'DM Mono',monospace;font-size:10px">${m.no}</span></div></td><td style="font-weight:500">${b?b.name:'—'}</td><td style="text-align:right;font-weight:500">฿${(m.cost||0).toLocaleString()}</td><td style="text-align:right"><span style="background:${stBg};color:${stText};padding:2px 8px;border-radius:9px;font-size:10px;font-weight:600">${m.status}</span></td></tr>
      <tr><td colspan="4" style="padding:6px 0;font-size:10px;color:${dim.ink3}">${(m.title||'').replace(/^[^—]+—\s*/,'')||(m.detail||'')}</td></tr>`;
  }).join('');

  const maintCard=`<div style="background:white;border-radius:14px;padding:12px 14px;border:1px solid ${dim.line}">
    <table style="width:100%;font-size:11px;border-collapse:collapse">
      <thead>
        <tr style="color:${dim.ink3}"><th style="text-align:left;padding-bottom:8px;font-weight:500">Job</th><th style="text-align:left;font-weight:500">Boat</th><th style="text-align:right;font-weight:500">Cost</th><th style="text-align:right;font-weight:500">Status</th></tr>
      </thead>
      <tbody>
        <tr><td colspan="4" style="border-top:1px solid ${dim.line2}"></td></tr>
        ${maintRows||`<tr><td colspan="4" style="text-align:center;padding:14px;color:${dim.ink3};font-size:11px">no open jobs</td></tr>`}
        <tr><td colspan="4" style="padding:8px 0 0"><div style="display:flex;align-items:center;justify-content:space-between"><span style="font-size:11px;color:${dim.ink2};font-weight:500">${maintOpen.length} open / ${maintTotal} total</span><div style="display:flex;gap:6px"><span style="background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600">▴ ${maintOpen.length}</span><span style="background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600">฿${maintCost.toLocaleString()}</span></div></div></td></tr>
      </tbody>
    </table>
  </div>`;

  // Spare card (pink) — compact horizontal
  const spareCard=`<div onclick="nav(document.querySelector('[data-view=fl-asset]'))" style="background:${SVG_PINK.accent};border-radius:14px;padding:12px 14px;color:white;cursor:pointer;display:flex;flex-direction:column;justify-content:space-between">
    <div>
      <div style="font-size:9px;color:rgba(255,255,255,.75);font-weight:600;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px">Spare inventory</div>
      <div style="font-size:22px;font-weight:700;line-height:1">${totalSpare}<span style="font-size:11px;color:rgba(255,255,255,.75);font-weight:500;margin-left:4px">items</span></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:8px">
      <div><div style="font-size:9px;color:rgba(255,255,255,.7)">Gearbox</div><div style="font-size:13px;font-weight:700">${spareGbCnt}</div></div>
      <div><div style="font-size:9px;color:rgba(255,255,255,.7)">Propeller</div><div style="font-size:13px;font-weight:700">${sparePropCnt}</div></div>
      <div><div style="font-size:9px;color:rgba(255,255,255,.7)">On board</div><div style="font-size:12px;font-weight:600">${sparesOnBoats}<span style="font-size:9px;font-weight:500;opacity:.85"> · ${boatsCarrying} boats</span></div></div>
      <div><div style="font-size:9px;color:rgba(255,255,255,.7)">In repair</div><div style="font-size:12px;font-weight:600">${sparesInRepair}</div></div>
    </div>
  </div>`;

  // Low stock + memos — compact
  const lowStockRows=lowStock.slice(0,3).map(it=>`<tr style="border-top:0.5px solid ${dim.line2}">
    <td style="padding:5px 0"><span style="font-size:9px;color:${dim.ink3};font-family:'DM Mono',monospace">${it.partNo}</span></td>
    <td style="padding:5px 0;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:180px">${it.name}</td>
    <td style="text-align:right;padding:5px 0"><span style="background:#FCEBEB;color:#A32D2D;padding:2px 6px;border-radius:7px;font-size:10px;font-weight:600;font-family:'DM Mono',monospace">${it.qty}/${it.minQty}</span></td>
  </tr>`).join('');

  const memoChips=[
    ...memosPending.map(m=>`<span style="background:#FAEEDA;color:#854F0B;padding:2px 8px;border-radius:11px;font-size:9px;font-weight:600;font-family:'DM Mono',monospace">${m.no} · ฿${(m.amount||0).toLocaleString()}</span>`),
    ...memosOrdered.map(m=>`<span style="background:#E1F5EE;color:#0F6E56;padding:2px 8px;border-radius:11px;font-size:9px;font-weight:600;font-family:'DM Mono',monospace">${m.no} · ordered</span>`)
  ].slice(0,2).join('');

  const lowCard=`<div style="background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
      <span style="font-size:11px;color:${dim.ink};font-weight:600">Low stock</span>
      <span style="background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:1px 7px;border-radius:9px;font-size:9px;font-weight:600">${lowStock.length}</span>
      <span onclick="nav(document.querySelector('[data-view=fl-inventory]'))" style="margin-left:auto;font-size:10px;color:${dim.ink3};cursor:pointer">view →</span>
    </div>
    ${lowStock.length?`<table style="width:100%;font-size:11px;border-collapse:collapse"><tbody>${lowStockRows}</tbody></table>${lowStock.length>3?`<div style="font-size:9px;color:${dim.ink3};margin-top:4px;text-align:right">+${lowStock.length-3} more</div>`:''}`:`<div style="font-size:10px;color:${dim.ink3};text-align:center;padding:8px 0">all above min</div>`}
    <div style="display:flex;align-items:center;gap:6px;margin-top:8px;padding-top:8px;border-top:1px solid #f5f5f5">
      <span style="font-size:10px;color:${dim.ink};font-weight:600">Memos</span>
      <div style="display:flex;gap:4px;flex-wrap:wrap;flex:1;justify-content:flex-end">${memoChips||`<span style="font-size:9px;color:${dim.ink3}">none</span>`}</div>
    </div>
  </div>`;

  // Main grid: Available boats (left, tall) + right column with engine/maint and spare/low rows
  const midGrid=`<div style="display:grid;grid-template-columns:1fr 1.6fr;gap:10px;margin-bottom:10px;align-items:stretch">
    ${availCard}
    <div style="display:flex;flex-direction:column;gap:10px;min-width:0">
      <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:10px">${engCard}${maintCard}</div>
      <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:10px">${spareCard}${lowCard}</div>
    </div>
  </div>`;

  // ── A · Active Incidents detail ──
  const incCards=incOpen.slice(0,3).map(inc=>{
    const b=BOATS.find(x=>x.id===inc.boatId);
    const isMajor=inc.severity==='major';
    const accent=isMajor?'#A32D2D':'#854F0B';
    const bgTint=isMajor?'#FCEBEB':'#FAEEDA';
    const sevLabel=isMajor?'MAJOR':'MINOR';
    const dt=new Date(inc.date);
    const dateLbl=`${MONTHS_EN[dt.getMonth()]} ${dt.getDate()}`;
    return`<div onclick="nav(document.querySelector('[data-view=fl-incident]'))" style="background:white;border:1px solid ${dim.line};border-left:3px solid ${accent};border-radius:10px;padding:9px 11px;cursor:pointer;transition:all .12s" onmouseover="this.style.background='${bgTint}'" onmouseout="this.style.background='white'">
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
        <span style="font-family:'DM Mono',monospace;font-size:10px;font-weight:700;color:${accent}">${inc.no}</span>
        <span style="background:${bgTint};color:${accent};font-size:8px;font-weight:700;padding:1px 6px;border-radius:8px;letter-spacing:.06em">${sevLabel}</span>
        <span style="margin-left:auto;font-size:10px;color:${dim.ink3};font-family:'DM Mono',monospace">${dateLbl}</span>
      </div>
      <div style="font-size:12px;font-weight:600;color:${dim.ink};margin-bottom:2px">${b?b.name:'—'}</div>
      <div style="font-size:10px;color:${dim.ink2};line-height:1.4;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">${inc.title}</div>
      ${inc.maintId?`<div style="margin-top:6px;font-size:9px;color:${SVG_PINK.text};background:${SVG_PINK.soft};padding:2px 7px;border-radius:8px;display:inline-block;font-weight:500">linked maintenance</div>`:''}
    </div>`;
  }).join('');

  const incCard=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line}">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px">
      <span style="font-size:11px;color:${dim.ink};font-weight:600">⚠ Active incidents</span>
      <span style="background:#FCEBEB;color:#A32D2D;padding:1px 8px;border-radius:10px;font-size:10px;font-weight:600">${incOpen.length}</span>
      <span onclick="event.stopPropagation();nav(document.querySelector('[data-view=fl-incident]'))" style="margin-left:auto;font-size:11px;color:${dim.ink3};cursor:pointer">view all →</span>
    </div>
    ${incOpen.length?`<div style="display:flex;flex-direction:column;gap:7px">${incCards}</div>`:`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:30px 0">no active incidents</div>`}
  </div>`;

  // ── B · Service Due ── engines approaching/exceeding service interval (every 500h)
  const SERVICE_INTERVAL=500;
  const engineDue=FL_ENGINES.map(e=>{
    const h=(typeof flEngHours==='function'?flEngHours(e.id):e.baseHours||0)||0;
    const cyclesDone=Math.floor(h/SERVICE_INTERVAL);
    const nextServiceAt=(cyclesDone+1)*SERVICE_INTERVAL;
    const remaining=nextServiceAt-h;
    const pctToNext=((h%SERVICE_INTERVAL)/SERVICE_INTERVAL)*100;
    const b=BOATS.find(x=>x.id===e.boatId);
    return {e,b,h,nextServiceAt,remaining,pctToNext};
  }).filter(x=>x.b&&x.pctToNext>=70).sort((a,b)=>b.pctToNext-a.pctToNext);

  const dueRows=engineDue.slice(0,5).map(({e,b,h,remaining,pctToNext})=>{
    const isOverdue=remaining<=0;
    const isCritical=pctToNext>=95;
    const barColor=isOverdue?'#A32D2D':isCritical?SVG_PINK.accent:'#BA7517';
    const barBg=isOverdue?'#FCEBEB':isCritical?SVG_PINK.soft:'#FAEEDA';
    const labelColor=isOverdue?'#A32D2D':isCritical?SVG_PINK.text:'#854F0B';
    const remainText=isOverdue?`overdue ${Math.abs(remaining)}h`:`${remaining}h to service`;
    return`<div onclick="flGoToAsset('engines','${e.id}')" style="cursor:pointer;padding:6px 0;border-top:0.5px solid ${dim.line2}">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span style="font-family:'DM Mono',monospace;font-size:10px;font-weight:600;color:${dim.ink}">${e.serial}</span>
        <span style="font-size:10px;color:${dim.ink3}">${b.name} · ${e.pos}</span>
        <span style="margin-left:auto;font-family:'DM Mono',monospace;font-size:10px;color:${labelColor};font-weight:600">${h}h</span>
      </div>
      <div style="display:flex;align-items:center;gap:6px">
        <div style="flex:1;height:5px;background:${barBg};border-radius:3px;overflow:hidden">
          <div style="width:${Math.min(pctToNext,100)}%;height:100%;background:${barColor};border-radius:3px"></div>
        </div>
        <span style="font-size:9px;color:${labelColor};font-weight:600;min-width:80px;text-align:right">${remainText}</span>
      </div>
    </div>`;
  }).join('');

  const dueCard=`<div style="background:white;border-radius:14px;padding:13px 14px;border:1px solid ${dim.line}">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px">
      <span style="font-size:11px;color:${dim.ink};font-weight:600">🔧 Service due</span>
      <span style="background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:1px 8px;border-radius:10px;font-size:10px;font-weight:600">${engineDue.length}</span>
      <span onclick="event.stopPropagation();nav(document.querySelector('[data-view=fl-asset]'))" style="margin-left:auto;font-size:11px;color:${dim.ink3};cursor:pointer">view all →</span>
    </div>
    ${engineDue.length?`<div>${dueRows}</div>`:`<div style="font-size:11px;color:${dim.ink3};text-align:center;padding:30px 0">all engines healthy</div>`}
    <div style="margin-top:8px;padding-top:8px;border-top:1px solid #f5f5f5;font-size:9px;color:${dim.ink3};text-align:right">interval ${SERVICE_INTERVAL}h</div>
  </div>`;

  // ── C · Maintenance cost trend (last 6 months) ──
  const now=new Date(ds);
  const monthBuckets=[];
  for(let i=5;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    monthBuckets.push({key:`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`,label:MONTHS_EN[d.getMonth()],year:d.getFullYear(),cost:0,count:0});
  }
  FL_MAINT.forEach(m=>{
    const dt=m.startDate?m.startDate:m.endDate;
    if(!dt)return;
    const k=dt.slice(0,7);
    const bucket=monthBuckets.find(b=>b.key===k);
    if(bucket){bucket.cost+=m.cost||0;bucket.count++;}
  });
  const maxCost=Math.max(...monthBuckets.map(b=>b.cost),1);

  // Track which boats had work each month for marker avatars
  monthBuckets.forEach(b=>{b.boats=new Set();});
  FL_MAINT.forEach(m=>{
    const dt=m.startDate?m.startDate:m.endDate;
    if(!dt)return;
    const k=dt.slice(0,7);
    const bucket=monthBuckets.find(bb=>bb.key===k);
    if(bucket&&m.boatId)bucket.boats.add(m.boatId);
  });

  // SVG line chart
  const W=300, H=72, padX=8, padY=8;
  const innerW=W-padX*2, innerH=H-padY*2;
  const n=monthBuckets.length;
  const xAt=(i)=>padX+(i/(n-1))*innerW;
  const yAt=(v)=>padY+innerH-(v/maxCost)*innerH;

  // Smooth path using Catmull-Rom → cubic bezier
  const points=monthBuckets.map((b,i)=>({x:xAt(i),y:yAt(b.cost)}));
  const smoothPath=(pts)=>{
    if(pts.length<2)return'';
    let d=`M ${pts[0].x.toFixed(1)} ${pts[0].y.toFixed(1)}`;
    for(let i=0;i<pts.length-1;i++){
      const p0=pts[i-1]||pts[i];
      const p1=pts[i];
      const p2=pts[i+1];
      const p3=pts[i+2]||pts[i+1];
      const cp1x=p1.x+(p2.x-p0.x)/6;
      const cp1y=p1.y+(p2.y-p0.y)/6;
      const cp2x=p2.x-(p3.x-p1.x)/6;
      const cp2y=p2.y-(p3.y-p1.y)/6;
      d+=` C ${cp1x.toFixed(1)} ${cp1y.toFixed(1)}, ${cp2x.toFixed(1)} ${cp2y.toFixed(1)}, ${p2.x.toFixed(1)} ${p2.y.toFixed(1)}`;
    }
    return d;
  };
  const linePath=smoothPath(points);
  const fillPath=linePath+` L ${points[points.length-1].x.toFixed(1)} ${(padY+innerH).toFixed(1)} L ${points[0].x.toFixed(1)} ${(padY+innerH).toFixed(1)} Z`;

  // Previous period (mock: shifted by -20% as comparison baseline)
  const prevPath=smoothPath(monthBuckets.map((b,i)=>({x:xAt(i),y:yAt(b.cost*0.65+(maxCost*0.15))})));

  // Markers on peaks: top 2 cost months
  const sortedByCost=[...monthBuckets].map((b,i)=>({...b,i})).filter(b=>b.cost>0).sort((a,b)=>b.cost-a.cost).slice(0,2);
  const markersHtml=sortedByCost.map(m=>{
    const cx=xAt(m.i), cy=yAt(m.cost);
    const firstBoatId=[...m.boats][0];
    const boat=firstBoatId?BOATS.find(x=>x.id===firstBoatId):null;
    const init=boat?boatInitials(boat.name):'M';
    const c=boat?boatAvatarColor(boat):SVG_PINK.accent;
    return`<g><circle cx="${cx}" cy="${cy}" r="9" fill="${c}" stroke="white" stroke-width="2"/><text x="${cx}" y="${cy+3}" text-anchor="middle" fill="white" font-size="8" font-weight="700" font-family="-apple-system,sans-serif">${init}</text></g>`;
  }).join('');

  // Month labels
  const xLabels=monthBuckets.map((b,i)=>`<text x="${xAt(i)}" y="${H+10}" text-anchor="middle" fill="${dim.ink4}" font-size="9" font-family="-apple-system,sans-serif">${b.label}</text>`).join('');

  const totalCost6mo=monthBuckets.reduce((s,b)=>s+b.cost,0);
  const totalCount6mo=monthBuckets.reduce((s,b)=>s+b.count,0);

  // Segmented timeline bar (green→amber→red) — represents budget zones
  const segY=H+18;
  const seg1End=padX+innerW*0.4, seg2End=padX+innerW*0.7;
  const segBar=`
    <line x1="${padX}" y1="${segY}" x2="${seg1End}" y2="${segY}" stroke="#1D9E75" stroke-width="3" stroke-linecap="round"/>
    <line x1="${seg1End}" y1="${segY}" x2="${seg2End}" y2="${segY}" stroke="#BA7517" stroke-width="3" stroke-linecap="round"/>
    <line x1="${seg2End}" y1="${segY}" x2="${padX+innerW}" y2="${segY}" stroke="#A32D2D" stroke-width="3" stroke-linecap="round"/>`;

  const trendCard=`<div onclick="nav(document.querySelector('[data-view=fl-maintenance]'))" style="background:linear-gradient(to right, #FFF5EC 0%, #FBEAF0 40%, #FCE5EC 70%, #F5DDE6 100%);border-radius:14px;padding:13px 14px;border:1px solid ${dim.line};cursor:pointer;position:relative">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
      <span style="font-size:11px;color:${dim.ink};font-weight:600">📊 Maintenance cost</span>
      <span style="background:rgba(255,255,255,.5);color:${dim.ink2};padding:1px 8px;border-radius:10px;font-size:10px;font-weight:500">last 6 months</span>
      <span style="margin-left:auto;color:${dim.ink3};font-size:14px">↗</span>
    </div>
    <svg viewBox="0 0 ${W} ${H+30}" preserveAspectRatio="none" style="width:100%;height:110px;display:block;overflow:visible">
      <defs>
        <linearGradient id="trendFillGrad" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0" stop-color="#FAEEDA" stop-opacity="0.5"/>
          <stop offset="0.5" stop-color="#FCE5EC" stop-opacity="0.6"/>
          <stop offset="1" stop-color="${SVG_PINK.soft}" stop-opacity="0.85"/>
        </linearGradient>
      </defs>
      <path d="${fillPath}" fill="url(#trendFillGrad)"/>
      <path d="${prevPath}" fill="none" stroke="${dim.ink5}" stroke-width="1.3" stroke-dasharray="3 2.5" stroke-linecap="round"/>
      <path d="${linePath}" fill="none" stroke="${SVG_PINK.accent}" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round"/>
      ${markersHtml}
      ${segBar}
      ${xLabels}
    </svg>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:6px;padding-top:8px;border-top:1px solid rgba(0,0,0,.06)">
      <div>
        <div style="font-size:9px;color:${dim.ink3}">Total spend</div>
        <div style="font-size:14px;font-weight:700;color:${dim.ink};font-family:'DM Mono',monospace">฿${totalCost6mo.toLocaleString()}</div>
      </div>
      <div style="text-align:right">
        <div style="font-size:9px;color:${dim.ink3}">Jobs done</div>
        <div style="font-size:14px;font-weight:700;color:${dim.ink};font-family:'DM Mono',monospace">${totalCount6mo}</div>
      </div>
    </div>
  </div>`;

  const extraGrid=`<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">${incCard}${dueCard}${trendCard}</div>`;

  // Wrap in pink theme container
  const html=`<div style="background:${dim.bg};margin:-16px -16px 0;padding:18px 20px 22px;border-radius:0">
    ${headerBar}
    ${kpiStrip}
