}
#view-agents .ct-btn-renew:hover{background:var(--fd-coral-deep)}
#view-agents .ct-btn-renew svg{width:12px;height:12px}
#view-agents .ct-btn-renew.warn{background:#A32D2D}
#view-agents .ct-btn-renew.warn:hover{background:#7d2222}

/* Contract history bar */
#view-agents .ct-history{
  padding:12px 22px;background:var(--fd-bg);border-bottom:1px solid var(--fd-line-soft);
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
}
#view-agents .ct-history-lbl{font-size:9px;font-weight:700;color:var(--fd-ink-soft);letter-spacing:.06em;text-transform:uppercase;flex-shrink:0}
#view-agents .ct-history-pill{
  display:inline-flex;align-items:center;gap:8px;padding:5px 12px;
  background:#fff;border:1px solid var(--fd-line);border-radius:14px;font-size:11px;cursor:pointer;
  transition:all .12s;
}
#view-agents .ct-history-pill:hover{border-color:var(--fd-ink-faint)}
#view-agents .ct-history-pill.active{background:#E1F5EE;border-color:transparent;color:#0F6E56;font-weight:600}
#view-agents .ct-history-pill.active::before{content:'';width:6px;height:6px;border-radius:50%;background:#0F6E56;box-shadow:0 0 0 3px rgba(15,110,86,.15)}
#view-agents .ct-history-pill.expired{color:var(--fd-ink-soft)}
#view-agents .ct-history-pill .v{font-variant-numeric:tabular-nums;font-weight:700}
#view-agents .ct-history-pill .period{font-variant-numeric:tabular-nums;font-size:10px;color:inherit;opacity:.85}
#view-agents .ct-history-pill .ct-archived-icon{opacity:.6;font-size:11px}
#view-agents .ct-history-total{margin-left:auto;font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}

/* Renewal Wizard Modal */
#view-agents .ct-wiz{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center}
#view-agents .ct-wiz-backdrop{position:absolute;inset:0;background:rgba(20,20,20,.4);backdrop-filter:blur(2px)}
#view-agents .ct-wiz-card{position:relative;background:#fff;border-radius:18px;box-shadow:0 16px 48px rgba(0,0,0,.15);width:92%;max-width:680px;max-height:92vh;display:flex;flex-direction:column;overflow:hidden}
#view-agents .ct-wiz-hd{
  padding:18px 22px;border-bottom:1px solid var(--fd-line-soft);
  display:flex;align-items:center;justify-content:space-between;gap:14px;
  background:linear-gradient(90deg, var(--fd-coral-veryfaint) 0%, transparent 50%);
}
#view-agents .ct-wiz-ttl{font-size:15px;font-weight:700;color:var(--fd-coral-deep);letter-spacing:-0.01em}
#view-agents .ct-wiz-sub{font-size:11px;color:var(--fd-ink-mid);font-variant-numeric:tabular-nums;margin-top:1px}
#view-agents .ct-wiz-x{width:30px;height:30px;border-radius:50%;border:1px solid var(--fd-line);background:#fff;color:var(--fd-ink-mid);cursor:pointer;font-size:14px;line-height:1;display:flex;align-items:center;justify-content:center}
#view-agents .ct-wiz-x:hover{background:#FCEBEB;color:#A32D2D}

#view-agents .ct-wiz-steps{padding:14px 22px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--fd-line-soft);background:var(--fd-bg)}
#view-agents .ct-wstep{display:flex;align-items:center;gap:7px;color:var(--fd-ink-soft);font-size:11px;font-weight:600}
#view-agents .ct-wstep-num{width:22px;height:22px;border-radius:50%;background:#fff;border:1.5px solid var(--fd-ink-faint);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums}
#view-agents .ct-wstep.done .ct-wstep-num{background:#0F6E56;border-color:#0F6E56;color:#fff}
