}
function bkV2ReleaseModalSet(val){
  if(!_bkV2ReleaseModal) return;
  _bkV2ReleaseModal.value = Math.min(Math.max(0, Number(val)||0), _bkV2ReleaseModal.max);
  bkV2Render();
}
function bkV2ReleaseModalCancel(){ _bkV2ReleaseModal = null; bkV2Render(); }
function bkV2ReleaseModalCommit(){
  const m = _bkV2ReleaseModal; if(!m) return;
