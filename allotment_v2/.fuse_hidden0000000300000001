const LOCATION_TYPES={
  'Phang Nga':[
    {val:'Tub Lamu Pier',type:'pier',label:'Tub Lamu Pier'},
    {val:'อู่ซ่อม Phang Nga',type:'shop',label:'อู่ซ่อม'},
