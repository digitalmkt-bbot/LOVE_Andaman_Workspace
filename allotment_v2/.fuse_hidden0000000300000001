#view-agents .agi-info-card.coral{background:var(--fd-coral-soft)}
#view-agents .agi-info-card.coral .agi-info-lbl{color:var(--fd-coral-deep)}
#view-agents .agi-info-card.coral .agi-info-val{color:var(--fd-coral-deep)}
#view-agents .agi-info-lbl{font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--fd-ink-soft);margin-bottom:2px}
#view-agents .agi-info-val{font-size:14px;font-weight:600;color:var(--fd-ink);letter-spacing:-0.005em;line-height:1.35}
#view-agents .agi-info-val.mono{font-variant-numeric:tabular-nums;font-size:13px}
