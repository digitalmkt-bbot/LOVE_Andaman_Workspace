        return `
          <tr class="t2-row${r.cxl?' t2-cxl':''}">
            <td>${bk.voucherRef?`<span class="t2-mono">${esc(bk.voucherRef)}</span>`:'<span class="t2-dim">—</span>'}</td>
            <td><span class="t2-agency">${esc(norm.agentName)}</span></td>
            <td>
              <span class="t2-lead">${esc(lead)}</span>${r.cxl?`<span class="t2-cxlbadge" title="${bk.cancellation?('Cancelled · '+(bk.cancellation.chargeType==='full'?'Full charge':bk.cancellation.chargeType==='partial'?'Partial charge':'No charge')+(bk.cancellation.reason?' · '+esc(bk.cancellation.reason):'')):'Cancelled'}">CXL</span>`:''}
              ${others.length?`<button class="t2-more" onclick="event.stopPropagation();bkV2Tab2TogglePax('${rowId}')"><span id="${rowId}-ic" style="display:inline-block">▾</span> +${others.length}</button>`:'<span class="t2-dim t2-leadonly">lead only</span>'}
              ${(bk.rebook && bk.rebook.to===date && bk.rebook.reason==='weather')?`<div class="t2-movedin" title="Rescheduled from ${esc(bk.rebook.from)} due to weather">&#8617; Moved from ${esc(String(bk.rebook.from).slice(5))} · weather</div>`:''}
            </td>
            <td class="t2-c t2-mono">${P(r.pax,'ad')||'<span class="t2-dim">0</span>'}</td>
            <td class="t2-c t2-mono">${P(r.pax,'chd')||'<span class="t2-dim">0</span>'}</td>
            <td class="t2-c t2-mono">${P(r.pax,'inf')||'<span class="t2-dim">0</span>'}</td>
            <td class="t2-c t2-mono">${P(r.pax,'foc')?`<span style="color:#A32D2D">${P(r.pax,'foc')}</span>`:'<span class="t2-dim">0</span>'}</td>
            <td class="t2-mono">${esc(r.pickupTime || bk.pickupTime || '—')}</td>
            <td>${(bk.hotelName||bk.pickup)?esc(bk.hotelName||bk.pickup):'<span class="t2-needpickup" title="ยังไม่ได้ระบุจุดรับ · กดแก้ไขเพื่อเพิ่ม">&#9888; no pickup</span>'}</td>
            <td class="t2-c t2-mono">${esc(bk.roomNumber||'')||'<span class="t2-dim">—</span>'}</td>
