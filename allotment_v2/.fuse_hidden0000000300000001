}

function flMaintStart(id){
  const m=FL_MAINT.find(x=>x.id===id);if(!m)return;
  m.status='inprogress';
  const b=getBoat(m.boatId);
  // Determine target boat status (new field, fallback to legacy setFixing)
  const targetStatus = m.boatStatus || (m.setFixing===false ? 'available' : 'fixing');
  const targetReason = m.boatStatusReason || '';
  // Only push boat log if status is NOT available
  if(b && targetStatus !== 'available'){
    const cur=getCurStatus(b,TODAY_STR);
    if(typeof autoClosePrevLog==='function') autoClosePrevLog(b,TODAY_STR);
    b.log.push({
      id:'sl'+Date.now(),
      s:targetStatus,
      from:TODAY_STR,to:null,
      loc:m.location||cur.loc||'',
      note:`Maintenance Job ${m.no}`,
      reason: targetReason
    });
    renderBoats();
  }
  // Only cascade asset status to 'fixing' if boatStatus = fixing
  const cascadeAssetFixing = (targetStatus === 'fixing');

  // log "เริ่มซ่อม" to each affected asset (only set asset status if cascadeAssetFixing)
  (m.assets||[]).forEach(a=>{
    if(a.type==='engine'&&a.engId){
      const eng=flGetEng(a.engId);
      if(eng){
        if(!eng.log)eng.log=[];
        eng.log.push({date:TODAY_STR,type:'service-start',
          desc:`▶ เริ่มซ่อม · ${m.no} · ${m.title}${m.location?' @ '+m.location:''}`,
          detail:a.detail||m.detail||'',hours:flEngHours(eng.id)});
        if(cascadeAssetFixing) eng.status='fixing';
      }
    }
    if(a.type==='gearbox'&&a.gbId){
      const gb=FL_GEARBOXES.find(g=>g.id===a.gbId);
      if(gb){
        if(!gb.log)gb.log=[];
        gb.log.push({date:TODAY_STR,type:'service-start',
          desc:`▶ เริ่มซ่อม · ${m.no} · ${m.title}`,detail:a.detail||''});
        if(cascadeAssetFixing) gb.status='fixing';
      }
    }
    if(a.type==='propeller'&&a.propId){
      const p=FL_PROPELLERS.find(x=>x.id===a.propId);
      if(p){
        if(!p.log)p.log=[];
        p.log.push({date:TODAY_STR,type:'service-start',
          desc:`▶ เริ่มซ่อม · ${m.no} · ${m.title}`,detail:a.detail||''});
        if(cascadeAssetFixing) p.status='fixing';
      }
    }
  });

  const statusLabel = targetStatus==='fixing'?'Fixing':targetStatus==='unavailable'?'Unavailable':'Available';
  flPushLog(m.id,`▶ เริ่มงาน ${m.no} · ${m.title}${m.location?' → '+m.location:''}${b?' · '+b.name+' = '+statusLabel:''}`);
