  const opts=grid.querySelectorAll('.fl-st-opt');
  const colors=[{border:'var(--green)',bg:'var(--green-light)',txt:'var(--green-dark)'},{border:'var(--amber)',bg:'var(--amber-light)',txt:'#7a4a00'},{border:'var(--red)',bg:'var(--red-light)',txt:'var(--red)'},{border:'var(--border)',bg:'var(--sand)',txt:'var(--ink-soft)'}];
  opts.forEach((el,i)=>{
    if(i===idx){el.style.border=`1px solid ${colors[i].border}`;el.style.background=colors[i].bg;el.querySelector('div').style.color=colors[i].txt;}
    else{el.style.border='1px solid var(--border)';el.style.background='var(--white)';el.querySelector('div').style.color='var(--ink-soft)';}
