        memMj.closeNote = rawMj.closeNote;
        memMj.progressLog = rawMj.progressLog;
      }
    }
  }
  
  // Hook: Normalize NPSK Marine supplier names (merge "NPSK Marine (Honda)" + "NGK" → "NPSK Marine")
  if(d._app_hooks && !d._app_hooks.normalize_npsk_marine_v1){
    if(d.fleet_inventory){
      d.fleet_inventory.forEach(it=>{
        if(it.supplier === 'NPSK Marine (Honda)' || it.supplier === 'NGK'){
          it.supplier = 'NPSK Marine';
        }
      });
    }
    if(d.fleet_memos){
      d.fleet_memos.forEach(mo=>{
        if(mo.supplier === 'NPSK Marine (Honda)' || mo.supplier === 'NGK'){
          mo.supplier = 'NPSK Marine';
        }
        if(mo.title && mo.title.includes('NPSK Marine (Honda)')){
          mo.title = mo.title.replace('NPSK Marine (Honda)', 'NPSK Marine');
        }
      });
    }
    d._app_hooks.normalize_npsk_marine_v1 = true;
    localStorage.setItem(LS_KEY, JSON.stringify(d));
  }
  
  // Hook: Backfill supplier field for existing memos (one-time)
  if(d._app_hooks && !d._app_hooks.backfill_memo_supplier_v1){
    if(d.fleet_memos && d.fleet_inventory){
      d.fleet_memos.forEach(mo=>{
        if(mo.supplier && mo.supplier.trim()) return; // already has
        // Try inventory link first
        if(mo.items && mo.items.length > 0){
          const supplierCounts = {};
          mo.items.forEach(it => {
            if(it.invId){
              const inv = d.fleet_inventory.find(x=>x.id===it.invId);
              if(inv && inv.supplier) supplierCounts[inv.supplier] = (supplierCounts[inv.supplier]||0) + 1;
            }
          });
          const top = Object.entries(supplierCounts).sort((a,b)=>b[1]-a[1])[0];
          if(top){ mo.supplier = top[0]; return; }
        }
        // Fallback: regex on refNote
        if(mo.refNote){
          const segments = mo.refNote.split('·').map(s=>s.trim());
          const companyRegex = /\b(Marine|Mall|Co\.?\s*Ltd|Co\.|Ltd|Suzuki|Honda|Yamaha|Megazip|บจ\.|บริษัท|Hilltribe|Industries|Hardware|Parts|Service|Materials|Trading)\b/i;
          for(const seg of segments){
            if(companyRegex.test(seg)){
              mo.supplier = seg.replace(/^อ้างอิง\s*/i,'').replace(/\s+(IV\S+|SO\S+|QT\S+|IN\S*|CO\d+|\d{2}\/\d{2}\/\d{4}).*$/i,'').trim();
              return;
            }
          }
        }
      });
      d._app_hooks.backfill_memo_supplier_v1 = true;
      localStorage.setItem(LS_KEY, JSON.stringify(d));
    }
  }
}
function flSave(){
  const d=JSON.parse(localStorage.getItem(LS_KEY)||'{}');
  d.fleet_engines=FL_ENGINES;d.fleet_gearboxes=FL_GEARBOXES;d.fleet_propellers=FL_PROPELLERS;
  d.fleet_daily=FL_DAILY;d.fleet_maintenance=FL_MAINT;d.fleet_incidents=FL_INCIDENTS;
  d.fleet_inventory=FL_INVENTORY;d.fleet_memos=FL_MEMOS;d.fleet_safety=FL_SAFETY;d.fleet_projects=FL_PROJECTS;d.fleet_version=FLEET_VERSION;
  localStorage.setItem(LS_KEY,JSON.stringify(d));
}

