function flAdvanceMemo(id){
  const m=FL_MEMOS.find(x=>x.id===id);if(!m)return;
  // Flow depends on memo type:
  // - parts: created → pending → approved → ordered → received → paid
  // - labor: created → pending → approved → paid (skip ordered/received)
  // - mixed: same as parts (will partial-receive only parts items)
  const isLaborOnly=m.memoType==='labor'||(m.memoType==='mixed'&&!(m.items||[]).some(it=>(it.category||'parts')==='parts'));
  const s=isLaborOnly?['created','pending_approval','approved','paid','paid','paid']:['created','pending_approval','approved','ordered','received','paid'];
  const nextStep=m.currentStep+1;
  const nextStatus=s[nextStep]||'paid';

  // ถ้ากำลังจะอนุมัติ → เปิด approval modal
  if(nextStatus==='approved'){
    flOpenApproveModal(id);
    return;
  }
  // ถ้ากำลังจะรับของ → เปิด modal รับอะไหล่ก่อน (เฉพาะ parts/mixed memo ที่มี parts items)
  if(nextStatus==='received'&&(m.items||[]).some(it=>(it.category||'parts')==='parts')){
    flOpenReceiveMemo(id);
    return;
  }
  m.currentStep=nextStep;
  m.status=nextStatus;
  flSave();flRenderInventory();
  flShowToast(`Memo ${m.no} → ${['สร้าง','รออนุมัติ','อนุมัติ','สั่งซื้อ','รับของ','จ่ายแล้ว'][nextStep]||''}`);
}

