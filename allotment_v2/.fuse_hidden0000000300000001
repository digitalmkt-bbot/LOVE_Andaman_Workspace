// ═══════════════ GANTT VIEW (original bar chart) ═══════════════
function flProjRenderGantt(allProjects){
  const P = PROJ_PALETTE;
  // Build month range: from earliest planFrom (or today - 1m) to latest planTo + buffer
  const today = new Date(TODAY_STR);
  const monthsBack = 1;
  const monthsForward = Math.max(_projTimelineMonths, 6);
  const start = new Date(today.getFullYear(), today.getMonth()-monthsBack, 1);
  const end   = new Date(today.getFullYear(), today.getMonth()+monthsForward, 0);
  const totalDays = Math.ceil((end-start)/86400000) + 1;
  const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  // Build month columns
  const months = [];
  let cursor = new Date(start);
  while(cursor<=end){
    const y = cursor.getFullYear(), m = cursor.getMonth();
    const dim = new Date(y,m+1,0).getDate();
    const monthStart = new Date(y,m,1);
    const offset = Math.ceil((monthStart-start)/86400000);
    months.push({label:`${MON[m]} ${String(y).slice(2)}`, days:dim, offset, y, m});
    cursor.setMonth(cursor.getMonth()+1);
  }
  // Filter projects with valid date ranges + overlap window
  const inWindow = allProjects.filter(p=>{
    if(!p.planFrom||!p.planTo) return false;
    return p.planFrom<=end.toISOString().slice(0,10) && p.planTo>=start.toISOString().slice(0,10);
  });
  if(!inWindow.length){
    return `<div style="background:white;border:1px dashed ${P.line};border-radius:18px;padding:48px;text-align:center;color:${P.ink3};font-size:13px;box-shadow:${P.shadow}">
      <div style="display:inline-flex;width:48px;height:48px;border-radius:50%;background:${P.bg};color:${P.ink3};align-items:center;justify-content:center;margin-bottom:12px">${flProjIcon('ganttChart',22,P.ink3)}</div>
      <div>No projects with date range overlapping this window.</div>
      <div style="font-size:11px;color:${P.ink4};margin-top:6px">${start.toISOString().slice(0,10)} → ${end.toISOString().slice(0,10)}</div>
    </div>`;
  }
  // Group by boat
  const byBoat = {};
  inWindow.forEach(p=>{
    if(!byBoat[p.boatId]) byBoat[p.boatId] = [];
    byBoat[p.boatId].push(p);
  });
  // Bar style by status — match Timeline side-panel tone palette (BuildAxis style)
  const barStyle = (status)=>{
    if(status==='completed')  return {bg:'#DCFCE7', border:'#22C55E', ink:'#15803D', icon:'checkCircle'};
    if(status==='inprogress') return {bg:'#FEEDE8', border:'#F97316', ink:'#C2410C', icon:'wrench'};
    if(status==='on_hold')    return {bg:'#FEF3CD', border:'#F59E0B', ink:'#92400E', icon:'pause'};
    if(status==='cancelled')  return {bg:'#FEE7E7', border:'#EF4444', ink:'#B91C1C', icon:'xCircle'};
    return {bg:'#E0E7FF', border:'#6366F1', ink:'#3730A3', icon:'calendar'};
  };
  // Today marker position
  const todayOffset = Math.ceil((today-start)/86400000);
  const todayPct = todayOffset/totalDays*100;

  // Header: month columns
  const monthHeader = months.map(mo=>`
    <div style="flex:${mo.days};text-align:center;padding:10px 6px;font-size:10px;font-weight:700;color:${P.ink3};border-right:1px solid ${P.line};letter-spacing:.08em;text-transform:uppercase">${mo.label}</div>
  `).join('');

  // Boat rows
  const rows = Object.keys(byBoat).map((bId, rowIdx)=>{
    const boat = BOATS.find(b=>b.id===bId);
    const projs = byBoat[bId].sort((a,b)=>(a.planFrom||'').localeCompare(b.planFrom||''));
    const bars = projs.map(p=>{
      const ps = new Date(p.planFrom);
      const pe = new Date(p.planTo);
      const startOffset = Math.max(0, Math.ceil((ps-start)/86400000));
      const endOffset   = Math.min(totalDays, Math.ceil((pe-start)/86400000)+1);
      const leftPct = startOffset/totalDays*100;
      const widthPct = Math.max(1, (endOffset-startOffset)/totalDays*100);
      const s = barStyle(p.status);
      const label = `${p.no} · ${p.name.length>34?p.name.slice(0,32)+'…':p.name}`;
      const showIcon = widthPct > 3;
      return `<div onclick="flProjOpen('${p.id}')" style="position:absolute;left:${leftPct}%;width:${widthPct}%;top:8px;bottom:8px;background:${s.bg};border:1px solid ${s.border};border-radius:10px;color:${s.ink};font-size:11px;padding:0 10px;cursor:pointer;display:flex;align-items:center;gap:6px;overflow:hidden;white-space:nowrap;font-weight:600;transition:all .15s;box-shadow:0 1px 2px rgba(15,23,42,.05)" onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 4px 8px rgba(15,23,42,.08)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 1px 2px rgba(15,23,42,.05)'" title="${p.name} · ${p.planFrom} → ${p.planTo} · ${p.status}">
        ${showIcon?`<span style="flex-shrink:0;display:inline-flex">${flProjIcon(s.icon,12,s.border,2)}</span>`:''}
        <span style="overflow:hidden;text-overflow:ellipsis">${label}</span>
      </div>`;
    }).join('');
    const rowBg = rowIdx%2===0 ? 'white' : '#FAFBFD';
    const avatarColor = flBoatAvatarColor(boat);
    const initials = flBoatInitials(boat?boat.name:'?');
    const meta = flBoatMeta(boat);
    return `<div style="display:grid;grid-template-columns:200px 1fr;border-bottom:1px solid ${P.line};min-height:58px;background:${rowBg}">
      <div style="padding:12px 16px;border-right:1px solid ${P.line};display:flex;align-items:center;gap:11px">
        <div style="width:36px;height:36px;border-radius:50%;background:${avatarColor};color:white;font-size:11px;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;letter-spacing:.02em">${initials}</div>
        <div style="min-width:0;flex:1">
          <div style="font-size:13px;font-weight:700;color:${P.navy};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${boat?boat.name:'?'}</div>
          <div style="font-size:10px;color:${P.ink3};margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${meta||`${projs.length} project${projs.length===1?'':'s'}`}</div>
        </div>
      </div>
      <div style="position:relative">${bars}</div>
    </div>`;
  }).join('');

  // Legend chips (BuildAxis style)
  const legendChip = (label, bg, border, ink, icon)=>`<span style="display:inline-flex;align-items:center;gap:6px;background:${bg};color:${ink};border:1px solid ${border};border-radius:14px;padding:3px 10px;font-size:10px;font-weight:600">${flProjIcon(icon,11,border,2)} ${label}</span>`;

  return `
    <div style="background:white;border:1px solid ${P.line};border-radius:18px;overflow:hidden;box-shadow:${P.shadow}">
      <!-- Top header bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid ${P.line};background:linear-gradient(180deg, #FAFBFD 0%, white 100%)">
        <div>
          <div style="font-size:14px;letter-spacing:.4px;color:${P.navy};font-weight:800;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px">${flProjIcon('ganttChart',13,P.blue)} Gantt Overview</div>
          <div style="font-size:14px;color:${P.navy};font-weight:700;margin-top:4px;font-variant-numeric:tabular-nums">${Object.keys(byBoat).length} boats · ${inWindow.length} projects</div>
        </div>
        <div style="display:flex;gap:6px;align-items:center">
          <button onclick="_projTimelineMonths=Math.max(3,_projTimelineMonths-3);flRenderProjects()" style="background:white;border:1px solid ${P.line};color:${P.ink2};border-radius:10px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:4px">${flProjIcon('arrowLeft',12,P.ink2)} 3m</button>
          <span style="font-size:10px;color:${P.ink3};padding:0 4px">${monthsBack}m back · ${monthsForward}m fwd</span>
          <button onclick="_projTimelineMonths+=3;flRenderProjects()" style="background:white;border:1px solid ${P.line};color:${P.ink2};border-radius:10px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:4px">3m ${flProjIcon('arrowRight',12,P.ink2)}</button>
        </div>
      </div>

      <!-- Month header strip -->
      <div style="display:grid;grid-template-columns:200px 1fr;border-bottom:1px solid ${P.line};background:${P.bg}">
        <div style="padding:10px 16px;font-size:10px;font-weight:700;color:${P.ink3};border-right:1px solid ${P.line};letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:6px">${flProjIcon('hardHat',12,P.ink3)} Boat <span style="background:white;color:${P.ink3};border:1px solid ${P.line};border-radius:8px;padding:1px 7px;font-size:9px;font-weight:700;margin-left:4px">${Object.keys(byBoat).length}</span></div>
        <div style="display:flex">${monthHeader}</div>
      </div>

      <!-- Rows with today marker overlay -->
      <div style="position:relative">
        ${rows}
        ${todayPct>=0 && todayPct<=100 ? `
          <div style="position:absolute;left:calc(200px + (100% - 200px) * ${todayPct}/100);top:0;bottom:0;width:0;pointer-events:none">
            <div style="position:absolute;top:0;bottom:0;width:2px;background:${P.red};opacity:.45;transform:translateX(-1px)"></div>
            <div style="position:absolute;top:-1px;left:-22px;background:${P.red};color:white;font-size:9px;font-weight:700;padding:2px 8px;border-radius:0 0 8px 8px;letter-spacing:.06em">TODAY</div>
          </div>
        ` : ''}
      </div>

      <!-- Footer legend bar -->
      <div style="padding:14px 20px;border-top:1px solid ${P.line};background:${P.bg};display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        ${legendChip('Scheduled',   '#E0E7FF', '#6366F1', '#3730A3', 'calendar')}
        ${legendChip('In Progress', '#FEEDE8', '#F97316', '#C2410C', 'wrench')}
        ${legendChip('On Hold',     '#FEF3CD', '#F59E0B', '#92400E', 'pause')}
        ${legendChip('Completed',   '#DCFCE7', '#22C55E', '#15803D', 'checkCircle')}
        ${legendChip('Cancelled',   '#FEE7E7', '#EF4444', '#B91C1C', 'xCircle')}
        <span style="margin-left:auto;display:inline-flex;align-items:center;gap:6px;font-size:10px;color:${P.ink2};font-weight:600">
          <span style="display:inline-block;width:2px;height:14px;background:${P.red};opacity:.45;border-radius:1px"></span>
          Today line
        </span>
      </div>
    </div>`;
}

