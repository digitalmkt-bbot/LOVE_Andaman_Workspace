function flSaveIncident(){
  const boatId=document.getElementById('fl-inc-boat').value;
  const date=document.getElementById('fl-inc-date').value;
  const time=document.getElementById('fl-inc-time').value;
  const title=document.getElementById('fl-inc-title').value.trim();
  if(!boatId||!date||!title){alert('กรุณากรอกข้อมูลให้ครบ');return;}
  // collect damaged assets (multi-select)
  const damagedAssets=[];
  document.querySelectorAll('.dmg-engine-cb:checked').forEach(cb=>{
    const id=cb.value;const e=flGetEng(id);
    if(e)damagedAssets.push({type:'engine',id,label:`${e.serial} · ${e.pos||''}`});
  });
  document.querySelectorAll('.dmg-gearbox-cb:checked').forEach(cb=>{
    const id=cb.value;const g=FL_GEARBOXES.find(x=>x.id===id);
    if(g)damagedAssets.push({type:'gearbox',id,label:`${g.serial}${g.note?' · '+g.note:''}`});
  });
  document.querySelectorAll('.dmg-propeller-cb:checked').forEach(cb=>{
    const id=cb.value;const p=FL_PROPELLERS.find(x=>x.id===id);
    if(p)damagedAssets.push({type:'propeller',id,label:`${p.serial}${p.note?' · '+p.note:''}`});
  });
  const dmgHullRaw=document.getElementById('fl-inc-dmg-hull')?.value.trim()||'';
  if(dmgHullRaw){
    dmgHullRaw.split(',').map(s=>s.trim()).filter(Boolean).forEach(label=>{
      damagedAssets.push({type:'hull',id:null,label});
    });
  }
  const remark=document.getElementById('fl-inc-remark').value.trim();
  const detail=document.getElementById('fl-inc-detail-input').value.trim();
  const priority=parseInt(document.getElementById('fl-inc-priority').value)||5;
  const severity=priority>=4?'critical':priority>=3?'major':'minor';

  // ── EDIT MODE — update existing incident ──
  if(_editingIncId){
    const existing=FL_INCIDENTS.find(i=>i.id===_editingIncId);
    if(existing){
      existing.boatId=boatId;
      existing.date=date;
      existing.time=time;
      existing.title=title;
      existing.detail=detail;
      existing.remark=remark;
      existing.damagedAssets=damagedAssets;
      existing.priority=priority;
      existing.severity=severity;
      if(!existing.progressLog) existing.progressLog=[];
      existing.progressLog.push({date:TODAY_STR,text:`✎ แก้ไขรายละเอียด${damagedAssets.length?' · ความเสียหาย: '+damagedAssets.map(a=>a.label).join(', '):''}`,by:remark||'ระบบ'});
    }
    _editingIncId=null;
    flSave();closeModal('fl-modal-incident');flRenderIncident();
    return;
  }

  // ── CREATE MODE — new incident ──
  const isQuickFix = !!document.getElementById('fl-inc-quickfix')?.checked;
  const cause = document.getElementById('fl-inc-cause')?.value || '';

  const _incMaxNo = FL_INCIDENTS.length
    ? Math.max(0, ...FL_INCIDENTS.map(i => parseInt(String(i.no||'').replace(/^INC-/,'')) || 0))
    : 0;
  const no='INC-'+String(_incMaxNo+1).padStart(3,'0');

  // Build remark — prepend Root cause if specified
  const remarkParts = [];
  if(cause) remarkParts.push(`Root cause: ${cause}`);
  if(remark) remarkParts.push(remark);
  if(isQuickFix) remarkParts.push('Quick Fix · resolved same-day · no maintenance job');
  const remarkFinal = remarkParts.join(' · ');

  // Build progress log
  const progressLog = [{date, text:`เปิด Incident: ${title}${damagedAssets.length?' · ความเสียหาย: '+damagedAssets.map(a=>a.label).join(', '):''}`, by:remark||'ระบบ'}];
  if(isQuickFix){
    progressLog.push({date, text:`✓ ปิดทันที (Quick Fix)${cause?' · Root cause: '+cause:''}${detail?' · '+detail.slice(0,140)+(detail.length>140?'…':''):''}`, by:''});
  }

  const inc={
    id:'inc'+Date.now(), no, boatId, date, time, title,
    detail, remark:remarkFinal, damagedAssets, priority, severity,
    type:'incident',
    status: isQuickFix ? 'resolved' : 'open',
    maintId:null,
    quickFix: isQuickFix ? true : undefined,
    resolvedDate: isQuickFix ? date : undefined,
    progressLog
  };
  flAssertUniqueNo(FL_INCIDENTS, no, 'INC');
  FL_INCIDENTS.unshift(inc);

  // Append asset log entries (audit trail) for Quick Fix
  if(isQuickFix){
    damagedAssets.forEach(a => {
      let obj = null;
      if(a.type==='engine') obj = (FL_ENGINES||[]).find(e=>e.id===a.id);
      else if(a.type==='gearbox') obj = (FL_GEARBOXES||[]).find(g=>g.id===(a.gbId||a.id));
      else if(a.type==='propeller') obj = (FL_PROPELLERS||[]).find(p=>p.id===(a.propId||a.id));
      if(obj){
        obj.log = obj.log || [];
        obj.log.push({date, type:'quickfix', desc:`Quick Fix · ${no} · ${title}`, engineHours:0});
      }
    });
  }

  flSave();
  closeModal('fl-modal-incident');
  if(typeof flRenderIncident==='function') flRenderIncident();
  if(isQuickFix && typeof renderBoats==='function') renderBoats();
  if(typeof flShowToast==='function') flShowToast(`${isQuickFix?'Quick Fix':'Incident'} logged: ${no}`);
}


