  // Hook: MIGRATE PROPELLER SERIALS to new format
  //   Active: {BOAT}-{POS}-{ROT}-{PITCH}-{NN}
  //   Spare:  SPARE-{ROT}-{PITCH}-{NN}
  // v2: ใช้ parseFloat (ไม่ parseInt) เพื่อคง decimal pitch เช่น 16.5
  
  // Reset v1 flag เพื่อให้ v2 run ใหม่บน data ที่ migrate ผิดไปแล้ว
  if(d._app_hooks && d._app_hooks.migrate_propeller_serials_v1 && !d._app_hooks.migrate_propeller_serials_reset_for_v2){
    delete d._app_hooks.migrate_propeller_serials_v1;
    // Reset serials ของ propeller ที่ migrate ผิด (pitch 16.5 → 16) กลับเป็น oldSerial เพื่อให้ v2 migrate ใหม่
    if(d.fleet_propellers){
      d.fleet_propellers.forEach(p => {
        if(p.oldSerial && /^AL2-/.test(p.serial||'') && parseFloat(p.pitch||0) === 16.5){
          p.serial = p.oldSerial;
          delete p.oldSerial;
          if(Array.isArray(p.log)){
            p.log = p.log.filter(l => !(l.type === 'rename' && (l.desc||'').includes('Migrate serial')));
          }
        }
      });
    }
    d._app_hooks.migrate_propeller_serials_reset_for_v2 = true;
    localStorage.setItem(LS_KEY,JSON.stringify(d));
  }
  
  if(d._app_hooks && !d._app_hooks.migrate_propeller_serials_v2){
    if(!d.fleet_propellers) d.fleet_propellers = [];
    
    // Boat code lookup
    const BOAT_CODE = {
      'b1':'AL1','b2':'ART','b3':'OK','b4':'IR','b5':'ARY',
      'b6':'ZE','b7':'VE','b8':'TA','b9':'RO','b10':'AL2',
      'b11':'AC','b12':'HE','b13':'OC','b14':'JU','b15':'RL'
    };
    
    // Position parse: PR-SL-PO-001 → POS = PO (Port)
    //                 PR-SL-CP-001 → POS = CP
    //                 PR-SL-CS-001 → POS = CS
    //                 PR-SL-ST-001 → POS = ST → S
    const POS_FROM_OLD = {
      'PO':'P', 'CP':'CP', 'CS':'CS', 'ST':'S',
      'CE':'CE' // center (Juliet 3-engine boats)
    };
    
    // Rotation code: Standard → RH, Counter → LH
    const ROT_CODE = (rotation) => rotation === 'Counter' ? 'LH' : 'RH';
    
    // Track NN counter per (boat, pos, rot, pitch) and per (SPARE, rot, pitch)
    const activeCounter = {};
    const spareCounter = {};
    
    let migratedActive = 0, migratedSpare = 0;
    
    d.fleet_propellers.forEach(p => {
      // Skip if already migrated (new format starts with letters not "PR-" or "LEXOR" or "SOLAS")
      const oldSerial = p.serial || '';
      const isOldPR = oldSerial.startsWith('PR-');
      const isLexorSolas = /^(LEXOR|SOLAS)\s/.test(oldSerial);
      if(!isOldPR && !isLexorSolas) return; // assume already new format
      
      // Save old serial for trace
      if(!p.oldSerial) p.oldSerial = oldSerial;
      
      const rot = ROT_CODE(p.rotation);
      const pitch = parseFloat(p.pitch) || 0;
      
      if(p.status === 'spare' || !p.boatId){
        // SPARE case
        const key = `SPARE-${rot}-${pitch}`;
        spareCounter[key] = (spareCounter[key] || 0) + 1;
        const nn = String(spareCounter[key]).padStart(2,'0');
        p.serial = `SPARE-${rot}-${pitch}-${nn}`;
        migratedSpare++;
      } else {
        // ACTIVE case
        const boatCode = BOAT_CODE[p.boatId] || 'UNK';
        // Parse position from old serial: PR-SL-XX-NNN → XX
        let pos = 'P';
        if(isOldPR){
          const parts = oldSerial.split('-');
          const oldPos = parts[2] || '';
          pos = POS_FROM_OLD[oldPos] || oldPos;
        } else {
          // For LEXOR/SOLAS active props (shouldn't happen normally · fallback to note)
          const noteLower = (p.note||'').toLowerCase();
          if(noteLower.includes('c.port') || noteLower.includes('c port')) pos = 'CP';
          else if(noteLower.includes('c.std') || noteLower.includes('c std')) pos = 'CS';
          else if(noteLower.includes('center') || noteLower.includes('centre')) pos = 'CE';
          else if(noteLower.includes('port')) pos = 'P';
          else if(noteLower.includes('std') || noteLower.includes('starboard')) pos = 'S';
        }
        const key = `${boatCode}-${pos}-${rot}-${pitch}`;
        activeCounter[key] = (activeCounter[key] || 0) + 1;
        const nn = String(activeCounter[key]).padStart(2,'0');
        p.serial = `${boatCode}-${pos}-${rot}-${pitch}-${nn}`;
        migratedActive++;
      }
      
      // Add log entry for migration
      if(!Array.isArray(p.log)) p.log = [];
      p.log.push({
        date: '2026-05-23',
        type: 'rename',
        desc: `Migrate serial: ${oldSerial} -> ${p.serial}`
      });
    });
    
    console.log(`[Migrate Props v2] Active: ${migratedActive} · Spare: ${migratedSpare} · Total: ${migratedActive+migratedSpare}`);
    d._app_hooks.migrate_propeller_serials_v2 = true;
    localStorage.setItem(LS_KEY,JSON.stringify(d));
  }
  
