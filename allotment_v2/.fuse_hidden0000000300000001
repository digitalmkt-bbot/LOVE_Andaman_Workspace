<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOVE Andaman · Allotment</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ocean:#1a6a8a;--ocean-mid:#2196be;--ocean-light:#c8eaf5;--ocean-50:#edf7fc;
  --coral:#e05a38;--coral-light:#fbe8e3;
  --sand:#f5f2ed;--sand-dark:#e8e4dc;--sand-mid:#ede9e3;
  --ink:#1a2332;--ink-mid:#435870;--ink-soft:#7a8fa3;
  --white:#ffffff;
  --navy:#0f1f2e;
  --green:#2d9a6a;--green-light:#d8f4e8;--green-dark:#1a6040;
  --amber:#d48a14;--amber-light:#fef6df;
  --red:#c43a2e;--red-light:#fdecea;
  --purple:#6c5ce7;--purple-light:#ede9ff;
  --border:rgba(26,35,50,0.09);
  --r:10px;--r-sm:6px;--r-lg:14px;
  --sidebar:220px;--topbar:52px;
  --shadow:0 1px 3px rgba(26,35,50,.07),0 4px 12px rgba(26,35,50,.04);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--sand);color:var(--ink);font-size:13px;line-height:1.5;min-height:100vh}

/* ── TOPBAR ── */
.topbar{height:var(--topbar);background:#0f1f2e;display:flex;align-items:center;padding:0 18px;gap:12px;position:fixed;top:0;left:0;right:0;z-index:100;border-bottom:1px solid rgba(255,255,255,.07)}
.topbar-brand{display:flex;align-items:center;gap:10px;color:#fff;font-weight:600;font-size:15px}
.brand-icon{width:30px;height:30px;background:rgba(255,255,255,.1);border-radius:7px;display:flex;align-items:center;justify-content:center}
.brand-icon svg{width:16px;height:16px}
.topbar-sep{width:1px;height:18px;background:rgba(255,255,255,.12);margin:0 4px}
.topbar-sub{font-size:11px;font-weight:400;color:rgba(255,255,255,.4);letter-spacing:.04em;text-transform:uppercase}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.topbar-date{font-size:12px;color:rgba(255,255,255,.45);font-family:'DM Mono',monospace}
.topbar-btn{padding:4px 11px;border-radius:var(--r-sm);border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:rgba(255,255,255,.75);font-size:11px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s}
.topbar-btn:hover{background:rgba(255,255,255,.12)}

/* ── LAYOUT ── */
.app{display:flex;margin-top:var(--topbar);min-height:calc(100vh - var(--topbar))}

/* ── SIDEBAR ── */
.sidebar{width:var(--sidebar);background:#0f1f2e;position:fixed;top:var(--topbar);left:0;bottom:0;display:flex;flex-direction:column;padding:10px 8px;overflow-y:auto;border-right:1px solid rgba(255,255,255,.05)}
.nav-section{font-size:9px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.25);padding:12px 10px 4px}
.nav-item{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:var(--r-sm);color:rgba(255,255,255,.45);font-size:12px;cursor:pointer;transition:all .15s;border:1px solid transparent;user-select:none;margin-bottom:1px}
.nav-item:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.8)}
.nav-item.active{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.1);color:#fff;font-weight:500}
.nav-item svg{width:14px;height:14px;flex-shrink:0;opacity:.6}
.nav-item.active svg{opacity:1}
.sidebar-footer{margin-top:auto;padding:10px 10px;font-size:10px;color:rgba(255,255,255,.2);border-top:1px solid rgba(255,255,255,.06)}

/* ── MAIN ── */
.main{margin-left:var(--sidebar);flex:1;padding:22px;min-width:0}
.view{display:none}.view.active{display:block}
.page-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;gap:12px}
.page-hd h1{font-size:20px;font-weight:600;color:var(--ink)}
.page-hd p{font-size:12px;color:var(--ink-soft);margin-top:2px}
.page-actions{display:flex;gap:7px;flex-shrink:0}

/* ── CARDS ── */
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;box-shadow:var(--shadow)}
.card-title{font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:12px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:var(--r-sm);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;border:1px solid}
.btn svg{width:13px;height:13px}
.btn-primary{background:var(--ocean);border-color:var(--ocean);color:#fff}
.btn-primary:hover{background:var(--ocean-mid)}
.btn-ghost{background:transparent;border-color:var(--border);color:var(--ink-mid)}
.btn-ghost:hover{background:var(--sand)}
.btn-sm{padding:5px 10px;font-size:11px}
.btn-danger{background:transparent;border-color:var(--red-light);color:var(--red)}
.btn-danger:hover{background:var(--red-light)}

/* ── PILLS / BADGES ── */
.pill{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500}
.pill::before{content:'';width:4px;height:4px;border-radius:50%}
.pill-green{background:var(--green-light);color:var(--green-dark)}.pill-green::before{background:var(--green)}
.pill-amber{background:var(--amber-light);color:#7a4a00}.pill-amber::before{background:var(--amber)}
.pill-red{background:var(--red-light);color:var(--red)}.pill-red::before{background:var(--red)}
.pill-blue{background:var(--ocean-50);color:var(--ocean)}.pill-blue::before{background:var(--ocean-mid)}
.pill-purple{background:var(--purple-light);color:var(--purple)}.pill-purple::before{background:var(--purple)}
.pill-gray{background:var(--sand-dark);color:var(--ink-soft)}.pill-gray::before{background:var(--ink-soft)}

/* ── KPI CARDS ── */
.kpi{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;position:relative;overflow:hidden;box-shadow:var(--shadow)}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.kpi.k-blue::after{background:var(--ocean-mid)}
.kpi.k-coral::after{background:var(--coral)}
.kpi.k-green::after{background:var(--green)}
.kpi.k-amber::after{background:var(--amber)}
.kpi-lbl{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft);margin-bottom:3px}
.kpi-val{font-size:26px;font-weight:600;color:var(--ink);line-height:1}
.kpi-sub{font-size:11px;color:var(--ink-soft);margin-top:3px}

/* ── FILL BAR ── */
.fbar{height:5px;background:var(--sand-dark);border-radius:3px;overflow:hidden}
.fbar-inner{height:100%;border-radius:3px;transition:width .3s}
.fb-green{background:var(--green)}.fb-amber{background:var(--amber)}.fb-red{background:var(--red)}

/* ── TABLE ── */
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);padding:7px 10px;border-bottom:1px solid var(--border)}
td{padding:9px 10px;border-bottom:1px solid rgba(26,35,50,.05);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(26,35,50,.015)}
.td-mono{font-family:'DM Mono',monospace;font-size:11px}
.td-bold{font-weight:500}

/* ── INPUTS ── */
select,input[type=date],input[type=text],input[type=number],input[type=time]{font-family:'DM Sans',sans-serif;font-size:12px;padding:6px 9px;border:1px solid var(--border);border-radius:var(--r-sm);background:var(--white);color:var(--ink);outline:none;transition:border-color .15s}
select:focus,input:focus{border-color:var(--ocean-mid);box-shadow:0 0 0 3px rgba(26,127,160,.1)}
.form-label{font-size:10px;font-weight:500;color:var(--ink-soft);margin-bottom:3px;display:block}
.form-row{margin-bottom:10px}
.form-2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.form-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--white);border-radius:var(--r-lg);max-width:420px;width:94%;box-shadow:0 20px 60px rgba(0,0,0,.2);position:relative;max-height:88vh;display:flex;flex-direction:column;overflow:hidden}
.modal-hd{padding:14px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.modal-body{padding:16px 18px;display:flex;flex-direction:column;gap:10px;overflow-y:auto;flex:1}
.modal-footer{padding:12px 18px;border-top:1px solid var(--border);display:flex;gap:7px;justify-content:flex-end;background:var(--sand);flex-shrink:0}
.modal-title{font-size:14px;font-weight:600;color:var(--ink)}
.modal-sub{font-size:11px;color:var(--ink-soft);margin-top:1px}
.modal-close{margin-left:auto;width:28px;height:28px;border-radius:6px;border:none;background:var(--sand);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--ink-soft);flex-shrink:0}
.modal-close:hover{background:var(--sand-dark)}

/* ══════════════════════════════
   DASHBOARD
══════════════════════════════ */
.dash-routes{display:flex;flex-direction:column;gap:8px}
.dash-route-row{display:flex;align-items:center;gap:10px}
.drt-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.drt-name{flex:1;font-size:12px}
.drt-bar{flex:2}
.drt-val{font-size:11px;font-family:'DM Mono',monospace;min-width:30px;text-align:right;color:var(--ink-soft)}

/* ══════════════════════════════
   CALENDAR
══════════════════════════════ */
.cal-toolbar{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.cal-nav{width:28px;height:28px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink-soft)}
.cal-nav:hover{background:var(--ocean-light)}
.cal-month{font-size:15px;font-weight:600;min-width:140px}
.cal-grid-wd{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:2px}
.cal-wd{text-align:center;font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft);padding:5px 0}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-day{min-height:100px;padding:5px 4px;border-radius:var(--r-sm);background:var(--white);border:1px solid var(--border);cursor:pointer;transition:all .15s;position:relative}
.cal-day:hover{border-color:var(--ocean-mid);box-shadow:0 2px 8px rgba(10,79,110,.1)}
.cal-day.empty{background:transparent;border-color:transparent;cursor:default}
.cal-day.today{border-color:var(--ocean-mid);background:#f0f8ff}
.cal-day-num{font-size:11px;font-weight:500;color:var(--ink-soft);line-height:1;margin-bottom:3px}
.cal-day.today .cal-day-num{color:var(--ocean)}
.cal-chip{display:flex;align-items:center;justify-content:space-between;border-radius:4px;padding:2px 4px;margin-bottom:2px;border-left:2px solid transparent;font-size:9px}
.cal-chip-name{font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:85px}
.cal-chip-free{font-weight:600;font-size:11px;flex-shrink:0}
.pier-sep{height:1px;background:var(--border);margin:3px 0}
.pier-tiny{font-size:8px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:2px}

/* day detail */
.cal-detail{background:var(--white);border:1px solid var(--border);border-radius:var(--r);margin-top:12px;box-shadow:var(--shadow)}
.cal-detail-hd{padding:12px 16px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.cal-detail-title{font-size:13px;font-weight:600}
.cal-detail-body{padding:12px 16px;display:grid;grid-template-columns:1fr 1fr;gap:16px}
.pier-section-title{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);padding-bottom:8px;border-bottom:1px solid var(--border);margin-bottom:6px}
.detail-route-row{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(26,35,50,.05)}
.detail-route-row:last-child{border-bottom:none}
.drr-dot{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.drr-info{flex:1;min-width:0}
.drr-name{font-size:12px;font-weight:500}
.drr-sub{font-size:10px;color:var(--ink-soft);margin-top:1px}
.drr-free{font-size:20px;font-weight:600;text-align:right;flex-shrink:0;padding-left:8px}
.drr-of{font-size:9px;color:var(--ink-soft);text-align:right}

/* ══════════════════════════════
   BOAT STATUS
══════════════════════════════ */
.boats-layout{display:grid;grid-template-columns:250px 1fr;gap:14px;align-items:start}
.boat-list-panel{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.boat-list-hd{padding:10px 12px;border-bottom:1px solid var(--border)}
.boat-list-scroll{max-height:520px;overflow-y:auto}
.boat-item{padding:9px 12px;border-bottom:1px solid rgba(26,35,50,.05);cursor:pointer;border-left:3px solid transparent;transition:all .12s}
.boat-item:last-child{border-bottom:none}
.boat-item:hover{background:var(--sand)}
.boat-item.sel{background:var(--ocean-50);border-left-color:var(--ocean-mid)}
.boat-item.st-available{border-left-color:var(--green)}
.boat-item.st-fixing{border-left-color:var(--amber)}
.boat-item.st-unavailable{border-left-color:var(--red)}
.bi-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:2px}
.bi-name{font-size:12px;font-weight:500;color:var(--ink)}
.bi-meta{font-size:10px;color:var(--ink-soft)}
.bi-loc{font-size:10px;color:var(--ink-soft);margin-top:2px;display:flex;align-items:center;gap:3px}

/* right detail */
.boat-detail-panel{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);position:sticky;top:0;align-self:start}
.bdp-empty{padding:60px 24px;text-align:center;color:var(--ink-soft)}
.bdp-hd{padding:14px 16px 0;border-bottom:1px solid var(--border)}
.bdp-name-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.bdp-name{font-size:15px;font-weight:600;color:var(--ink)}
.name-input{font-size:15px;font-weight:600;border:none;border-bottom:2px solid var(--ocean-mid);outline:none;background:transparent;color:var(--ink);padding:1px 2px;width:180px;font-family:'DM Sans',sans-serif}
.icon-btn{width:24px;height:24px;border-radius:5px;border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink-soft)}
.icon-btn:hover{background:var(--sand)}
.icon-btn.confirm{border-color:var(--green);background:var(--green-light)}
.bdp-sub{font-size:11px;color:var(--ink-soft);margin-bottom:12px}
.detail-tabs{display:flex;gap:0}
.detail-tab{padding:7px 14px;font-size:11px;font-weight:500;cursor:pointer;color:var(--ink-soft);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s}
.detail-tab.on{color:var(--ocean);border-bottom-color:var(--ocean)}
.detail-tab:hover{color:var(--ink)}
.detail-body{padding:14px 16px}

/* timeline */
.tl-entry{display:grid;grid-template-columns:12px 1fr;gap:0 10px;margin-bottom:0}
.tl-dot-col{display:flex;flex-direction:column;align-items:center;padding-top:2px}
.tl-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.tl-dot.g{background:var(--green);box-shadow:0 0 0 2px var(--green-light)}
.tl-dot.a{background:var(--amber);box-shadow:0 0 0 2px var(--amber-light)}
.tl-dot.r{background:var(--red);box-shadow:0 0 0 2px var(--red-light)}
.tl-line{width:1.5px;background:var(--border);flex:1;margin-top:4px}
.tl-body{padding-bottom:14px}
.tl-entry:last-child .tl-line{display:none}
.tl-entry:last-child .tl-body{padding-bottom:0}
.tl-hd{display:flex;align-items:center;gap:6px;margin-bottom:3px;flex-wrap:wrap}
.cur-tag{font-size:9px;font-weight:600;background:var(--ocean);color:#fff;padding:1px 5px;border-radius:3px}
.tl-dates{font-size:10px;font-family:'DM Mono',monospace;color:var(--ink-soft);margin-bottom:2px}
.tl-loc{font-size:11px;color:var(--ink-mid);display:flex;align-items:center;gap:3px;margin-bottom:2px}
.tl-note{font-size:10px;color:var(--ink-soft);font-style:italic;margin-bottom:3px}
.tl-acts{display:flex;gap:5px;margin-top:4px}
.btn-xs{font-size:10px;padding:2px 8px;border-radius:5px;border:1px solid var(--border);background:var(--white);color:var(--ink-soft);cursor:pointer}
.btn-xs:hover{background:var(--sand)}
.btn-xs.del{color:var(--red);border-color:rgba(185,52,40,.2)}
.btn-xs.del:hover{background:var(--red-light)}

/* gantt */
.gantt-controls{display:flex;align-items:center;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.gantt-lbl{font-size:11px;color:var(--ink-mid);min-width:120px}
.gantt-legend{display:flex;gap:10px;margin-left:auto}
.gantt-lg-item{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--ink-soft)}
.gantt-lg-dot{width:8px;height:8px;border-radius:2px}
.gantt-wrap{overflow-x:auto}
.gantt-tbl{border-collapse:collapse;width:100%;min-width:400px}
.gantt-th{font-size:9px;color:var(--ink-soft);text-align:center;padding-bottom:4px;width:22px;min-width:22px;vertical-align:bottom}
.gantt-th.today-col{background:rgba(26,127,160,.06)}
.gantt-boat-cell{font-size:11px;padding:2px 8px 2px 0;white-space:nowrap;min-width:80px;vertical-align:middle}
.gantt-day-cell{padding:1px;vertical-align:middle;width:22px;min-width:22px;position:relative}
.gantt-day-cell.today-col{background:rgba(26,127,160,.06)}
.gantt-bar{height:16px;border-radius:2px}
.gantt-bar.g{background:var(--green)}.gantt-bar.a{background:var(--amber)}.gantt-bar.r{background:var(--red)}.gantt-bar.e{background:var(--sand-dark);opacity:.5}
.gantt-today-line{position:absolute;top:0;bottom:0;left:50%;width:2px;background:var(--ocean-mid);opacity:.5;transform:translateX(-50%)}
.sel-hl td{background:rgba(26,127,160,.04)!important}

/* status type picker */
.st-picker{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:10px}
.st-opt{border-radius:var(--r-sm);padding:9px 6px;text-align:center;cursor:pointer;border:1px solid var(--border);transition:all .12s}
.st-opt:hover{border-color:var(--ocean-light)}
.st-opt.sel-available{background:var(--green-light);border-color:var(--green)}
.st-opt.sel-fixing{background:var(--amber-light);border-color:var(--amber)}
.st-opt.sel-unavailable{background:var(--red-light);border-color:var(--red)}
.st-opt-dot{width:7px;height:7px;border-radius:50%;margin:0 auto 4px}
.st-opt-name{font-size:11px;font-weight:500}

/* ══════════════════════════════
   BOAT OPERATION (inline cell)
══════════════════════════════ */
.op-toolbar{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap;background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:10px 14px;box-shadow:var(--shadow)}
.op-sep{width:1px;height:18px;background:var(--border);margin:0 2px}
.matrix-wrap{overflow-x:auto;overflow-y:auto;border:1px solid var(--border);border-radius:var(--r);background:var(--white);box-shadow:var(--shadow);max-height:calc(100vh - 220px)}
.matrix-tbl{border-collapse:separate;border-spacing:0;width:100%;table-layout:fixed}
.th-date{width:68px;min-width:68px;padding:6px 7px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-soft);position:sticky;left:0;top:0;z-index:4}
.th-boat{padding:5px 8px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);text-align:center;min-width:230px;width:230px;position:sticky;top:0;z-index:3}
.th-boat-name{font-size:11px;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.th-boat-cap{font-size:9px;color:var(--ink-soft);margin-top:1px}
.td-date{padding:5px 8px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);position:sticky;left:0;z-index:1;vertical-align:middle;width:68px;min-width:68px}
.td-date.today-row{background:var(--ocean-50)}
.td-date-day{font-size:11px;font-weight:600;color:var(--ink);line-height:1}
.td-date.today-row .td-date-day{color:var(--ocean)}
.td-date-wd{font-size:9px;color:var(--ink-soft);margin-top:1px}
.td-cell{padding:3px 6px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);vertical-align:middle;width:230px;min-width:230px}
.td-cell.unavail{background:repeating-linear-gradient(45deg,var(--sand),var(--sand) 4px,var(--sand-dark) 4px,var(--sand-dark) 8px)}
.unavail-cell-inner{display:flex;align-items:center;justify-content:center;height:28px;gap:3px}
.unavail-label{font-size:9px;color:var(--ink-soft)}
.cell-line{display:flex;align-items:center;gap:4px;height:28px}
.sel-route{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:4px;border:1px solid var(--border);cursor:pointer;font-size:10px;font-weight:500;width:96px;min-width:96px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;transition:border-color .1s;color:var(--ink-mid);background:var(--white)}
.sel-route:hover{border-color:var(--ocean-mid)}
.sel-route.empty{color:var(--ink-soft);font-style:italic;font-size:9px}
.sel-route-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.sel-type-btn{padding:2px 7px;border-radius:20px;font-size:9px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--ink-soft);flex-shrink:0;background:var(--white);white-space:nowrap}
.sel-type-btn:hover{background:var(--sand)}
.sel-type-btn.early{background:#fff7d6;border-color:#d4a800;color:#7a5500}
.sel-type-btn.normal{background:var(--white);border-color:var(--border);color:var(--ink-soft)}
.sel-type-btn.charter{background:var(--purple-light);border-color:var(--purple);color:var(--purple)}
.op-inp{width:34px;font-size:12px;font-weight:600;padding:2px 3px;border:1.5px solid var(--ocean-light);border-radius:4px;background:var(--ocean-50);color:var(--ink);text-align:center;font-family:'DM Mono',monospace;flex-shrink:0;-moz-appearance:textfield}
.op-inp::-webkit-outer-spin-button,.op-inp::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
.op-inp:focus{border-color:var(--ocean-mid);outline:none;box-shadow:0 0 0 2px rgba(26,127,160,.15);background:var(--white)}
.stepper{display:inline-flex;align-items:center;gap:2px;flex-shrink:0}
.step-btn{width:16px;height:20px;border-radius:3px;border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink-soft);font-size:11px;line-height:1;flex-shrink:0;user-select:none}
.step-btn:hover{background:var(--sand);color:var(--ink)}
.op-cap{font-size:9px;color:var(--ink-soft);flex-shrink:0}
.op-free{font-size:10px;font-weight:600;flex-shrink:0;margin-left:auto;font-family:'DM Mono',monospace;white-space:nowrap}
.op-free.ok{color:var(--green-dark)}.op-free.warn{color:#7a4a00}.op-free.full{color:var(--red)}
/* portal dropdown — fixed position, appended to body */
#dd-portal{position:fixed;background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm);padding:4px;z-index:99999;min-width:160px;box-shadow:0 8px 24px rgba(0,0,0,.15);display:none}
#dd-portal.open{display:block}
.dd-item{padding:5px 10px;border-radius:4px;font-size:11px;cursor:pointer;color:var(--ink-soft);display:flex;align-items:center;gap:7px;white-space:nowrap}
.dd-item:hover{background:var(--sand);color:var(--ink)}
.dd-item.on{background:var(--ocean-50);color:var(--ocean);font-weight:500}
.dd-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dd-divider{height:1px;background:var(--border);margin:3px 0}


/* ══════════════════════════════
   SETTINGS / ROUTES
══════════════════════════════ */
.settings-layout{display:grid;grid-template-columns:180px 1fr;gap:14px;align-items:start}
.settings-nav{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.settings-nav-title{font-size:9px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);padding:10px 14px 6px}
.settings-nav-item{display:flex;align-items:center;gap:8px;padding:8px 14px;font-size:12px;cursor:pointer;color:var(--ink-soft);transition:all .12s}
.settings-nav-item:hover{background:var(--sand);color:var(--ink)}
.settings-nav-item.on{background:var(--ocean-50);color:var(--ocean);font-weight:500}
.settings-nav-item svg{width:13px;height:13px;flex-shrink:0}
.settings-content{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.settings-hd{padding:14px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.settings-title{font-size:14px;font-weight:600}
.settings-sub{font-size:11px;color:var(--ink-soft);margin-top:1px}
.pier-group-hd{padding:5px 18px 4px;background:var(--sand);border-bottom:1px solid var(--border);border-top:1px solid var(--border);display:flex;align-items:center;gap:6px;position:sticky;top:0;z-index:1}
.pier-group-hd:first-child{border-top:none}
.pgd{width:7px;height:7px;border-radius:50%}
.pgd-label{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft)}
.pgd-count{font-size:9px;color:var(--ink-soft)}
.route-row-item{display:grid;grid-template-columns:20px 1fr auto;align-items:center;gap:10px;padding:9px 18px;border-bottom:1px solid rgba(26,35,50,.05);transition:background .1s}
.route-row-item:last-child{border-bottom:none}
.route-row-item:hover{background:var(--sand)}
.rri-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.rri-name{font-size:12px;font-weight:500}
.rri-sub{font-size:10px;color:var(--ink-soft);margin-top:1px}
.rri-times{display:flex;gap:3px;flex-wrap:wrap;margin-top:3px}
.time-badge{font-size:9px;padding:1px 5px;border-radius:3px;background:var(--sand);color:var(--ink-soft);border:1px solid var(--border)}
.row-acts{display:flex;gap:4px;opacity:0;transition:opacity .15s}
.route-row-item:hover .row-acts{opacity:1}
.act-btn{width:24px;height:24px;border-radius:5px;border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink-soft)}
.act-btn:hover{background:var(--sand)}
.act-btn.del:hover{background:var(--red-light);border-color:var(--red-light);color:var(--red)}

/* location picker */
.loc-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:4px}
.loc-opt{border-radius:var(--r-sm);padding:9px 10px;cursor:pointer;border:1px solid var(--border);transition:all .12s;display:flex;align-items:center;gap:8px}
.loc-opt:hover{background:var(--sand)}
.loc-opt.sel-tl{background:var(--ocean-50);border-color:var(--ocean-mid)}
.loc-opt.sel-pn{background:var(--green-light);border-color:var(--green)}
.loc-opt.sel-rn{background:var(--amber-light);border-color:var(--amber)}
.loc-opt.sel-pn{background:var(--green-light);border-color:var(--green)}
.loc-dot-big{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.loc-opt-name{font-size:11px;font-weight:500;color:var(--ink)}
.loc-opt-sub{font-size:9px;color:var(--ink-soft)}

/* times builder */
.time-row-inp{display:flex;align-items:center;gap:6px;margin-bottom:5px}
.time-row-inp input{flex:1}
.rm-time{width:22px;height:22px;border-radius:5px;border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--ink-soft);flex-shrink:0}
.rm-time:hover{background:var(--red-light);border-color:var(--red-light);color:var(--red)}
.add-time-lnk{font-size:10px;color:var(--ocean);cursor:pointer;background:none;border:none;font-family:'DM Sans',sans-serif;padding:0}
.add-time-lnk:hover{text-decoration:underline}

/* ══════════════════════════════
   DAILY AVAILABILITY
══════════════════════════════ */
.da-layout{display:grid;grid-template-columns:1fr 1fr;gap:14px;min-height:400px}
.da-left{display:flex;flex-direction:column;gap:14px}
.da-date-row{display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid var(--border)}
.da-date-lbl{font-size:13px;font-weight:500;flex:1;text-align:center}
.da-body{padding:10px 14px;overflow-y:auto;flex:1}
.da-pier-lbl{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin:10px 0 5px;display:flex;align-items:center;gap:5px}
.da-pier-lbl:first-child{margin-top:0}
.da-route-row{display:flex;align-items:center;gap:6px;padding:6px 0;border-bottom:1px solid rgba(26,35,50,.05)}
.da-route-row:last-child{border-bottom:none}
.da-rr-dot{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.da-rr-name{font-size:12px;font-weight:500;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.da-rr-free{font-size:17px;font-weight:600;flex-shrink:0;text-align:right}
.da-rr-free.ok{color:var(--green-dark)}
.da-rr-free.warn{color:#7a4a00}
.da-rr-full{font-size:11px;font-weight:600;color:var(--red);flex-shrink:0}
.da-rr-of{font-size:9px;color:var(--ink-soft);flex-shrink:0}
.da-right{background:var(--white);border:1px solid var(--border);border-radius:var(--r);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow)}
.da-preview-hd{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.da-preview-lbl{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft)}
.da-preview-hint{font-size:10px;color:var(--ink-soft)}
.da-preview-text{flex:1;padding:12px 14px;font-family:'DM Mono',monospace;font-size:11px;line-height:1.9;color:var(--ink);white-space:pre;overflow:auto;background:var(--sand);cursor:text;user-select:all}
.da-copy-btn{display:flex;align-items:center;justify-content:center;gap:6px;padding:11px;border-top:1px solid var(--border);cursor:pointer;font-size:12px;font-weight:500;color:var(--ocean);background:var(--white);border:none;width:100%;border-radius:0 0 var(--r) var(--r);border-top:1px solid var(--border);transition:background .12s}
.da-copy-btn:hover{background:var(--ocean-50)}
.da-copy-btn.done{color:var(--green);background:var(--green-light)}

/* ── FILTER PILLS ── */
.filter-pills{display:flex;gap:5px;flex-wrap:wrap}
.fp{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--ink-soft);background:var(--white);transition:all .12s}
.fp:hover{background:var(--sand)}
.fp.on{background:var(--ocean-50);color:var(--ocean);border-color:var(--ocean-light)}

/* scrollbar */
/* Fleet tabs */
.fl-tab-btn{padding:8px 14px;border-radius:0;font-size:12px;font-weight:500;cursor:pointer;color:var(--ink-soft);border:none;border-bottom:2px solid transparent;background:transparent;font-family:'DM Sans',sans-serif;white-space:nowrap;transition:color .12s,border-color .12s}
.fl-tab-btn.active{color:var(--navy);border-bottom-color:var(--navy);font-weight:600;background:rgba(10,79,110,.05)}
.fl-tab-btn:hover:not(.active){color:var(--ink);background:var(--sand-dark)}
.fl-tab-panel{display:none;flex-direction:column;gap:10px}
.fl-tab-panel.active{display:flex}
.fl-split{display:grid;grid-template-columns:220px 1fr;gap:10px;align-items:start}
.fl-list-col{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);display:flex;flex-direction:column;max-height:calc(100vh - 180px)}
.fl-list-hd{padding:8px 12px;border-bottom:1px solid var(--border);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.fl-list-body-scroll{overflow-y:auto;flex:1}
.fl-list-item{padding:9px 12px;border-bottom:1px solid rgba(26,35,50,.05);cursor:pointer;display:flex;align-items:flex-start;gap:8px}
.fl-list-item:last-child{border-bottom:none}
.fl-list-item:hover{background:var(--sand);color:var(--ink)}
.fl-list-item.sel{background:var(--ocean-50);color:var(--ink)}
.loc-pill{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--ink-soft);background:var(--white);user-select:none}
.loc-pill.on{background:var(--ocean-50);color:var(--navy);border-color:var(--ocean-light)}
.fl-list-item.sel{background:var(--ocean-50)}
.fl-detail-col{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.fl-empty-detail{display:flex;align-items:center;justify-content:center;height:160px;color:var(--ink-soft);font-size:12px}
.fl-boat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.07);margin-bottom:8px}
.fl-boat-card:last-child{margin-bottom:0}
.fl-bc-hd{display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--white);cursor:pointer;border-bottom:1px solid var(--border)}
.fl-bc-body{padding:10px 14px;display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:8px;background:var(--white)}
.fl-eng-card{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:8px 10px;display:flex;flex-direction:column;gap:4px}
.fl-ec-row{display:flex;justify-content:space-between;font-size:10px;color:var(--ink-soft)}
.fl-ec-val{color:var(--ink);font-weight:500;font-family:'DM Mono',monospace}
.fl-ec-child{margin-top:4px;padding-top:4px;border-top:1px solid rgba(26,35,50,.08)}
.fl-mj{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:12px;border-left:3px solid;box-shadow:var(--shadow)}
.fl-mc-flow{display:flex;align-items:center;gap:3px;margin-top:4px;flex-wrap:wrap}
.fl-mc-step{font-size:9px;padding:2px 6px;border-radius:20px;border:1px solid var(--border);color:var(--ink-soft)}
.fl-mc-step.done{background:var(--green-light);border-color:var(--green);color:var(--green-dark)}
.fl-mc-step.cur{background:var(--navy);border-color:var(--navy);color:#fff}
.fl-mx-th-dt{width:64px;min-width:64px;padding:6px 7px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-soft);position:sticky;left:0;z-index:2}
.fl-mx-th-b{padding:5px 7px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);text-align:center;min-width:185px;width:185px}
.fl-mx-td-dt{padding:5px 7px;background:var(--sand);border-right:1px solid var(--border);border-bottom:1px solid var(--border);position:sticky;left:0;z-index:1;vertical-align:middle;width:64px;min-width:64px}
.fl-mx-td-dt.today{background:var(--ocean-50)}
.fl-mx-td-cell{padding:0;border-right:1px solid var(--border);border-bottom:1px solid var(--border);vertical-align:top;min-width:185px;width:185px;background:var(--white)}
.fl-mx-td-cell.na{background:repeating-linear-gradient(45deg,var(--sand),var(--sand) 4px,var(--sand-dark) 4px,var(--sand-dark) 8px)}
.fl-fuel-row{display:flex;align-items:center;gap:4px;padding:3px 6px;background:#fef3d8;border-bottom:1px solid rgba(196,122,16,.12)}
.fl-fuel-inp{width:46px;font-size:10px;font-weight:600;font-family:'DM Mono',monospace;color:#7a4a00;background:rgba(196,122,16,.1);border:1px solid rgba(196,122,16,.2);border-radius:3px;padding:1px 3px;text-align:center}
.fl-trip-block{border-bottom:1px solid rgba(26,35,50,.05)}
.fl-trip-block:last-child{border-bottom:none}
.fl-trip-hd{display:flex;align-items:center;gap:4px;padding:3px 6px;background:rgba(26,35,50,.02)}
.fl-eng-rows{padding:2px 6px 3px}
.fl-eng-row{display:flex;align-items:center;gap:4px;padding:1.5px 0}
.fl-eng-pos{font-size:8px;color:var(--ink-soft);width:34px;flex-shrink:0;font-family:'DM Mono',monospace;font-weight:500}
.fl-meter-inp{width:52px;font-size:10px;font-weight:600;font-family:'DM Mono',monospace;background:var(--ocean-50);border:1px solid rgba(26,127,160,.18);border-radius:3px;padding:1px 3px;text-align:center;color:var(--navy)}
.fl-meter-inp:focus{outline:none;border-color:var(--ocean)}
.fl-delta{font-size:9px;font-weight:500;font-family:'DM Mono',monospace;margin-left:auto;min-width:28px;text-align:right}
.fl-dp{color:var(--green)}.fl-d0{color:#bbb}
.da-pier-btn{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--ink-soft);background:var(--white)}
.da-pier-btn.active{background:var(--ocean-50);color:var(--navy);border-color:var(--ocean-light)}
.fl-doc-filter-btn{padding:4px 12px;border-radius:20px;font-size:11px;font-weight:500;cursor:pointer;border:1.5px solid;box-shadow:0 1px 2px rgba(0,0,0,.06);transition:all .1s}
.fl-doc-filter-btn.active{box-shadow:0 0 0 2px rgba(0,0,0,.15)}
.fl-doc-filter-all{background:#fff;border-color:var(--border-mid);color:var(--ink-mid)}
.fl-doc-filter-all.active{background:var(--navy);border-color:var(--navy);color:#fff}
.fl-doc-filter-expired{background:#fde8e6;border-color:#b93428;color:#b93428}
.fl-doc-filter-expired.active{background:#b93428;border-color:#b93428;color:#fff}
.fl-doc-filter-warn30{background:#fef3d8;border-color:#c47a10;color:#c47a10}
.fl-doc-filter-warn30.active{background:#c47a10;border-color:#c47a10;color:#fff}
.fl-doc-filter-warn90{background:#fff7e6;border-color:#e09020;color:#9a5c00}
.fl-doc-filter-warn90.active{background:#e09020;border-color:#e09020;color:#fff}
.fl-doc-filter-ok{background:#d6f0e5;border-color:#2d8a5e;color:#1a5c3d}
.fl-doc-filter-ok.active{background:#2d8a5e;border-color:#2d8a5e;color:#fff}
.fl-doc-view-btn{padding:4px 12px;border-radius:5px;font-size:11px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--ink-soft);font-family:'DM Sans',sans-serif}
.fl-doc-view-btn.active{background:var(--navy);color:#fff}
/* doc matrix */
.doc-mx{border-collapse:collapse;font-size:11px;width:100%;table-layout:fixed}
.doc-mx-th-boat{width:120px;min-width:120px;padding:7px 10px;background:#f0eeea;border:0.5px solid var(--border);text-align:left;font-size:11px;font-weight:600;color:#1a2332;position:sticky;left:0;z-index:3;white-space:nowrap}
.doc-mx-th-group{padding:6px 6px;border:0.5px solid rgba(0,0,0,.1);text-align:center;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.doc-mx-th-doc{padding:5px 4px;border:0.5px solid rgba(0,0,0,.08);text-align:center;font-size:9px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80px}
.doc-mx-td-boat{padding:7px 10px;background:var(--white);border:0.5px solid var(--border);position:sticky;left:0;z-index:2;white-space:nowrap}
.doc-mx-td{padding:4px 3px;border:0.5px solid var(--border);text-align:center;background:var(--white)}
.doc-mx-group-sep{border-left:2px solid rgba(0,0,0,.15) !important}
.th-grp-track{background:#ede9f6;color:#4a3578}
.td-grp-track{background:#e8e4f5;color:#4a3578}
.cell-grp-track{background:#faf9fe}
.th-grp-ins{background:#c0dd97;color:#27500a}
.th-grp-park{background:#f5c4b3;color:#712b13}
