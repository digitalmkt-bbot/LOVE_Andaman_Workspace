  const hist=(item.history||[]).slice().reverse();
  document.getElementById('ihp-hist').innerHTML=hist.length
    ?hist.map((h,i,arr)=>{
      const isEdit=h.type==='edit';
      const isIn=h.type==='receive';
      const isLast=i===arr.length-1;
      const dotColor=isEdit?'#666':(isIn?'var(--green)':'var(--red)');
      let mainText, rightText;
      if(isEdit){
        const chCount=(h.changes||[]).length;
        const fieldsList=(h.changes||[]).map(c=>c.field).join(', ');
        mainText='แก้ไข: '+(fieldsList||'รายการ');
