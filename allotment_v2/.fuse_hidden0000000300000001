// ── Rule-based AI Insight (no real AI, just smart rules) ──
function flProjInsight(p){
  const lines = [];
  const recs = [];
  const cost = (typeof flProjCalcCost==='function')?flProjCalcCost(p.id):0;
  const budget = p.plannedBudget||0;
  const today = new Date(TODAY_STR);
  const ps = p.planFrom?new Date(p.planFrom):null;
  const pe = p.planTo?new Date(p.planTo):null;
  const kids = flProjChildMJs(p.id);
  const openKids = kids.filter(m=>m.status!=='done');
  // Budget insights
  if(budget && cost>budget){
    lines.push(`Over budget by ฿${(cost-budget).toLocaleString()} (${Math.round((cost-budget)/budget*100)}% above plan).`);
    recs.push('Review remaining scope · consider raising budget or cutting non-critical items');
  } else if(budget && cost/budget>0.85){
    lines.push(`Budget ${Math.round(cost/budget*100)}% utilized · ฿${(budget-cost).toLocaleString()} remaining`);
    recs.push('Monitor any new memo · close to exhausting budget');
  }
  // Schedule insights · skip if no planTo (open-ended)
  if(!pe && p.status==='inprogress'){
    lines.push('No fixed end date set · project runs open-ended');
    recs.push('Set a target end date in Edit if vendor confirms timeline');
  } else if(pe && today>pe && p.status!=='completed'){
    const over = Math.ceil((today-pe)/86400000);
    lines.push(`${over} day${over>1?'s':''} past planned end date.`);
    recs.push('Update planned end date · negotiate handover · OR mark on-hold');
  } else if(pe && ps){
    const total = (pe-ps)/86400000;
    const elapsed = (today-ps)/86400000;
    const tPct = elapsed/total;
    const wPct = kids.length?(kids.length-openKids.length)/kids.length:0;
    if(tPct>0.5 && wPct<tPct-0.2){
      lines.push(`Behind schedule · ${Math.round(tPct*100)}% time elapsed but only ${Math.round(wPct*100)}% of MJs done.`);
      recs.push('Consider adding labor or re-prioritizing MJs');
    }
  }
  // Hold insight
  if(p.status==='on_hold'){
    lines.push(`On hold since ${p.holdSince||'?'} · reason: ${p.holdReason||'(none)'}`);
    recs.push('Resume when blocker cleared · or convert to cancellation');
  }
  // Documents
  const docs = p.docs||[];
  const verifiedDocs = docs.filter(d=>d.status==='verified').length;
  if(docs.length && verifiedDocs/docs.length<0.5){
    lines.push(`Only ${verifiedDocs} / ${docs.length} documents verified`);
    recs.push('Verify pending documents to maintain compliance');
  }
  if(!lines.length) lines.push('Project running smoothly · all KPIs within healthy range');
  return {lines, recs};
}

