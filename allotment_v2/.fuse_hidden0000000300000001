function flSaveAddSpare(){
  const type=document.getElementById('fl-add-spare-type').value;
  const serial=document.getElementById('fl-add-spare-serial').value.trim();
  if(!serial){alert('กรุณากรอก serial');return;}
  const brand=document.getElementById('fl-add-spare-brand').value.trim()||'Honda';
  const note=document.getElementById('fl-add-spare-note').value.trim();
  const loc=document.getElementById('fl-add-spare-loc').value;
  const locInfo=flParseSpareLoc(loc);
  const initLog=[{date:TODAY_STR,type:'purchase',desc:`ลงทะเบียนเข้าระบบ — ${locInfo.label}${note?' · '+note:''}`,toLoc:loc}];

  if(type==='gearbox'){
    const model=document.getElementById('fl-add-spare-model').value.trim()||'BF250D Gearbox';
    // Generate next id
    const ids=FL_GEARBOXES.map(g=>parseInt((g.id||'g0').replace('g',''))||0);
    const newId='g'+(Math.max(...ids,0)+1);
    FL_GEARBOXES.push({id:newId,boatId:null,engineId:null,brand,model,serial,status:loc.startsWith('shop:')?'fixing':'spare',baseHours:0,buyDate:TODAY_STR,note,spareLocation:loc,log:initLog});
  }else{
    const size=document.getElementById('fl-add-spare-size').value.trim()||'15.5×17';
    const rotation=document.getElementById('fl-add-spare-rotation').value;
    const sizeMatch=size.match(/^([\d.]+)[×x]([\d.]+)$/);
    const diameter=sizeMatch?parseFloat(sizeMatch[1]):15.5;
    const pitch=sizeMatch?parseFloat(sizeMatch[2]):17;
    const ids=FL_PROPELLERS.map(p=>parseInt((p.id||'p0').replace('p',''))||0);
    const newId='p'+(Math.max(...ids,0)+1);
    FL_PROPELLERS.push({id:newId,boatId:null,gearboxId:null,brand,serial,diameter,pitch,size,blades:'3',material:'Stainless',rotation,hubSize:'4.75',cupping:'no',cost:8500,status:loc.startsWith('shop:')?'fixing':'spare',buyDate:TODAY_STR,note,spareLocation:loc,log:initLog});
  }
  flSave();
  closeModal('fl-modal-add-spare');
  if(flAssetTab==='overview')flRenderOverview();
}

let _editingIncId=null;

// Toggle handler for "Quick Fix" checkbox in Incident modal
function flIncToggleQuickFix(on){
  const badge = document.getElementById('fl-inc-quickfix-badge');
  if(badge) badge.style.display = on ? 'inline-block' : 'none';
