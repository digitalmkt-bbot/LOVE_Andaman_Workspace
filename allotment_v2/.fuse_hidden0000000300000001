// ── Quick Swap (Spare exchange during incident) ──
let flSwapCtx={incId:null,assetType:null,assetId:null};
function flOpenSwapModal(incId,assetType,assetId){
  const inc=FL_INCIDENTS.find(x=>x.id===incId);if(!inc)return;
  const boatId=inc.boatId;
  flSwapCtx={incId,assetType,assetId};

  // Find the damaged asset
  const damaged=assetType==='gearbox'?FL_GEARBOXES.find(g=>g.id===assetId):FL_PROPELLERS.find(p=>p.id===assetId);
  if(!damaged){alert('ไม่พบ asset');return;}

  // Find compatible spares
  // - Schema: spare ถูกระบุด้วย spareLocation (truthy) — ไม่ใช่ status='spare' (legacy)
  // - ตัด shop:* ออก (อยู่ร้านซ่อม = ไม่พร้อมใช้)
  // - Business rule (แบบ A · เข้ม): ผูก spare กับ pier ของเรือเท่านั้น · cross-pier ไม่ให้เห็น
  const arr=assetType==='gearbox'?FL_GEARBOXES:FL_PROPELLERS;
  const allSpares=arr.filter(s=>s.spareLocation && !String(s.spareLocation).startsWith('shop:'));
  // Compatibility — relaxed: match brand only (warn if model differs)
  // For propeller: still match size (size IS the model)
  const compat=allSpares.filter(s=>{
    if(assetType==='gearbox') return s.brand===damaged.brand;
    return s.size===damaged.size;
  });
  // Group by location · ภายใต้ pier ของเรือเท่านั้น
  const boatPier=boatId?(getBoat(boatId)?.pier||''):'';
  const onBoat=compat.filter(s=>s.spareLocation===`boat:${boatId}`);
  const samePier=compat.filter(s=>boatPier && s.spareLocation===`pier:${boatPier}`);
  // ❌ ไม่มี otherSpares (cross-pier) — แบบ A ล็อกเฉพาะ pier ของเรือ
  const otherSpares=[];

  const renderSp=(sp,group)=>sp.map(s=>{
    const info=flParseSpareLoc(s.spareLocation);
    const extra=assetType==='gearbox'?'':` · ${s.size} · ${s.rotation||''}`;
    // Model mismatch warning (gearbox only; propeller compat is size-only)
    const modelMatch=assetType==='gearbox'?(s.model===damaged.model):true;
    const warnBadge=!modelMatch?`<span style="background:#FAEEDA;color:#854F0B;padding:2px 6px;border-radius:7px;font-size:9px;font-weight:600;letter-spacing:.02em" title="Model ของ spare ไม่ตรงกับเกียร์ที่พัง · ใส่แทนแล้วอาจไม่เข้ากับตำแหน่ง/ทิศหมุน">⚠ model ต่าง</span>`:'';
    const dimStyle=!modelMatch?'opacity:.78;':'';
    const modelLine=!modelMatch?`<div style="font-size:9.5px;color:#854F0B;margin-top:2px">spare: ${s.model||'?'} · damaged: ${damaged.model||'?'}</div>`:'';
    return`<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid ${modelMatch?'var(--border)':'#f0c875'};border-radius:6px;cursor:pointer;background:${modelMatch?'var(--white)':'#fffaf0'};${dimStyle}transition:all .12s" onmouseover="this.style.background='${modelMatch?'var(--ocean-50)':'#fff6e6'}';this.style.borderColor='${modelMatch?'var(--ocean)':'#d99c2b'}'" onmouseout="this.style.background='${modelMatch?'var(--white)':'#fffaf0'}';this.style.borderColor='${modelMatch?'var(--border)':'#f0c875'}'" onclick="flConfirmSwap('${s.id}')">
      <span style="font-size:14px">${info.icon}</span>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
          <span style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600">${s.serial}${extra}</span>
          ${warnBadge}
        </div>
        <div style="font-size:10px;color:var(--ink-soft);margin-top:1px">${info.label}${s.note?` · ${s.note}`:''}</div>
        ${modelLine}
      </div>
      <span style="font-size:9px;color:${modelMatch?'var(--ocean)':'#854F0B'};font-weight:600;text-transform:uppercase">เลือก</span>
    </div>`;
  }).join('');

  const html=`<div style="margin-bottom:12px">
    <div style="font-size:11px;color:var(--ink-soft);margin-bottom:4px">เปลี่ยนแทน:</div>
    <div style="background:var(--red-light);border:1px solid rgba(196,58,46,.2);border-radius:6px;padding:8px 10px">
      <div style="font-family:'DM Mono',monospace;font-size:11px;font-weight:600;color:var(--red)">${damaged.serial}</div>
      <div style="font-size:10px;color:var(--ink-mid);margin-top:1px">${damaged.brand} ${damaged.model||damaged.size||''} · ${damaged.note||''}</div>
    </div>
  </div>
  ${onBoat.length?`<div style="margin-bottom:12px">
    <div style="font-size:10px;font-weight:600;color:#1c4e7e;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px">🚢 บนเรือลำนี้ (เร็วที่สุด)</div>
    <div style="display:flex;flex-direction:column;gap:4px">${renderSp(onBoat,'boat')}</div>
  </div>`:''}
  ${samePier.length?`<div style="margin-bottom:12px">
    <div style="font-size:10px;font-weight:600;color:#0e6b87;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px">🏪 คลังท่าเดียวกัน</div>
    <div style="display:flex;flex-direction:column;gap:4px">${renderSp(samePier,'pier')}</div>
  </div>`:''}
  ${otherSpares.length?`<div style="margin-bottom:12px">
    <div style="font-size:10px;font-weight:600;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px">📦 สแปร์อื่นๆ</div>
    <div style="display:flex;flex-direction:column;gap:4px">${renderSp(otherSpares,'other')}</div>
  </div>`:''}
  ${!onBoat.length && !samePier.length?`<div style="text-align:center;padding:20px;font-size:12px;color:var(--ink-soft);line-height:1.6">
    <div style="font-size:24px;opacity:.3;margin-bottom:8px">📭</div>
    <div style="font-weight:600;color:var(--ink-mid);margin-bottom:3px">ไม่มีสแปร์ ${damaged.brand} ที่ท่านี้</div>
    <div style="font-size:11px">ไม่พบ ${assetType==='gearbox'?'เกียร์':'ใบจักร'} ${damaged.brand} ในคลังท่า ${boatPier==='tublamu'?'Tub Lamu':boatPier==='panwa'?'Visit Panwa':boatPier||'—'} หรือบนเรือลำนี้<br/><span style="color:var(--ink-soft)">ลองขนสแปร์จากท่าอื่นมาก่อนใช้ · หรือเพิ่ม spare ใหม่</span></div>
  </div>`:''}`;

  document.getElementById('fl-swap-body').innerHTML=html;
  document.getElementById('fl-swap-title').textContent=`เลือกสแปร์ ${assetType==='gearbox'?'เกียร์':'ใบจักร'}`;
  openModal('fl-modal-swap');
}
function flConfirmSwap(spareId){
  const {incId,assetType,assetId}=flSwapCtx;
  const inc=FL_INCIDENTS.find(x=>x.id===incId);if(!inc)return;
  const arr=assetType==='gearbox'?FL_GEARBOXES:FL_PROPELLERS;
  const damaged=arr.find(x=>x.id===assetId);
  const spare=arr.find(x=>x.id===spareId);
  if(!damaged||!spare){alert('error');return;}
  if(!confirm(`ยืนยันเปลี่ยน ${damaged.serial} → ${spare.serial}?`))return;

  // Swap: spare takes damaged's position, damaged becomes spare (status=damaged)
  const dBoat=damaged.boatId, dEng=damaged.engineId, dGb=damaged.gearboxId;
  const dNote=damaged.note;
  const dPropPos=damaged.propPos;
  const dSpareLoc=damaged.spareLocation;
  const boatName=getBoat(dBoat)?.name||'';

  // engine hours snapshot for log
  let engHours=null;
  if(assetType==='gearbox'){
    const e=flGetEng(dEng);if(e)engHours=flEngHours(e.id);
  }else{
    const gb=FL_GEARBOXES.find(g=>g.id===dGb);
    const e=gb?flGetEng(gb.engineId):null;
    if(e)engHours=flEngHours(e.id);
  }

  // ── ประวัติของตัวเสียหาย (damaged) ──
  if(!damaged.log)damaged.log=[];
  // Calc usedHours since last install
  const lastInstall=[...damaged.log].reverse().find(l=>l.type==='install');
  const usedHours=lastInstall&&engHours!=null?Math.max(0,engHours-(lastInstall.engineHours||0)):null;
  damaged.log.push({
    date:TODAY_STR,
    type:'remove',
    desc:`ถอดจาก ${boatName} (Incident ${inc.no}) — สลับสแปร์ ${spare.serial}`,
    engineHours:engHours,
    usedHours:usedHours,
    incidentId:inc.id
  });
  damaged.log.push({
    date:TODAY_STR,
    type:'transfer',
    desc:`ส่งซ่อม → อู่ Honda Phuket`,
    incidentId:inc.id
  });

  // ── ประวัติของสแปร์ที่เอามาใส่ (spare → installed) ──
  if(!spare.log)spare.log=[];
  const dEngObj=assetType==='gearbox'?flGetEng(dEng):null;
  const posLabel=assetType==='gearbox'?(dEngObj?.pos||dNote||''):(dPropPos?'· '+dPropPos:'');
  spare.log.push({
    date:TODAY_STR,
    type:'install',
    desc:`ติดตั้งบน ${boatName} ${posLabel} (Quick Swap จาก Incident ${inc.no})`.replace(/\s+/g,' ').trim(),
    engineHours:engHours,
    incidentId:inc.id
  });

  // ── Apply swap ──
  // spare → installed
  spare.boatId=dBoat;
  if(assetType==='gearbox')spare.engineId=dEng;
  else spare.gearboxId=dGb;
  spare.status=assetType==='gearbox'?'ready':'active';
  spare.note=dNote;
  if(assetType==='propeller'&&dPropPos)spare.propPos=dPropPos;
  spare.spareLocation=null;
  // baseHours align with engine for new install cycle
  if(assetType==='gearbox'&&engHours!=null)spare.baseHours=engHours;
  if(assetType==='propeller'&&engHours!=null)spare.installHours=engHours;

  // damaged → out for repair
  damaged.boatId=null;
  if(assetType==='gearbox')damaged.engineId=null;
  else damaged.gearboxId=null;
  damaged.status=assetType==='gearbox'?'fixing':'damaged';
  damaged.spareLocation='shop:honda-phuket'; // default
  damaged.note='ส่งซ่อมจาก '+boatName;

  // Mark in damagedAssets
  if(!inc.damagedAssets)inc.damagedAssets=[];
  const ass=inc.damagedAssets.find(a=>a.type===assetType&&a.id===assetId);
  if(ass){ass.swapped=true;ass.swappedTo=spare.serial;ass.swappedDate=TODAY_STR;}

  // Add progress log
  if(!inc.progressLog)inc.progressLog=[];
  inc.progressLog.push({date:TODAY_STR,text:`เปลี่ยน${assetType==='gearbox'?'เกียร์':'ใบจักร'} ${damaged.serial} → ${spare.serial}`,by:'ระบบ Quick Swap'});

  flSave();
  closeModal('fl-modal-swap');
  // หาก swap gearbox และมีใบจักรผูกอยู่กับเกียร์เดิม → เปิด cascade modal ให้ user เลือก
  if(assetType==='gearbox'){
    const attached=FL_PROPELLERS.filter(p=>p.gearboxId===damaged.id || p._origGearboxId===damaged.id);
    if(attached.length){
      flOpenPropCascadeModal(incId, damaged.id, spare.id, attached.map(p=>p.id), engHours);
      return; // flShowInc จะถูกเรียกหลัง user confirm/cancel cascade
    }
  }
  flShowInc(incId);
}

