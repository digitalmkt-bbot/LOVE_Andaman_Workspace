#view-agents .ag-edit-btn.ghost{background:#fff;color:var(--fd-ink);border:1px solid var(--fd-line)}
#view-agents .ag-edit-btn.ghost:hover{background:var(--fd-bg)}
#view-agents .ag-edit-btn.primary{background:var(--fd-coral);color:#fff}
#view-agents .ag-edit-btn.primary:hover{background:var(--fd-coral-deep)}

/* ══════════ CONTRACT BANNER + HISTORY BAR ══════════ */
#view-agents .ct-banner{
  background:linear-gradient(90deg, #FAEEDA 0%, transparent 50%);
