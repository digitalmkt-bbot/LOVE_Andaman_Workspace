      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px">
      ${groupCard('คลังท่าเรือ','🏪','#0e6b87',pierOpts)}
      ${groupCard('บนเรือ (พกระหว่างทริป)','🚢','#1c4e7e',boatOpts)}
