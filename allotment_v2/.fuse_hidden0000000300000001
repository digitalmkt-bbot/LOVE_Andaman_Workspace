function flRenderInsights(){
  const wrap=document.getElementById('fl-insights-wrap');
  if(!wrap)return;
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)',line2:'#f0f0f0'};
  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};
  const calcCost=(m)=>typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0);
  const fmtShort=(n)=>{if(!n)return'฿0';if(n>=1000000)return'฿'+(n/1000000).toFixed(1)+'M';if(n>=1000)return'฿'+Math.round(n/1000)+'k';return'฿'+n;};
  const fmtFull=(n)=>'฿'+(Math.round(n||0)).toLocaleString();
  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // ── Time filter setup ──
  const todayD=new Date(TODAY_STR);
  const yr=todayD.getFullYear(); const mo=todayD.getMonth();
  let startDate, endDate=TODAY_STR, periodLabel;
  if(_insightsTimeFilter==='month'){
    startDate=new Date(yr,mo,1).toISOString().slice(0,10);
    periodLabel='This Month';
  } else if(_insightsTimeFilter==='quarter'){
    const qStart=Math.floor(mo/3)*3;
    startDate=new Date(yr,qStart,1).toISOString().slice(0,10);
    periodLabel='This Quarter';
  } else if(_insightsTimeFilter==='ytd'){
    startDate=new Date(yr,0,1).toISOString().slice(0,10);
    periodLabel='YTD';
  } else {
    startDate=null; periodLabel='All Time';
  }
  const inPeriod=(d)=>{ if(!startDate) return true; return d && d>=startDate && d<=endDate; };
  const dateLabel=`${MONTHS_EN[mo]} ${todayD.getDate()}, ${yr}`;

  // ── Aggregate data ──
  const allJobs = FL_MAINT||[];
  const allIncs = FL_INCIDENTS||[];
  const allMemos = FL_MEMOS||[];
  const periodJobs = allJobs.filter(j=>inPeriod(j.startDate));
  const periodIncs = allIncs.filter(i=>inPeriod(i.date));
  const periodSpent = periodJobs.reduce((s,j)=>s+calcCost(j),0);
  const activeJobs = allJobs.filter(j=>j.status==='inprogress' || j.status==='pending');
  const boats = BOATS || [];
  const companyBoats = boats.filter(b=>b.ownership!=='charter' && !b.retired);
  const fixingCount = companyBoats.filter(b=>{
    const cur = typeof getCurStatus==='function' ? getCurStatus(b, TODAY_STR).s : 'available';
    return cur === 'fixing';
  }).length;
  const unavailableCount = companyBoats.filter(b=>{
    const cur = typeof getCurStatus==='function' ? getCurStatus(b, TODAY_STR).s : 'available';
    return cur === 'unavailable';
  }).length;
  // Strict available count — matches Fleet Dashboard logic
  const availableCount = companyBoats.filter(b=>{
    const cur = typeof getCurStatus==='function' ? getCurStatus(b, TODAY_STR).s : 'available';
    return cur === 'available';
  }).length;

  // Per-boat aggregation
  const boatStats = {};
  companyBoats.forEach(b=>{
    boatStats[b.id] = {
      id:b.id, name:b.name, pier:b.pier,
      jobs:0, jobsActive:0, cost:0, incidents:0,
      curStatus: typeof getCurStatus==='function' ? getCurStatus(b, TODAY_STR).s : 'available'
    };
  });
  periodJobs.forEach(j=>{
    const s = boatStats[j.boatId]; if(!s) return;
    s.jobs++;
    if(j.status==='inprogress' || j.status==='pending') s.jobsActive++;
    s.cost += calcCost(j);
  });
  periodIncs.forEach(i=>{
    const s = boatStats[i.boatId]; if(!s) return;
    s.incidents++;
  });

  const getHealth = (s) => {
    if(s.jobs >= 3 || s.cost >= 100000) return {level:'critical', icon:'critical', text:'Critical', color:'#A32D2D', bg:'#FBE9E9'};
    if(s.jobs >= 1) return {level:'watch', icon:'watch', text:'Watch', color:'#854F0B', bg:'#FAEEDA'};
    return {level:'healthy', icon:'healthy', text:'Healthy', color:'#0F6E56', bg:'#E6F4ED'};
  };

  if(typeof _insightsSort === 'undefined') window._insightsSort = 'cost';
  const sortMode = window._insightsSort || 'cost';
  const boatRows = Object.values(boatStats).sort((a,b)=>{
    if(sortMode==='cost') return b.cost - a.cost;
    if(sortMode==='incidents') return b.incidents - a.incidents;
    if(sortMode==='jobs') return b.jobs - a.jobs;
    if(sortMode==='name') return a.name.localeCompare(b.name);
    return 0;
  });

  // Most-attention boat (Tier 1 alert card)
  const alertBoat = boatRows.find(s=>s.cost>0 || s.jobs>0) || null;
  const alertB = alertBoat ? boats.find(b=>b.id===alertBoat.id) : null;
  const alertReason = alertBoat ? (alertBoat.jobs ? `${alertBoat.jobs} job${alertBoat.jobs>1?'s':''} · ${fmtShort(alertBoat.cost)}` : `${alertBoat.incidents} incidents`) : '';

  // Pier counts
  const tlBoats = companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='tublamu').length;
  const vpBoats = companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='panwa').length;
  const rnBoats = companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='ranong').length;

  // Memos pending
  const memosPending = allMemos.filter(m=>m.status==='pending_approval');
  const memosPendingAmt = memosPending.reduce((s,m)=>s+(m.amount||0),0);
  const memosReceived = allMemos.filter(m=>m.status==='received');
  const memosPaidAmt = memosReceived.reduce((s,m)=>s+(m.amount||0),0);

  // ──────── HEADER BAR (matching Dashboard) ────────
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
      <div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#185FA5;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">TL</div><span style="font-size:12px;font-weight:500">Tub Lamu · ${tlBoats}</span></div>
      <div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#0F6E56;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">VP</div><span style="font-size:12px;font-weight:500">Visit Panwa · ${vpBoats}</span></div>
      ${rnBoats?`<div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#BA7517;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">RN</div><span style="font-size:12px;font-weight:500">Ranong · ${rnBoats}</span></div>`:''}
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">I</div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
      <span style="font-size:12px;color:${dim.ink2}">${dateLabel}</span>
      <span style="color:${dim.ink5}">·</span>
      <div style="display:flex;gap:4px;background:white;border:1px solid ${dim.line};border-radius:18px;padding:2px">
        ${['month','Month','quarter','Q','ytd','YTD','all','All'].reduce((a,_,i,arr)=>{ if(i%2===0){a.push([arr[i],arr[i+1]]);} return a; }, []).map(([v,l])=>{
          const on=_insightsTimeFilter===v;
          return`<button onclick="insightsSetTime('${v}')" style="background:${on?dim.ink:'transparent'};color:${on?'white':dim.ink2};border:none;border-radius:14px;padding:4px 12px;font-size:11px;font-weight:${on?600:500};cursor:pointer">${l}</button>`;
        }).join('')}
      </div>
    </div>
  </div>`;

  // ──────── TIER 1: KPI Strip (Dashboard style + Hybrid accents) ────────
  // Layout: Fleet hero | High alert (forest green) | Maintenance (pink border) | Incidents | Spent
  const FOREST = '#1F4D2C', LIME = '#C8F47C', LIME_SOFT = '#E8F5D8', LIME_DARK = '#3B6D11';
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 0.85fr 0.85fr 0.85fr 0.85fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Fleet · ${periodLabel}</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${companyBoats.length}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">boats</span>
        <span style="display:inline-flex;align-items:center;background:${LIME};color:${FOREST};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${availableCount} available</span>
        ${fixingCount?`<span style="display:inline-flex;align-items:center;background:#FAEEDA;color:#854F0B;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${fixingCount} fixing</span>`:''}
        ${unavailableCount?`<span style="display:inline-flex;align-items:center;background:#FBE9E9;color:#A32D2D;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${unavailableCount} unavailable</span>`:''}
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${periodIncs.length} incidents · ${periodJobs.length} jobs · ${fmtShort(periodSpent)} spent · avg ${fmtShort(periodJobs.length?periodSpent/periodJobs.length:0)}/job</div>
    </div>

    <div ${alertB?`onclick="flGoToAsset('boats','${alertB.id}')"`:''} style="grid-column:2;background:${FOREST};color:white;border-radius:14px;padding:11px 13px;position:relative;${alertB?'cursor:pointer':''}">
      <div style="display:flex;align-items:center;justify-content:space-between"><span style="font-size:10px;color:#9BB89B">High alert</span><span style="color:${LIME};font-size:11px">◆</span></div>
      <div style="font-size:18px;font-weight:700;line-height:1.2;margin-top:2px">${alertB?alertB.name:'—'}</div>
      <div style="font-size:11px;color:#9BB89B;margin-top:6px">${alertReason||'no alerts'}</div>
      ${alertB?`<span style="position:absolute;bottom:11px;right:11px;color:${LIME};font-size:14px">›</span>`:''}
    </div>

    <div onclick="nav(document.querySelector('[data-view=fl-maintenance]'))" style="grid-column:3;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${SVG_PINK.accent};cursor:pointer">
      <div style="font-size:10px;color:${dim.ink3}">Active Jobs</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${SVG_PINK.accent};color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${activeJobs.length}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">in progress</span></div>
      <div style="display:flex;align-items:center;gap:3px;margin-top:7px"><span style="color:${SVG_PINK.text};font-size:11px;font-weight:600">${activeJobs.filter(j=>j.status==='pending').length} pending</span></div>
    </div>

    <div onclick="nav(document.querySelector('[data-view=fl-incident]'))" style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line};cursor:pointer">
      <div style="font-size:10px;color:${dim.ink3}">Incidents</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${dim.bg};color:${dim.ink};padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${periodIncs.length}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">${periodLabel.toLowerCase()}</span></div>
      <div style="display:flex;align-items:center;gap:3px;margin-top:7px"><span style="color:#A32D2D;font-size:11px;font-weight:600">${periodIncs.filter(i=>i.priority>=4).length} critical</span></div>
    </div>

    <div onclick="nav(document.querySelector('[data-view=fl-cost]'))" style="grid-column:5;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line};cursor:pointer">
      <div style="font-size:10px;color:${dim.ink3}">Spent</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2">${fmtShort(periodSpent)}</span></div>
      <div style="display:flex;align-items:center;gap:3px;margin-top:7px"><span style="color:#0F6E56;font-size:11px;font-weight:600">${periodJobs.length} jobs</span></div>
    </div>
  </div>`;

  // ──────── PILL ROW (Dashboard style) ────────
