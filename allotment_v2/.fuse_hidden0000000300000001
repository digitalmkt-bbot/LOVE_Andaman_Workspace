    vatEnabled,vatRate,
    subtotal:sub,discount:discTotal,afterDiscount:afterDisc,vat,amount:total,
    status:'pending_approval',currentStep:1,createdDate:memoDate
  };

  // ════ Phase 3: Auto-register inventory items ════
  // สำหรับ items ที่มี autoRegister:true → สร้าง inventory item ใหม่ + ผูก invId เข้า memo
  let autoCreatedCount = 0;
  memo.items.forEach(it => {
    if(it.autoRegister && !it.invId){
      // Double-check: หากระหว่างที่กรอก memo มีคนสร้าง inv ชื่อเดียวกันไปก่อน → ลิ้งของเดิม
      const existing = (FL_INVENTORY||[]).find(x => x.name === it.name);
      if(existing){
        it.invId = existing.id;
        it.fromInventory = true;
        it.autoRegister = false;
        return;
      }
      // สร้าง inventory item ใหม่
      const newId = 'i_auto_'+Date.now()+'_'+Math.floor(Math.random()*1000);
      const newInv = {
        id: newId,
        name: it.name,
        partNo: it.partNo||'',
        category: 'general',
        supplier: memo.supplier || '',
        location: '',
        stocks: [],  // ยังไม่มี stock จริง · จะมีตอน Receive
        qty: 0, totalQty: 0, primaryLocation: '', minQty: 0,
        unit: it.unit||'ชิ้น',
        cost: it.price||0,
        note: `สร้างอัตโนมัติจาก Memo ${memo.no}`,
        createdFrom: memo.no,
        createdDate: memoDate,
        history: [{
          date: memoDate, type: 'register', qty: 0,
          note: `ลงทะเบียนรายการอัตโนมัติจาก Memo ${memo.no}`,
          by: 'ระบบ (auto)'
        }]
      };
      FL_INVENTORY.push(newInv);
      // ผูก invId เข้า memo item
      it.invId = newId;
      it.fromInventory = true;
      it.autoRegister = false; // reset flag · ตอนนี้เป็น registered แล้ว
      autoCreatedCount++;
    }
  });
  if(autoCreatedCount > 0){
    console.log(`[Memo Save] Auto-registered ${autoCreatedCount} new inventory item(s)`);
  }

  flAssertUniqueNo(FL_MEMOS, no, 'MO');
  FL_MEMOS.push(memo);
  if(_memoMaintId){
    flPushLog(_memoMaintId,`📋 สร้าง Memo ${no} · ${subject} · ฿${total.toLocaleString()}`);
    if(m){if(!m.progressLog)m.progressLog=[];m.progressLog.push({date:memoDate,text:`📋 สร้าง Memo ${no} · ฿${total.toLocaleString()}`,by:'ระบบ'});}
  }
  // Project-level memo log
  const _projMemoId = _memoProjectId;
  if(_projMemoId){
    const _proj = (FL_PROJECTS||[]).find(x=>x.id===_projMemoId);
    if(_proj){
      if(!_proj.log) _proj.log=[];
      _proj.log.push({date:memoDate, text:`Memo ${no} · ${subject} · ฿${total.toLocaleString()} (Project overhead)`, by:'user'});
    }
  }
  _memoProjectId = null;  // reset for next memo
  flSave();
  closeModal('fl-modal-memo');
