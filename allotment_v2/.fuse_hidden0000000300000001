      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
      Registry
    </div>
    <div class="nav-item" data-view="fl-asset" onclick="nav(this)" style="border-left:2px solid rgba(255,190,80,.25);padding-left:9px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      Company Asset
    </div>
    <div style="height:1px;background:rgba(255,255,255,.07);margin:8px 6px 2px"></div>
