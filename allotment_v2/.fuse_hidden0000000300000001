    } else {
      const capList = (typeof getAssignedBoatsForRouteDate==='function') ? getAssignedBoatsForRouteDate(rid,date).filter(a=>!a.charterBookingId) : [];
      const cap = capList.reduce((s,a)=>s+(a.boat?.cap||0),0);
      const booked = (typeof getSeatsConsumed==='function') ? getSeatsConsumed(rid,date) : 0;
      const locked = bkV2LockedTotal(rid,date);
      const avail = Math.max(0, cap - booked - locked);
      availBar = cap>0 ? `
        <div style="display:flex;height:8px;border-radius:5px;overflow:hidden;background:#EEF0F3;margin-top:6px">
          <div style="width:${Math.round(booked/cap*100)}%;background:#64748B"></div>
          <div style="width:${Math.round(locked/cap*100)}%;background:#C0392B"></div>
        </div>
        <div style="display:flex;gap:14px;margin-top:5px;font-size:10px;color:var(--ink-soft)">
          <span><b style="color:var(--ink)">${cap}</b> cap</span>
