  const holdBtn   = `<button onclick="flProjHold('${p.id}')" style="background:white;border:1px solid #FDE68A;color:${P.amberInk};${btnBase};box-shadow:${P.shadow}">${flProjIcon('pause',13,P.amberInk)} Hold</button>`;
