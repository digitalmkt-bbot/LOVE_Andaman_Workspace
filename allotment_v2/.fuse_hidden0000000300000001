#view-agents .ct-arch-prog-info{display:flex;flex-direction:column;gap:1px;min-width:0}
#view-agents .ct-arch-prog-name{font-size:12px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.005em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#view-agents .ct-arch-prog-pier{font-size:9px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.04em;text-transform:uppercase;font-weight:600}
#view-agents .ct-arch-prog-period{display:flex;flex-direction:column;gap:1px;text-align:right;font-size:10px;font-variant-numeric:tabular-nums;color:var(--fd-ink-mid)}
#view-agents .ct-arch-prog-period-lbl{font-size:8px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--fd-ink-soft)}

/* Add-on list (compact) */
#view-agents .ct-arch-addon-row{
  background:var(--fd-bg);border-radius:10px;padding:9px 12px;margin-bottom:5px;
  display:grid;grid-template-columns:28px 1fr;gap:10px;align-items:center;
}
#view-agents .ct-arch-addon-row .aos-svc-icon{width:28px;height:28px}
#view-agents .ct-arch-addon-row .aos-svc-icon svg{width:13px;height:13px}
#view-agents .ct-arch-addon-info{display:flex;flex-direction:column;gap:1px}
#view-agents .ct-arch-addon-name{font-size:12px;font-weight:700;color:var(--fd-ink)}
#view-agents .ct-arch-addon-vars{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}

/* Signatory card */
#view-agents .ct-arch-sig{
  background:#E1F5EE;border-radius:12px;padding:12px 14px;
}
#view-agents .ct-arch-sig-role{font-size:9px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#0F6E56;margin-bottom:5px}
#view-agents .ct-arch-sig-name{font-size:13px;font-weight:700;color:#0F6E56;letter-spacing:-0.005em}
#view-agents .ct-arch-sig-pos{font-size:11px;color:var(--fd-ink-mid);font-variant-numeric:tabular-nums;margin-top:1px}
#view-agents .ct-arch-sig-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em;margin-top:5px}

/* Empty data */
#view-agents .ct-arch-empty{
  font-size:11px;color:var(--fd-ink-soft);font-style:italic;
  padding:10px 14px;background:var(--fd-bg);border-radius:10px;text-align:center;
}

/* Action: open as wizard from archived */
#view-agents .ct-arch-actions{
  padding:14px 20px;border-top:1px solid var(--fd-line-soft);
  display:flex;justify-content:space-between;align-items:center;gap:10px;
  background:var(--fd-bg);flex-shrink:0;
}
#view-agents .ct-arch-actions-l{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}

/* Highlight current-viewing pill */
#view-agents .ct-history-pill.viewing{
  background:#f4ecde;border-color:transparent;color:#8a7548;font-weight:600;
}
#view-agents .ct-history-pill.viewing::before{content:'';width:6px;height:6px;border-radius:50%;background:#8a7548;box-shadow:0 0 0 3px rgba(138,117,72,.15)}
/* Form fields */
#view-agents .ag-fld{display:flex;flex-direction:column;gap:5px}
#view-agents .ag-fld-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
#view-agents .ag-fld-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
#view-agents .ag-fld-lbl{font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--fd-ink-soft)}
#view-agents .ag-fld-lbl .req{color:var(--fd-coral)}
#view-agents .ag-fld input,#view-agents .ag-fld textarea,#view-agents .ag-fld select{padding:8px 12px;font-size:12px;font-family:inherit;border:1px solid var(--fd-line);border-radius:10px;outline:none;transition:all .12s;color:var(--fd-ink);background:#fff}
#view-agents .ag-fld textarea{resize:vertical;min-height:60px;font-family:inherit}
#view-agents .ag-fld input:focus,#view-agents .ag-fld textarea:focus,#view-agents .ag-fld select:focus{border-color:var(--fd-coral);box-shadow:0 0 0 3px var(--fd-coral-veryfaint)}
#view-agents .ag-fld input[disabled]{background:var(--fd-bg);color:var(--fd-ink-soft);cursor:not-allowed}
#view-agents .ag-fld-hint{font-size:10px;color:var(--fd-ink-soft);margin-top:2px;font-style:italic}
#view-agents .ag-sub-dd{position:absolute;left:0;right:0;top:100%;margin-top:4px;background:#fff;border:1px solid var(--fd-line);border-radius:9px;box-shadow:0 8px 24px rgba(15,23,42,.14);max-height:208px;overflow-y:auto;z-index:60;padding:4px}
#view-agents .ag-sub-opt{padding:8px 11px;font-size:12.5px;color:var(--fd-ink);border-radius:6px;cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#view-agents .ag-sub-opt:hover{background:var(--fd-coral-soft)}
#view-agents .ag-sub-new{color:#185FA5;font-weight:600;border-top:1px solid var(--fd-line-soft);margin-top:2px}

/* Section subtitle inside modal */
#view-agents .ag-edit-subhd{font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--fd-coral-deep);padding-bottom:6px;border-bottom:1px dashed var(--fd-coral-soft);margin-top:8px}

/* Program period editor row */
#view-agents .ag-pp-row{background:var(--fd-bg);border-radius:12px;padding:12px;display:flex;flex-direction:column;gap:8px;position:relative}
#view-agents .ag-pp-row-hd{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:2px}
#view-agents .ag-pp-route-pick{flex:1}
#view-agents .ag-pp-row-rm{background:transparent;border:none;color:var(--fd-ink-soft);font-size:13px;cursor:pointer;padding:4px 6px;border-radius:6px}
#view-agents .ag-pp-row-rm:hover{background:#FCEBEB;color:#A32D2D}
#view-agents .ag-pp-dates{display:grid;grid-template-columns:1fr 1fr;gap:8px}
#view-agents .ag-pp-period-block{display:flex;flex-direction:column;gap:4px}
#view-agents .ag-pp-period-ttl{font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--fd-ink-soft);display:flex;align-items:center;gap:5px}
#view-agents .ag-pp-period-ttl::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--fd-ink-faint)}
#view-agents .ag-pp-period-ttl.book::before{background:#185FA5}
#view-agents .ag-pp-period-ttl.travel::before{background:var(--fd-coral)}
#view-agents .ag-pp-period-inputs{display:grid;grid-template-columns:1fr 1fr;gap:6px}
#view-agents .ag-pp-add{background:transparent;border:1px dashed var(--fd-line);border-radius:12px;padding:11px;color:var(--fd-ink-soft);font-size:12px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:inherit}
#view-agents .ag-pp-add:hover{border-color:var(--fd-coral);color:var(--fd-coral-deep)}

/* ══════════ Pricing Tab — Sections (incl. Additional Services) ══════════ */
#view-agents .agp-sect{margin-bottom:24px}
#view-agents .agp-sect:last-child{margin-bottom:0}
#view-agents .agp-sect-hd{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--fd-line-soft);gap:14px}
#view-agents .agp-sect-ttl{font-size:13px;font-weight:700;color:var(--fd-ink);letter-spacing:0;display:flex;align-items:center;gap:8px}
#view-agents .agp-sect-ttl::before{content:'';width:4px;height:14px;background:var(--fd-coral);border-radius:2px}
#view-agents .agp-sect-cnt{font-size:10px;font-weight:600;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;margin-left:6px;letter-spacing:.02em}
#view-agents .agp-sect-desc{font-size:11px;color:var(--fd-ink-soft);margin-top:2px;font-weight:400}
#view-agents .agp-sect-act{font-size:11px;color:var(--fd-coral);font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;background:transparent;border:1px solid var(--fd-coral-soft);font-family:inherit;padding:5px 12px;border-radius:14px;transition:all .12s}
#view-agents .agp-sect-act:hover{background:var(--fd-coral-veryfaint)}
#view-agents .agp-sect-act svg{width:11px;height:11px}

/* Add-on empty state */
#view-agents .agp-addon-empty{background:var(--fd-bg);border-radius:14px;padding:30px 18px;text-align:center}

/* Add-on cards */
#view-agents .agp-addon-list{display:flex;flex-direction:column;gap:10px}
#view-agents .agp-addon-card{background:#fff;border:1px solid var(--fd-line);border-radius:14px;overflow:hidden}
#view-agents .agp-addon-card-hd{padding:12px 16px;display:grid;grid-template-columns:32px 1fr auto;gap:12px;align-items:center;border-bottom:1px solid var(--fd-line-soft)}
#view-agents .agp-addon-card-info{display:flex;flex-direction:column;gap:1px;min-width:0}
#view-agents .agp-addon-card-name{font-size:13px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.005em}
#view-agents .agp-addon-card-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums}
#view-agents .agp-addon-card-body{padding:10px 16px 12px}
#view-agents .agp-addon-variants{display:flex;flex-direction:column;gap:6px}
#view-agents .agp-addon-variant{display:grid;grid-template-columns:1fr auto auto;gap:14px;align-items:center;padding:8px 12px;background:var(--fd-bg);border-radius:10px}
#view-agents .agp-addon-variant-info{display:flex;flex-direction:column;gap:1px;min-width:0}
#view-agents .agp-addon-variant-ttl{font-size:12px;font-weight:600;color:var(--fd-ink-mid)}
#view-agents .agp-addon-variant-unit{font-size:9px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}
#view-agents .agp-addon-pcol{display:flex;flex-direction:column;align-items:flex-end;gap:1px;min-width:78px}
#view-agents .agp-addon-plbl{font-size:9px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--fd-ink-soft)}
#view-agents .agp-addon-pval{font-size:13px;font-weight:700;font-variant-numeric:tabular-nums;font-variant-numeric:tabular-nums;color:var(--fd-ink)}
#view-agents .agp-addon-pval.net{color:#0F6E56}

/* Service picker modal list */
#view-agents .agp-pick-list{display:flex;flex-direction:column;gap:8px;margin-top:4px}
#view-agents .agp-pick-card{background:#fff;border:1px solid var(--fd-line);border-radius:14px;padding:12px 14px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:all .12s}
#view-agents .agp-pick-card:hover{border-color:var(--fd-coral);background:var(--fd-coral-veryfaint)}
#view-agents .agp-pick-info{display:flex;flex-direction:column;gap:1px;flex:1;min-width:0}
#view-agents .agp-pick-name{font-size:13px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.005em}
#view-agents .agp-pick-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums}

/* Variant price editor modal */
#view-agents .agp-var-list{display:flex;flex-direction:column;gap:8px;margin-top:4px}
#view-agents .agp-var-row{background:var(--fd-bg);border-radius:12px;padding:12px;display:grid;grid-template-columns:1fr 110px 110px;gap:10px;align-items:end}
#view-agents .agp-var-info{display:flex;flex-direction:column;gap:2px;min-width:0;padding-bottom:8px}
#view-agents .agp-var-ttl{font-size:12px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.005em}
#view-agents .agp-var-unit{font-size:9px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em;text-transform:uppercase;font-weight:600}
#view-agents .agp-var-fld{display:flex;flex-direction:column;gap:3px}
#view-agents .agp-var-fld label{font-size:9px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--fd-ink-soft)}
#view-agents .agp-var-fld input{padding:7px 10px;font-size:12px;font-variant-numeric:tabular-nums;border:1px solid var(--fd-line);border-radius:8px;outline:none;color:var(--fd-ink);background:#fff;text-align:right}
#view-agents .agp-var-fld input:focus{border-color:var(--fd-coral);box-shadow:0 0 0 3px var(--fd-coral-veryfaint)}

/* Modal buttons */
#view-agents .agp-btn-ghost{background:#fff;color:var(--fd-ink);border:1px solid var(--fd-line);font-family:inherit;font-size:12px;font-weight:600;padding:8px 16px;border-radius:18px;cursor:pointer}
#view-agents .agp-btn-ghost:hover{background:var(--fd-bg)}
#view-agents .agp-btn-primary{background:var(--fd-coral);color:#fff;border:none;font-family:inherit;font-size:12px;font-weight:600;padding:8px 16px;border-radius:18px;cursor:pointer}
#view-agents .agp-btn-primary:hover{background:var(--fd-coral-deep)}

/* Re-use aos-svc-icon classes for icons */
#view-agents .aos-svc-icon{display:flex;align-items:center;justify-content:center;border-radius:50%;flex-shrink:0;width:36px;height:36px}
#view-agents .aos-svc-icon svg{width:16px;height:16px}
#view-agents .aos-svc-icon.boat{background:#E6F1FB;color:#185FA5}
#view-agents .aos-svc-icon.van{background:#FAEEDA;color:#854F0B}
#view-agents .aos-svc-icon.guide{background:var(--fd-coral-soft);color:var(--fd-coral-deep)}
#view-agents .aos-svc-icon.other{background:#E1F5EE;color:#0F6E56}
#view-agents .aos-icon-btn{width:28px;height:28px;border-radius:50%;background:#fff;border:1px solid var(--fd-line);color:var(--fd-ink-soft);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .12s}
#view-agents .aos-icon-btn:hover{background:var(--fd-bg);color:var(--fd-ink)}
#view-agents .aos-icon-btn.danger:hover{background:#FCEBEB;color:#A32D2D;border-color:#FCEBEB}
#view-agents .aos-icon-btn svg{width:11px;height:11px}

/* Filter button + popover */
#view-agents .ag-filter-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:5px;
  width:28px;height:24px;padding:0 6px;
  background:#fff;border:1px solid var(--fd-line);border-radius:7px;
  color:var(--fd-ink-mid);cursor:pointer;transition:all .12s;
  font-variant-numeric:tabular-nums;font-size:9px;font-weight:600;
  position:relative;
}
#view-agents .ag-filter-btn:hover{border-color:var(--fd-ink-soft);color:var(--fd-ink)}
#view-agents .ag-filter-btn.has-filter{background:var(--fd-coral);border-color:var(--fd-coral);color:#fff}
#view-agents .ag-filter-btn svg{width:11px;height:11px}
#view-agents .ag-filter-btn span{font-size:9px;font-weight:700;line-height:1}
#view-agents .ag-filter-btn span:empty{display:none}

/* Popover */
#view-agents .ag-filter-pop{
  position:absolute;top:calc(100% + 8px);right:0;z-index:50;
  background:#fff;border:1px solid var(--fd-line);
  border-radius:14px;box-shadow:0 8px 24px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);
  padding:14px;width:320px;
  display:flex;flex-direction:column;gap:10px;
}
#view-agents .ag-filter-pop-hd{
  display:flex;align-items:center;justify-content:space-between;
  padding-bottom:8px;border-bottom:1px solid var(--fd-line-soft);
  margin-bottom:2px;
}
#view-agents .ag-filter-pop-ttl{
  font-size:12px;font-weight:700;color:var(--fd-ink);letter-spacing:-0.005em;
}
#view-agents .ag-filter-pop-clear{
  background:transparent;border:none;color:var(--fd-coral);cursor:pointer;
  font-size:11px;font-weight:600;font-family:inherit;padding:2px 6px;
}
#view-agents .ag-filter-pop-clear:hover{text-decoration:underline}

/* Filter rows inside popover */
#view-agents .ag-filter-pop .ag-filter-row{
  display:flex;flex-direction:column;gap:6px;align-items:stretch;
  background:transparent;border:none;border-radius:0;padding:0;
}
#view-agents .ag-filter-pop .ag-filter-lbl{
  font-size:10px;font-weight:700;color:var(--fd-ink-soft);
  min-width:auto;text-transform:uppercase;letter-spacing:.06em;
  padding:0;border:none;margin:0;
}
#view-agents .ag-filter-pop .filter-pills{display:flex;gap:4px;flex-wrap:wrap}

/* Chips inside popover — smaller, same C1 style */
#view-agents .ag-filter-pop .fp{
  padding:4px 10px 4px 6px;border-radius:14px;
  font-size:10.5px;color:var(--fd-ink-mid);background:transparent;
  border:none;font-weight:500;display:inline-flex;align-items:center;gap:6px;
  cursor:pointer;transition:all .12s;
}
#view-agents .ag-filter-pop .fp:hover{background:var(--fd-bg)}
#view-agents .ag-filter-pop .fp.on{font-weight:700;color:var(--fd-ink);background:#eeece6}
#view-agents .ag-filter-pop .fp-cnt{font-size:9px;font-variant-numeric:tabular-nums;color:var(--fd-ink-soft);font-weight:600}
#view-agents .ag-filter-pop .fp.on .fp-cnt{display:none}
#view-agents .ag-filter-pop .fp > span:first-child{display:inline-flex;align-items:center;justify-content:center;width:9px;height:9px;border-radius:50%;flex-shrink:0;color:transparent;font-size:0;transition:all .15s}




/* Agent List */
.sb-wrap{display:grid;grid-template-columns:300px 1fr;gap:14px;align-items:flex-start}
.sb-side{background:#fff;border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;position:sticky;top:80px;max-height:calc(100vh - 100px);display:flex;flex-direction:column}
.sb-side-hd{padding:11px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--sand-mid)}
.sb-side-hd-ttl{font-size:11px;font-weight:600;color:var(--ink)}
.sb-side-body{overflow-y:auto;flex:1}
.sb-mkt-group{border-bottom:1px solid var(--border)}
.sb-mkt-hd{padding:8px 14px;background:var(--sand);font-size:10px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-mid);cursor:pointer;display:flex;align-items:center;gap:6px;user-select:none}
.sb-mkt-hd:hover{background:var(--sand-dark)}
.sb-mkt-chev{transition:transform .15s;display:inline-block;font-size:9px;color:var(--ink-soft)}
.sb-mkt-group.collapsed .sb-mkt-chev{transform:rotate(-90deg)}
.sb-mkt-group.collapsed .sb-mkt-list{display:none}
.sb-mkt-count{margin-left:auto;font-size:10px;color:var(--ink-soft);background:rgba(0,0,0,.04);padding:1px 6px;border-radius:8px;font-family:'DM Mono',monospace}
.sb-mkt-list{padding:4px 0}
.sb-ag-row:hover{background:var(--sand);color:var(--ink)}
.sb-ag-row.sel{background:var(--sb-pink-light);border-left-color:var(--sb-pink);color:var(--sb-pink-dark);font-weight:500}
.sb-ag-dot{width:6px;height:6px;border-radius:50%;background:var(--ink-soft);flex-shrink:0}
.sb-ag-row.sel .sb-ag-dot{background:var(--sb-pink)}
.sb-ag-sub{margin-left:auto;font-size:9px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em}

.sb-main{background:#fff;border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;min-height:400px}
.sb-main-hd{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.sb-main-ttl{font-size:15px;font-weight:600;color:var(--ink);display:flex;align-items:center;gap:8px}
.sb-main-sub{font-size:11px;color:var(--ink-soft);margin-top:2px}
.sb-main-body{padding:18px}
.sb-empty{padding:50px 20px;text-align:center;color:var(--ink-soft);font-size:12px}

.sb-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 18px;background:#fff}
.sb-tab{padding:10px 16px;font-size:12px;font-weight:500;color:var(--ink-soft);cursor:pointer;border-bottom:2px solid transparent;transition:all .12s;display:flex;align-items:center;gap:6px}
.sb-tab:hover{color:var(--ink)}
.sb-tab.on{color:var(--sb-pink-dark);border-bottom-color:var(--sb-pink)}

.sb-meta-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:16px}
.sb-meta-card{background:var(--sand);border:1px solid var(--border);border-radius:var(--r-sm);padding:10px 12px}
.sb-meta-lbl{font-size:9px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:3px}
.sb-meta-val{font-size:13px;color:var(--ink);font-weight:500}
.sb-meta-val.mono{font-family:'DM Mono',monospace;font-size:12px}

.sb-chip{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:500;background:var(--sand-dark);color:var(--ink-mid)}
.sb-chip.pink{background:var(--sb-pink-light);color:var(--sb-pink-dark)}
.sb-chip.blue{background:var(--ocean-50);color:var(--ocean)}
.sb-chip.green{background:var(--green-light);color:var(--green-dark)}
.sb-chip.amber{background:var(--amber-light);color:#7a4a00}

/* Price Matrix */
.sb-price-tbl{width:100%;border-collapse:collapse;font-size:11px}
.sb-price-tbl th{padding:8px 10px;text-align:left;font-size:10px;font-weight:600;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em;background:var(--sand);border-bottom:1px solid var(--border)}
.sb-price-tbl th.num,.sb-price-tbl td.num{text-align:right;font-family:'DM Mono',monospace}
.sb-price-tbl td{padding:9px 10px;border-bottom:1px solid var(--border);color:var(--ink)}
.sb-price-tbl tr:hover td{background:var(--sand)}
.sb-price-tbl tr.prog-row td{background:var(--sand-mid);font-weight:500}
.sb-price-tbl .prog-name{font-size:12px;font-weight:500;color:var(--ink)}
.sb-price-tbl .prog-pier{font-size:9px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em}
.sb-price-tbl .pax-cell{display:flex;flex-direction:column;gap:2px}
.sb-price-tbl .pax-thai{color:var(--ink)}
.sb-price-tbl .pax-foreigner{color:var(--ocean)}
.sb-price-tbl .pax-lbl{font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-soft);margin-right:4px}
.sb-price-tbl input.price-in{width:70px;padding:3px 5px;font-size:11px;font-family:'DM Mono',monospace;text-align:right;border:1px solid var(--border);border-radius:3px;background:transparent}
.sb-price-tbl input.price-in:focus{border-color:var(--sb-pink);outline:none}

/* Booking entry */
.bk-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);background:#fff;border-radius:var(--r) var(--r) 0 0;overflow:hidden}
.bk-tab{flex:1;padding:14px 20px;font-size:13px;font-weight:500;color:var(--ink-soft);cursor:pointer;border-bottom:3px solid transparent;text-align:center;transition:all .12s;background:var(--sand)}
.bk-tab.on{background:#fff;color:var(--sb-pink-dark);border-bottom-color:var(--sb-pink)}
.bk-tab svg{width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:6px}

.bk-form{background:#fff;border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r) var(--r);padding:20px;box-shadow:var(--shadow)}
.bk-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.bk-fld{display:flex;flex-direction:column;gap:5px}
.bk-fld-lbl{font-size:10px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-soft)}
.bk-fld-lbl .req{color:var(--coral);margin-left:2px}
.bk-fld input,.bk-fld select,.bk-fld textarea{padding:8px 10px;font-size:12px;font-family:'DM Sans',sans-serif;border:1px solid var(--border);border-radius:var(--r-sm);background:#fff;color:var(--ink);outline:none;transition:all .12s}
.bk-fld input:focus,.bk-fld select:focus,.bk-fld textarea:focus{border-color:var(--sb-pink);box-shadow:0 0 0 3px var(--sb-pink-light)}
.bk-fld textarea{resize:vertical;min-height:60px;font-family:'DM Sans',sans-serif}

.bk-pax-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.bk-pax-card{background:var(--sand);border:1px solid var(--border);border-radius:var(--r-sm);padding:10px;display:flex;flex-direction:column;gap:4px;text-align:center}
.bk-pax-card .lbl{font-size:9px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft)}
.bk-pax-card input{padding:6px;font-size:18px;font-weight:600;text-align:center;border:1px solid var(--border);border-radius:var(--r-sm);font-family:'DM Mono',monospace;color:var(--ink);background:#fff}
.bk-pax-card .price{font-size:10px;color:var(--ink-soft);font-family:'DM Mono',monospace}

.bk-summary{background:linear-gradient(135deg,var(--sb-pink-light) 0%,#fff 100%);border:1px solid var(--sb-pink-light);border-radius:var(--r);padding:14px 16px;margin-top:14px}
.bk-summary-row{display:flex;justify-content:space-between;padding:5px 0;font-size:12px}
.bk-summary-row .lbl{color:var(--ink-soft)}
.bk-summary-row .val{font-family:'DM Mono',monospace;color:var(--ink);font-weight:500}
.bk-summary-row.total{border-top:1px solid rgba(212,74,127,.2);margin-top:6px;padding-top:10px}
.bk-summary-row.total .lbl{font-weight:600;color:var(--sb-pink-dark)}
.bk-summary-row.total .val{font-size:18px;font-weight:600;color:var(--sb-pink-dark)}

.bk-section-divider{display:flex;align-items:center;gap:10px;margin:18px 0 12px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft)}
.bk-section-divider::before,.bk-section-divider::after{content:'';flex:1;height:1px;background:var(--border)}

.bk-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)}
.btn-pink{background:var(--sb-pink);border-color:var(--sb-pink);color:#fff}
.btn-pink:hover{background:var(--sb-pink-dark)}

/* Recent bookings strip */
.bk-recent{margin-top:18px;background:#fff;border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.bk-recent-hd{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--sand-mid)}
.bk-recent-hd-ttl{font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-mid)}
.bk-recent-tbl{width:100%;border-collapse:collapse;font-size:11px}
.bk-recent-tbl th{padding:9px 12px;text-align:left;font-size:9px;font-weight:600;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.05em;background:#fff;border-bottom:1px solid var(--border)}
.bk-recent-tbl th.num,.bk-recent-tbl td.num{text-align:right;font-family:'DM Mono',monospace}
.bk-recent-tbl td{padding:9px 12px;border-bottom:0.5px solid var(--border);color:var(--ink)}
.bk-recent-tbl tr:hover td{background:var(--sand)}
.bk-recent-tbl .bk-id{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink-soft)}

/* B2C channels - card style */
.b2c-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px}
.b2c-card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:16px;box-shadow:var(--shadow);transition:all .15s;cursor:pointer;position:relative;overflow:hidden}
.b2c-card:hover{border-color:var(--sb-pink);transform:translateY(-1px);box-shadow:0 4px 12px rgba(212,74,127,.08)}
.b2c-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--sb-pink)}
.b2c-card.campaign::before{background:var(--coral)}
.b2c-card-hd{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.b2c-card-icon{width:36px;height:36px;border-radius:8px;background:var(--sb-pink-light);display:flex;align-items:center;justify-content:center;color:var(--sb-pink-dark)}
.b2c-card.campaign .b2c-card-icon{background:var(--coral-light);color:var(--coral)}
.b2c-card-icon svg{width:18px;height:18px}
.b2c-card-name{font-size:13px;font-weight:600;color:var(--ink)}
.b2c-card-type{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-soft);margin-top:1px}
.b2c-card-stats{display:flex;gap:14px;padding:10px 0;border-top:1px solid var(--border);margin-top:8px}
.b2c-card-stat{flex:1}
.b2c-card-stat-lbl{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-soft)}
.b2c-card-stat-val{font-size:16px;font-weight:600;color:var(--ink);font-family:'DM Mono',monospace;line-height:1.2;margin-top:2px}
.b2c-card-note{font-size:10px;color:var(--ink-soft);margin-top:6px;line-height:1.4}

/* KPI cards adapted for sales */
.sb-kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
.sb-kpi{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.sb-kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--sb-pink)}
.sb-kpi.k-blue::after{background:var(--ocean-mid)}
.sb-kpi.k-green::after{background:var(--green)}
.sb-kpi.k-amber::after{background:var(--amber)}
.sb-kpi-lbl{font-size:9px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--ink-soft)}
.sb-kpi-val{font-size:22px;font-weight:600;color:var(--ink);font-family:'DM Sans',sans-serif;margin-top:3px;line-height:1}
.sb-kpi-sub{font-size:10px;color:var(--ink-soft);margin-top:3px;font-family:'DM Mono',monospace}
</style>
<style id="bkv2-buildaxis-skin">
/* ===== Booking · BuildAxis re-skin (color / font / card) · scoped to #view-booking ===== */
#view-booking{
  font-family:'Inter',system-ui,sans-serif;
  font-variant-numeric:tabular-nums;
  background:#F6F7F9;
  /* accent ramp · navy -> bright blue */
  --bk-navy-deep:#2952C8; --bk-navy:#3A6FF7; --bk-navy-mid:#7DA0E8;
  --bk-navy-soft:#AFC4F0; --bk-navy-light:#D6E2FB; --bk-navy-50:#EEF3FF;
  /* neutrals */
  --ink:#1F2A44; --ink-mid:#475569; --ink-soft:#64748B;
  --border:#E5E7EB;
  --sand:#F6F7F9; --sand-mid:#F1F5F9; --sand-dark:#E5E7EB;
  /* card geometry + shadow */
  --r:16px; --r-sm:11px; --r-lg:18px;
  --shadow:0 1px 2px rgba(15,23,42,.04),0 1px 3px rgba(15,23,42,.06);
  /* vars consumed by the t2 manifest (By trip date) */
  --coral:#3A6FF7; --coral-light:#EEF3FF; --coral-soft:#EEF3FF;
  --bg:#F6F7F9; --ink-faint:#94A3B8; --border-2:#EEF0F3; --white:#ffffff;
}
#view-booking *{font-family:inherit}
/* soft shadow on inner cards that previously had border only */
#view-booking .bkv2-stat,
#view-booking .bkv2-route-card,
#view-booking .bkv2-rd-card,
#view-booking .t2-trip,
#view-booking .t2-side{box-shadow:0 1px 2px rgba(15,23,42,.04),0 1px 3px rgba(15,23,42,.06)}
#view-booking .t2-trip{border-radius:16px}
/* cream cards -> clean white / pale blue */
#view-booking .bkv2-route-card{background:#fff;border-color:#E5E7EB}
#view-booking .bkv2-week-summary{background:#EEF3FF;border-color:#D6E2FB}
/* calendar day chips -> cooler neutral fill */
#view-booking .bkv2-cal-chip{background:#F1F5F9}
/* heavier navy headings */
#view-booking .bkv2-stat .s-val,
#view-booking .bkv2-selday-ttl,
#view-booking .t2-tnm,
#view-booking .bkv2-week-summary .ws-total{font-weight:800;letter-spacing:-.3px}
/* primary tab active -> filled blue */
#view-booking .bkv2-tab.on{background:var(--bk-navy);color:#fff;box-shadow:none}

/* ===== Topbar · Option A (underline tabs) · separate card ===== */
#view-booking .bkv2-topcard{margin-bottom:12px;overflow:visible}
#view-booking .bkv2-topbar2{display:flex;align-items:center;gap:13px;padding:7px 16px;flex-wrap:wrap;background:#fff}
#view-booking .bkv2-utabs{display:flex;align-items:flex-end;gap:6px}
#view-booking .bkv2-utab{font-size:13px;font-weight:600;color:#64748B;padding:9px 4px 10px;border:none;background:none;border-bottom:2px solid transparent;cursor:pointer;font-family:inherit;line-height:1.2}
#view-booking .bkv2-utab:hover{color:#1F2A44}
#view-booking .bkv2-utab.on{color:#1F2A44;font-weight:700;border-bottom-color:#3A6FF7}
#view-booking .bkv2-topdiv{width:1px;height:22px;background:#E5E7EB}
#view-booking .bkv2-vseg{display:inline-flex;background:#F1F5F9;border-radius:8px;padding:3px;gap:2px}
#view-booking .bkv2-vsegbtn{width:30px;height:26px;border:none;background:transparent;border-radius:6px;color:#64748B;cursor:pointer;font-size:14px;font-family:inherit;display:flex;align-items:center;justify-content:center}
#view-booking .bkv2-vsegbtn.on{background:#fff;color:#3A6FF7;box-shadow:0 1px 2px rgba(15,23,42,.08)}
#view-booking .bkv2-datechip{display:inline-flex;align-items:center;gap:3px;border:1px solid #E5E7EB;border-radius:9px;padding:3px 5px}
#view-booking .bkv2-dcbtn{width:24px;height:24px;border:none;background:transparent;color:#94A3B8;cursor:pointer;font-size:15px;border-radius:6px;font-family:inherit;display:flex;align-items:center;justify-content:center}
#view-booking .bkv2-dcbtn:hover{background:#F1F5F9;color:#3A6FF7}
#view-booking .bkv2-dclbl{font-size:13px;font-weight:700;color:#1F2A44;min-width:80px;text-align:center;font-variant-numeric:tabular-nums}
