let _memoSelectedInv = null;

function memoSearchInv(query){
  const dd = document.getElementById('memo-inv-dropdown');
  if(!dd) return;
  const q = String(query||'').trim().toLowerCase();
  // Fuzzy match: name + partNo + supplier
  const matches = (FL_INVENTORY||[])
    .map(inv => {
      const nm = (inv.name||'').toLowerCase();
      const pn = (inv.partNo||'').toLowerCase();
      const sp = (inv.supplier||'').toLowerCase();
      // scoring: exact start > contains in name > contains in partNo > contains in supplier
      let score = 0;
      if(!q){ score = 1; }  // empty query → show recent
      else if(nm.startsWith(q)) score = 100;
      else if(nm.includes(q)) score = 60;
      else if(pn.includes(q)) score = 40;
      else if(sp.includes(q)) score = 20;
      return {inv, score};
    })
    .filter(x => x.score > 0)
    .sort((a,b) => b.score - a.score || (b.inv.totalQty||b.inv.qty||0) - (a.inv.totalQty||a.inv.qty||0))
    .slice(0, 8);

  if(matches.length === 0 && q.length > 0){
    // ไม่เจอ match → แสดง "เพิ่มใหม่" option เท่านั้น
    dd.innerHTML = `
      <div style="padding:10px 12px;color:var(--ink-soft);font-size:10px;border-bottom:1px solid var(--border)">ไม่พบใน Inventory</div>
      <div style="padding:10px 12px;cursor:pointer;background:#FFF8E1;border-left:3px solid #BA7517"
        onmousedown="event.preventDefault();memoCreateNewFromQuery('${q.replace(/'/g,"\\'")}')">
        <div style="font-size:11px;font-weight:600;color:#854F0B">➕ เพิ่มใหม่: "${query}"</div>
        <div style="font-size:9px;color:#854F0B;margin-top:2px">${_memoType==='labor'?'ค่าแรง · ไม่ลงทะเบียนเข้า Inventory':'🆕 จะถูกลงทะเบียนเข้า Inventory อัตโนมัติเมื่อบันทึก Memo'}</div>
      </div>`;
    dd.style.display = 'block';
    return;
  }
  if(matches.length === 0){
    dd.style.display = 'none';
    return;
  }
  // Render matches
  const html = matches.map(({inv}) => {
    const stockBadge = (inv.totalQty||inv.qty||0) > 0 
      ? `<span style="background:#E1F5EE;color:#0F6E56;padding:1px 5px;border-radius:6px;font-size:9px;font-weight:600">${inv.totalQty||inv.qty} ${inv.unit||''}</span>`
      : `<span style="background:#FCEBEB;color:#A32D2D;padding:1px 5px;border-radius:6px;font-size:9px;font-weight:600">หมด</span>`;
    const locStr = inv.primaryLocation || inv.location || '';
    const locLbl = ({'pier:tublamu':'Tub Lamu','pier:panwa':'Visit Panwa','pier:ranong':'Ranong','pier:central':'กลาง'}[locStr]) || locStr.replace(/^(pier|shop):/,'') || '';
    return `
      <div style="padding:8px 12px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px"
        onmouseover="this.style.background='#FBFAF7'"
        onmouseout="this.style.background='white'"
        onmousedown="event.preventDefault();memoSelectInv('${inv.id}')">
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;font-weight:600;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${inv.name}</div>
