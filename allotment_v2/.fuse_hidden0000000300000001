#view-booking .bkv2-meta2{font-size:12px;color:#94A3B8;font-variant-numeric:tabular-nums}
#view-booking .bkv2-newbtn2{display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:700;color:#fff;background:#3A6FF7;border:none;border-radius:9px;padding:8px 14px;cursor:pointer;font-family:inherit}
#view-booking .bkv2-newbtn2:hover{background:#2952C8}
#view-booking .bkv2-kbd2{background:rgba(255,255,255,.2);border-radius:4px;padding:1px 6px;font-size:10px;font-weight:600}

/* ===== Calendar · locked-seats indicator ===== */
#view-booking .bkv2-cal-lock{margin-top:auto;align-self:flex-start;font-size:9px;font-weight:700;color:#C0392B;background:#FBEAE6;border-radius:5px;padding:1px 6px;font-family:'DM Mono',monospace}

/* ===== Seat Locks tab · RED tone (differentiate from blue views) ===== */
#view-booking .bkv2-locks .bkv2-stat.hero{background:#C0392B;border-color:#9A2D1E}
#view-booking .bkv2-locks .bkv2-newbtn2{background:#C0392B}
#view-booking .bkv2-locks .bkv2-newbtn2:hover{background:#9A2D1E}
