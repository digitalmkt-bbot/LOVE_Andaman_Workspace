          <span style="color:#C0392B">&#9632; ${locked} locked</span>
          <span style="color:#0F7A5A">${avail} available</span>
        </div>` : `<div style="margin-top:5px;font-size:10px;color:#A05A1A">No boat assigned for this trip yet · locked ${bkV2LockedTotal(rid,date)}</div>`;
    }
    const rows = locks.map(l => {
      const rem = bkV2LockRemaining(l);
      const pct = l.qty ? Math.round(l.used/l.qty*100) : 0;
      return `
        <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-top:1px solid var(--border-2);flex-wrap:wrap">
