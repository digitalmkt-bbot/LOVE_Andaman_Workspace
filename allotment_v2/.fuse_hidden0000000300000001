      ${kpiTile('coin',        '#F3E8FF',  P.purple,  'YTD Spend',       '฿'+(ytdSpend>=1000?(ytdSpend/1000).toFixed(0)+'K':ytdSpend), 'across all projects', P.ink3)}
    </div>`;

  const tabs = ['planned','inprogress','on_hold','completed','cancelled'];
  const tabLabel = {planned:'Scheduled', inprogress:'In Progress', on_hold:'On Hold', completed:'Completed', cancelled:'Cancelled'};
  const tabStrip = `
    <div style="display:flex;gap:6px;margin-bottom:12px;border-bottom:1px solid ${P.line};padding-bottom:0">
      ${tabs.map(t=>{
        const on = t===_projTab;
        return `<button onclick="_projTab='${t}';flRenderProjects()" style="background:none;border:none;padding:8px 14px 10px;font-size:12px;font-weight:600;color:${on?P.navy:P.ink3};border-bottom:2px solid ${on?P.navy:'transparent'};cursor:pointer">${tabLabel[t]} <span style="color:${P.ink4};font-weight:500">· ${byStatus[t].length}</span></button>`;
      }).join('')}
    </div>`;

  const list = visible.length ? `
    <div style="display:flex;flex-direction:column;gap:10px">
      ${visible.sort((a,b)=>(b.planFrom||'').localeCompare(a.planFrom||'')).map(p=>flProjRowCard(p)).join('')}
    </div>` : `
    <div style="background:white;border:1px dashed ${P.line};border-radius:14px;padding:40px;text-align:center;color:${P.ink3};font-size:13px">
      No ${tabLabel[_projTab].toLowerCase()} projects. ${_projTab==='planned'?'Click + New Project to schedule one.':''}
    </div>`;

  // Hub Dashboard panels (At Risk · Upcoming · Activity · Spend trend) shown above list only
  const hubPanels = _projViewMode==='list' ? flProjRenderHubPanels(all) : '';
  // Dispatch by view mode
  let mainBody;
  if(_projViewMode==='timeline')      mainBody = flProjRenderTimeline(all);
  else if(_projViewMode==='gantt')    mainBody = flProjRenderGantt(all);
  else                                 mainBody = hubPanels + tabStrip + list;
  wrap.innerHTML = `
    <div style="background:${P.bg};min-height:100vh;padding:28px 32px;font-family:'Inter','Manrope',system-ui,-apple-system,sans-serif;color:${P.ink}">
      ${header}
      ${kpi}
      ${mainBody}
    </div>`;
}

// ═══════════════ HUB DASHBOARD PANELS ═══════════════
function flProjRenderHubPanels(all){
  const P = PROJ_PALETTE;
  // At-Risk projects (health critical or atrisk)
  const active = all.filter(p=>p.status==='inprogress'||p.status==='on_hold'||p.status==='planned');
  const withHealth = active.map(p=>({p, h:flProjHealth(p)}));
  const atRisk = withHealth.filter(x=>x.h.key==='critical'||x.h.key==='atrisk')
                            .sort((a,b)=>a.h.score-b.h.score).slice(0,5);

  // Upcoming Deadlines · projects with planTo within next 30 days
  const today = new Date(TODAY_STR);
  const horizon = new Date(today); horizon.setDate(today.getDate()+30);
  const upcoming = active.filter(p=>{
    if(!p.planTo) return false;
    const pe = new Date(p.planTo);
    return pe>=today && pe<=horizon;
  }).sort((a,b)=>(a.planTo||'').localeCompare(b.planTo||'')).slice(0,5);

  // Recent Activity feed · combine logs from all projects · last 8 entries
  const allActivity = [];
  all.forEach(p=>{
    (p.log||[]).forEach(l=>allActivity.push({date:l.date||'', text:l.text||'', by:l.by||'', projNo:p.no, projId:p.id, projName:p.name}));
  });
  allActivity.sort((a,b)=>(b.date||'').localeCompare(a.date||''));
  const recent = allActivity.slice(0,8);

  // Spend trend · monthly spend over last 6 months (completed projects)
  const months = [];
  const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  for(let i=5;i>=0;i--){
    const d = new Date(today); d.setMonth(d.getMonth()-i);
    const y=d.getFullYear(), m=d.getMonth();
    const mkey = `${y}-${String(m+1).padStart(2,'0')}`;
    let spend = 0;
    all.filter(p=>p.status==='completed' && (p.actualTo||p.planTo||'').startsWith(mkey))
       .forEach(p=>{ spend += flProjCalcCost(p.id); });
    months.push({label:`${MON[m]} ${String(y).slice(2)}`, spend});
  }
  const maxSpend = Math.max(...months.map(m=>m.spend), 1);

  const atRiskCard = `
    <div style="background:white;border:1px solid ${P.line};border-radius:16px;padding:16px 18px;height:100%;box-shadow:${P.shadow}">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
        <div style="font-size:14px;letter-spacing:.4px;color:${P.navy};font-weight:800;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px">${flProjIcon('alert',13,P.red)} At-Risk Projects</div>
        <span style="background:${P.redSoft};color:${P.red};padding:2px 9px;border-radius:10px;font-size:10px;font-weight:700">${atRisk.length}</span>
      </div>
      ${atRisk.length ? `
        <div style="display:flex;flex-direction:column;gap:6px">
          ${atRisk.map(({p,h})=>{
            const boat = BOATS.find(b=>b.id===p.boatId);
            return `<div onclick="flProjOpen('${p.id}')" style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:${P.bg};border-radius:8px;cursor:pointer;border-left:3px solid ${h.color}">
              <div style="flex:1;min-width:0">
                <div style="font-size:11px;font-weight:700;color:${P.navy};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.no} · ${boat?boat.name:'?'}</div>
                <div style="font-size:10px;color:${P.ink3};margin-top:1px">${h.label} · score ${h.score}/100</div>
              </div>
              <span style="font-size:10px;color:${h.color};font-weight:700">›</span>
            </div>`;
          }).join('')}
        </div>
      ` : `<div style="font-size:11px;color:${P.mintInk};text-align:center;padding:18px;font-weight:600">✓ All active projects on track</div>`}
    </div>`;

  const upcomingCard = `
    <div style="background:white;border:1px solid ${P.line};border-radius:16px;padding:16px 18px;height:100%;box-shadow:${P.shadow}">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
        <div style="font-size:14px;letter-spacing:.4px;color:${P.navy};font-weight:800;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px">${flProjIcon('calendar',13,P.amber)} Upcoming Deadlines</div>
        <span style="background:${P.amberSoft};color:${P.amber};padding:2px 9px;border-radius:10px;font-size:10px;font-weight:700">${upcoming.length}</span>
      </div>
      ${upcoming.length ? `
        <div style="display:flex;flex-direction:column;gap:6px">
          ${upcoming.map(p=>{
            const boat = BOATS.find(b=>b.id===p.boatId);
            const daysLeft = Math.ceil((new Date(p.planTo)-today)/86400000);
            const urgColor = daysLeft<=3?P.red:daysLeft<=7?P.amber:P.ink2;
            return `<div onclick="flProjOpen('${p.id}')" style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:${P.bg};border-radius:8px;cursor:pointer">
              <div style="flex:1;min-width:0">
                <div style="font-size:11px;font-weight:700;color:${P.navy};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.no} · ${boat?boat.name:'?'}</div>
                <div style="font-size:10px;color:${P.ink3};margin-top:1px;font-variant-numeric:tabular-nums">due ${p.planTo}</div>
              </div>
              <span style="background:white;color:${urgColor};padding:2px 8px;border-radius:8px;font-size:10px;font-weight:700;border:1px solid ${urgColor}33">${daysLeft}d</span>
            </div>`;
          }).join('')}
        </div>
      ` : `<div style="font-size:11px;color:${P.ink3};text-align:center;padding:18px">No deadlines in the next 30 days</div>`}
    </div>`;

  const activityCard = `
    <div style="background:white;border:1px solid ${P.line};border-radius:16px;padding:16px 18px;height:100%;box-shadow:${P.shadow}">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
        <div style="font-size:14px;letter-spacing:.4px;color:${P.navy};font-weight:800;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px">${flProjIcon('clock',13,P.blue)} Recent Activity</div>
        <span style="font-size:10px;color:${P.ink3}">across all projects</span>
      </div>
      ${recent.length ? `
        <div style="display:flex;flex-direction:column;gap:5px">
          ${recent.map(a=>`
            <div onclick="flProjOpen('${a.projId}')" style="padding:6px 0;border-bottom:1px dashed ${P.line};cursor:pointer">
              <div style="font-size:11px;color:${P.ink};line-height:1.4">${a.text}</div>
              <div style="font-size:10px;color:${P.ink3};margin-top:1px;font-variant-numeric:tabular-nums">${a.date||'—'} · <span style="color:${P.navy};font-weight:600">${a.projNo}</span>${a.by?` · ${a.by}`:''}</div>
            </div>
          `).join('')}
        </div>
      ` : `<div style="font-size:11px;color:${P.ink3};text-align:center;padding:18px">No activity yet</div>`}
    </div>`;

  // Spend trend SVG mini-bar chart
  const w=300, h=110, padL=30, padR=10, padT=10, padB=22;
  const cw=w-padL-padR, ch=h-padT-padB;
  const bw=cw/months.length;
  const bars = months.map((m,i)=>{
    const bh = (m.spend/maxSpend)*ch;
    const x = padL + i*bw + 4;
    const y = padT + (ch-bh);
    return `<g>
      <rect x="${x}" y="${y}" width="${bw-8}" height="${bh}" fill="${P.navy}" rx="3"/>
      <text x="${x+(bw-8)/2}" y="${h-6}" text-anchor="middle" font-size="8" fill="${P.ink3}" font-family="Manrope,sans-serif" font-weight="600">${m.label}</text>
      ${m.spend>0?`<text x="${x+(bw-8)/2}" y="${y-3}" text-anchor="middle" font-size="8" fill="${P.navy}" font-family="Manrope,sans-serif" font-weight="700">${(m.spend/1000).toFixed(0)}K</text>`:''}
    </g>`;
  }).join('');
  const ytickY = padT + ch/2;
  const totalSpend = months.reduce((s,m)=>s+m.spend,0);

  const spendCard = `
    <div style="background:white;border:1px solid ${P.line};border-radius:16px;padding:16px 18px;height:100%;box-shadow:${P.shadow}">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
        <div>
          <div style="font-size:14px;letter-spacing:.4px;color:${P.navy};font-weight:800;text-transform:uppercase;display:inline-flex;align-items:center;gap:6px">${flProjIcon('trending',13,P.purple)} Spend Trend</div>
          <div style="font-size:10px;color:${P.ink3};margin-top:1px">last 6 months · completed projects</div>
        </div>
        <div style="text-align:right">
          <div style="font-size:16px;color:${P.navy};font-weight:700;font-variant-numeric:tabular-nums">฿${(totalSpend/1000).toFixed(0)}K</div>
          <div style="font-size:9px;color:${P.ink3}">6mo total</div>
        </div>
      </div>
      <svg viewBox="0 0 ${w} ${h}" width="100%" height="${h}" preserveAspectRatio="xMidYMid meet">
        <line x1="${padL}" y1="${padT}" x2="${padL}" y2="${padT+ch}" stroke="${P.line}" stroke-width="1"/>
        <line x1="${padL}" y1="${padT+ch}" x2="${w-padR}" y2="${padT+ch}" stroke="${P.line}" stroke-width="1"/>
        <line x1="${padL}" y1="${ytickY}" x2="${w-padR}" y2="${ytickY}" stroke="${P.line}" stroke-width="1" stroke-dasharray="2 2"/>
        <text x="${padL-4}" y="${padT+4}" text-anchor="end" font-size="8" fill="${P.ink3}" font-family="Manrope,sans-serif">${(maxSpend/1000).toFixed(0)}K</text>
        <text x="${padL-4}" y="${ytickY+3}" text-anchor="end" font-size="8" fill="${P.ink3}" font-family="Manrope,sans-serif">${(maxSpend/2000).toFixed(0)}K</text>
        ${bars}
      </svg>
    </div>`;

  return `<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-bottom:14px;align-items:stretch">
    ${atRiskCard}
    ${upcomingCard}
    ${activityCard}
    ${spendCard}
  </div>`;
}

// ═══════════════ NEW TIMELINE VIEW (project cards with day swimlane) ═══════════════
function flProjRenderTimeline(allProjects){
  const P = PROJ_PALETTE;
  // Filter to active-ish projects (planned, inprogress, on_hold) — completed/cancelled go to Gantt history
  const visible = allProjects.filter(p=>p.status==='planned'||p.status==='inprogress'||p.status==='on_hold')
                              .sort((a,b)=>(a.planFrom||'').localeCompare(b.planFrom||''));
  if(!visible.length){
    return `<div style="background:white;border:1px dashed ${P.line};border-radius:18px;padding:48px;text-align:center;color:${P.ink3};font-size:13px">No active projects to show in Timeline.</div>`;
  }
  const cards = visible.map(p=>flProjRenderTimelineCard(p)).join('');
  return `<div style="display:flex;flex-direction:column;gap:14px">${cards}</div>`;
}

// One project card with side panel + tabbed body
function flProjRenderTimelineCard(p){
  const P = PROJ_PALETTE;
  const boat = BOATS.find(b=>b.id===p.boatId);
  const kids = flProjChildMJs(p.id);
  const done = kids.filter(m=>m.status==='done').length;
  const open = kids.length - done;
  const today = new Date(TODAY_STR);
  const pe = p.planTo ? new Date(p.planTo) : null;
  const daysLeft = pe ? Math.ceil((pe-today)/86400000) : null;
  const overdue = pe && today>pe;
  // Side panel palette by status
  const sideTone = (function(){
    if(p.status==='inprogress') return {bg:'#FEEDE8', ink:'#C2410C', accent:'#F97316', label:overdue?'OVERDUE':'IN PROGRESS'};
    if(p.status==='on_hold')    return {bg:'#FEF3CD', ink:'#92400E', accent:'#F59E0B', label:'ON HOLD'};
    if(p.status==='planned')    return {bg:'#E0E7FF', ink:'#3730A3', accent:'#6366F1', label:'SCHEDULED'};
    return {bg:'#DCFCE7', ink:'#15803D', accent:'#22C55E', label:'COMPLETED'};
  })();
  const dueText = pe===null ? 'Open' : (overdue?`${Math.abs(daysLeft)} Past` : daysLeft===0?'Today' : `${daysLeft} Due`);

  // Card sub-tab
  const cardTab = flProjGetCardTab(p.id);
  const tabs = [
    {k:'general', label:'GENERAL'},
    {k:'info',    label:'MORE INFO'},
    {k:'fin',     label:'FINANCIALS'}
  ];
  const tabBar = tabs.map(t=>{
    const on = t.k===cardTab;
    return `<button onclick="event.stopPropagation();flProjSetCardTab('${p.id}','${t.k}')" style="background:none;border:none;padding:8px 0;margin-right:24px;font-size:11px;font-weight:700;letter-spacing:.08em;color:${on?P.navy:P.ink3};border-bottom:2px solid ${on?P.navy:'transparent'};cursor:pointer">${t.label}</button>`;
  }).join('');

  const actionIcons = `
    <div style="display:flex;align-items:center;gap:4px">
      <button onclick="event.stopPropagation();flProjOpen('${p.id}')" title="View detail" style="background:none;border:none;cursor:pointer;padding:6px;color:${P.ink3};border-radius:6px">${flProjIcon('camera',16,P.ink3)}</button>
      <button onclick="event.stopPropagation();flProjOpen('${p.id}')" title="Plan" style="background:none;border:none;cursor:pointer;padding:6px;color:${P.ink3};border-radius:6px">${flProjIcon('clipboard',16,P.ink3)}</button>
      <button onclick="event.stopPropagation();flProjOpenEdit('${p.id}')" title="Edit" style="background:none;border:none;cursor:pointer;padding:6px;color:${P.ink3};border-radius:6px">${flProjIcon('edit',16,P.ink3)}</button>
      <div title="${(p.vendorVisits||[]).length} vendor visits" style="position:relative;width:28px;height:28px;border-radius:50%;background:${P.bg};border:1px solid ${P.line};display:flex;align-items:center;justify-content:center;color:${P.ink2}">${flProjIcon('users',14,P.ink2)}${(p.vendorVisits||[]).length?`<span style="position:absolute;top:-4px;right:-4px;background:${P.blue};color:white;font-size:9px;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center">${(p.vendorVisits||[]).length}</span>`:''}</div>
      <button onclick="event.stopPropagation();flProjOpen('${p.id}')" title="Expand" style="background:none;border:none;cursor:pointer;padding:6px;color:${P.ink3};border-radius:6px">${flProjIcon('arrowRight',16,P.ink3)}</button>
    </div>`;

  // Per-tab body
  let body = '';
  if(cardTab==='general')      body = flProjRenderTimelineGeneral(p, kids);
  else if(cardTab==='info')    body = flProjRenderTimelineInfo(p, boat);
  else                          body = flProjRenderTimelineFin(p, kids);

  // Side panel
  const sidePanel = `
    <div style="background:${sideTone.bg};padding:18px 16px;display:flex;flex-direction:column;align-items:center;gap:14px;min-height:100%">
      <div style="background:white;border:2px solid ${sideTone.accent};border-radius:16px;padding:10px 12px;text-align:center;min-width:96px">
        <div style="display:flex;justify-content:center;color:${sideTone.accent};margin-bottom:4px">${flProjIcon('clock',16,sideTone.accent)}</div>
        <div style="font-size:14px;font-weight:800;color:${sideTone.ink};line-height:1">${dueText}</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:14px;font-weight:700;color:${sideTone.ink};font-variant-numeric:tabular-nums">${done}/${kids.length||'—'}</div>
        <div style="font-size:11px;color:${sideTone.ink};opacity:.7;margin-top:1px">Completed MJs</div>
      </div>
      <div style="width:60%;height:1px;background:${sideTone.ink};opacity:.25"></div>
      <div style="text-align:center">
        <div style="font-size:11px;color:${sideTone.ink};opacity:.8;font-weight:600">Complete by</div>
        <div style="font-size:13px;font-weight:700;color:${sideTone.ink};margin-top:2px;font-variant-numeric:tabular-nums">${p.planTo||'Open'}</div>
      </div>
    </div>`;

  // Title bar
  const titleBar = `
    <div style="padding:18px 22px 0">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px">
        <div style="flex:1;min-width:0">
          <div style="font-size:11px;color:${P.ink3};font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:4px">${p.no} · ${boat?boat.name:'?'}</div>
          <div style="font-size:18px;font-weight:700;color:${P.navy};letter-spacing:-.3px;line-height:1.3">${p.name}</div>
        </div>
        ${actionIcons}
      </div>
      <div style="display:flex;align-items:center;border-bottom:1px solid ${P.line};margin-top:14px;padding-bottom:0">
        ${tabBar}
      </div>
    </div>`;

  return `
    <div style="background:white;border:1px solid ${P.line};border-radius:18px;overflow:hidden;box-shadow:${P.shadow};display:grid;grid-template-columns:140px 1fr">
      ${sidePanel}
      <div style="display:flex;flex-direction:column">
        ${titleBar}
        <div style="padding:18px 22px 22px">${body}</div>
      </div>
    </div>`;
}

// ── GENERAL tab body: TODAY line + horizontal day swimlane ──
function flProjRenderTimelineGeneral(p, kids){
  const P = PROJ_PALETTE;
  const today = new Date(TODAY_STR);
  const days = [];
  for(let i=0; i<_projTimelineDays; i++){
    const d = new Date(today);
    d.setDate(today.getDate()+i);
    days.push(d);
  }
  const MON_SHORT = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  // Helper: MJs active on a given day
  const mjsOn = (date)=>{
    const ds = date.toISOString().slice(0,10);
    return kids.filter(m=>{
      const ms = m.startDate || '';
      const me = m.endDate || p.planTo || ds;
      return ms<=ds && me>=ds;
    });
  };
  const overdueCount = kids.filter(m=>{
    if(m.status==='done') return false;
    const me = m.endDate || p.planTo;
    return me && me<today.toISOString().slice(0,10);
  }).length;
  // Today marker + day columns
  const dayCols = days.map((d,i)=>{
    const ds = d.toISOString().slice(0,10);
    const isToday = i===0;
    const list = mjsOn(d);
    return `<div style="min-width:200px;flex-shrink:0">
      <div style="background:${P.bg};border:1px solid ${P.line};border-radius:10px 10px 0 0;padding:6px 10px;text-align:center;font-size:11px;font-weight:700;color:${P.ink2};letter-spacing:.06em">${MON_SHORT[d.getMonth()]} ${d.getDate()}</div>
      <div style="border:1px solid ${P.line};border-top:none;border-radius:0 0 10px 10px;padding:10px;min-height:140px;display:flex;flex-direction:column;gap:8px">
        ${list.length ? list.map(m=>{
          const stColor = m.status==='done'?P.mintInk : m.status==='inprogress'?P.amber : P.blue;
          return `<div onclick="event.stopPropagation();_selMaintId='${m.id}';nav(document.querySelector('[data-view=\\'fl-maintenance\\']'))" style="cursor:pointer;padding:8px;background:white;border:1px solid ${P.line};border-radius:8px;border-left:3px solid ${stColor}">
            <div style="display:flex;align-items:flex-start;gap:6px;margin-bottom:6px">
              <span style="color:${stColor};flex-shrink:0;margin-top:1px">${flProjIcon('wrench',12,stColor)}</span>
              <div style="font-size:11px;font-weight:600;color:${P.ink};line-height:1.3">${(m.title||'').slice(0,40)}${(m.title||'').length>40?'…':''}</div>
            </div>
            <div style="font-size:10px;color:${P.ink3};margin-bottom:4px">${m.startDate||''}${m.endDate?` → ${m.endDate}`:''}</div>
            ${m.location?`<div style="display:flex;align-items:center;gap:5px;margin-bottom:4px">
