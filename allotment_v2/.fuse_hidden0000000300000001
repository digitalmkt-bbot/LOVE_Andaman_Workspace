  const maintCost=maintOpen.reduce((s,m)=>s+(typeof flMaintCalcCost==='function'?flMaintCalcCost(m.id):(m.cost||0)),0);

  // Incidents
  const incOpen=FL_INCIDENTS.filter(i=>i.status==='open');
