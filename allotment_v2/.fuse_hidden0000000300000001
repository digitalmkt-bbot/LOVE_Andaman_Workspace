      return `
        <div class="t2-zhead"><span class="t2-zdot" style="background:${bkV2ZoneColor(z)}"></span><span class="t2-zn">${bkV2ZoneLabel(z)}</span><span class="t2-zc">· ${list.length} ${list.length>1?'bookings':'booking'} · ${zpax} pax</span></div>
        <div class="t2-tblscroll">
          <table class="t2-mtbl">
            <thead><tr>
              <th>Voucher</th><th>Agency</th><th>Customer (lead)</th>
