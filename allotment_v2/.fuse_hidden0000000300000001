            <div style="font-size:10px;color:var(--ink-soft)">${esc(l.reason||'—')}${l.expiry?` · expires ${esc(l.expiry)}`:''}</div>
          </div>
          <div style="min-width:120px">
            <div style="font-family:Manrope,sans-serif;font-size:12px;font-variant-numeric:tabular-nums"><b>${l.used}</b>/${l.qty} used · <b style="color:#C0392B">${rem}</b> left</div>
            <div style="height:6px;border-radius:4px;background:#EEF0F3;margin-top:3px;overflow:hidden"><div style="width:${pct}%;height:100%;background:#0F7A5A"></div></div>
          </div>
          ${(l.status==='active') ? `<button onclick="bkV2LockReleaseConfirm('${l.id}')" style="font-size:11px;font-weight:600;color:#A32D2D;background:#FDECEA;border:1px solid #F5C9C4;border-radius:6px;padding:5px 10px;cursor:pointer;font-family:inherit">Release</button>` : ''}
        </div>`;
    }).join('');
    return `
      <div class="bkv2-stat" style="margin:0;padding:12px 14px;border-radius:var(--r-sm)">
        <div style="display:flex;align-items:baseline;gap:8px;flex-wrap:wrap">
          <span style="font-size:13px;font-weight:800;color:var(--ink)">${esc(routeName(rid))}</span>
          <span style="font-size:11px;color:var(--ink-soft);font-family:Manrope,sans-serif">${monthScope ? esc(monthLabel) : esc(date)}</span>
        </div>
        ${availBar}
        ${rows}
      </div>`;
  }).join('');
  // ── Per-holder KPI breakdown (Step 3d) · conversion = used / locked ──
  const holders = {};
  SB_SEAT_LOCKS.forEach(l => {
    const key = l.holderType==='agent' ? ('a:'+l.holderId) : l.holderType;
    const label = l.holderType==='agent' ? bkV2LockHolderName(l) : (l.holderType==='office'?'Office hold':'Global pool');
    const h = holders[key] = holders[key] || { label, type:l.holderType, lockCount:0, qty:0, used:0, active:0, released:0, expired:0 };
    h.lockCount++; h.qty += l.qty||0; h.used += l.used||0;
    if(l.status==='active') h.active++; else if(l.status==='released') h.released++; else if(l.status==='expired') h.expired++;
  });
  const hRows = Object.values(holders).sort((a,b)=> b.qty - a.qty).map(h => {
    const conv = h.qty ? Math.round(h.used/h.qty*100) : 0;
    const cc = conv>=70 ? '#0F7A5A' : (conv>=40 ? '#A05A1A' : '#A32D2D');
    const waste = h.released + h.expired;
    return `
      <tr>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2)"><span style="font-size:12px;font-weight:600;color:var(--ink)">${esc(h.label)}</span>${h.type!=='agent'?`<span style="font-size:9px;color:var(--ink-soft);margin-left:5px;text-transform:uppercase;letter-spacing:.04em">${h.type}</span>`:''}</td>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2);text-align:center;font-family:Manrope,sans-serif;font-variant-numeric:tabular-nums">${h.lockCount}</td>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2);text-align:center;font-family:Manrope,sans-serif;font-variant-numeric:tabular-nums">${h.qty}</td>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2);text-align:center;font-family:Manrope,sans-serif;font-variant-numeric:tabular-nums">${h.used}</td>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2);min-width:120px">
          <div style="display:flex;align-items:center;gap:7px"><div style="flex:1;height:6px;background:#EEF0F3;border-radius:4px;overflow:hidden"><div style="width:${conv}%;height:100%;background:${cc}"></div></div><span style="font-family:Manrope,sans-serif;font-weight:700;font-variant-numeric:tabular-nums;color:${cc};font-size:12px;min-width:34px;text-align:right">${conv}%</span></div>
        </td>
        <td style="padding:8px 12px;border-top:1px solid var(--border-2);text-align:center;font-size:11px;color:${waste?'#A32D2D':'var(--ink-soft)'}">${waste? (h.released+' rel · '+h.expired+' exp') : '—'}</td>
      </tr>`;
  }).join('');
  const breakdown = hRows ? `
    <div class="bkv2-nb-sec" style="margin:12px 12px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm)">
      <div class="bkv2-nb-sec-h">&#9679; Lock performance by holder <em style="font-weight:500;color:var(--ink-soft);font-style:normal;font-size:11px">· conversion = used / locked</em></div>
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead><tr>
          <th style="text-align:left;font-size:9px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.05em;padding:6px 12px">Holder</th>
          <th style="text-align:center;font-size:9px;color:var(--ink-faint);text-transform:uppercase;padding:6px 12px">Locks</th>
          <th style="text-align:center;font-size:9px;color:var(--ink-faint);text-transform:uppercase;padding:6px 12px">Locked</th>
          <th style="text-align:center;font-size:9px;color:var(--ink-faint);text-transform:uppercase;padding:6px 12px">Used</th>
          <th style="text-align:left;font-size:9px;color:var(--ink-faint);text-transform:uppercase;padding:6px 12px">Conversion</th>
          <th style="text-align:center;font-size:9px;color:var(--ink-faint);text-transform:uppercase;padding:6px 12px">Wasted</th>
        </tr></thead>
        <tbody>${hRows}</tbody>
      </table>
    </div>` : '';
  // Release modal (custom · on-brand · replaces native prompt)
  const rm = _bkV2ReleaseModal;
  const releaseModal = rm ? `
    <div onclick="bkV2ReleaseModalCancel()" style="position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:9999;display:flex;align-items:center;justify-content:center">
      <div onclick="event.stopPropagation()" style="background:#fff;border-radius:14px;width:344px;max-width:92vw;box-shadow:0 14px 44px rgba(0,0,0,.28);overflow:hidden">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border)">
          <div style="font-size:9px;font-weight:700;letter-spacing:.06em;color:#C0392B;text-transform:uppercase">Release seats</div>
