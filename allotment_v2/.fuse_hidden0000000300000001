        ${_ghosts.map(bk=>{
          const norm=bkV2Norm(bk);
          const mt=(bk.trips||[]).find(t=>t.routeId===rid && t.date===bk.weatherResolve.newDate) || (bk.trips||[]).find(t=>t.routeId===rid) || {};
          const gpax=(typeof bkV2PaxAllTot==='function')?bkV2PaxAllTot(mt.pax||{}):0;
          const lead=bk.leadPax||bk.customerName||'—';
