// ═══════════════ PHASE TRACKER ═══════════════
function flProjRenderPhaseTracker(p){
  const P = PROJ_PALETTE;
  if(p.status==='cancelled') return '';
  const phases = flProjPhasesFor(p);
  const curIdx = flProjCurrentPhaseIdx(p);
  return `
    <div style="margin-top:16px;padding-top:14px;border-top:1px solid ${P.line}">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
        <span style="font-size:10px;letter-spacing:.6px;color:${P.ink3};font-weight:700;text-transform:uppercase">Project Phase</span>
        <span style="font-size:10px;color:${P.ink3}">Click a step to advance</span>
      </div>
      <div style="display:flex;align-items:center;gap:0;width:100%">
        ${phases.map((ph,i)=>{
          const done = i<curIdx;
          const cur  = i===curIdx;
          const bg = done?P.mintInk : cur?P.navy : 'white';
          const fg = (done||cur)?'white':P.ink3;
          const border = done?P.mintInk : cur?P.navy : P.line;
          const icon = done?'✓':(i+1);
          const lineColor = i<curIdx?P.mintInk:P.line;
          return `
            <div style="display:flex;align-items:center;flex:1;${i===phases.length-1?'flex:0':''}">
              <div onclick="flProjSetPhase('${p.id}','${ph.k}')" style="display:flex;flex-direction:column;align-items:center;cursor:pointer;min-width:64px" title="${ph.label}">
                <div style="width:32px;height:32px;border-radius:50%;background:${bg};border:2px solid ${border};color:${fg};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;transition:all .15s">${icon}</div>
                <div style="font-size:10px;color:${cur?P.navy:done?P.mintInk:P.ink3};font-weight:${cur||done?700:500};margin-top:5px;text-align:center;letter-spacing:.02em">${ph.label}</div>
              </div>
              ${i<phases.length-1?`<div style="flex:1;height:2px;background:${lineColor};margin:0 4px;margin-top:-16px"></div>`:''}
            </div>`;
        }).join('')}
      </div>
    </div>`;
}

// ═══════════════ SVG DONUT (cost breakdown) ═══════════════
function flProjRenderDonut(parts, centerLabel, centerVal){
  // parts: [{label, value, color}]
  const total = parts.reduce((s,p)=>s+p.value, 0);
  if(total<=0){
    return `<svg viewBox="0 0 140 140" width="140" height="140">
      <circle cx="70" cy="70" r="56" fill="none" stroke="#EEE" stroke-width="18"/>
      <text x="70" y="68" text-anchor="middle" font-size="10" fill="#999" font-family="Manrope,sans-serif" font-weight="600">${centerLabel}</text>
      <text x="70" y="84" text-anchor="middle" font-size="12" fill="#666" font-family="Manrope,sans-serif" font-weight="700">no data</text>
    </svg>`;
  }
  const cx=70, cy=70, r=56, sw=18;
  const C = 2 * Math.PI * r;
  let offset = 0;
  const segs = parts.map(p=>{
    const len = p.value/total*C;
    const seg = `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${p.color}" stroke-width="${sw}" stroke-dasharray="${len} ${C-len}" stroke-dashoffset="${-offset}" transform="rotate(-90 ${cx} ${cy})"/>`;
    offset += len;
    return seg;
  }).join('');
  return `<svg viewBox="0 0 140 140" width="140" height="140">
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#F4F2EE" stroke-width="${sw}"/>
    ${segs}
    <text x="70" y="66" text-anchor="middle" font-size="9" fill="#8896AB" font-family="Manrope,sans-serif" font-weight="600" letter-spacing=".5">${centerLabel}</text>
    <text x="70" y="84" text-anchor="middle" font-size="14" fill="#1B2A4E" font-family="Manrope,sans-serif" font-weight="800">${centerVal}</text>
  </svg>`;
}

