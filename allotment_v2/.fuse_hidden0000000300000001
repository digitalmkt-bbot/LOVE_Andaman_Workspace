}

// ── Migration · one-shot · scan boats for dry_dock / long-unavailable → create Projects ──
// ── Auto-create Project for unlinked Scheduled MJ · 1 MJ = 1 Project minimum ──
// Runs after resync · catches MJs whose boat log isn't dry_dock (so migration skipped them)
function flProjAutoCreateForScheduledMJs(){
  let created = 0;
  const today = new Date(TODAY_STR);
  (FL_MAINT||[]).forEach(m=>{
    if(m.type!=='scheduled') return;
    if(m.parentProjectId) return;
    if(!m.startDate) return;
    if(!m.boatId) return;
    // Skip if a non-completed project already exists for this boat with overlapping dates
    const ms = new Date(m.startDate);
    const me = m.endDate ? new Date(m.endDate) : today;
    const overlap = (FL_PROJECTS||[]).find(p=>{
      if(p.boatId!==m.boatId) return false;
      if(p.status==='completed') return false;
      const ps = new Date(p.planFrom);
      const pe = new Date(p.planTo||TODAY_STR);
      return ms<=pe && me>=ps;
    });
    if(overlap){
      // Link to it instead of creating new
      m.parentProjectId = overlap.id;
      if(!overlap.log) overlap.log=[];
      overlap.log.push({date:TODAY_STR, text:`+ Auto-linked MJ ${m.no} (auto-create resync)`, by:'auto-create'});
      if(!m.progressLog) m.progressLog=[];
      m.progressLog.push({date:TODAY_STR, text:`Auto-linked to project ${overlap.no}`, by:'auto-create'});
      return;
    }
    // Create new Project from MJ
    const boat = BOATS.find(b=>b.id===m.boatId);
    const boatName = boat?boat.name:'(unknown boat)';
    const yr  = m.startDate.slice(0,4);
    const seq = (FL_PROJECTS.length+1).toString().padStart(3,'0');
    const pid = `proj_${yr}_${m.boatId}_${seq}`;
    const planTo = m.endDate || flProjGuessEnd(m.startDate);
    const status = m.status==='done' ? 'completed' : (m.status==='inprogress' ? 'inprogress' : 'planned');
    const proj = {
      id: pid,
      no: `PRJ-${seq}`,
      name: `Scheduled · ${boatName} · ${(m.title||'Service').slice(0,40)}`,
      boatId: m.boatId,
      type: 'scheduled',
      vendor: m.location||'',
      planFrom: m.startDate,
      planTo,
      originalPlanTo: planTo, // BASELINE
      actualFrom: m.status!=='pending' ? m.startDate : null,
      actualTo: m.endDate||null,
      status,
      plannedBudget: 0,
      notes: m.detail||'',
      log: [
        {date:m.startDate, text:`+ Auto-created from scheduled MJ ${m.no}`, by:'auto-create'}
      ],
      createdAt: TODAY_STR,
      createdBy: 'auto-create'
    };
    FL_PROJECTS.push(proj);
    m.parentProjectId = pid;
    if(!m.progressLog) m.progressLog=[];
    m.progressLog.push({date:TODAY_STR, text:`Auto-linked to new project ${proj.no}`, by:'auto-create'});
    created++;
  });
  if(created){
    flSave();
    console.log(`[Projects auto-create] created ${created} project(s) from scheduled MJs`);
  }
  return created;
}

// ── Resync · always runs · links any unlinked scheduled MJ to a matching project ──
// Runs every time you open Projects page · safe (idempotent) · ignores migration flag
function flProjResyncMJLinks(){
  let linked = 0;
  const today = new Date(TODAY_STR);
  (FL_MAINT||[]).forEach(m=>{
    if(m.type!=='scheduled') return;          // scheduled only
    if(m.parentProjectId) return;              // already linked
    if(!m.startDate) return;
    const ms = new Date(m.startDate);
    const me = m.endDate ? new Date(m.endDate) : today;
    // Find project on same boat with overlapping date range
    const proj = (FL_PROJECTS||[]).find(p=>{
      if(p.boatId!==m.boatId) return false;
      if(p.status==='completed') return false;  // don't re-attach to closed
      const ps = new Date(p.planFrom);
      const pe = new Date(p.planTo||TODAY_STR);
      return ms<=pe && me>=ps;
    });
    if(proj){
      m.parentProjectId = proj.id;
      if(!proj.log) proj.log=[];
      proj.log.push({date:TODAY_STR, text:`+ Auto-linked MJ ${m.no} (resync)`, by:'resync'});
      if(!m.progressLog) m.progressLog=[];
      m.progressLog.push({date:TODAY_STR, text:`Auto-linked to project ${proj.no} (resync)`, by:'resync'});
      linked++;
    }
  });
  if(linked){
    flSave();
    console.log(`[Projects resync] linked ${linked} scheduled MJ(s) to projects`);
  }
  return linked;
}

