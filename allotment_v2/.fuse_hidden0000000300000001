// Derive engine model group for inventory item
function invGetGroup(item){
  // Explicit note (DF325A, BF250D, etc.) takes priority
  const note=(item.note||'').trim();
  if(/DF325A/i.test(note)) return 'Suzuki DF325A';
  if(/DF250W/i.test(note)) return 'Suzuki DF250W';
  if(/BF250D/i.test(note)) return 'Honda BF250D';
  if(/BF250A/i.test(note)) return 'Honda BF250A';
  // Fall back to supplier inference
  const sup=(item.supplier||'').toLowerCase();
  if(sup.includes('honda')) return 'Honda BF250D'; // default Honda → 250D
  if(sup.includes('suzuki')) return 'Suzuki DF325A'; // default Suzuki → 325A
  // Special: oil items (MARINE OIL, GEAR OIL) → General
  if(item.partNo && /^(AC-NP-|ZFR)/i.test(item.partNo)) return 'ทั่วไป';
  // Default
  return 'ทั่วไป';
}
