function flProjAddPlanItem(projId){
  const inp = document.getElementById('proj-plan-input-'+projId);
  if(!inp) return;
  const text = inp.value.trim();
  if(!text) return;
  flProjAddPlanItemDirect(projId, text);
  inp.value = '';
}
function flProjAddPlanItemDirect(projId, text){
  const p = flProjGetById(projId); if(!p) return;
  if(!p.plan) p.plan=[];
  p.plan.push({id:'pl_'+Date.now()+'_'+Math.random().toString(36).slice(2,6), text, done:false, addedAt:TODAY_STR});
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`+ Plan item: ${text}`, by:'user'});
  flSave();
  flRenderProjects();
}
function flProjTogglePlanItem(projId, itemId){
  const p = flProjGetById(projId); if(!p||!p.plan) return;
  const it = p.plan.find(x=>x.id===itemId); if(!it) return;
  it.done = !it.done;
  it.doneDate = it.done ? TODAY_STR : null;
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`${it.done?'✓':'↺'} ${it.text}`, by:'user'});
  flSave();
  flRenderProjects();
}
function flProjDeletePlanItem(projId, itemId){
  const p = flProjGetById(projId); if(!p||!p.plan) return;
  const it = p.plan.find(x=>x.id===itemId); if(!it) return;
  if(!confirm(`Delete plan item: ${it.text}?`)) return;
  p.plan = p.plan.filter(x=>x.id!==itemId);
  if(!p.log) p.log=[];
  p.log.push({date:TODAY_STR, text:`- Plan item removed: ${it.text}`, by:'user'});
  flSave();
  flRenderProjects();
}

