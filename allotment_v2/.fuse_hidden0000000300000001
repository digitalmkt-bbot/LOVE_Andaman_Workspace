function flMaintAutoAddEngines(jobId){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m)return;
  if(!m.assets)m.assets=[];
  const engs=(typeof FL_ENGINES!=='undefined'?FL_ENGINES:[]).filter(e=>e.boatId===m.boatId);
  if(!engs.length){alert('เรือนี้ไม่มีเครื่องยนต์');return;}
  const existingEngIds=new Set(m.assets.filter(a=>a.engId).map(a=>a.engId));
  let added=0;
  engs.forEach(e=>{
    if(existingEngIds.has(e.id))return;
    m.assets.push({type:'engine',engId:e.id,label:`${e.serial} · ${e.pos||''}`,detail:`${e.brand||''} ${e.model||''}`.trim(),status:'fixing'});
    added++;
  });
  if(!added){alert('เครื่องยนต์ทั้งหมดอยู่ในรายการแล้ว');return;}
  if(!m.progressLog)m.progressLog=[];
  m.progressLog.push({date:TODAY_STR,text:`+ เพิ่มเครื่องยนต์ทั้งหมด ${added} ตัว`,by:'ระบบ'});
  flSave();flRenderMaintDetail(jobId);
}

function flMaintAddAssetPrompt(jobId){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m)return;
  const choice=prompt('เพิ่ม asset ประเภทไหน?\n\n  e = engine (เครื่องยนต์)\n  g = gearbox (เกียร์)\n  p = propeller (ใบจักร)\n  h = hull (ตัวเรือ)','e');
  if(!choice)return;
  const c=choice.toLowerCase().trim();
  const type=c.startsWith('e')?'engine':c.startsWith('g')?'gearbox':c.startsWith('p')?'propeller':c.startsWith('h')?'hull':null;
  if(!type){alert('ประเภทไม่ถูกต้อง');return;}
  if(type==='hull'){
    const lbl=prompt('รายการซ่อมตัวเรือ:','');
    if(!lbl)return;
    if(!m.assets)m.assets=[];
    m.assets.push({type:'hull',label:lbl,detail:'',status:'fixing'});
    flSave();flRenderMaintDetail(jobId);
    return;
  }
  // engine/gearbox/propeller — pick from boat's assets
  const list=type==='engine'?FL_ENGINES.filter(e=>e.boatId===m.boatId):
             type==='gearbox'?FL_GEARBOXES.filter(g=>g.boatId===m.boatId):
             FL_PROPELLERS.filter(p=>{
               const gb=FL_GEARBOXES.find(g=>g.id===p.gearboxId);
               return gb&&gb.boatId===m.boatId;
             });
  if(!list.length){alert(`ไม่มี ${type} ในเรือนี้`);return;}
  const opts=list.map((x,i)=>`${i+1}. ${x.serial}${x.pos?' ('+x.pos+')':''}`).join('\n');
  const pickStr=prompt(`เลือก ${type}:\n${opts}\n\n(พิมพ์เลข):`,'1');
  if(!pickStr)return;
  const idx=parseInt(pickStr)-1;
  if(isNaN(idx)||idx<0||idx>=list.length){alert('เลือกไม่ถูกต้อง');return;}
  const x=list[idx];
  if(!m.assets)m.assets=[];
  const aid=type==='engine'?'engId':type==='gearbox'?'gbId':'propId';
  m.assets.push({type,[aid]:x.id,label:`${x.serial}${x.pos?' · '+x.pos:''}`,detail:`${x.brand||''} ${x.model||''}`.trim(),status:'fixing'});
  flSave();flRenderMaintDetail(jobId);
}

