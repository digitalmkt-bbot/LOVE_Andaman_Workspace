function flMaintCalcCost(id){
  const m=FL_MAINT.find(x=>x.id===id);if(!m)return 0;
  const partsCost=(m.parts||[]).reduce((s,p)=>s+p.qty*p.cost,0);
  const memoCost=FL_MEMOS.filter(mo=>mo.maintId===id&&(mo.status==='paid'||mo.status==='received'||mo.status==='approved')).reduce((s,mo)=>s+(mo.amount||0),0);
  const total=partsCost+memoCost;
  m.cost=total; // keep cost synced
  return total;
}

// Fill the warehouse dropdown based on the selected part's stocks[]
function flMaintFillLoc(jobId){
  const sel=document.getElementById('maint-inv-sel-'+jobId);
  const locSel=document.getElementById('maint-inv-loc-'+jobId);
  if(!sel||!locSel) return;
  const invId=(window._maintInvLabelMap||{})[sel.value];
  const inv=invId?FL_INVENTORY.find(x=>x.id===invId):null;
  if(!inv){ locSel.innerHTML='<option value="">— Select warehouse —</option>'; return; }
  invSyncLegacy(inv);
  const stocks=(inv.stocks||[]).filter(s=>(s.qty||0)>0);
  if(stocks.length===0){ locSel.innerHTML='<option value="">(no stock in any warehouse)</option>'; return; }
  locSel.innerHTML='<option value="">— Select warehouse —</option>'+
    stocks.map(s=>`<option value="${(s.location||'').replace(/"/g,'&quot;')}">${s.location} (${s.qty} ${inv.unit||''})</option>`).join('');
}

function flMaintAddPart(jobId){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m)return;
  const sel=document.getElementById('maint-inv-sel-'+jobId);
  const locSel=document.getElementById('maint-inv-loc-'+jobId);
  const qtyEl=document.getElementById('maint-inv-qty-'+jobId);
  const invId=(window._maintInvLabelMap||{})[sel?.value];if(!invId){alert('กรุณาเลือกอะไหล่จากรายการ (พิมพ์แล้วเลือกจากที่ขึ้นมา)');return;}
  const location=locSel?.value;if(!location){alert('กรุณาเลือกคลังก่อน');return;}
  const qty=parseInt(qtyEl?.value)||1;
  const inv=FL_INVENTORY.find(x=>x.id===invId);if(!inv)return;
  invSyncLegacy(inv);
  const avail=invQtyAt(inv,location);
  if(qty>avail){alert(`คลังนี้เหลือ ${avail} ${inv.unit||''} เท่านั้น`);return;}
  // deduct from the chosen warehouse's stock entry
  if(!invRemoveAt(inv,location,qty)){alert('หักสต็อกไม่สำเร็จ');return;}
  // log to inventory history
  if(!inv.history) inv.history=[];
  inv.history.push({date:TODAY_STR,type:'withdraw',qty,location,note:`เบิกใช้งาน ${m.no||''} · ${m.title||''} · @ ${location}`,by:'ระบบ',jobId:m.id});
  // add to job parts (merge by part + location)
  if(!m.parts) m.parts=[];
  const existing=m.parts.find(p=>p.invId===invId && p.location===location && p.date===TODAY_STR);
  if(existing){existing.qty+=qty;}
  else{m.parts.push({invId,name:inv.name,qty,unit:inv.unit,cost:inv.cost,location,date:TODAY_STR});}
  flPushLog(jobId,`📦 เบิก ${inv.name} ${qty} ${inv.unit} · ${location} (฿${(qty*inv.cost).toLocaleString()})`);
  if(!m.progressLog) m.progressLog=[];
  m.progressLog.push({date:TODAY_STR,text:`📦 เบิก ${inv.name} ${qty} ${inv.unit} · ${location} (฿${(qty*inv.cost).toLocaleString()})`,by:'ระบบ'});
  flMaintCalcCost(jobId); // sync m.cost
  flSave();flRenderMaintDetail(jobId);
}

function flMaintRemovePart(jobId,idx){
  const m=FL_MAINT.find(x=>x.id===jobId);if(!m||!m.parts)return;
  const p=m.parts[idx];
  // return to inventory — to the SAME warehouse it was withdrawn from
  const inv=FL_INVENTORY.find(x=>x.id===p.invId);
  if(inv){
    invSyncLegacy(inv);
    const retLoc=p.location||inv.primaryLocation||inv.location||'คลัง Tub Lamu';
    invAddAt(inv,retLoc,p.qty);
    if(!inv.history) inv.history=[];
    inv.history.push({date:TODAY_STR,type:'receive',qty:p.qty,location:retLoc,note:`คืนสต็อก (ยกเลิกเบิก ${m.no||''}) · @ ${retLoc}`,by:'ระบบ',jobId:m.id});
  }
  flPushLog(jobId,`↩ คืนอะไหล่ ${p.name} ${p.qty} ${p.unit} กลับสต็อก`);
  if(!m.progressLog) m.progressLog=[];
  m.progressLog.push({date:TODAY_STR,text:`↩ ยกเลิกเบิก ${p.name} ${p.qty} ${p.unit||''} (คืนสต็อก)`,by:'ระบบ'});
  m.parts.splice(idx,1);
  flMaintCalcCost(jobId); // sync m.cost
  flSave();flRenderMaintDetail(jobId);
}

