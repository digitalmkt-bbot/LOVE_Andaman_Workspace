#view-agents .ct-carry-row-info{flex:1;display:flex;flex-direction:column;gap:1px;min-width:0}
#view-agents .ct-carry-row-name{font-weight:600;color:var(--fd-ink);letter-spacing:-0.005em}
#view-agents .ct-carry-row-meta{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em}
#view-agents .ct-carry-row-pct{font-size:10px;color:var(--fd-ink-soft);font-variant-numeric:tabular-nums;letter-spacing:.02em;flex-shrink:0}

/* Step 3 — review */
#view-agents .ct-review-card{background:var(--fd-bg);border-radius:12px;padding:12px 14px;margin-bottom:8px}
#view-agents .ct-review-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
#view-agents .ct-review-ttl{font-size:11px;font-weight:700;color:var(--fd-ink);letter-spacing:.02em;display:flex;align-items:center;gap:6px}
#view-agents .ct-review-ttl::before{content:'';width:3px;height:12px;background:var(--fd-coral);border-radius:2px}
#view-agents .ct-review-body{font-size:11px;color:var(--fd-ink-mid);line-height:1.5}

/* Step 4 — activate */
#view-agents .ct-activate{background:#E1F5EE;border-radius:14px;padding:18px;text-align:center;margin-bottom:14px}
#view-agents .ct-activate-icon{width:50px;height:50px;border-radius:50%;background:#0F6E56;color:#fff;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:24px}
