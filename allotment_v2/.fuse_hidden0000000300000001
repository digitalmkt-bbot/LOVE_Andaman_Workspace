}
function flConfirmMove(){
  const {assetType,assetId}=flMoveCtx;
  const arr=assetType==='gearbox'?FL_GEARBOXES:FL_PROPELLERS;
  const item=arr.find(x=>x.id===assetId);
  if(!item){closeModal('fl-modal-move');return;}
  const sel=document.querySelector('input[name="fl-move-loc"]:checked');
  if(!sel){alert('กรุณาเลือก location');return;}
  const newLoc=sel.value;
  const note=document.getElementById('fl-move-note').value.trim();
  const oldLoc=item.spareLocation;
  if(oldLoc===newLoc){closeModal('fl-modal-move');return;}
  const fromInfo=flParseSpareLoc(oldLoc);
  const toInfo=flParseSpareLoc(newLoc);

  // ── เพิ่ม log entry ──
  if(!item.log)item.log=[];
  let logType='transfer';
  let desc=`ย้าย: ${fromInfo.label} → ${toInfo.label}`;
  if(newLoc.startsWith('shop:')&&!oldLoc?.startsWith('shop:')){
    logType='repair';
    desc=`ส่งซ่อม: ${fromInfo.label} → ${toInfo.label}`;
  }else if(oldLoc?.startsWith('shop:')&&!newLoc.startsWith('shop:')){
    logType='repair';
    desc=`รับกลับจากซ่อม: ${fromInfo.label} → ${toInfo.label}`;
  }
  if(note&&note!==item.note)desc+=` · ${note}`;
  item.log.push({date:TODAY_STR,type:logType,desc,fromLoc:oldLoc,toLoc:newLoc});

  // Apply move
  item.spareLocation=newLoc;
  if(note)item.note=note;
  // status: shop → fixing, others → spare
  if(newLoc.startsWith('shop:')){
    item.status='fixing';
  }else{
    item.status='spare';
  }
  flSave();
  closeModal('fl-modal-move');
  if(flAssetTab==='overview')flRenderOverview();
}

