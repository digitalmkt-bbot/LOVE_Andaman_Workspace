<script>
// ── Doc Inline Edit ──
let _depBoatId=null, _depDocName=null, _depSt='exp';

function depOpen(boatId, docName, currentSt, currentExp, chipEl, evt){
  if(evt) evt.stopPropagation();
  _depBoatId=boatId; _depDocName=docName;
  const b=getBoat(boatId);
  document.getElementById('dep-title').textContent=`${b?b.name:''} · ${docName}`;

  // set status
  _depSt=currentSt==='processing'?'processing':currentSt==='ok'?'ok':'exp';
  depPickSt(_depSt);

  // set date
  document.getElementById('dep-exp-input').value=currentExp||'';

  // position popup — use fixed positioning based on viewport
  const rect=chipEl.getBoundingClientRect();
  const popup=document.getElementById('doc-edit-popup');
  popup.style.position='fixed';
  let top=rect.bottom+6;
  let left=rect.left;
  if(left+270>window.innerWidth) left=window.innerWidth-278;
  if(left<4) left=4;
  if(top+220>window.innerHeight) top=rect.top-226;
  popup.style.top=top+'px';
  popup.style.left=left+'px';
  popup.classList.add('open');

  document.addEventListener('click',depOutside);
}
function depOutside(e){
  if(!document.getElementById('doc-edit-popup').contains(e.target)){
    depClose();
  }
}
function depClose(){
  document.getElementById('doc-edit-popup').classList.remove('open');
  document.removeEventListener('click',depOutside);
}
function depPickSt(st){
  _depSt=st;
  ['exp','processing','ok'].forEach(s=>{
    const el=document.getElementById('dep-st-'+s);
    el.className='dep-st'+(s===st?' active-'+s:'');
  });
  // show date input for 'ok' and 'processing' (to record when it expired)
  document.getElementById('dep-exp-row').style.display=(st==='ok'||st==='processing')?'flex':'none';
  document.querySelector('#dep-exp-row label.dep-lbl').textContent=
    st==='ok'?'วันหมดอายุใหม่':'วันหมดอายุเดิม (อ้างอิง)';
}
function depSave(){
  const b=getBoat(_depBoatId);if(!b)return;
  if(!b.docs) b.docs=[];

  if(_depSt==='exp'){
    // mark existing as not processing
    const doc=b.docs.filter(d=>d.name===_depDocName).at(-1);
    if(doc) doc.renewStatus=null;
  } else if(_depSt==='processing'){
    // mark existing as processing (update latest)
    const doc=b.docs.filter(d=>d.name===_depDocName).at(-1);
    if(doc){
      doc.renewStatus='processing';
      const expVal=document.getElementById('dep-exp-input').value;
      if(expVal) doc.exp=expVal;
    } else {
      // no existing — create
      const expVal=document.getElementById('dep-exp-input').value;
      b.docs.push({name:_depDocName,exp:expVal||null,renewStatus:'processing'});
    }
  } else if(_depSt==='ok'){
    const newExp=document.getElementById('dep-exp-input').value;
    if(!newExp){alert('กรุณาระบุวันหมดอายุใหม่');return;}
    // add NEW record — keep old for history
    b.docs.push({name:_depDocName, exp:newExp, renewStatus:null});
    // mark previous as closed (set renewStatus to null = done)
    b.docs.filter(d=>d.name===_depDocName&&d.renewStatus==='processing')
      .forEach(d=>d.renewStatus='done');
  }

  save();
  if(typeof flRenderDocsList==='function') flRenderDocsList();
  depClose();
}

