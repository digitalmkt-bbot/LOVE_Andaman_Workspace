// ── FLEET DAILY REPORT ──
function flShiftDRDay(n){
  const el=document.getElementById('fl-dr-date');
  const cur=new Date(el.value||TODAY_STR);
  cur.setDate(cur.getDate()+n);
  el.value=cur.toISOString().slice(0,10);
  flRenderDR();
}

function flRenderDR(){
  const dateEl=document.getElementById('fl-dr-date');
  if(!dateEl.value)dateEl.value=TODAY_STR;
  const ds=dateEl.value;

  // Computed metrics for the day
  const companyBoats=BOATS.filter(b=>b.ownership!=='charter'&&!b.retired&&FL_ENGINES.some(e=>e.boatId===b.id));
  const tlBoats=companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='tublamu');
  const vpBoats=companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='panwa');
  const rnBoats=companyBoats.filter(b=>(typeof getBoatCurrentPier==='function'?getBoatCurrentPier(b):b.pier)==='ranong');

  let totalPAX=0,totalFuel=0,totalTrips=0,operatingBoats=0,topBoatId=null,topBoatPAX=0;
  const charters=[];
  const anomalies=[];
  Object.entries(TRIPS[ds]||{}).forEach(([bid,op])=>{
    if(op.booked){totalPAX+=op.booked;totalTrips++;operatingBoats++;
      if(op.booked>topBoatPAX){topBoatPAX=op.booked;topBoatId=bid;}
      if((op.route||'').toLowerCase().includes('charter')||op.charter)charters.push(bid);
    }
  });
  Object.entries(FL_DAILY[ds]||{}).forEach(([bid,bd])=>{
    if(bd.fuel)totalFuel+=bd.fuel;
    const op=(TRIPS[ds]||{})[bid];
    if(op?.booked&&bd.fuel){
      const lpp=bd.fuel/op.booked;
      if(lpp>20)anomalies.push({bid,lpp:lpp.toFixed(1)});
    }
  });
  const avgLPP=totalPAX>0?(totalFuel/totalPAX).toFixed(2):'—';
  const topBoat=topBoatId?BOATS.find(b=>b.id===topBoatId):null;
  const topBoatTrips=topBoatId?(((TRIPS[ds]||{})[topBoatId]?.trips)||1):0;

  // Honda/Suzuki by engine brand
  const operatingBoatIds=Object.keys(TRIPS[ds]||{}).filter(bid=>(TRIPS[ds]||{})[bid]?.booked);
  let hondaBoats=0,suzukiBoats=0;
  operatingBoatIds.forEach(bid=>{
    const engs=FL_ENGINES.filter(e=>e.boatId===bid);
    if(engs.some(e=>e.brand==='Honda'))hondaBoats++;
    if(engs.some(e=>e.brand==='Suzuki'))suzukiBoats++;
  });

  // Total trip count expected (sum of routes per boat)
  let plannedTrips=companyBoats.length; // baseline 1/boat
  const tripsExecutedPct=plannedTrips>0?Math.round(totalTrips/plannedTrips*100):0;

  // Date label EN
  const MONTHS_EN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const WEEKDAYS_EN=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const dt=new Date(ds);
  const dateLabelEN=`${MONTHS_EN[dt.getMonth()]} ${dt.getDate()}, ${dt.getFullYear()}`;
  const weekday=WEEKDAYS_EN[dt.getDay()];

  const SVG_PINK={accent:'#E03B7E',soft:'#FCE5EC',text:'#9F1B4F'};
  const dim={bg:'#F4F2EE',ink:'#1A1A1A',ink2:'#666',ink3:'#999',ink4:'#bbb',ink5:'#ccc',line:'rgba(0,0,0,.04)',line2:'#f0f0f0'};

  // Header bar
  const headerBar=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
    <div style="display:flex;align-items:center;gap:6px">
      <button style="width:32px;height:32px;border-radius:50%;border:1px solid rgba(0,0,0,.08);background:white;font-size:16px;cursor:pointer;color:${dim.ink2}">+</button>
      <div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#185FA5;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">TL</div><span style="font-size:12px;font-weight:500">Tub Lamu · ${tlBoats.length}</span></div>
      <div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#0F6E56;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">VP</div><span style="font-size:12px;font-weight:500">Visit Panwa · ${vpBoats.length}</span></div>
      ${rnBoats.length?`<div onclick="nav(document.querySelector('[data-view=fl-boatstatus]'))" style="display:flex;align-items:center;gap:6px;background:white;border:1px solid ${dim.line};border-radius:20px;padding:3px 12px 3px 3px;cursor:pointer"><div style="width:24px;height:24px;border-radius:50%;background:#BA7517;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">RN</div><span style="font-size:12px;font-weight:500">Ranong · ${rnBoats.length}</span></div>`:''}
      <div style="width:32px;height:32px;border-radius:50%;background:${dim.ink};color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">D</div>
    </div>
    <div style="display:flex;align-items:center;gap:10px">
      <span style="font-size:12px;color:${dim.ink2}">${dateLabelEN}</span>
    </div>
  </div>`;

  // KPI strip
  const kpiStrip=`<div style="display:grid;grid-template-columns:1.6fr 1fr 0.85fr 0.85fr 0.85fr;gap:8px;margin-bottom:14px;align-items:stretch">
    <div style="grid-column:1;align-self:end;padding-bottom:6px">
      <div style="font-size:13px;font-weight:500;color:${dim.ink4};margin-bottom:2px">Daily Report</div>
      <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;flex-wrap:wrap">
        <span style="font-size:42px;font-weight:700;letter-spacing:-1.5px;line-height:1">${totalPAX||'—'}</span>
        <span style="font-size:18px;color:${dim.ink3};font-weight:500">PAX</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.accent};color:white;padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">▴ ${totalTrips} trips</span>
        <span style="display:inline-flex;align-items:center;background:${SVG_PINK.soft};color:${SVG_PINK.text};padding:3px 10px;border-radius:14px;font-size:11px;font-weight:600">${operatingBoats} boats</span>
      </div>
      <div style="font-size:11px;color:${dim.ink3}">${weekday} · ${dt.getDate()} ${['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'][dt.getMonth()]} ${dt.getFullYear()+543} · ${operatingBoats}/${companyBoats.length} fleet</div>
    </div>

    <div style="grid-column:2;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line};position:relative;cursor:pointer">
      <div style="font-size:10px;color:${dim.ink3}">Total fuel used</div>
      <div style="display:flex;align-items:baseline;gap:3px;margin-top:2px"><span style="font-size:18px;font-weight:700;line-height:1.2">${totalFuel?totalFuel.toLocaleString():'—'}</span><span style="font-size:11px;color:${dim.ink3};font-weight:500">L</span></div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
        <div style="display:flex;align-items:center;gap:4px"><span style="font-size:11px;color:${dim.ink2}">Avg</span><span style="font-size:12px;font-weight:600;font-family:'DM Mono',monospace">${avgLPP}</span><span style="font-size:10px;color:${dim.ink3}">L / PAX</span></div>
      </div>
      <span style="position:absolute;bottom:11px;right:11px;color:${dim.ink5};font-size:14px">›</span>
    </div>

    <div ${topBoat?`onclick="flGoToAsset('boats','${topBoat.id}')"`:''} style="grid-column:3;background:${dim.ink};color:white;border-radius:14px;padding:11px 13px;position:relative;${topBoat?'cursor:pointer':''}">
      <div style="display:flex;align-items:center;justify-content:space-between"><span style="font-size:10px;color:#aaa">Top boat</span><span style="color:#666;font-size:12px">★</span></div>
      <div style="font-size:18px;font-weight:700;line-height:1.2;margin-top:2px">${topBoat?topBoat.name:'—'}</div>
      <div style="font-size:11px;color:#aaa;margin-top:6px">${topBoatPAX?`${topBoatPAX} PAX`:'no trips'}</div>
      <span style="position:absolute;bottom:11px;right:11px;color:#666;font-size:14px">›</span>
    </div>

    <div style="grid-column:4;background:white;border-radius:14px;padding:11px 13px;border:2px solid ${SVG_PINK.accent}">
      <div style="font-size:10px;color:${dim.ink3}">Trips today</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${SVG_PINK.accent};color:white;padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${totalTrips}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">/ ${plannedTrips} fleet</span></div>
      <div style="display:flex;align-items:center;gap:3px;margin-top:7px"><span style="color:${SVG_PINK.text};font-size:11px;font-weight:600">${tripsExecutedPct}% executed</span></div>
    </div>

    <div style="grid-column:5;background:white;border-radius:14px;padding:11px 13px;border:1px solid ${dim.line}">
      <div style="font-size:10px;color:${dim.ink3}">Anomalies</div>
      <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px"><span style="background:${anomalies.length?'#FCEBEB':dim.bg};color:${anomalies.length?'#A32D2D':dim.ink};padding:2px 9px;border-radius:14px;font-size:14px;font-weight:700">${anomalies.length}</span><span style="font-size:11px;color:${dim.ink3};margin-left:2px">flagged</span></div>
      <div style="display:flex;align-items:center;gap:3px;margin-top:7px"><span style="color:${anomalies.length?'#A32D2D':dim.ink3};font-size:11px;font-weight:600">${anomalies.length?(BOATS.find(x=>x.id===anomalies[0].bid)?.name||'—')+' · high fuel':'all normal'}</span></div>
    </div>
  </div>`;

  // Pill row
  const pillRow=`<div style="display:flex;gap:6px;margin-bottom:14px;align-items:center;flex-wrap:wrap">
    <div style="flex:1;min-width:160px;background:white;border-radius:24px;padding:7px 14px;display:flex;align-items:center;gap:10px;border:1px solid ${dim.line}">
      <div style="width:24px;height:24px;border-radius:50%;background:#185FA5;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">HN</div>
      <span style="font-size:12px;font-weight:600">Honda boats</span>
      <span style="margin-left:auto;font-size:11px;font-weight:500">${hondaBoats}</span>
      <span style="font-size:11px;color:${dim.ink3}">operating</span>
    </div>
    <div style="flex:1;min-width:160px;background:white;border-radius:24px;padding:7px 14px;display:flex;align-items:center;gap:10px;border:1px solid ${dim.line}">
      <div style="width:24px;height:24px;border-radius:50%;background:#A32D2D;color:white;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">SZ</div>
      <span style="font-size:12px;font-weight:600">Suzuki boats</span>
      <span style="margin-left:auto;font-size:11px;font-weight:500">${suzukiBoats}</span>
      <span style="font-size:11px;color:${dim.ink3}">operating</span>
    </div>
    <div style="flex:1;min-width:160px;background:white;border-radius:24px;padding:7px 14px;display:flex;align-items:center;gap:10px;border:1px solid ${dim.line}">
      <div style="width:24px;height:24px;border-radius:50%;background:#534AB7;color:white;display:flex;align-items:center;justify-content:center;font-size:11px">⚡</div>
      <span style="font-size:12px;font-weight:600">Charter</span>
      <span style="margin-left:auto;font-size:11px;font-weight:500">${charters.length}</span>
      <span style="font-size:11px;color:${dim.ink3}">trips</span>
    </div>
    <div style="background:${dim.ink};color:white;border-radius:24px;padding:8px 22px;font-size:12px;font-weight:600;cursor:pointer">+ Report</div>
  </div>`;

  // Week strip
  const weekStrip=(()=>{
    const startOfWeek=new Date(dt);
    startOfWeek.setDate(dt.getDate()-((dt.getDay()+6)%7));
    const days=[];
    const wdsTH=['จ','อ','พ','พฤ','ศ','ส','อา'];
    for(let i=0;i<7;i++){
      const d=new Date(startOfWeek);
      d.setDate(startOfWeek.getDate()+i);
      const ds2=d.toISOString().slice(0,10);
      const isCur=ds2===ds;
      const isFuture=ds2>TODAY_STR;
      const cellBg=isCur?SVG_PINK.accent:'white';
      const labelColor=isCur?'rgba(255,255,255,.85)':dim.ink3;
      const numColor=isCur?'white':(isFuture?dim.ink4:dim.ink);
      const numWeight=isCur?700:600;
      days.push(`<div onclick="document.getElementById('fl-dr-date').value='${ds2}';flRenderDR()" style="display:flex;flex-direction:column;align-items:center;background:${cellBg};border:1px solid ${isCur?'transparent':dim.line};border-radius:10px;padding:6px 10px;flex:1;cursor:pointer">
        <span style="font-size:9px;color:${labelColor};font-weight:500;text-transform:uppercase">${wdsTH[i]}</span>
        <span style="font-family:'DM Mono',monospace;font-size:13px;font-weight:${numWeight};color:${numColor}">${d.getDate()}</span>
      </div>`);
    }
    return`<div style="display:flex;gap:5px;margin-bottom:14px;align-items:center">${days.join('')}</div>`;
  })();

  // Boat row builder
  const boatAvatarColor=(b)=>{
    const palette=['#185FA5','#534AB7','#1D9E75','#BA7517','#A32D2D','#0F6E56','#7F77DD','#D85A30','#993556','#185FA5'];
    const i=companyBoats.findIndex(x=>x.id===b.id);
    return palette[i%palette.length];
  };
  const boatInitials=(name)=>{
    const w=name.split(/\s+/);
    if(w.length>=2)return (w[0][0]+w[1][0]).toUpperCase();
    if(name.length>=2&&/\d/.test(name))return (name.match(/[A-Z]/g)?.[0]||name[0])+name.slice(-1);
    return name.slice(0,2).toUpperCase();
  };

  // Route lookup
  const getRouteInfo=(rawRoute)=>{
    if(!rawRoute||rawRoute==='Normal')return {code:'NM',name:'Normal',color:'#185FA5',isCharter:false};
    if(rawRoute==='Early')return {code:'EA',name:'Early',color:'#0F6E56',isCharter:false};
    const r=(typeof ROUTES!=='undefined'?ROUTES:[]).find(x=>x.id===rawRoute);
    const isCharter=(r?.name||rawRoute||'').toLowerCase().includes('charter');
    return {
      code:(r?.code||rawRoute.slice(0,2)).toUpperCase().slice(0,3),
      name:r?.name||rawRoute,
      color:r?.color||'#185FA5',
      isCharter
    };
  };

  // Determine engine pos label
  const engPosLabel=(pos)=>{
    if(!pos)return 'EN';
    const p=pos.toUpperCase();
    if(p==='PORT'||p==='STARBOARD')return p==='PORT'?'PORT':'STBD';
    if(p==='C.PORT'||p==='C.P')return 'C.P';
    if(p==='C.STARBOARD'||p==='C.S')return 'C.S';
    if(p==='STD'||p==='STANDARD')return 'STD';
    if(p==='CTR'||p==='CENTER')return 'CTR';
    if(p==='STBD')return 'STBD';
    if(p.length<=4)return p;
    return p.slice(0,4);
  };

  // Build a boat row
  const buildBoatRow=(b,maxEng)=>{
    const c=boatAvatarColor(b);
    const init=boatInitials(b.name);
    const tShort=b.type==='Catamaran'?'Cat':'Sp';
    const dayDR=(FL_DAILY[ds]||{})[b.id];
    const dayOp=(TRIPS[ds]||{})[b.id];
    // Reality: boat status that day
    const boatStat=(typeof getCurStatus==='function')?getCurStatus(b,ds).s:'available';
    const isNotAvail=boatStat!=='available';
    // PAX zero if boat not available (Reality lock)
    const pax=isNotAvail?0:(dayOp?.booked||0);
    const fuel=dayDR?.fuel;
    const isAnomaly=anomalies.find(a=>a.bid===b.id);
    const engs=FL_ENGINES.filter(e=>e.boatId===b.id);

    // Trips list (route entries) — try operations.trips array first; fallback single route
    const tripEntries=[];
    if(dayOp?.trips&&Array.isArray(dayOp.trips)){
      dayOp.trips.forEach(t=>tripEntries.push({route:t.route||t.program,time:t.time||''}));
    }else if(dayOp?.route||dayOp?.program){
      tripEntries.push({route:dayOp.route||dayOp.program,time:dayOp.time||''});
    }
    if(tripEntries.length===0&&pax>0){
      tripEntries.push({route:'Normal',time:''});
    }

    const tripsHtml=isNotAvail
      ?`<div style="display:flex;align-items:center;gap:6px;padding:3px 8px;background:${boatStat==='fixing'?'#FAEEDA':'#FCEBEB'};border-radius:6px;width:fit-content"><span style="width:5px;height:14px;background:${boatStat==='fixing'?'#854F0B':'#A32D2D'};border-radius:2px"></span><span style="font-size:10px;color:${boatStat==='fixing'?'#854F0B':'#A32D2D'};font-weight:700;text-transform:uppercase;letter-spacing:.04em">${boatStat==='fixing'?'Fixing':'Unavailable'}</span></div>`
      :(tripEntries.length?tripEntries.map(t=>{
      const ri=getRouteInfo(t.route);
      const bg=ri.isCharter?'#534AB7':`${ri.color}1A`;
      const fg=ri.isCharter?'white':ri.color;
      return`<div style="display:flex;align-items:center;gap:6px;font-size:11px"><span style="background:${bg};color:${fg};padding:1px 6px;border-radius:8px;font-size:9px;font-weight:600;font-family:'DM Mono',monospace">${ri.code}</span><span style="color:${dim.ink};font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${ri.name}</span>${t.time?`<span style="margin-left:auto;font-size:9px;color:${dim.ink3};flex-shrink:0">${t.time}</span>`:''}</div>`;
    }).join(''):`<div style="font-size:10px;color:${dim.ink3};font-style:italic">— ไม่ออก</div>`);

    // Fuel input
    const fuelBg=isAnomaly?'#FCEBEB':'#fef3d8';
    const fuelBorder=isAnomaly?'#f0c0c0':'rgba(196,122,16,.2)';
    const fuelColor=isAnomaly?'#A32D2D':'#7a4a00';
    const fuelHtml=`<div style="display:flex;align-items:center;justify-content:center;width:100%"><div style="display:flex;align-items:center;gap:4px;background:${pax===0?'#F4F2EE':fuelBg};border-radius:7px;padding:5px 9px;border:0.5px solid ${pax===0?dim.line:fuelBorder};width:90px;${pax===0?'opacity:.45':''}"><input type="number" step="1" value="${fuel!=null?fuel:''}" placeholder="${pax===0?'—':'0'}" ${pax===0?'disabled':''} onchange="flSaveFuel('${ds}','${b.id}',this.value)" style="flex:1;width:0;min-width:0;font-family:'DM Mono',monospace;font-size:12px;font-weight:${isAnomaly?700:600};color:${pax===0?dim.ink3:fuelColor};background:transparent;border:none;text-align:right;outline:none;${pax===0?'cursor:not-allowed':''}"/><span style="font-size:10px;color:${pax===0?dim.ink3:fuelColor};font-weight:500">L</span></div></div>`;

    // PAX
    const paxHtml=`<div style="display:flex;flex-direction:column;align-items:center"><span style="font-family:'DM Mono',monospace;font-size:14px;font-weight:700">${pax||'—'}</span></div>`;

    // Engine pills
    const isSuzuki=engs.some(e=>e.brand==='Suzuki');
    const enBg=isSuzuki?'#FCEBEB':'#E6F1FB';
    const enBorder=isSuzuki?'#f0c0c0':'#b5d4f4';
    const enLabelColor=isSuzuki?'#A32D2D':'#185FA5';
    const enValColor=isSuzuki?'#791F1F':'#0C447C';
    const engHtml=`<div style="display:flex;gap:4px;justify-content:flex-end">${(maxEng&&engs.length<maxEng)?Array(maxEng-engs.length).fill(0).map(()=>`<div style="min-width:90px;padding:4px 8px;visibility:hidden">.</div>`).join(''):''}${engs.map(eng=>{
      const cur=dayDR?.trips?.normal?.engines?.[eng.id];
      const lbl=engPosLabel(eng.pos);
      const noTrip=pax===0;
      const pillBg=noTrip?'#F4F2EE':enBg;
      const pillBorder=noTrip?dim.line:enBorder;
      const pillLabelColor=noTrip?dim.ink3:enLabelColor;
      const pillValColor=noTrip?dim.ink3:enValColor;
      return`<div style="display:flex;flex-direction:column;align-items:center;background:${pillBg};border-radius:6px;padding:4px 8px;border:0.5px solid ${pillBorder};min-width:90px;${noTrip?'opacity:.45':''}"><span style="font-size:9px;color:${pillLabelColor};font-weight:700;letter-spacing:.05em;margin-bottom:2px">${lbl}</span><div style="display:flex;align-items:baseline;gap:3px"><input type="number" step="0.1" value="${cur!=null?cur:''}" placeholder="${noTrip?'—':'0'}" ${noTrip?'disabled':''} onchange="flSaveMeter('${ds}','${b.id}','normal','${eng.id}',this.value)" style="width:72px;font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:${pillValColor};background:transparent;border:none;text-align:right;outline:none;${noTrip?'cursor:not-allowed':''}"/><span style="font-size:9px;color:${pillLabelColor};opacity:.7">h</span></div></div>`;
    }).join('')}</div>`;

